        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCreditConf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCredited</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:serviceTask id="TaskCreateLabel" name="Create label">
      <bpmn:incoming>StartReturnRegistered_TaskCreateLabel_flow</bpmn:incoming>
      <bpmn:outgoing>TaskCreateLabel_TaskSendLabel_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="StartReturnRegistered_TaskCreateLabel_flow" sourceRef="StartReturnRegistered" targetRef="TaskCreateLabel" />
