  <bpmn:collaboration id="Collaboration_08vpe3l">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_1" />
    <bpmn:participant id="PoolCustomer" name="Customer" />
    <bpmn:messageFlow id="TaskSendLabel_PoolCustomer_flow" name="Return label" sourceRef="TaskSendLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="EndRejectedNoRefund_PoolCustomer_flow" name="Rejection" sourceRef="EndRejectedNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="TaskSendCreditConf_PoolCustomer_flow" name="Credit confirmation" sourceRef="TaskSendCreditConf" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="PoolCustomer_CatchReturnArrived_flow" name="Return shipment" sourceRef="PoolCustomer" targetRef="CatchReturnArrived" />
    <bpmn:messageFlow id="Flow_13us91x" name="Return message" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1yvb0hu">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>TaskCreateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendLabel</bpmn:flowNodeRef>
