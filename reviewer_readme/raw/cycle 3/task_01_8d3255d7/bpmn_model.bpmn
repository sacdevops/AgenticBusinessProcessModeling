    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Catch14Days_EndTimeoutClosed_flow" sourceRef="Catch14Days" targetRef="EndTimeoutClosed" />
    <bpmn:userTask id="TaskInspectGoods" name="Inspect goods">
