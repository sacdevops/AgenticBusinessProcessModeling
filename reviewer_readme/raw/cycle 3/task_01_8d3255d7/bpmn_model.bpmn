  <bpmn:collaboration id="Collaboration_0y2clvf">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_1" />
    <bpmn:participant id="PoolCustomer" name="Customer" />
    <bpmn:messageFlow id="TaskSendLabel_PoolCustomer_flow" name="Return label" sourceRef="TaskSendLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="PoolCustomer_StartReturnRegistered_flow" name="Return request" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
    <bpmn:messageFlow id="PoolCustomer_CatchReturnArrived_flow" name="Returned package" sourceRef="PoolCustomer" targetRef="CatchReturnArrived" />
    <bpmn:messageFlow id="TaskInformNoRefund_PoolCustomer_flow" name="No refund notice" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="TaskSendCreditConfirm_PoolCustomer_flow" name="Credit confirmation" sourceRef="TaskSendCreditConfirm" targetRef="PoolCustomer" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1ldwb2y">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRecordRegistration</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitArrival</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReturnArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch14Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndTimeoutClosed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToAccounting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCreditConfirm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCreditConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>StartReturnRegistered_TaskRecordRegistration_flow</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0vmw8dj" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="TaskRecordRegistration" name="Record return">
      <bpmn:incoming>StartReturnRegistered_TaskRecordRegistration_flow</bpmn:incoming>
      <bpmn:outgoing>TaskRecordRegistration_TaskGenerateLabel_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="StartReturnRegistered_TaskRecordRegistration_flow" sourceRef="StartReturnRegistered" targetRef="TaskRecordRegistration" />
    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>TaskRecordRegistration_TaskGenerateLabel_flow</bpmn:incoming>
      <bpmn:outgoing>TaskGenerateLabel_TaskSendLabel_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="TaskRecordRegistration_TaskGenerateLabel_flow" sourceRef="TaskRecordRegistration" targetRef="TaskGenerateLabel" />
    <bpmn:sendTask id="TaskSendLabel" name="Send label">
      <bpmn:incoming>TaskGenerateLabel_TaskSendLabel_flow</bpmn:incoming>
      <bpmn:outgoing>TaskSendLabel_GwWaitArrival_flow</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="TaskGenerateLabel_TaskSendLabel_flow" sourceRef="TaskGenerateLabel" targetRef="TaskSendLabel" />
    <bpmn:eventBasedGateway id="GwWaitArrival">
      <bpmn:incoming>TaskSendLabel_GwWaitArrival_flow</bpmn:incoming>
      <bpmn:outgoing>GwWaitArrival_CatchReturnArrived_flow</bpmn:outgoing>
      <bpmn:outgoing>GwWaitArrival_Catch14Days_flow</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="TaskSendLabel_GwWaitArrival_flow" sourceRef="TaskSendLabel" targetRef="GwWaitArrival" />
    <bpmn:intermediateCatchEvent id="CatchReturnArrived" name="Return arrived">
      <bpmn:incoming>GwWaitArrival_CatchReturnArrived_flow</bpmn:incoming>
      <bpmn:outgoing>CatchReturnArrived_TaskInspectGoods_flow</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0q4fdly" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="GwWaitArrival_CatchReturnArrived_flow" sourceRef="GwWaitArrival" targetRef="CatchReturnArrived" />
    <bpmn:intermediateCatchEvent id="Catch14Days" name="14 days passed">
      <bpmn:incoming>GwWaitArrival_Catch14Days_flow</bpmn:incoming>
      <bpmn:outgoing>Catch14Days_EndTimeoutClosed_flow</bpmn:outgoing>
