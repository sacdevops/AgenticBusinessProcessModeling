      <bpmn:outgoing>TaskSendCreditConfirm_EndCreditConfirmed_flow</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndCreditConfirmed" name="Credited">
      <bpmn:incoming>TaskSendCreditConfirm_EndCreditConfirmed_flow</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
