    <bpmn:sequenceFlow id="TaskInspectGoods_GwGoodsOk_flow" sourceRef="TaskInspectGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="GwGoodsOk_TaskInformNoRefund_flow" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="TaskInformNoRefund_EndNoRefund_flow" sourceRef="TaskInformNoRefund" targetRef="EndNoRefund" />
    <bpmn:task id="TaskForwardToAccounting" name="Forward refund">
