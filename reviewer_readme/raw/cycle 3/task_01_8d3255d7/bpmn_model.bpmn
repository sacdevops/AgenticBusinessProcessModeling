    <bpmn:sequenceFlow id="CatchReturnArrived_TaskInspectGoods_flow" sourceRef="CatchReturnArrived" targetRef="TaskInspectGoods" />
    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods OK?">
      <bpmn:incoming>TaskInspectGoods_GwGoodsOk_flow</bpmn:incoming>
      <bpmn:outgoing>GwGoodsOk_TaskInformNoRefund_flow</bpmn:outgoing>
