    <bpmn:sequenceFlow id="TaskAutoReject_EndRejectedInsufficient_flow" sourceRef="TaskAutoReject" targetRef="EndRejectedInsufficient" />
    <bpmn:sendTask id="TaskSendToSupervisor" name="Request approval">
