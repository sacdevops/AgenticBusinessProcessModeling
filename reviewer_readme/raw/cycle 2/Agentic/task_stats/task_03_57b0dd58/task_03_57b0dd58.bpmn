      <bpmn:outgoing>TaskCheckDays_GwEnoughDays_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="TaskRegisterRequest_TaskCheckDays_flow" sourceRef="TaskRegisterRequest" targetRef="TaskCheckDays" />
    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>TaskCheckDays_GwEnoughDays_flow</bpmn:incoming>
