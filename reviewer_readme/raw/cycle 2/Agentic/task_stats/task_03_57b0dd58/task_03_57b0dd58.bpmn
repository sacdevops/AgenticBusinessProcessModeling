    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="GwEnoughDays_TaskAutoReject_flow" name="No" sourceRef="GwEnoughDays" targetRef="TaskAutoReject" />
    <bpmn:endEvent id="EndRejectedInsufficient" name="Rejected (insufficient)">
      <bpmn:incoming>TaskAutoReject_EndRejectedInsufficient_flow</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1icol1f" />
