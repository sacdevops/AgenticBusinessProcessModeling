    <bpmn:sequenceFlow id="TaskInventoryCheck_GwMinStockReached_flow" sourceRef="TaskInventoryCheck" targetRef="GwMinStockReached" />
    <bpmn:endEvent id="EndNoOrderNeeded" name="No order needed">
