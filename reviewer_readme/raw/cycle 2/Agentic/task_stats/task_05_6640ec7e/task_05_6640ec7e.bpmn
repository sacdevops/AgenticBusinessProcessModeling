    <bpmn:startEvent id="StartQuarterStart" name="Quarter start">
      <bpmn:outgoing>StartQuarterStart_TaskEvaluateInventory_flow</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_07kxl05" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="TaskEvaluateInventory" name="Evaluate inventory">
      <bpmn:incoming>StartQuarterStart_TaskEvaluateInventory_flow</bpmn:incoming>
      <bpmn:outgoing>TaskEvaluateInventory_GwMinStockReached_flow</bpmn:outgoing>
