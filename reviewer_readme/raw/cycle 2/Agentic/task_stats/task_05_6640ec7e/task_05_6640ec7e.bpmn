    <bpmn:sequenceFlow id="GwMinStockReached_TaskSendOrderStandard_flow" name="No" sourceRef="GwMinStockReached" targetRef="TaskSendOrderStandard" />
    <bpmn:eventBasedGateway id="GwWaitSupplier">
      <bpmn:incoming>TaskSendOrderStandard_GwWaitSupplier_flow</bpmn:incoming>
      <bpmn:outgoing>GwWaitSupplier_CatchSupplierConfirmation_flow</bpmn:outgoing>
