    <bpmn:sequenceFlow id="StartQuarterStart_TaskEvaluateInventory_flow" sourceRef="StartQuarterStart" targetRef="TaskEvaluateInventory" />
    <bpmn:exclusiveGateway id="GwMinStockReached" name="Min stock reached?">
      <bpmn:incoming>TaskEvaluateInventory_GwMinStockReached_flow</bpmn:incoming>
      <bpmn:outgoing>GwMinStockReached_EndNoOrderNeeded_flow</bpmn:outgoing>
      <bpmn:outgoing>GwMinStockReached_TaskSendOrderStandard_flow</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="TaskEvaluateInventory_GwMinStockReached_flow" sourceRef="TaskEvaluateInventory" targetRef="GwMinStockReached" />
    <bpmn:endEvent id="EndNoOrderNeeded" name="No order needed">
      <bpmn:incoming>GwMinStockReached_EndNoOrderNeeded_flow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="GwMinStockReached_EndNoOrderNeeded_flow" name="Yes" sourceRef="GwMinStockReached" targetRef="EndNoOrderNeeded" />
    <bpmn:task id="TaskSendOrderStandard" name="Send order">
