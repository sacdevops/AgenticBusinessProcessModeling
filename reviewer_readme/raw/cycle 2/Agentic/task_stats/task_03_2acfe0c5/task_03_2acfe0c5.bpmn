    <bpmn:messageFlow id="PoolDirectSupervisor_CatchSupApproved_flow" name="Approval response (same request)" sourceRef="PoolDirectSupervisor" targetRef="CatchSupApproved" />
    <bpmn:messageFlow id="PoolDirectSupervisor_CatchSupRejected_flow" name="Rejection response (same request)" sourceRef="PoolDirectSupervisor" targetRef="CatchSupRejected" />
