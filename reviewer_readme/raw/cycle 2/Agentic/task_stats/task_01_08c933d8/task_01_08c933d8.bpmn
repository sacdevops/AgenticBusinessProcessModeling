    <bpmn:sequenceFlow id="Catch14Days_TaskCloseNoReturn_flow" sourceRef="Catch14Days" targetRef="TaskCloseNoReturn" />
    <bpmn:endEvent id="EndClosedNoRefund" name="Closed (no refund)">
