        <bpmn:flowNodeRef>EndClosedNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardOk</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCreditConfirm</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>StartReturnRegistered_TaskCreateReturnCase_flow</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="TaskCreateReturnCase" name="Create return case">
      <bpmn:incoming>StartReturnRegistered_TaskCreateReturnCase_flow</bpmn:incoming>
      <bpmn:outgoing>TaskCreateReturnCase_TaskGenerateLabel_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="StartReturnRegistered_TaskCreateReturnCase_flow" sourceRef="StartReturnRegistered" targetRef="TaskCreateReturnCase" />
    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>TaskCreateReturnCase_TaskGenerateLabel_flow</bpmn:incoming>
      <bpmn:outgoing>TaskGenerateLabel_TaskSendLabel_flow</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="TaskCreateReturnCase_TaskGenerateLabel_flow" sourceRef="TaskCreateReturnCase" targetRef="TaskGenerateLabel" />
    <bpmn:sendTask id="TaskSendLabel" name="Send label">
      <bpmn:incoming>TaskGenerateLabel_TaskSendLabel_flow</bpmn:incoming>
      <bpmn:outgoing>TaskSendLabel_GwWaitArrival_flow</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="TaskGenerateLabel_TaskSendLabel_flow" sourceRef="TaskGenerateLabel" targetRef="TaskSendLabel" />
    <bpmn:eventBasedGateway id="GwWaitArrival">
      <bpmn:incoming>TaskSendLabel_GwWaitArrival_flow</bpmn:incoming>
      <bpmn:outgoing>GwWaitArrival_CatchPackageArrived_flow</bpmn:outgoing>
      <bpmn:outgoing>GwWaitArrival_Catch14Days_flow</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="TaskSendLabel_GwWaitArrival_flow" sourceRef="TaskSendLabel" targetRef="GwWaitArrival" />
    <bpmn:intermediateCatchEvent id="CatchPackageArrived" name="Package arrived">
      <bpmn:incoming>GwWaitArrival_CatchPackageArrived_flow</bpmn:incoming>
      <bpmn:outgoing>CatchPackageArrived_TaskInspectGoods_flow</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_15n5o6o" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="GwWaitArrival_CatchPackageArrived_flow" sourceRef="GwWaitArrival" targetRef="CatchPackageArrived" />
    <bpmn:intermediateCatchEvent id="Catch14Days" name="14 days exceeded">
