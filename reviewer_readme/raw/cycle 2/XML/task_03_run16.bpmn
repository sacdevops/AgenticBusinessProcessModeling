<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_VacationRequest"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_VacationRequest">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolMgmt" name="Supervisor &amp; HR Manager" processRef="Process_Mgmt" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="PoolEmployee" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_ApprovalRequest" name="Approval request" sourceRef="TaskSendApprovalRequest" targetRef="PoolMgmt" />
    <bpmn:messageFlow id="MF_SupervisorDecision" name="Decision" sourceRef="PoolMgmt" targetRef="CatchSupervisorDecision" />
    <bpmn:messageFlow id="MF_Escalation" name="Escalation" sourceRef="TaskSendEscalation" targetRef="PoolMgmt" />
    <bpmn:messageFlow id="MF_HRManagerDecision" name="Final decision" sourceRef="PoolMgmt" targetRef="CatchHRManagerDecision" />
    <bpmn:messageFlow id="MF_InformEmployee" name="Outcome" sourceRef="TaskSendOutcome" targetRef="PoolEmployee" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendAutoRejection" name="Send rejection">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedAuto" name="Rejected">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendApprovalRequest" name="Send approval">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback" >
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorDecision" name="Feedback received">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendOutcome" name="Send outcome">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndCompleted" name="Completed">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendEscalation" name="Send escalation">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchHRManagerDecision" name="Decision received">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_HRManagerDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_3" name="No" sourceRef="GwEnoughDays" targetRef="TaskSendAutoRejection" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApprovalRequest" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendAutoRejection" targetRef="EndRejectedAuto" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskSendApprovalRequest" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchSupervisorDecision" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_10" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_11" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskSendOutcome" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskBookVacation" targetRef="TaskSendOutcome" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskSendOutcome" targetRef="EndCompleted" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="CatchTimeout" targetRef="TaskSendEscalation" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskSendEscalation" targetRef="CatchHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="CatchHRManagerDecision" targetRef="GwHRManagerApproved" />
    <bpmn:sequenceFlow id="Flow_17" name="No" sourceRef="GwHRManagerApproved" targetRef="TaskSendOutcome" />
    <bpmn:sequenceFlow id="Flow_18" name="Yes" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
  </bpmn:process>

  <bpmn:process id="Process_Employee" isExecutable="false" />
  <bpmn:process id="Process_Mgmt" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_VacationRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_VacationRequest" bpmnElement="Collaboration_VacationRequest">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolMgmt_di" bpmnElement="PoolMgmt" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="232" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="209" y="245" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="340" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="520" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="507" y="252" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendAutoRejection_di" bpmnElement="TaskSendAutoRejection">
        <dc:Bounds x="650" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedAuto_di" bpmnElement="EndRejectedAuto">
        <dc:Bounds x="820" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="808" y="185" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalRequest_di" bpmnElement="TaskSendApprovalRequest">
        <dc:Bounds x="650" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="820" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorDecision_di" bpmnElement="CatchSupervisorDecision">
        <dc:Bounds x="950" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="919" y="305" width="98" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="1040" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1035" y="312" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1140" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOutcome_di" bpmnElement="TaskSendOutcome">
        <dc:Bounds x="1290" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCompleted_di" bpmnElement="EndCompleted">
        <dc:Bounds x="1445" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1433" y="305" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout_di" bpmnElement="CatchTimeout">
        <dc:Bounds x="950" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="924" y="118" width="88" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendEscalation_di" bpmnElement="TaskSendEscalation">
        <dc:Bounds x="1040" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchHRManagerDecision_di" bpmnElement="CatchHRManagerDecision">
        <dc:Bounds x="1180" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1142" y="185" width="112" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRManagerApproved_di" bpmnElement="GwHRManagerApproved" isMarkerVisible="true">
        <dc:Bounds x="1260" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1255" y="192" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="268" y="220" />
        <di:waypoint x="340" y="220" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="220" />
        <di:waypoint x="520" y="220" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="545" y="195" />
        <di:waypoint x="545" y="160" />
        <di:waypoint x="650" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="555" y="169" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="570" y="220" />
        <di:waypoint x="650" y="280" />
        <bpmndi:BPMNLabel><dc:Bounds x="598" y="253" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="750" y="160" />
        <di:waypoint x="820" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="750" y="280" />
        <di:waypoint x="820" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="870" y="280" />
        <di:waypoint x="950" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="845" y="255" />
        <di:waypoint x="845" y="170" />
        <di:waypoint x="950" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="986" y="280" />
        <di:waypoint x="1040" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1090" y="280" />
        <di:waypoint x="1140" y="280" />
        <bpmndi:BPMNLabel><dc:Bounds x="1103" y="260" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1065" y="305" />
        <di:waypoint x="1065" y="360" />
        <di:waypoint x="1340" y="360" />
        <di:waypoint x="1340" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="1073" y="332" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1240" y="280" />
        <di:waypoint x="1290" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1390" y="280" />
        <di:waypoint x="1445" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="986" y="170" />
        <di:waypoint x="1040" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1140" y="160" />
        <di:waypoint x="1180" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1216" y="160" />
        <di:waypoint x="1260" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_di" bpmnElement="Flow_17">
        <di:waypoint x="1310" y="160" />
        <di:waypoint x="1340" y="160" />
        <di:waypoint x="1340" y="240" />
        <bpmndi:BPMNLabel><dc:Bounds x="1317" y="140" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_18_di" bpmnElement="Flow_18">
        <di:waypoint x="1285" y="185" />
        <di:waypoint x="1285" y="220" />
        <di:waypoint x="1190" y="220" />
        <di:waypoint x="1190" y="240" />
        <bpmndi:BPMNLabel><dc:Bounds x="1292" y="193" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitRequest_di" bpmnElement="MF_SubmitRequest">
        <di:waypoint x="420" y="490" />
        <di:waypoint x="420" y="120" />
        <di:waypoint x="250" y="120" />
        <di:waypoint x="250" y="202" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_ApprovalRequest_di" bpmnElement="MF_ApprovalRequest">
        <di:waypoint x="700" y="320" />
        <di:waypoint x="700" y="600" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SupervisorDecision_di" bpmnElement="MF_SupervisorDecision">
        <di:waypoint x="980" y="600" />
        <di:waypoint x="980" y="298" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Escalation_di" bpmnElement="MF_Escalation">
        <di:waypoint x="1090" y="200" />
        <di:waypoint x="1090" y="600" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_HRManagerDecision_di" bpmnElement="MF_HRManagerDecision">
        <di:waypoint x="1220" y="600" />
        <di:waypoint x="1220" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_InformEmployee_di" bpmnElement="MF_InformEmployee">
        <di:waypoint x="1340" y="240" />
        <di:waypoint x="1340" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>