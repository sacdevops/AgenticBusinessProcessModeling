<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupply" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_OfficeSupply">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_StandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_AlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="StartStandardOrderReceived" />
    <bpmn:messageFlow id="MF_OrderConfirmed" name="Confirmation" sourceRef="EndStandardConfirmed" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_OrderRejected" name="Rejection" sourceRef="EndStandardRejected" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_OrderRequest_Alternative" name="Order request" sourceRef="TaskSendOrderAlternative" targetRef="StartAlternativeOrderReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchNoResponse3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskManualIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndAlternativeOrdered</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterStart" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low stock?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmation received">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdConfirm" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejection received">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdReject" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchNoResponse3Days" name="3 days exceeded">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervention" name="Manual intervene">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Alternative?">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendOrderAlternative" name="Send order">
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAlternativeOrdered" name="Alt ordered">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndCancelled" name="Cancelled">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartQuarter" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwLowInventory" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="GwWaitResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitResponse" targetRef="CatchNoResponse3Days" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchStandardConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchStandardRejection" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="CatchNoResponse3Days" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskManualIntervention" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_C13" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_C14" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_C15" sourceRef="TaskSendOrderAlternative" targetRef="EndAlternativeOrdered" />
  </bpmn:process>

  <bpmn:process id="Process_StandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStandardQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_S0</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_StdQuarter" />
    </bpmn:startEvent>
    <bpmn:endEvent id="EndStandardIdle" name="Idle">
      <bpmn:incoming>Flow_S0</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartStandardOrderReceived" name="Request received">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdReq" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="TaskEvaluateStandard" name="Check deliverable">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GwDeliverable" name="Deliverable?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndStandardConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdConfOut" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndStandardRejected" name="Rejected">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdRejOut" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S0" sourceRef="StartStandardQuarter" targetRef="EndStandardIdle" />
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartStandardOrderReceived" targetRef="TaskEvaluateStandard" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskEvaluateStandard" targetRef="GwDeliverable" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwDeliverable" targetRef="EndStandardConfirmed" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwDeliverable" targetRef="EndStandardRejected" />
  </bpmn:process>

  <bpmn:process id="Process_AlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAlternativeQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_A0</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_AltQuarter" />
    </bpmn:startEvent>
    <bpmn:endEvent id="EndAlternativeIdle" name="Idle">
      <bpmn:incoming>Flow_A0</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartAlternativeOrderReceived" name="Order received">
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AltReq" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="TaskRecordAlternative" name="Record order">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndAlternativeRecorded" name="Recorded">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A0" sourceRef="StartAlternativeQuarter" targetRef="EndAlternativeIdle" />
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAlternativeOrderReceived" targetRef="TaskRecordAlternative" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="TaskRecordAlternative" targetRef="EndAlternativeRecorded" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupply">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupply" bpmnElement="Collaboration_OfficeSupply">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarter_di" bpmnElement="StartQuarter">
        <dc:Bounds x="230" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="195" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="340" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwLowInventory_di" bpmnElement="GwLowInventory" isMarkerVisible="true">
        <dc:Bounds x="510" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="492" y="202" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStockSufficient_di" bpmnElement="EndStockSufficient">
        <dc:Bounds x="650" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="635" y="195" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="650" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitResponse_di" bpmnElement="GwWaitResponse">
        <dc:Bounds x="820" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardConfirmation_di" bpmnElement="CatchStandardConfirmation">
        <dc:Bounds x="940" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="907" y="83" width="102" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1080" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1054" y="163" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="940" y="220" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="910" y="263" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchNoResponse3Days_di" bpmnElement="CatchNoResponse3Days">
        <dc:Bounds x="940" y="330" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="916" y="373" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervention_di" bpmnElement="TaskManualIntervention">
        <dc:Bounds x="1120" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1280" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1266" y="382" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderAlternative_di" bpmnElement="TaskSendOrderAlternative">
        <dc:Bounds x="1390" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeOrdered_di" bpmnElement="EndAlternativeOrdered">
        <dc:Bounds x="1520" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1502" y="335" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1410" y="360" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1398" y="403" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="240" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartStandardQuarter_di" bpmnElement="StartStandardQuarter">
        <dc:Bounds x="230" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="635" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardIdle_di" bpmnElement="EndStandardIdle">
        <dc:Bounds x="340" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="349" y="635" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartStandardOrderReceived_di" bpmnElement="StartStandardOrderReceived">
        <dc:Bounds x="230" y="532" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="575" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskEvaluateStandard_di" bpmnElement="TaskEvaluateStandard">
        <dc:Bounds x="340" y="510" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwDeliverable_di" bpmnElement="GwDeliverable" isMarkerVisible="true">
        <dc:Bounds x="510" y="525" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="498" y="582" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardConfirmed_di" bpmnElement="EndStandardConfirmed">
        <dc:Bounds x="650" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="640" y="535" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardRejected_di" bpmnElement="EndStandardRejected">
        <dc:Bounds x="650" y="572" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="642" y="615" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="780" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartAlternativeQuarter_di" bpmnElement="StartAlternativeQuarter">
        <dc:Bounds x="230" y="882" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="925" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeIdle_di" bpmnElement="EndAlternativeIdle">
        <dc:Bounds x="340" y="882" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="349" y="925" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartAlternativeOrderReceived_di" bpmnElement="StartAlternativeOrderReceived">
        <dc:Bounds x="230" y="822" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="208" y="865" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskRecordAlternative_di" bpmnElement="TaskRecordAlternative">
        <dc:Bounds x="340" y="800" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeRecorded_di" bpmnElement="EndAlternativeRecorded">
        <dc:Bounds x="470" y="822" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="461" y="865" width="54" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="266" y="170" />
        <di:waypoint x="340" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="440" y="170" />
        <di:waypoint x="510" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C3_di" bpmnElement="Flow_C3">
        <di:waypoint x="535" y="195" />
        <di:waypoint x="535" y="250" />
        <di:waypoint x="650" y="250" />
        <bpmndi:BPMNLabel><dc:Bounds x="542" y="221" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <di:waypoint x="560" y="170" />
        <di:waypoint x="650" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="600" y="152" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C5_di" bpmnElement="Flow_C5">
        <di:waypoint x="750" y="250" />
        <di:waypoint x="820" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C6_di" bpmnElement="Flow_C6">
        <di:waypoint x="845" y="225" />
        <di:waypoint x="845" y="138" />
        <di:waypoint x="940" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C7_di" bpmnElement="Flow_C7">
        <di:waypoint x="870" y="250" />
        <di:waypoint x="940" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8_di" bpmnElement="Flow_C8">
        <di:waypoint x="845" y="275" />
        <di:waypoint x="845" y="348" />
        <di:waypoint x="940" y="348" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C9_di" bpmnElement="Flow_C9">
        <di:waypoint x="976" y="138" />
        <di:waypoint x="1080" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C10_di" bpmnElement="Flow_C10">
        <di:waypoint x="958" y="256" />
        <di:waypoint x="958" y="350" />
