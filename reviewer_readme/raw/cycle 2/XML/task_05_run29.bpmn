<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" />

    <bpmn:messageFlow id="MF_OrderReq_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="PoolStandardSupplier" />
    <bpmn:messageFlow id="MF_OrderConfirmed" name="Confirmation" sourceRef="PoolStandardSupplier" targetRef="CatchConfirmation" />
    <bpmn:messageFlow id="MF_OrderRejected" name="Rejection" sourceRef="PoolStandardSupplier" targetRef="CatchRejection" />

    <bpmn:messageFlow id="MF_OrderReq_Alternative" name="Order request" sourceRef="TaskSendOrderRequestAlternative" targetRef="PoolAlternativeSupplier" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" name="Office Supply Procurement" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterly</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndAlternativeOrdered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskReviewAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestAlternative</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterly" name="Quarter starts">
      <bpmn:outgoing>Flow_Start_To_Check</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Quarterly" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_Start_To_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_To_GwLow</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low stock?">
      <bpmn:incoming>Flow_Check_To_GwLow</bpmn:incoming>
      <bpmn:outgoing>Flow_GwLow_No_To_End</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwLow_Yes_To_SendStd</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndNoAction" name="No action">
      <bpmn:incoming>Flow_GwLow_No_To_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_GwLow_Yes_To_SendStd</bpmn:incoming>
      <bpmn:outgoing>Flow_SendStd_To_Wait</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse">
      <bpmn:incoming>Flow_SendStd_To_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Wait_To_Confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_Wait_To_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_Wait_To_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchConfirmation" name="Confirmation received">
      <bpmn:incoming>Flow_Wait_To_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Confirmation" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_Confirm_To_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchRejection" name="Rejection received">
      <bpmn:incoming>Flow_Wait_To_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_To_ReviewAlt</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Rejection" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="3 days exceeded">
      <bpmn:incoming>Flow_Wait_To_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_Timeout_To_ReviewAlt</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAlternative" name="Review option">
      <bpmn:incoming>Flow_Reject_To_ReviewAlt</bpmn:incoming>
      <bpmn:incoming>Flow_Timeout_To_ReviewAlt</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewAlt_To_GwUseAlt</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Use alternative?">
      <bpmn:incoming>Flow_ReviewAlt_To_GwUseAlt</bpmn:incoming>
      <bpmn:outgoing>Flow_GwUseAlt_No_To_EndCancelled</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwUseAlt_Yes_To_SendAlt</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendOrderRequestAlternative" name="Send request">
      <bpmn:incoming>Flow_GwUseAlt_Yes_To_SendAlt</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAlt_To_EndAlt</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAlternativeOrdered" name="Alternative ordered">
      <bpmn:incoming>Flow_SendAlt_To_EndAlt</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndCancelled" name="Order cancelled">
      <bpmn:incoming>Flow_GwUseAlt_No_To_EndCancelled</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Check" sourceRef="StartQuarterly" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_Check_To_GwLow" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_GwLow_No_To_End" name="No" sourceRef="GwLowInventory" targetRef="EndNoAction" />
    <bpmn:sequenceFlow id="Flow_GwLow_Yes_To_SendStd" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_SendStd_To_Wait" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_Wait_To_Confirm" sourceRef="GwWaitResponse" targetRef="CatchConfirmation" />
    <bpmn:sequenceFlow id="Flow_Wait_To_Reject" sourceRef="GwWaitResponse" targetRef="CatchRejection" />
    <bpmn:sequenceFlow id="Flow_Wait_To_Timeout" sourceRef="GwWaitResponse" targetRef="CatchTimeout" />
    <bpmn:sequenceFlow id="Flow_Confirm_To_End" sourceRef="CatchConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_Reject_To_ReviewAlt" sourceRef="CatchRejection" targetRef="TaskReviewAlternative" />
    <bpmn:sequenceFlow id="Flow_Timeout_To_ReviewAlt" sourceRef="CatchTimeout" targetRef="TaskReviewAlternative" />
    <bpmn:sequenceFlow id="Flow_ReviewAlt_To_GwUseAlt" sourceRef="TaskReviewAlternative" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_GwUseAlt_No_To_EndCancelled" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_GwUseAlt_Yes_To_SendAlt" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderRequestAlternative" />
    <bpmn:sequenceFlow id="Flow_SendAlt_To_EndAlt" sourceRef="TaskSendOrderRequestAlternative" targetRef="EndAlternativeOrdered" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarterly_di" bpmnElement="StartQuarterly">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="195" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwLowInventory_di" bpmnElement="GwLowInventory" isMarkerVisible="true">
        <dc:Bounds x="490" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="472" y="202" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNoAction_di" bpmnElement="EndNoAction">
        <dc:Bounds x="630" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="611" y="195" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="630" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitResponse_di" bpmnElement="GwWaitResponse">
        <dc:Bounds x="790" y="55" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchConfirmation_di" bpmnElement="CatchConfirmation">
        <dc:Bounds x="920" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="892" y="18" width="92" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchRejection_di" bpmnElement="CatchRejection">
        <dc:Bounds x="920" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="898" y="172" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout_di" bpmnElement="CatchTimeout">
        <dc:Bounds x="920" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="892" y="252" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1030" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1007" y="95" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAlternative_di" bpmnElement="TaskReviewAlternative">
        <dc:Bounds x="1030" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1200" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1180" y="372" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestAlternative_di" bpmnElement="TaskSendOrderRequestAlternative">
        <dc:Bounds x="1320" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndAlternativeOrdered_di" bpmnElement="EndAlternativeOrdered">
        <dc:Bounds x="1470" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1444" y="345" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1320" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1295" y="425" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_Check_di" bpmnElement="Flow_Start_To_Check">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Check_To_GwLow_di" bpmnElement="Flow_Check_To_GwLow">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="490" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GwLow_No_To_End_di" bpmnElement="Flow_GwLow_No_To_End">
        <di:waypoint x="540" y="170" />
        <di:waypoint x="630" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="579" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GwLow_Yes_To_SendStd_di" bpmnElement="Flow_GwLow_Yes_To_SendStd">
        <di:waypoint x="515" y="145" />
        <di:waypoint x="515" y="80" />
        <di:waypoint x="630" y="80" />
        <bpmndi:BPMNLabel><dc:Bounds x="522" y="104" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendStd_To_Wait_di" bpmnElement="Flow_SendStd_To_Wait">
        <di:waypoint x="730" y="80" />
        <di:waypoint x="790" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Wait_To_Confirm_di" bpmnElement="Flow_Wait_To_Confirm">
        <di:waypoint x="840" y="80" />
        <di:waypoint x="920" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Wait_To_Reject_di" bpmnElement="Flow_Wait_To_Reject">
        <di:waypoint x="815" y="105" />
        <di:waypoint x="815" y="150" />
        <di:waypoint x="920" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Wait_To_Timeout_di" bpmnElement="Flow_Wait_To_Timeout">
        <di:waypoint x="815" y="105" />
        <di:waypoint x="815" y="230" />
        <di:waypoint x="920" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirm_To_End_di" bpmnElement="Flow_Confirm_To_End">
        <di:waypoint x="956" y="70" />
        <di:waypoint x="1030" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Reject_To_ReviewAlt_di" bpmnElement="Flow_Reject_To_ReviewAlt">
        <di:waypoint x="938" y="168" />
        <di:waypoint x="938" y="340" />
        <di:waypoint x="1030" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Timeout_To_ReviewAlt_di" bpmnElement="Flow_Timeout_To_ReviewAlt">
        <di:waypoint x="938" y="248" />
        <di:waypoint x="938" y="340" />
        <di:waypoint x="1030" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReviewAlt_To_GwUseAlt_di" bpmnElement="Flow_ReviewAlt_To_GwUseAlt">
        <di:waypoint x="1130" y="340" />
        <di:waypoint x="1200" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GwUseAlt_Yes_To_SendAlt_di" bpmnElement="Flow_GwUseAlt_Yes_To_SendAlt">
        <di:waypoint x="1250" y="340" />
        <di:waypoint x="1320" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="1278" y="318" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GwUseAlt_No_To_EndCancelled_di" bpmnElement="Flow_GwUseAlt_No_To_EndCancelled">
        <di:waypoint x="1225" y="365" />
        <di:waypoint x="1225" y="400" />
        <di:waypoint x="1320" y="400" />
        <bpmndi:BPMNLabel><dc:Bounds x="1232" y="380" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendAlt_To_EndAlt_di" bpmnElement="Flow_SendAlt_To_EndAlt">
        <di:waypoint x="1420" y="320" />
        <di:waypoint x="1470" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderReq_Standard_di" bpmnElement="MF_OrderReq_Standard">
        <di:waypoint x="680" y="40" />
        <di:waypoint x="680" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_OrderConfirmed_di" bpmnElement="MF_OrderConfirmed">
        <di:waypoint x="880" y="520" />
        <di:waypoint x="938" y="88" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_OrderRejected_di" bpmnElement="MF_OrderRejected">
        <di:waypoint x="980" y="520" />
        <di:waypoint x="938" y="132" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_OrderReq_Alternative_di" bpmnElement="MF_OrderReq_Alternative">
        <di:waypoint x="1370" y="280" />
        <di:waypoint x="1370" y="600" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>