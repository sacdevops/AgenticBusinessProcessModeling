<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_NotifyApproved" name="Approved" sourceRef="EndNotifyApproved" targetRef="CatchDecisionApproved" />
    <bpmn:messageFlow id="MF_NotifyRejectedSupervisor" name="Rejected" sourceRef="EndNotifyRejectedSupervisor" targetRef="CatchDecisionRejectedSupervisor" />
    <bpmn:messageFlow id="MF_NotifyRejectedHR" name="Rejected" sourceRef="EndNotifyRejectedHR" targetRef="CatchDecisionRejectedHR" />
    <bpmn:messageFlow id="MF_NotifyAutoRejected" name="Rejected" sourceRef="EndNotifyAutoRejected" targetRef="CatchDecisionAutoRejected" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartNeedVacation" name="Vacation needed">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDecision">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:outgoing>Flow_E4</bpmn:outgoing>
      <bpmn:outgoing>Flow_E5</bpmn:outgoing>
      <bpmn:outgoing>Flow_E6</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchDecisionApproved" name="Approval received">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
      <bpmn:outgoing>Flow_E7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejectedSupervisor" name="Rejection received">
      <bpmn:incoming>Flow_E4</bpmn:incoming>
      <bpmn:outgoing>Flow_E8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchRejectedSup" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejectedHR" name="Rejection received">
      <bpmn:incoming>Flow_E5</bpmn:incoming>
      <bpmn:outgoing>Flow_E9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchRejectedHR" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionAutoRejected" name="Rejection received">
      <bpmn:incoming>Flow_E6</bpmn:incoming>
      <bpmn:outgoing>Flow_E10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchAutoRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndEmployeeApproved" name="Vacation approved">
      <bpmn:incoming>Flow_E7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEmployeeRejectedSupervisor" name="Request rejected">
      <bpmn:incoming>Flow_E8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEmployeeRejectedHR" name="Request rejected">
      <bpmn:incoming>Flow_E9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEmployeeAutoRejected" name="Request rejected">
      <bpmn:incoming>Flow_E10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartNeedVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="GwWaitDecision" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="GwWaitDecision" targetRef="CatchDecisionApproved" />
    <bpmn:sequenceFlow id="Flow_E4" sourceRef="GwWaitDecision" targetRef="CatchDecisionRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_E5" sourceRef="GwWaitDecision" targetRef="CatchDecisionRejectedHR" />
    <bpmn:sequenceFlow id="Flow_E6" sourceRef="GwWaitDecision" targetRef="CatchDecisionAutoRejected" />
    <bpmn:sequenceFlow id="Flow_E7" sourceRef="CatchDecisionApproved" targetRef="EndEmployeeApproved" />
    <bpmn:sequenceFlow id="Flow_E8" sourceRef="CatchDecisionRejectedSupervisor" targetRef="EndEmployeeRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_E9" sourceRef="CatchDecisionRejectedHR" targetRef="EndEmployeeRejectedHR" />
    <bpmn:sequenceFlow id="Flow_E10" sourceRef="CatchDecisionAutoRejected" targetRef="EndEmployeeAutoRejected" />
  </bpmn:process>

  <bpmn:process id="Process_Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskAutoReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNotifyAutoRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout5Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNotifyApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNotifyRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNotifyRejectedHR</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskReviewBySupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskReviewByHRManager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRManagerApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskAutoReject" name="Auto reject">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndNotifyAutoRejected" name="Rejection sent">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndAutoRejected" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskForwardToSupervisor" name="Send approval">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorFeedback" name="Feedback received">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchFeedback" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout5Days" name="5 days exceeded">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approved?">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndNotifyApproved" name="Approval sent">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndNotifyRejectedSupervisor" name="Rejection sent">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedSup" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewBySupervisor" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorApproved" name="Approval sent">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupApproved" />
    </bpmn:intermediateThrowEvent>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorRejected" name="Rejection sent">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupRejected" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndSupervisorDone" name="Done">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
      <bpmn:incoming>Flow_S6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewByHRManager" name="Review request">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndNotifyRejectedHR" name="Rejection sent">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedHR" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_C3" name="No" sourceRef="GwEnoughDays" targetRef="TaskAutoReject" />
    <bpmn:sequenceFlow id="Flow_C4" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskForwardToSupervisor" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskAutoReject" targetRef="EndNotifyAutoRejected" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="TaskForwardToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitFeedback" targetRef="CatchTimeout5Days" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchSupervisorFeedback" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchTimeout5Days" targetRef="TaskReviewByHRManager" />
    <bpmn:sequenceFlow id="Flow_C11" name="Yes" sourceRef="GwSupervisorDecision" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_C12" name="No" sourceRef="GwSupervisorDecision" targetRef="EndNotifyRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_C13" name="Yes" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_C14" sourceRef="TaskBookVacation" targetRef="EndNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_C15" name="No" sourceRef="GwHRManagerApproved" targetRef="EndNotifyRejectedHR" />

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="TaskForwardToSupervisor" targetRef="TaskReviewBySupervisor" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskReviewBySupervisor" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwSupervisorApproved" targetRef="ThrowSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwSupervisorApproved" targetRef="ThrowSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_S5" sourceRef="ThrowSupervisorApproved" targetRef="EndSupervisorDone" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="ThrowSupervisorRejected" targetRef="EndSupervisorDone" />

    <bpmn:sequenceFlow id="Flow_H1" sourceRef="TaskReviewByHRManager" targetRef="GwHRManagerApproved" />

    <bpmn:messageFlow id="MF_ToSupervisor" name="Approval request" sourceRef="TaskForwardToSupervisor" targetRef="TaskReviewBySupervisor" />
    <bpmn:messageFlow id="MF_SupApproval" name="Approval" sourceRef="ThrowSupervisorApproved" targetRef="CatchSupervisorFeedback" />
    <bpmn:messageFlow id="MF_SupRejection" name="Rejection" sourceRef="ThrowSupervisorRejected" targetRef="CatchSupervisorFeedback" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="260" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartNeedVacation_di" bpmnElement="StartNeedVacation">
        <dc:Bounds x="230" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="208" y="235" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="330" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDecision_di" bpmnElement="GwWaitDecision">
        <dc:Bounds x="500" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionApproved_di" bpmnElement="CatchDecisionApproved">
        <dc:Bounds x="620" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="596" y="96" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeApproved_di" bpmnElement="EndEmployeeApproved">
        <dc:Bounds x="740" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="715" y="175" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejectedSupervisor_di" bpmnElement="CatchDecisionRejectedSupervisor">
        <dc:Bounds x="620" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="592" y="235" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeRejectedSupervisor_di" bpmnElement="EndEmployeeRejectedSupervisor">
        <dc:Bounds x="740" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="712" y="235" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejectedHR_di" bpmnElement="CatchDecisionRejectedHR">
        <dc:Bounds x="620" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="592" y="295" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeRejectedHR_di" bpmnElement="EndEmployeeRejectedHR">
        <dc:Bounds x="740" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="712" y="295" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionAutoRejected_di" bpmnElement="CatchDecisionAutoRejected">
        <dc:Bounds x="620" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="592" y="355" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeAutoRejected_di" bpmnElement="EndEmployeeAutoRejected">
        <dc:Bounds x="740" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="712" y="355" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="630" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="230" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="207" y="475" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="330" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="500" y="425" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="484" y="482" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAutoReject_di" bpmnElement="TaskAutoReject">
        <dc:Bounds x="610" y="390" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNotifyAutoRejected_di" bpmnElement="EndNotifyAutoRejected">
        <dc:Bounds x="760" y="412" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="734" y="455" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToSupervisor_di" bpmnElement="TaskForwardToSupervisor">
        <dc:Bounds x="610" y="470" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="760" y="485" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorFeedback_di" bpmnElement="CatchSupervisorFeedback">
        <dc:Bounds x="900" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="874" y="406" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout5Days_di" bpmnElement="CatchTimeout5Days">
        <dc:Bounds x="900" y="512" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="868" y="555" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="1020" y="435" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1018" y="492" width="54" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1140" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNotifyApproved_di" bpmnElement="EndNotifyApproved">
        <dc:Bounds x="1290" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1266" y="475" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

