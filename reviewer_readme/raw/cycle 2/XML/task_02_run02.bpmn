        <di:waypoint x="1460" y="165" />
        <di:waypoint x="1505" y="165" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1140" y="265" />
        <di:waypoint x="1200" y="265" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_Msg_di" bpmnElement="Flow_11_Msg">
        <di:waypoint x="1250" y="265" />
        <di:waypoint x="1285" y="265" />
        <di:waypoint x="1285" y="230" />
        <di:waypoint x="1315" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_Tmr_di" bpmnElement="Flow_11_Tmr">
        <di:waypoint x="1250" y="265" />
        <di:waypoint x="1285" y="265" />
        <di:waypoint x="1285" y="330" />
