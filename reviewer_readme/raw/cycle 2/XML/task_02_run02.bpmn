      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="640" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="640" y="207" width="50" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejection_di" bpmnElement="TaskSendRejection">
        <dc:Bounds x="760" y="85" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="760" y="185" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwBelow1500_di" bpmnElement="GwBelow1500" isMarkerVisible="true">
        <dc:Bounds x="920" y="200" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="885" y="257" width="120" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveCase_di" bpmnElement="TaskApproveCase">
        <dc:Bounds x="1040" y="125" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment_di" bpmnElement="TaskInitiatePayment">
        <dc:Bounds x="1200" y="325" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalInfo_di" bpmnElement="TaskSendApprovalInfo">
        <dc:Bounds x="1360" y="125" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendAssessmentOrder_di" bpmnElement="TaskSendAssessmentOrder">
        <dc:Bounds x="1040" y="225" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitAssessment_di" bpmnElement="GwWaitAssessment">
        <dc:Bounds x="1200" y="240" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAssessmentReceived_di" bpmnElement="CatchAssessmentReceived">
        <dc:Bounds x="1315" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1288" y="185" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAssessmentTimeout_di" bpmnElement="CatchAssessmentTimeout">
        <dc:Bounds x="1315" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1286" y="355" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1400" y="195" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalDecision_di" bpmnElement="GwFinalDecision" isMarkerVisible="true">
        <dc:Bounds x="1520" y="210" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1516" y="267" width="58" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejection2_di" bpmnElement="TaskSendRejection2">
        <dc:Bounds x="1660" y="165" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalInfo2_di" bpmnElement="TaskSendApprovalInfo2">
        <dc:Bounds x="1660" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment2_di" bpmnElement="TaskInitiatePayment2">
        <dc:Bounds x="1820" y="325" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionDeadline_di" bpmnElement="TaskSendRejectionDeadline">
        <dc:Bounds x="1480" y="295" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosed_di" bpmnElement="EndClosed">
        <dc:Bounds x="1505" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1488" y="180" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="258" y="175" />
        <di:waypoint x="320" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="175" />
        <di:waypoint x="480" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="580" y="175" />
        <di:waypoint x="640" y="175" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_No_di" bpmnElement="Flow_4_No">
        <di:waypoint x="665" y="150" />
        <di:waypoint x="665" y="125" />
        <di:waypoint x="760" y="125" />
        <bpmndi:BPMNLabel><dc:Bounds x="675" y="114" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_Yes_di" bpmnElement="Flow_4_Yes">
        <di:waypoint x="690" y="175" />
        <di:waypoint x="725" y="175" />
        <di:waypoint x="725" y="225" />
        <di:waypoint x="760" y="225" />
        <bpmndi:BPMNLabel><dc:Bounds x="710" y="196" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="860" y="125" />
        <di:waypoint x="940" y="125" />
        <di:waypoint x="940" y="155" />
        <di:waypoint x="1505" y="155" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="860" y="225" />
        <di:waypoint x="920" y="225" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Yes_di" bpmnElement="Flow_7_Yes">
        <di:waypoint x="945" y="200" />
        <di:waypoint x="945" y="165" />
        <di:waypoint x="1040" y="165" />
        <bpmndi:BPMNLabel><dc:Bounds x="956" y="176" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_No_di" bpmnElement="Flow_7_No">
        <di:waypoint x="970" y="225" />
