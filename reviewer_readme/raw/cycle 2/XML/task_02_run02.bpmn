        <di:waypoint x="1660" y="205" />
        <bpmndi:BPMNLabel><dc:Bounds x="1556" y="190" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_18_Yes_di" bpmnElement="Flow_18_Yes">
        <di:waypoint x="1570" y="235" />
        <di:waypoint x="1605" y="235" />
        <di:waypoint x="1605" y="305" />
        <di:waypoint x="1660" y="305" />
        <bpmndi:BPMNLabel><dc:Bounds x="1591" y="250" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1760" y="205" />
        <di:waypoint x="1785" y="205" />
        <di:waypoint x="1785" y="155" />
        <di:waypoint x="1541" y="155" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_19_di" bpmnElement="Flow_19">
        <di:waypoint x="1760" y="305" />
        <di:waypoint x="1790" y="305" />
        <di:waypoint x="1790" y="365" />
        <di:waypoint x="1820" y="365" />
