<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="External Assessor" />

    <bpmn:messageFlow id="MF_AssessOrder" name="Assessment order" sourceRef="TaskSendAssessmentOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_AssessReport" name="Assessment report" sourceRef="PoolAssessor" targetRef="CatchAssessmentReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwBelow1500</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendAssessmentOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAssessmentReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAssessmentTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePayment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?" isMarkerVisible="true">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejection" name="Send rejection">
      <bpmn:incoming>Flow_4_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosed" name="Case closed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_4_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwBelow1500" name="Amount < €1500?" isMarkerVisible="true">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveCase" name="Approve case">
      <bpmn:incoming>Flow_7_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePayment" name="Initiate payment">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalInfo" name="Send approval">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendAssessmentOrder" name="Send order">
      <bpmn:incoming>Flow_7_No</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitAssessment">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11_Msg</bpmn:outgoing>
      <bpmn:outgoing>Flow_11_Tmr</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchAssessmentReceived" name="Assessment received">
      <bpmn:incoming>Flow_11_Msg</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AssessmentReceived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchAssessmentTimeout" name="10 days exceeded">
      <bpmn:incoming>Flow_11_Tmr</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendRejectionDeadline" name="Send deadline">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:userTask id="TaskReviewAssessment" name="Review report">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalDecision" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_18_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_18_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejection" name="Send rejection">
      <bpmn:incoming>Flow_4_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendRejection2" name="Send rejection">
      <bpmn:incoming>Flow_18_No</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendApprovalInfo2" name="Send approval">
      <bpmn:incoming>Flow_18_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:serviceTask id="TaskInitiatePayment2" name="Initiate payment">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_4_No" name="No" sourceRef="GwCovered" targetRef="TaskSendRejection" />
    <bpmn:sequenceFlow id="Flow_4_Yes" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendRejection" targetRef="EndClosed" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskCheckAmount" targetRef="GwBelow1500" />
    <bpmn:sequenceFlow id="Flow_7_Yes" name="Yes" sourceRef="GwBelow1500" targetRef="TaskApproveCase" />
    <bpmn:sequenceFlow id="Flow_7_No" name="No" sourceRef="GwBelow1500" targetRef="TaskSendAssessmentOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskApproveCase" targetRef="TaskInitiatePayment" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInitiatePayment" targetRef="TaskSendApprovalInfo" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskSendApprovalInfo" targetRef="EndClosed" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendAssessmentOrder" targetRef="GwWaitAssessment" />
    <bpmn:sequenceFlow id="Flow_11_Msg" sourceRef="GwWaitAssessment" targetRef="CatchAssessmentReceived" />
    <bpmn:sequenceFlow id="Flow_11_Tmr" sourceRef="GwWaitAssessment" targetRef="CatchAssessmentTimeout" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="CatchAssessmentReceived" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="CatchAssessmentTimeout" targetRef="TaskSendRejectionDeadline" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="TaskSendRejectionDeadline" targetRef="EndClosed" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskReviewAssessment" targetRef="GwFinalDecision" />
    <bpmn:sequenceFlow id="Flow_18_Yes" name="Yes" sourceRef="GwFinalDecision" targetRef="TaskSendApprovalInfo2" />
    <bpmn:sequenceFlow id="Flow_18_No" name="No" sourceRef="GwFinalDecision" targetRef="TaskSendRejection2" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskSendRejection2" targetRef="EndClosed" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="TaskSendApprovalInfo2" targetRef="TaskInitiatePayment2" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="TaskInitiatePayment2" targetRef="EndClosed" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">

      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="380" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="270" width="1400" height="190" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="222" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="192" y="200" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
