<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_VacationRequest" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_VacationRequest">
    <bpmn:participant id="PoolHR" name="HR Portal & HR Dept" processRef="Process_PoolHR" />
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_PoolEmployee" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="PoolEmployee" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_RequestDecisionApproved" name="Approved" sourceRef="EndApprovedMsg" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RequestDecisionRejectedNoDays" name="Rejected (no days)" sourceRef="EndRejectedNoDaysMsg" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RequestDecisionRejectedSupervisor" name="Rejected (supervisor)" sourceRef="EndRejectedSupervisorMsg" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RequestDecisionRejectedHR" name="Rejected (HR)" sourceRef="EndRejectedHRMsg" targetRef="PoolEmployee" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolEmployee" isExecutable="false" />

  <bpmn:process id="Process_PoolHR" isExecutable="false">

    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchFiveDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApprovedMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNoDaysMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSupervisorMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedHRMsg</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskSupervisorDecide</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskHRManagerDecide</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRManagerApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequestReceived" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?" isMarkerVisible="true">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskForwardToSupervisor" name="Send approval">
      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:userTask id="TaskSupervisorDecide" name="Review request">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_6_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_6_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_6_No</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Feedback</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorFeedback" name="Feedback received">
      <bpmn:incoming>Flow_7_Feedback</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorFeedback" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchFiveDays" name="5 days exceeded">
      <bpmn:incoming>Flow_7_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_CatchFiveDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorResult" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_10_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskHRManagerDecide" name="Decide case">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_10_Approved</bpmn:incoming>
      <bpmn:incoming>Flow_12_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndApprovedMsg" name="Decision sent">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApprovedMsg" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedNoDaysMsg" name="Rejection sent">
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedNoDaysMsg" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedSupervisorMsg" name="Rejection sent">
      <bpmn:incoming>Flow_10_Rejected</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedSupervisorMsg" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedHRMsg" name="Rejection sent">
      <bpmn:incoming>Flow_12_No</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedHRMsg" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartRequestReceived" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_3_Yes" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskForwardToSupervisor" />
    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="GwEnoughDays" targetRef="EndRejectedNoDaysMsg" />

    <bpmn:sequenceFlow id="Flow_4" sourceRef="TaskForwardToSupervisor" targetRef="TaskSupervisorDecide" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSupervisorDecide" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_6_Yes" name="Approved" sourceRef="GwSupervisorApproved" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_6_No" name="Rejected" sourceRef="GwSupervisorApproved" targetRef="GwWaitFeedback" />

    <bpmn:sequenceFlow id="Flow_7_Feedback" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_7_Timeout" sourceRef="GwWaitFeedback" targetRef="CatchFiveDays" />

    <bpmn:sequenceFlow id="Flow_8" sourceRef="CatchSupervisorFeedback" targetRef="GwSupervisorResult" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchFiveDays" targetRef="TaskHRManagerDecide" />

    <bpmn:sequenceFlow id="Flow_10_Approved" name="Approved" sourceRef="GwSupervisorResult" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_10_Rejected" name="Rejected" sourceRef="GwSupervisorResult" targetRef="EndRejectedSupervisorMsg" />

    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskHRManagerDecide" targetRef="GwHRManagerApproved" />
    <bpmn:sequenceFlow id="Flow_12_Yes" name="Approved" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_12_No" name="Rejected" sourceRef="GwHRManagerApproved" targetRef="EndRejectedHRMsg" />

    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskBookVacation" targetRef="EndApprovedMsg" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_VacationRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_VacationRequest" bpmnElement="Collaboration_VacationRequest">

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="222" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="202" y="165" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckDays_di" bpmnElement="TaskCheckDays">
        <dc:Bounds x="340" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="520" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="500" y="170" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedNoDaysMsg_di" bpmnElement="EndRejectedNoDaysMsg">
        <dc:Bounds x="660" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="635" y="165" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToSupervisor_di" bpmnElement="TaskForwardToSupervisor">
        <dc:Bounds x="640" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSupervisorDecide_di" bpmnElement="TaskSupervisorDecide">
        <dc:Bounds x="780" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="930" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="912" y="290" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="1040" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorFeedback_di" bpmnElement="CatchSupervisorFeedback">
        <dc:Bounds x="1162" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1130" y="86" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchFiveDays_di" bpmnElement="CatchFiveDays">
        <dc:Bounds x="1162" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1128" y="405" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorResult_di" bpmnElement="GwSupervisorResult" isMarkerVisible="true">
        <dc:Bounds x="1260" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1242" y="170" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1360" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApprovedMsg_di" bpmnElement="EndApprovedMsg">
        <dc:Bounds x="1500" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1475" y="165" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisorMsg_di" bpmnElement="EndRejectedSupervisorMsg">
        <dc:Bounds x="1360" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1330" y="285" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskHRManagerDecide_di" bpmnElement="TaskHRManagerDecide">
        <dc:Bounds x="1260" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRManagerApproved_di" bpmnElement="GwHRManagerApproved" isMarkerVisible="true">
        <dc:Bounds x="1400" y="355" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1382" y="410" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHRMsg_di" bpmnElement="EndRejectedHRMsg">
        <dc:Bounds x="1500" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1478" y="405" width="95" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="258" y="140" />
        <di:waypoint x="340" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="140" />
        <di:waypoint x="520" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_Yes_di" bpmnElement="Flow_3_Yes">
        <di:waypoint x="570" y="140" />
        <di:waypoint x="620" y="140" />
        <di:waypoint x="620" y="270" />
        <di:waypoint x="640" y="270" />
        <bpmndi:BPMNLabel><dc:Bounds x="592" y="170" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_No_di" bpmnElement="Flow_3_No">
        <di:waypoint x="570" y="140" />
        <di:waypoint x="660" y="140" />
        <bpmndi:BPMNLabel><dc:Bounds x="606" y="122" width="18" height="14" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="740" y="270" />
        <di:waypoint x="780" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="880" y="260" />
        <di:waypoint x="930" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_Yes_di" bpmnElement="Flow_6_Yes">
        <di:waypoint x="980" y="260" />
        <di:waypoint x="1040" y="260" />
        <bpmndi:BPMNLabel><dc:Bounds x="992" y="242" width="55" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_No_di" bpmnElement="Flow_6_No">
        <di:waypoint x="980" y="260" />
        <di:waypoint x="1040" y="260" />
        <bpmndi:BPMNLabel><dc:Bounds x="992" y="274" width="55" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Feedback_di" bpmnElement="Flow_7_Feedback">
        <di:waypoint x="1065" y="235" />
        <di:waypoint x="1065" y="140" />
        <di:waypoint x="1162" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Timeout_di" bpmnElement="Flow_7_Timeout">
        <di:waypoint x="1065" y="285" />
        <di:waypoint x="1065" y="380" />
        <di:waypoint x="1162" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1198" y="140" />
        <di:waypoint x="1260" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1198" y="380" />
        <di:waypoint x="1260" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_Approved_di" bpmnElement="Flow_10_Approved">
        <di:waypoint x="1310" y="140" />
        <di:waypoint x="1360" y="140" />
        <bpmndi:BPMNLabel><dc:Bounds x="1318" y="122" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_Rejected_di" bpmnElement="Flow_10_Rejected">
        <di:waypoint x="1285" y="165" />
        <di:waypoint x="1285" y="260" />
        <di:waypoint x="1360" y="260" />
        <bpmndi:BPMNLabel><dc:Bounds x="1292" y="210" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1360" y="380" />
        <di:waypoint x="1400" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_Yes_di" bpmnElement="Flow_12_Yes">
        <di:waypoint x="1425" y="355" />
        <di:waypoint x="1425" y="220" />
        <di:waypoint x="1410" y="220" />
        <di:waypoint x="1410" y="180" />
        <di:waypoint x="1360" y="180" />
        <bpmndi:BPMNLabel><dc:Bounds x="1432" y="300" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_No_di" bpmnElement="Flow_12_No">
        <di:waypoint x="1450" y="380" />
        <di:waypoint x="1500" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="1458" y="362" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1460" y="140" />
        <di:waypoint x="1500" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitRequest_di" bpmnElement="MF_SubmitRequest">
        <di:waypoint x="950" y="490" />
        <di:waypoint x="950" y="60" />
        <di:waypoint x="240" y="60" />
        <di:waypoint x="240" y="122" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestDecisionApproved_di" bpmnElement="MF_RequestDecisionApproved">
        <di:waypoint x="1518" y="122" />
        <di:waypoint x="1518" y="520" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestDecisionRejectedNoDays_di" bpmnElement="MF_RequestDecisionRejectedNoDays">
        <di:waypoint x="678" y="158" />
        <di:waypoint x="678" y="520" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestDecisionRejectedSupervisor_di" bpmnElement="MF_RequestDecisionRejectedSupervisor">
        <di:waypoint x="1396" y="242" />
        <di:waypoint x="1396" y="520" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestDecisionRejectedHR_di" bpmnElement="MF_RequestDecisionRejectedHR">
        <di:waypoint x="1518" y="362" />
        <di:waypoint x="1518" y="520" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>