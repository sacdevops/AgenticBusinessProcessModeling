<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolHR" name="HR Department" processRef="Process_PoolHR" />
    <bpmn:participant id="PoolEmployee" name="Employee" />
    <bpmn:participant id="PoolBooking" name="Vacation Booking System" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="PoolEmployee" targetRef="StartRequestSubmitted" />

    <bpmn:messageFlow id="MF_RequestApproval" name="Approval" sourceRef="TaskSendApprovalRequest" targetRef="PoolEmployee" />

    <bpmn:messageFlow id="MF_Approved" name="Approved" sourceRef="TaskSendApproved" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RejectedNoDays" name="Rejected" sourceRef="TaskSendRejectedNoDays" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RejectedSupervisor" name="Rejected" sourceRef="TaskSendRejectedSupervisor" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_RejectedHR" name="Rejected" sourceRef="TaskSendRejectedHR" targetRef="PoolEmployee" />

    <bpmn:messageFlow id="MF_BookVacation" name="Booking" sourceRef="TaskBookVacation" targetRef="PoolBooking" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolHR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestSubmitted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectedNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectedHR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedHR</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorResponded</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestSubmitted" name="Request submitted">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectedNoDays" name="Send rejection">
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedNoDays" name="Rejected">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendApprovalRequest" name="Send request">
      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approved?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorApprove" name="Decision sent">
      <bpmn:incoming>Flow_7_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorApprove" />
    </bpmn:intermediateThrowEvent>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorReject" name="Decision sent">
      <bpmn:incoming>Flow_7_No</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorReject" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndSupervisorResponded" name="Responded">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorDecision" name="Decision received">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisor" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_14_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_14_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApproved" name="Send approval">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectedSupervisor" name="Send rejection">
      <bpmn:incoming>Flow_14_No</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Rejected">
      <bpmn:incoming>Flow_17</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewEscalation" name="Review escalation">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRDecision" name="Approved?">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_22_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartRequestSubmitted" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />

    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="GwEnoughDays" targetRef="TaskSendRejectedNoDays" />
    <bpmn:sequenceFlow id="Flow_3_Yes" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApprovalRequest" />

    <bpmn:sequenceFlow id="Flow_4" sourceRef="TaskSendRejectedNoDays" targetRef="EndRejectedNoDays" />

    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendApprovalRequest" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />

    <bpmn:sequenceFlow id="Flow_7_Yes" name="Yes" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorApprove" />
    <bpmn:sequenceFlow id="Flow_7_No" name="No" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorReject" />

    <bpmn:sequenceFlow id="Flow_8" sourceRef="ThrowSupervisorApprove" targetRef="EndSupervisorResponded" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="ThrowSupervisorReject" targetRef="EndSupervisorResponded" />

    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendApprovalRequest" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />

    <bpmn:sequenceFlow id="Flow_13" sourceRef="CatchSupervisorDecision" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_14_Yes" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_14_No" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskSendRejectedSupervisor" />

    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskBookVacation" targetRef="TaskSendApproved" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskSendApproved" targetRef="EndApproved" />

    <bpmn:sequenceFlow id="Flow_17" sourceRef="TaskSendRejectedSupervisor" targetRef="EndRejectedSupervisor" />

    <bpmn:sequenceFlow id="Flow_20" sourceRef="CatchTimeout" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="TaskReviewEscalation" targetRef="GwHRDecision" />

    <bpmn:sequenceFlow id="Flow_22_Yes" name="Yes" sourceRef="GwHRDecision" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_22_No" name="No" sourceRef="GwHRDecision" targetRef="TaskSendRejectedHR" />

    <bpmn:sequenceFlow id="Flow_23" sourceRef="TaskSendRejectedHR" targetRef="EndRejectedHR" />

    <bpmn:sendTask id="TaskSendRejectedHR" name="Send rejection">
      <bpmn:incoming>Flow_22_No</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedHR" name="Rejected">
      <bpmn:incoming>Flow_23</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="220" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="360" width="1400" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="550" width="1400" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolBooking_di" bpmnElement="PoolBooking" isHorizontal="true">
        <dc:Bounds x="160" y="660" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestSubmitted_di" bpmnElement="StartRequestSubmitted">
        <dc:Bounds x="220" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="175" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckDays_di" bpmnElement="TaskCheckDays">
        <dc:Bounds x="330" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="500" y="125" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="485" y="182" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectedNoDays_di" bpmnElement="TaskSendRejectedNoDays">
        <dc:Bounds x="610" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedNoDays_di" bpmnElement="EndRejectedNoDays">
        <dc:Bounds x="760" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="748" y="175" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalRequest_di" bpmnElement="TaskSendApprovalRequest">
        <dc:Bounds x="610" y="20" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="770" y="35" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorDecision_di" bpmnElement="CatchSupervisorDecision">
        <dc:Bounds x="900" y="22" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="0" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout_di" bpmnElement="CatchTimeout">
        <dc:Bounds x="900" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="865" y="120" width="106" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="1000" y="15" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="990" y="72" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1120" y="20" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproved_di" bpmnElement="TaskSendApproved">
        <dc:Bounds x="1270" y="20" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1420" y="42" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1410" y="85" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectedSupervisor_di" bpmnElement="TaskSendRejectedSupervisor">
        <dc:Bounds x="1120" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisor_di" bpmnElement="EndRejectedSupervisor">
        <dc:Bounds x="1270" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1252" y="185" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="770" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="930" y="265" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="915" y="322" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ThrowSupervisorApprove_di" bpmnElement="ThrowSupervisorApprove">
        <dc:Bounds x="1050" y="245" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1030" y="285" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ThrowSupervisorReject_di" bpmnElement="ThrowSupervisorReject">
        <dc:Bounds x="1050" y="305" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1030" y="345" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndSupervisorResponded_di" bpmnElement="EndSupervisorResponded">
        <dc:Bounds x="1160" y="275" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1146" y="318" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewEscalation_di" bpmnElement="TaskReviewEscalation">
        <dc:Bounds x="1000" y="390" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRDecision_di" bpmnElement="GwHRDecision" isMarkerVisible="true">
        <dc:Bounds x="1150" y="405" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1135" y="462" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectedHR_di" bpmnElement="TaskSendRejectedHR">
        <dc:Bounds x="1270" y="390" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHR_di" bpmnElement="EndRejectedHR">
        <dc:Bounds x="1420" y="412" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1402" y="455" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="150" />
        <di:waypoint x="330" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="150" />
        <di:waypoint x="500" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_No_di" bpmnElement="Flow_3_No">
        <di:waypoint x="550" y="150" />
        <di:waypoint x="610" y="150" />
        <bpmndi:BPMNLabel><dc:Bounds x="573" y="132" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_Yes_di" bpmnElement="Flow_3_Yes">
        <di:waypoint x="525" y="125" />
        <di:waypoint x="525" y="60" />
        <di:waypoint x="610" y="60" />
        <bpmndi:BPMNLabel><dc:Bounds x="535" y="82" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="710" y="150" />
        <di:waypoint x="760" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="710" y="60" />
        <di:waypoint x="770" y="60" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="820" y="50" />
        <di:waypoint x="900" y="40" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="820" y="70" />
        <di:waypoint x="860" y="100" />
        <di:waypoint x="900" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="936" y="40" />
        <di:waypoint x="1000" y="40" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_Yes_di" bpmnElement="Flow_14_Yes">
        <di:waypoint x="1050" y="40" />
        <di:waypoint x="1120" y="60" />
        <bpmndi:BPMNLabel><dc:Bounds x="1072" y="40" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_No_di" bpmnElement="Flow_14_No">
        <di:waypoint x="1025" y="65" />
        <di:waypoint x="1025" y="160" />
        <di:waypoint x="1120" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="1034" y="112" width="18" height="14" /></bpmndi:BPMNLabel>
