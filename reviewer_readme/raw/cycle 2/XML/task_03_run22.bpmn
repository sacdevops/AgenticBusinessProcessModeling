        <dc:Bounds x="980" y="345" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="965" y="402" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ThrowSupervisorDecision_di" bpmnElement="ThrowSupervisorDecision">
        <dc:Bounds x="1122" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1100" y="395" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="820" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorFeedback_di" bpmnElement="CatchSupervisorFeedback">
        <dc:Bounds x="940" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="910" y="275" width="95" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch5Days_di" bpmnElement="Catch5Days">
        <dc:Bounds x="940" y="472" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="905" y="515" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorOutcome_di" bpmnElement="GwSupervisorOutcome" isMarkerVisible="true">
        <dc:Bounds x="1040" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1025" y="282" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1220" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1380" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1360" y="275" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisor_di" bpmnElement="EndRejectedSupervisor">
        <dc:Bounds x="1220" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1190" y="375" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewHRManager_di" bpmnElement="TaskReviewHRManager">
        <dc:Bounds x="1040" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRApproved_di" bpmnElement="GwHRApproved" isMarkerVisible="true">
        <dc:Bounds x="1200" y="465" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1185" y="522" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHR_di" bpmnElement="EndRejectedHR">
        <dc:Bounds x="1380" y="472" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1355" y="515" width="95" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="258" y="250" />
        <di:waypoint x="340" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="250" />
        <di:waypoint x="520" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_No_di" bpmnElement="Flow_3_No">
        <di:waypoint x="545" y="225" />
        <di:waypoint x="545" y="160" />
        <di:waypoint x="640" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="553" y="185" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_Yes_di" bpmnElement="Flow_3_Yes">
        <di:waypoint x="570" y="250" />
        <di:waypoint x="640" y="250" />
        <bpmndi:BPMNLabel><dc:Bounds x="600" y="232" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="740" y="250" />
        <di:waypoint x="780" y="250" />
        <di:waypoint x="780" y="370" />
        <di:waypoint x="820" y="370" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="920" y="370" />
        <di:waypoint x="980" y="370" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_Yes_di" bpmnElement="Flow_6_Yes">
        <di:waypoint x="1030" y="370" />
        <di:waypoint x="1122" y="370" />
        <bpmndi:BPMNLabel><dc:Bounds x="1065" y="352" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_No_di" bpmnElement="Flow_6_No">
        <di:waypoint x="1005" y="395" />
        <di:waypoint x="1005" y="430" />
        <di:waypoint x="1140" y="430" />
        <di:waypoint x="1140" y="388" />
        <bpmndi:BPMNLabel><dc:Bounds x="1015" y="412" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1158" y="370" />
        <di:waypoint x="1185" y="370" />
        <di:waypoint x="1185" y="250" />
        <di:waypoint x="870" y="250" />
        <di:waypoint x="870" y="250" />
        <di:waypoint x="820" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_Msg_di" bpmnElement="Flow_8_Msg">
        <di:waypoint x="870" y="250" />
        <di:waypoint x="940" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_Timer_di" bpmnElement="Flow_8_Timer">
        <di:waypoint x="845" y="275" />
        <di:waypoint x="845" y="490" />
        <di:waypoint x="940" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="976" y="250" />
        <di:waypoint x="1040" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="976" y="490" />
        <di:waypoint x="1040" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_Yes_di" bpmnElement="Flow_11_Yes">
        <di:waypoint x="1090" y="250" />
