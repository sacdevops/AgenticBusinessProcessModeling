        <di:waypoint x="1065" y="275" />
        <di:waypoint x="1065" y="350" />
        <di:waypoint x="1220" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="1075" y="305" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1320" y="250" />
        <di:waypoint x="1380" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1140" y="490" />
        <di:waypoint x="1200" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_Yes_di" bpmnElement="Flow_14_Yes">
        <di:waypoint x="1250" y="490" />
        <di:waypoint x="1270" y="490" />
        <di:waypoint x="1270" y="290" />
        <di:waypoint x="1220" y="290" />
        <bpmndi:BPMNLabel><dc:Bounds x="1260" y="400" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_No_di" bpmnElement="Flow_14_No">
        <di:waypoint x="1225" y="515" />
        <di:waypoint x="1225" y="490" />
        <di:waypoint x="1380" y="490" />
        <bpmndi:BPMNLabel><dc:Bounds x="1270" y="472" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitRequest_di" bpmnElement="MF_SubmitRequest">
        <di:waypoint x="860" y="140" />
        <di:waypoint x="240" y="190" />
        <di:waypoint x="240" y="232" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyInsufficient_di" bpmnElement="MF_NotifyInsufficient">
        <di:waypoint x="658" y="142" />
        <di:waypoint x="658" y="110" />
        <di:waypoint x="860" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyRejectedSupervisor_di" bpmnElement="MF_NotifyRejectedSupervisor">
        <di:waypoint x="1238" y="332" />
        <di:waypoint x="1238" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyRejectedHR_di" bpmnElement="MF_NotifyRejectedHR">
        <di:waypoint x="1398" y="472" />
        <di:waypoint x="1398" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyApproved_di" bpmnElement="MF_NotifyApproved">
        <di:waypoint x="1398" y="232" />
        <di:waypoint x="1398" y="140" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
