<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolCustomer" name="Customer" />
    <bpmn:participant id="PoolAssessor" name="External Assessor" />

    <bpmn:messageFlow id="MF_DamageReport" name="Damage report" sourceRef="PoolCustomer" targetRef="StartDamageReport" />
    <bpmn:messageFlow id="MF_AssessorOrder" name="Assessment order" sourceRef="TaskSendAssessorOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_AssessmentReport" name="Assessment report" sourceRef="PoolAssessor" targetRef="CatchAssessment" />

    <bpmn:messageFlow id="MF_NotifyApproval" name="Approval" sourceRef="TaskSendApproval" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyRejection" name="Rejection" sourceRef="TaskSendRejection" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyDeadlineRejection" name="Deadline rejection" sourceRef="TaskSendDeadlineRejection" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmountHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveDirect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendAssessorOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendDeadlineRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndDeadlineRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePayment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartDamageReport" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?" isMarkerVisible="true">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejection" name="Send rejection">
      <bpmn:incoming>Flow_4_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5_RejEnd</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejected" name="Case closed">
      <bpmn:incoming>Flow_5_RejEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_4_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmountHigh" name="> €1500?" isMarkerVisible="true">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Low</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_High</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveDirect" name="Approve case">
      <bpmn:incoming>Flow_7_Low</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePayment" name="Initiate payment">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApproval" name="Send approval">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10_AppEnd</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Process ended">
      <bpmn:incoming>Flow_10_AppEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendAssessorOrder" name="Order assessment">
      <bpmn:incoming>Flow_7_High</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitAssessment" name="" >
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12_Assessment</bpmn:outgoing>
      <bpmn:outgoing>Flow_12_Deadline</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchAssessment" name="Assessment received">
      <bpmn:incoming>Flow_12_Assessment</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Assessment" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="10 days exceeded">
      <bpmn:incoming>Flow_12_Deadline</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendDeadlineRejection" name="Send rejection">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15_DeadEnd</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndDeadlineRejected" name="Process ended">
      <bpmn:incoming>Flow_15_DeadEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalDecision" name="Approve?" isMarkerVisible="true">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_17_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_4_No" name="No" sourceRef="GwCovered" targetRef="TaskSendRejection" />
    <bpmn:sequenceFlow id="Flow_4_Yes" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_5_RejEnd" sourceRef="TaskSendRejection" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskCheckAmount" targetRef="GwAmountHigh" />
    <bpmn:sequenceFlow id="Flow_7_Low" name="No" sourceRef="GwAmountHigh" targetRef="TaskApproveDirect" />
    <bpmn:sequenceFlow id="Flow_7_High" name="Yes" sourceRef="GwAmountHigh" targetRef="TaskSendAssessorOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskApproveDirect" targetRef="TaskInitiatePayment" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInitiatePayment" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_10_AppEnd" sourceRef="TaskSendApproval" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskSendAssessorOrder" targetRef="GwWaitAssessment" />
    <bpmn:sequenceFlow id="Flow_12_Assessment" sourceRef="GwWaitAssessment" targetRef="CatchAssessment" />
    <bpmn:sequenceFlow id="Flow_12_Deadline" sourceRef="GwWaitAssessment" targetRef="CatchDeadline" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="CatchAssessment" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="CatchDeadline" targetRef="TaskSendDeadlineRejection" />
    <bpmn:sequenceFlow id="Flow_15_DeadEnd" sourceRef="TaskSendDeadlineRejection" targetRef="EndDeadlineRejected" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskReviewAssessment" targetRef="GwFinalDecision" />
    <bpmn:sequenceFlow id="Flow_17_Yes" name="Yes" sourceRef="GwFinalDecision" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_17_No" name="No" sourceRef="GwFinalDecision" targetRef="TaskSendRejection" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">

      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="232" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="195" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="500" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="655" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="645" y="202" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejection_di" bpmnElement="TaskSendRejection">
        <dc:Bounds x="780" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="950" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="920" y="125" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="780" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmountHigh_di" bpmnElement="GwAmountHigh" isMarkerVisible="true">
        <dc:Bounds x="935" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="920" y="252" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveDirect_di" bpmnElement="TaskApproveDirect">
        <dc:Bounds x="1090" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment_di" bpmnElement="TaskInitiatePayment">
        <dc:Bounds x="1250" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproval_di" bpmnElement="TaskSendApproval">
        <dc:Bounds x="1410" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1525" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1502" y="185" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendAssessorOrder_di" bpmnElement="TaskSendAssessorOrder">
        <dc:Bounds x="1090" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitAssessment_di" bpmnElement="GwWaitAssessment">
        <dc:Bounds x="1250" y="245" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAssessment_di" bpmnElement="CatchAssessment">
        <dc:Bounds x="1360" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1335" y="295" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline_di" bpmnElement="CatchDeadline">
        <dc:Bounds x="1360" y="110" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1328" y="88" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendDeadlineRejection_di" bpmnElement="TaskSendDeadlineRejection">
        <dc:Bounds x="1410" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndDeadlineRejected_di" bpmnElement="EndDeadlineRejected">
        <dc:Bounds x="1525" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1496" y="135" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1410" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalDecision_di" bpmnElement="GwFinalDecision" isMarkerVisible="true">
        <dc:Bounds x="1525" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1516" y="302" width="58" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="268" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="170" />
        <di:waypoint x="655" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_No_di" bpmnElement="Flow_4_No">
        <di:waypoint x="680" y="145" />
        <di:waypoint x="680" y="100" />
        <di:waypoint x="780" y="100" />
        <bpmndi:BPMNLabel><dc:Bounds x="690" y="106" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_Yes_di" bpmnElement="Flow_4_Yes">
        <di:waypoint x="705" y="170" />
        <di:waypoint x="742" y="170" />
        <di:waypoint x="742" y="220" />
        <di:waypoint x="780" y="220" />
        <bpmndi:BPMNLabel><dc:Bounds x="716" y="186" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_RejEnd_di" bpmnElement="Flow_5_RejEnd">
        <di:waypoint x="880" y="100" />
        <di:waypoint x="950" y="100" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="880" y="220" />
        <di:waypoint x="935" y="220" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Low_di" bpmnElement="Flow_7_Low">
        <di:waypoint x="960" y="195" />
        <di:waypoint x="960" y="160" />
        <di:waypoint x="1090" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="968" y="166" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_High_di" bpmnElement="Flow_7_High">
        <di:waypoint x="985" y="220" />
        <di:waypoint x="1090" y="270" />
        <bpmndi:BPMNLabel><dc:Bounds x="1010" y="238" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1190" y="160" />
        <di:waypoint x="1220" y="160" />
        <di:waypoint x="1220" y="350" />
        <di:waypoint x="1250" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1350" y="350" />
        <di:waypoint x="1380" y="350" />
        <di:waypoint x="1380" y="160" />
        <di:waypoint x="1410" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_AppEnd_di" bpmnElement="Flow_10_AppEnd">
        <di:waypoint x="1510" y="160" />
        <di:waypoint x="1525" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1190" y="270" />
        <di:waypoint x="1250" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_Assessment_di" bpmnElement="Flow_12_Assessment">
        <di:waypoint x="1300" y="270" />
        <di:waypoint x="1360" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_Deadline_di" bpmnElement="Flow_12_Deadline">
        <di:waypoint x="1275" y="245" />
        <di:waypoint x="1275" y="128" />
        <di:waypoint x="1360" y="128" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1396" y="270" />
        <di:waypoint x="1410" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1396" y="128" />
        <di:waypoint x="1410" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_DeadEnd_di" bpmnElement="Flow_15_DeadEnd">
        <di:waypoint x="1510" y="110" />
        <di:waypoint x="1525" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1510" y="270" />
        <di:waypoint x="1525" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_Yes_di" bpmnElement="Flow_17_Yes">
        <di:waypoint x="1550" y="245" />
        <di:waypoint x="1550" y="160" />
        <di:waypoint x="1510" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="1556" y="190" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_No_di" bpmnElement="Flow_17_No">
        <di:waypoint x="1525" y="270" />
        <di:waypoint x="830" y="270" />
        <di:waypoint x="830" y="140" />
        <di:waypoint x="830" y="140" />
        <bpmndi:BPMNLabel><dc:Bounds x="1160" y="256" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_DamageReport_di" bpmnElement="MF_DamageReport">
        <di:waypoint x="860" y="490" />
        <di:waypoint x="250" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_AssessorOrder_di" bpmnElement="MF_AssessorOrder">
        <di:waypoint x="1140" y="310" />
        <di:waypoint x="1140" y="600" />
      </bpmndi:BPMNEdge>

