<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolAuthority" name="Building Authority" processRef="Process_Authority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissingDocs" name="Missing documents" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissingDocs" name="Missing documents" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_ForwardToEnv" name="Application" sourceRef="TaskForwardToEnvAgency" targetRef="PoolEnvAgency" />
    <bpmn:messageFlow id="MF_EnvFeedback" name="Opinion" sourceRef="PoolEnvAgency" targetRef="CatchEnvOpinion" />

    <bpmn:messageFlow id="MF_InformRejection" name="Rejection" sourceRef="EndRejected" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformPermit" name="Permit" sourceRef="EndPermitIssued" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Authority" name="Processing of building permits" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Authority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCompleteInitial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDocsTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRecheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCompleteAfterResub</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToEnvAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnvPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndPermitIssued</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnicalDetails</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechnicalOk</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:messageEventDefinition id="MED_StartApplication" />
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCompleteInitial" name="Complete?">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_03_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_03_No</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05_Msg</bpmn:outgoing>
      <bpmn:outgoing>Flow_05_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_05_Msg</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDocsTimeout" name="14 days exceeded">
      <bpmn:incoming>Flow_05_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskRecheckCompleteness" name="Recheck completeness">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCompleteAfterResub" name="Complete?">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_09_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskForwardToEnvAgency" name="Forward application">
      <bpmn:incoming>Flow_03_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_09_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchEnvOpinion" name="Opinion received">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_EnvOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwEnvPositive" name="Positive?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnicalDetails" name="Check technicals">
      <bpmn:incoming>Flow_12_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechnicalOk" name="OK?">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_14_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_14_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndPermitIssued" name="Permit issued">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Permit" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejected" name="Application rejected">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_09_No</bpmn:incoming>
      <bpmn:incoming>Flow_12_No</bpmn:incoming>
      <bpmn:incoming>Flow_14_No</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Rejection" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="TaskCheckCompleteness" targetRef="GwCompleteInitial" />
    <bpmn:sequenceFlow id="Flow_03_Yes" name="Yes" sourceRef="GwCompleteInitial" targetRef="TaskForwardToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_03_No" name="No" sourceRef="GwCompleteInitial" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_05_Msg" sourceRef="GwWaitDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_05_Timer" sourceRef="GwWaitDocs" targetRef="CatchDocsTimeout" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="CatchMissingDocs" targetRef="TaskRecheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="CatchDocsTimeout" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="TaskRecheckCompleteness" targetRef="GwCompleteAfterResub" />
    <bpmn:sequenceFlow id="Flow_09_Yes" name="Yes" sourceRef="GwCompleteAfterResub" targetRef="TaskForwardToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_09_No" name="No" sourceRef="GwCompleteAfterResub" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskForwardToEnvAgency" targetRef="CatchEnvOpinion" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="CatchEnvOpinion" targetRef="GwEnvPositive" />
    <bpmn:sequenceFlow id="Flow_12_Yes" name="Yes" sourceRef="GwEnvPositive" targetRef="TaskCheckTechnicalDetails" />
    <bpmn:sequenceFlow id="Flow_12_No" name="No" sourceRef="GwEnvPositive" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskCheckTechnicalDetails" targetRef="GwTechnicalOk" />
    <bpmn:sequenceFlow id="Flow_14_Yes" name="Yes" sourceRef="GwTechnicalOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_14_No" name="No" sourceRef="GwTechnicalOk" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskIssuePermit" targetRef="EndPermitIssued" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolAuthority_di" bpmnElement="PoolAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolEnvAgency_di" bpmnElement="PoolEnvAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="196" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCompleteInitial_di" bpmnElement="GwCompleteInitial" isMarkerVisible="true">
        <dc:Bounds x="490" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="482" y="202" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocs_di" bpmnElement="TaskRequestMissingDocs">
        <dc:Bounds x="610" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDocs_di" bpmnElement="GwWaitDocs">
        <dc:Bounds x="770" y="55" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocs_di" bpmnElement="CatchMissingDocs">
        <dc:Bounds x="900" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="875" y="26" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDocsTimeout_di" bpmnElement="CatchDocsTimeout">
        <dc:Bounds x="900" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="872" y="225" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRecheckCompleteness_di" bpmnElement="TaskRecheckCompleteness">
        <dc:Bounds x="1010" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCompleteAfterResub_di" bpmnElement="GwCompleteAfterResub" isMarkerVisible="true">
        <dc:Bounds x="1170" y="55" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1162" y="112" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToEnvAgency_di" bpmnElement="TaskForwardToEnvAgency">
        <dc:Bounds x="610" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchEnvOpinion_di" bpmnElement="CatchEnvOpinion">
        <dc:Bounds x="790" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="767" y="295" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnvPositive_di" bpmnElement="GwEnvPositive" isMarkerVisible="true">
        <dc:Bounds x="890" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="883" y="302" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnicalDetails_di" bpmnElement="TaskCheckTechnicalDetails">
        <dc:Bounds x="1010" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechnicalOk_di" bpmnElement="GwTechnicalOk" isMarkerVisible="true">
        <dc:Bounds x="1170" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1182" y="382" width="26" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1330" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndPermitIssued_di" bpmnElement="EndPermitIssued">
        <dc:Bounds x="1500" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1478" y="375" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1500" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1462" y="185" width="112" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="490" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_03_Yes_di" bpmnElement="Flow_03_Yes">
        <di:waypoint x="540" y="170" />
        <di:waypoint x="585" y="170" />
        <di:waypoint x="585" y="270" />
        <di:waypoint x="610" y="270" />
        <bpmndi:BPMNLabel><dc:Bounds x="560" y="214" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_03_No_di" bpmnElement="Flow_03_No">
        <di:waypoint x="515" y="145" />
        <di:waypoint x="515" y="80" />
        <di:waypoint x="610" y="80" />
        <bpmndi:BPMNLabel><dc:Bounds x="522" y="98" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="710" y="80" />
        <di:waypoint x="770" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_05_Msg_di" bpmnElement="Flow_05_Msg">
        <di:waypoint x="820" y="80" />
        <di:waypoint x="900" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_05_Timer_di" bpmnElement="Flow_05_Timer">
        <di:waypoint x="795" y="105" />
        <di:waypoint x="795" y="200" />
        <di:waypoint x="900" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="936" y="80" />
        <di:waypoint x="1010" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="1110" y="80" />
        <di:waypoint x="1170" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_09_Yes_di" bpmnElement="Flow_09_Yes">
        <di:waypoint x="1220" y="80" />
        <di:waypoint x="1260" y="80" />
        <di:waypoint x="1260" y="270" />
        <di:waypoint x="710" y="270" />
        <bpmndi:BPMNLabel><dc:Bounds x="1230" y="90" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_09_No_di" bpmnElement="Flow_09_No">
        <di:waypoint x="1195" y="105" />
        <di:waypoint x="1195" y="160" />
        <di:waypoint x="1500" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="1202" y="132" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="710" y="270" />
        <di:waypoint x="790" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="826" y="270" />
        <di:waypoint x="890" y="270" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_Yes_di" bpmnElement="Flow_12_Yes">
        <di:waypoint x="940" y="270" />
        <di:waypoint x="980" y="270" />
        <di:waypoint x="980" y="350" />
        <di:waypoint x="1010" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="955" y="288" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_No_di" bpmnElement="Flow_12_No">
        <di:waypoint x="915" y="245" />
        <di:waypoint x="915" y="160" />
        <di:waypoint x="1500" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="922" y="180" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1110" y="350" />
        <di:waypoint x="1170" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_Yes_di" bpmnElement="Flow_14_Yes">
        <di:waypoint x="1220" y="350" />
        <di:waypoint x="1330" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="1260" y="330" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_No_di" bpmnElement="Flow_14_No">
        <di:waypoint x="1195" y="325" />
        <di:waypoint x="1195" y="160" />
        <di:waypoint x="1500" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="1202" y="170" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1430" y="350" />
        <di:waypoint x="1500" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="936" y="200" />
        <di:waypoint x="1200" y="200" />
        <di:waypoint x="1200" y="160" />
        <di:waypoint x="1500" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitApplication_di" bpmnElement="MF_SubmitApplication">
        <di:waypoint x="520" y="490" />
        <di:waypoint x="520" y="120" />
        <di:waypoint x="238" y="120" />
        <di:waypoint x="238" y="152" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestMissingDocs_di" bpmnElement="MF_RequestMissingDocs">
        <di:waypoint x="660" y="40" />
        <di:waypoint x="660" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitMissingDocs_di" bpmnElement="MF_SubmitMissingDocs">
        <di:waypoint x="740" y="490" />
        <di:waypoint x="740" y="30" />
        <di:waypoint x="918" y="30" />
        <di:waypoint x="918" y="62" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_ForwardToEnv_di" bpmnElement="MF_ForwardToEnv">
        <di:waypoint x="660" y="310" />
        <di:waypoint x="660" y="600" />
      </bpmndi:BPMNEdge>

