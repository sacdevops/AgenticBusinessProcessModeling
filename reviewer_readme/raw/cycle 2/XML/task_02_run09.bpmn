<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="Assessor" />

    <bpmn:messageFlow id="MF_OrderAssessor" name="Order" sourceRef="TaskSendOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_Report" name="Report" sourceRef="PoolAssessor" targetRef="CatchReport" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmountHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveDirect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApprovedFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskAutoRejectDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage reported">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?" isMarkerVisible="true">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:outgoing>Flow_Cov_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Cov_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionNotCovered" name="Send rejection">
      <bpmn:incoming>Flow_Cov_No</bpmn:incoming>
      <bpmn:outgoing>Flow_R1</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedNotCovered" name="Case closed">
      <bpmn:incoming>Flow_R1</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_Cov_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmountHigh" name="> €1500?" isMarkerVisible="true">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_Amount_Low</bpmn:outgoing>
      <bpmn:outgoing>Flow_Amount_High</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveDirect" name="Approve case">
      <bpmn:incoming>Flow_Amount_Low</bpmn:incoming>
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePayment" name="Initiate payment">
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApproval" name="Send approval">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:outgoing>Flow_P3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Process ended">
      <bpmn:incoming>Flow_P3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrder" name="Send order">
      <bpmn:incoming>Flow_Amount_High</bpmn:incoming>
      <bpmn:outgoing>Flow_O1</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitReport" name="" >
      <bpmn:incoming>Flow_O1</bpmn:incoming>
      <bpmn:outgoing>Flow_W1</bpmn:outgoing>
      <bpmn:outgoing>Flow_W2</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReport" name="Report received">
      <bpmn:incoming>Flow_W1</bpmn:incoming>
      <bpmn:outgoing>Flow_W3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Report" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="10 days exceeded">
      <bpmn:incoming>Flow_W2</bpmn:incoming>
      <bpmn:outgoing>Flow_D1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskAutoRejectDeadline" name="Auto reject">
      <bpmn:incoming>Flow_D1</bpmn:incoming>
      <bpmn:outgoing>Flow_D2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendRejectionDeadline" name="Send rejection">
      <bpmn:incoming>Flow_D2</bpmn:incoming>
      <bpmn:outgoing>Flow_D3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedDeadline" name="Process ended">
      <bpmn:incoming>Flow_D3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_W3</bpmn:incoming>
      <bpmn:outgoing>Flow_F1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_F1</bpmn:incoming>
      <bpmn:outgoing>Flow_Final_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Final_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePaymentFinal" name="Initiate payment">
      <bpmn:incoming>Flow_Final_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_F2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalFinal" name="Send approval">
      <bpmn:incoming>Flow_F2</bpmn:incoming>
      <bpmn:outgoing>Flow_F3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApprovedFinal" name="Process ended">
      <bpmn:incoming>Flow_F3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectionFinal" name="Send rejection">
      <bpmn:incoming>Flow_Final_No</bpmn:incoming>
      <bpmn:outgoing>Flow_F4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedFinal" name="Process ended">
      <bpmn:incoming>Flow_F4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_S3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />

    <bpmn:sequenceFlow id="Flow_Cov_No" name="No" sourceRef="GwCovered" targetRef="TaskSendRejectionNotCovered" />
    <bpmn:sequenceFlow id="Flow_Cov_Yes" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />

    <bpmn:sequenceFlow id="Flow_R1" sourceRef="TaskSendRejectionNotCovered" targetRef="EndRejectedNotCovered" />

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="TaskCheckAmount" targetRef="GwAmountHigh" />
    <bpmn:sequenceFlow id="Flow_Amount_Low" name="No" sourceRef="GwAmountHigh" targetRef="TaskApproveDirect" />
    <bpmn:sequenceFlow id="Flow_Amount_High" name="Yes" sourceRef="GwAmountHigh" targetRef="TaskSendOrder" />

    <bpmn:sequenceFlow id="Flow_P1" sourceRef="TaskApproveDirect" targetRef="TaskInitiatePayment" />
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="TaskInitiatePayment" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_P3" sourceRef="TaskSendApproval" targetRef="EndApproved" />

    <bpmn:sequenceFlow id="Flow_O1" sourceRef="TaskSendOrder" targetRef="GwWaitReport" />
    <bpmn:sequenceFlow id="Flow_W1" sourceRef="GwWaitReport" targetRef="CatchReport" />
    <bpmn:sequenceFlow id="Flow_W2" sourceRef="GwWaitReport" targetRef="CatchDeadline" />

    <bpmn:sequenceFlow id="Flow_W3" sourceRef="CatchReport" targetRef="TaskReviewAssessment" />

    <bpmn:sequenceFlow id="Flow_D1" sourceRef="CatchDeadline" targetRef="TaskAutoRejectDeadline" />
    <bpmn:sequenceFlow id="Flow_D2" sourceRef="TaskAutoRejectDeadline" targetRef="TaskSendRejectionDeadline" />
    <bpmn:sequenceFlow id="Flow_D3" sourceRef="TaskSendRejectionDeadline" targetRef="EndRejectedDeadline" />

    <bpmn:sequenceFlow id="Flow_F1" sourceRef="TaskReviewAssessment" targetRef="GwFinalApproved" />
    <bpmn:sequenceFlow id="Flow_Final_Yes" name="Yes" sourceRef="GwFinalApproved" targetRef="TaskInitiatePaymentFinal" />
    <bpmn:sequenceFlow id="Flow_F2" sourceRef="TaskInitiatePaymentFinal" targetRef="TaskSendApprovalFinal" />
    <bpmn:sequenceFlow id="Flow_F3" sourceRef="TaskSendApprovalFinal" targetRef="EndApprovedFinal" />

    <bpmn:sequenceFlow id="Flow_Final_No" name="No" sourceRef="GwFinalApproved" targetRef="TaskSendRejectionFinal" />
    <bpmn:sequenceFlow id="Flow_F4" sourceRef="TaskSendRejectionFinal" targetRef="EndRejectedFinal" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">
      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="240" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="218" y="195" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="480" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="630" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="621" y="202" width="55" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionNotCovered_di" bpmnElement="TaskSendRejectionNotCovered">
        <dc:Bounds x="750" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedNotCovered_di" bpmnElement="EndRejectedNotCovered">
        <dc:Bounds x="920" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="895" y="155" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="750" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmountHigh_di" bpmnElement="GwAmountHigh" isMarkerVisible="true">
        <dc:Bounds x="900" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="880" y="242" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveDirect_di" bpmnElement="TaskApproveDirect">
        <dc:Bounds x="1030" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment_di" bpmnElement="TaskInitiatePayment">
        <dc:Bounds x="1180" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproval_di" bpmnElement="TaskSendApproval">
        <dc:Bounds x="1330" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1490" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1476" y="235" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrder_di" bpmnElement="TaskSendOrder">
        <dc:Bounds x="1030" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitReport_di" bpmnElement="GwWaitReport">
        <dc:Bounds x="1180" y="325" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReport_di" bpmnElement="CatchReport">
        <dc:Bounds x="1310" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1285" y="355" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline_di" bpmnElement="CatchDeadline">
        <dc:Bounds x="1310" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1278" y="425" width="102" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAutoRejectDeadline_di" bpmnElement="TaskAutoRejectDeadline">
        <dc:Bounds x="1410" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionDeadline_di" bpmnElement="TaskSendRejectionDeadline">
        <dc:Bounds x="1200" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedDeadline_di" bpmnElement="EndRejectedDeadline">
        <dc:Bounds x="1360" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1336" y="155" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1410" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalApproved_di" bpmnElement="GwFinalApproved" isMarkerVisible="true">
        <dc:Bounds x="1530" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1522" y="342" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePaymentFinal_di" bpmnElement="TaskInitiatePaymentFinal">
        <dc:Bounds x="1620" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalFinal_di" bpmnElement="TaskSendApprovalFinal">
        <dc:Bounds x="1760" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApprovedFinal_di" bpmnElement="EndApprovedFinal">
        <dc:Bounds x="1920" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1906" y="155" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionFinal_di" bpmnElement="TaskSendRejectionFinal">
        <dc:Bounds x="1620" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedFinal_di" bpmnElement="EndRejectedFinal">
        <dc:Bounds x="1770" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1744" y="395" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="276" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="480" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="580" y="170" />
        <di:waypoint x="630" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Cov_No_di" bpmnElement="Flow_Cov_No">
        <di:waypoint x="655" y="145" />
        <di:waypoint x="655" y="130" />
        <di:waypoint x="750" y="130" />
        <bpmndi:BPMNLabel><dc:Bounds x="663" y="123" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Cov_Yes_di" bpmnElement="Flow_Cov_Yes">
        <di:waypoint x="680" y="170" />
        <di:waypoint x="730" y="210" />
        <di:waypoint x="750" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="697" y="187" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_R1_di" bpmnElement="Flow_R1">
        <di:waypoint x="850" y="130" />
        <di:waypoint x="920" y="130" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1">
        <di:waypoint x="850" y="210" />
        <di:waypoint x="900" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Amount_Low_di" bpmnElement="Flow_Amount_Low">
        <di:waypoint x="950" y="210" />
        <di:waypoint x="1030" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="975" y="190" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Amount_High_di" bpmnElement="Flow_Amount_High">
        <di:waypoint x="925" y="235" />
        <di:waypoint x="925" y="350" />
        <di:waypoint x="1030" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="932" y="288" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <di:waypoint x="1130" y="210" />
        <di:waypoint x="1180" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <di:waypoint x="1280" y="350" />
        <di:waypoint x="1320" y="210" />
        <di:waypoint x="1330" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P3_di" bpmnElement="Flow_P3">
        <di:waypoint x="1430" y="210" />
        <di:waypoint x="1490" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_O1_di" bpmnElement="Flow_O1">
        <di:waypoint x="1130" y="350" />
        <di:waypoint x="1180" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_W1_di" bpmnElement="Flow_W1">
        <di:waypoint x="1230" y="350" />
        <di:waypoint x="1310" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_W2_di" bpmnElement="Flow_W2">
