<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ReturnProcess" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_ReturnProcessing">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_Retailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" />
    <bpmn:messageFlow id="MF_RegisterReturn" name="Return request" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
    <bpmn:messageFlow id="MF_ReturnLabel" name="Return label" sourceRef="TaskGenerateLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_PackageArrives" name="Return delivered" sourceRef="PoolCustomer" targetRef="CatchReturnArrived" />
    <bpmn:messageFlow id="MF_NoRefundDamaged" name="No refund" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NoRefundTimeout" name="No refund" sourceRef="TaskCloseNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_RefundConfirmation" name="Credit confirmation" sourceRef="TaskSendCredit" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Retailer" name="Return Processing" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReturn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReturnArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout14d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCloseNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoRefundDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToAccounting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCredit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRefunded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartReturnRegistered" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:eventBasedGateway id="GwWaitReturn">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReturnArrived" name="Return arrived">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchReturnArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout14d" name="14 days exceeded">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Timeout14d" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskCloseNoRefund" name="Close return">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedNoRefund" name="Closed no refund">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskInspectGoods" name="Inspect goods">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods ok?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformNoRefund" name="Inform customer">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndNoRefundDamaged" name="No refund">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="TaskForwardToAccounting" name="Forward info">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendCredit" name="Send confirmation">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRefunded" name="Refunded">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateLabel" targetRef="GwWaitReturn" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="GwWaitReturn" targetRef="CatchReturnArrived" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitReturn" targetRef="CatchTimeout14d" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="CatchReturnArrived" targetRef="TaskInspectGoods" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchTimeout14d" targetRef="TaskCloseNoRefund" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="TaskCloseNoRefund" targetRef="EndClosedNoRefund" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskInspectGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_9" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="Flow_10" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardToAccounting" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskInformNoRefund" targetRef="EndNoRefundDamaged" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskForwardToAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskInitiateRefund" targetRef="TaskSendCredit" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskSendCredit" targetRef="EndRefunded" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ReturnProcessing">
    <bpmndi:BPMNPlane id="BPMNPlane_ReturnProcessing" bpmnElement="Collaboration_ReturnProcessing">
      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouse_di" bpmnElement="LaneWarehouse" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAccounting_di" bpmnElement="LaneAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="220" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="200" y="165" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskGenerateLabel_di" bpmnElement="TaskGenerateLabel">
        <dc:Bounds x="320" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitReturn_di" bpmnElement="GwWaitReturn">
        <dc:Bounds x="490" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout14d_di" bpmnElement="CatchTimeout14d">
        <dc:Bounds x="610" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="588" y="88" width="82" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCloseNoRefund_di" bpmnElement="TaskCloseNoRefund">
        <dc:Bounds x="720" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoRefund_di" bpmnElement="EndClosedNoRefund">
        <dc:Bounds x="880" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="852" y="165" width="92" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReturnArrived_di" bpmnElement="CatchReturnArrived">
        <dc:Bounds x="610" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="592" y="285" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInspectGoods_di" bpmnElement="TaskInspectGoods">
        <dc:Bounds x="720" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="890" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="872" y="292" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformNoRefund_di" bpmnElement="TaskInformNoRefund">
        <dc:Bounds x="1010" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNoRefundDamaged_di" bpmnElement="EndNoRefundDamaged">
        <dc:Bounds x="1170" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1158" y="285" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToAccounting_di" bpmnElement="TaskForwardToAccounting">
        <dc:Bounds x="1010" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="1170" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendCredit_di" bpmnElement="TaskSendCredit">
        <dc:Bounds x="1330" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRefunded_di" bpmnElement="EndRefunded">
        <dc:Bounds x="1480" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1469" y="405" width="58" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="140" />
        <di:waypoint x="320" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="140" />
        <di:waypoint x="490" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="515" y="165" />
        <di:waypoint x="515" y="260" />
        <di:waypoint x="610" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="540" y="140" />
        <di:waypoint x="610" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="646" y="140" />
        <di:waypoint x="720" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="820" y="140" />
        <di:waypoint x="880" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="646" y="260" />
        <di:waypoint x="720" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="820" y="260" />
        <di:waypoint x="890" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="940" y="260" />
        <di:waypoint x="1010" y="260" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="968" y="242" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1110" y="260" />
        <di:waypoint x="1170" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="915" y="285" />
        <di:waypoint x="915" y="380" />
        <di:waypoint x="1010" y="380" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="922" y="320" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1110" y="380" />
        <di:waypoint x="1170" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1270" y="380" />
        <di:waypoint x="1330" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1430" y="380" />
        <di:waypoint x="1480" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RegisterReturn_di" bpmnElement="MF_RegisterReturn">
        <di:waypoint x="860" y="490" />
        <di:waypoint x="860" y="70" />
        <di:waypoint x="238" y="70" />
        <di:waypoint x="238" y="122" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ReturnLabel_di" bpmnElement="MF_ReturnLabel">
        <di:waypoint x="370" y="180" />
        <di:waypoint x="370" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_PackageArrives_di" bpmnElement="MF_PackageArrives">
        <di:waypoint x="650" y="490" />
        <di:waypoint x="650" y="278" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_NoRefundDamaged_di" bpmnElement="MF_NoRefundDamaged">
        <di:waypoint x="1060" y="300" />
        <di:waypoint x="1060" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_NoRefundTimeout_di" bpmnElement="MF_NoRefundTimeout">
        <di:waypoint x="770" y="180" />
        <di:waypoint x="770" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_RefundConfirmation_di" bpmnElement="MF_RefundConfirmation">
        <di:waypoint x="1380" y="340" />
        <di:waypoint x="1380" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>