<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="Assessor" />
    <bpmn:messageFlow id="MF_DamageReport" name="Damage report" sourceRef="PoolAssessor" targetRef="StartDamageReport" />
    <bpmn:messageFlow id="MF_Commission" name="Assessment order" sourceRef="TaskSendOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_Report" name="Assessment report" sourceRef="PoolAssessor" targetRef="CatchReport" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveDirect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectUncovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWait</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:messageEventDefinition id="MED_StartDamageReport" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?" isMarkerVisible="true">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_Covered</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_NotCovered</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskRejectUncovered" name="Reject claim">
      <bpmn:incoming>Flow_4_NotCovered</bpmn:incoming>
      <bpmn:outgoing>Flow_5_ToEndRejected</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_4_Covered</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmount" name="Amount > €1500?" isMarkerVisible="true">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Below</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_Above</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveDirect" name="Approve claim">
      <bpmn:incoming>Flow_7_Below</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePayment" name="Initiate payment">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9_ToEndApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendOrder" name="Send order">
      <bpmn:incoming>Flow_7_Above</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWait">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11_Report</bpmn:outgoing>
      <bpmn:outgoing>Flow_11_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReport" name="Report received">
      <bpmn:incoming>Flow_11_Report</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Report" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="10 days exceeded">
      <bpmn:incoming>Flow_11_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_13_ToEndDeadline</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalDecision" name="Approve?" isMarkerVisible="true">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_15_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePayment2" name="Initiate payment">
      <bpmn:incoming>Flow_15_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_16_ToEndApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="TaskRejectAssessment" name="Reject claim">
      <bpmn:incoming>Flow_15_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_17_ToEndRejected</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndApproved" name="Approval sent">
      <bpmn:incoming>Flow_9_ToEndApproved</bpmn:incoming>
      <bpmn:incoming>Flow_16_ToEndApproved</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejected" name="Rejection sent">
      <bpmn:incoming>Flow_5_ToEndRejected</bpmn:incoming>
      <bpmn:incoming>Flow_17_ToEndRejected</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejected" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedDeadline" name="Deadline rejection sent">
      <bpmn:incoming>Flow_13_ToEndDeadline</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndDeadline" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_4_Covered" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_4_NotCovered" name="No" sourceRef="GwCovered" targetRef="TaskRejectUncovered" />
    <bpmn:sequenceFlow id="Flow_5_ToEndRejected" sourceRef="TaskRejectUncovered" targetRef="EndRejected" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskCheckAmount" targetRef="GwAmount" />
    <bpmn:sequenceFlow id="Flow_7_Below" name="No" sourceRef="GwAmount" targetRef="TaskApproveDirect" />
    <bpmn:sequenceFlow id="Flow_7_Above" name="Yes" sourceRef="GwAmount" targetRef="TaskSendOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskApproveDirect" targetRef="TaskInitiatePayment" />
    <bpmn:sequenceFlow id="Flow_9_ToEndApproved" sourceRef="TaskInitiatePayment" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendOrder" targetRef="GwWait" />
    <bpmn:sequenceFlow id="Flow_11_Report" sourceRef="GwWait" targetRef="CatchReport" />
    <bpmn:sequenceFlow id="Flow_11_Timeout" sourceRef="GwWait" targetRef="CatchDeadline" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="CatchReport" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_13_ToEndDeadline" sourceRef="CatchDeadline" targetRef="EndRejectedDeadline" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskReviewAssessment" targetRef="GwFinalDecision" />
    <bpmn:sequenceFlow id="Flow_15_Approved" name="Yes" sourceRef="GwFinalDecision" targetRef="TaskInitiatePayment2" />
    <bpmn:sequenceFlow id="Flow_15_Rejected" name="No" sourceRef="GwFinalDecision" targetRef="TaskRejectAssessment" />
    <bpmn:sequenceFlow id="Flow_16_ToEndApproved" sourceRef="TaskInitiatePayment2" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_17_ToEndRejected" sourceRef="TaskRejectAssessment" targetRef="EndRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">
      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="188" y="195" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="470" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="620" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="610" y="202" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectUncovered_di" bpmnElement="TaskRejectUncovered">
        <dc:Bounds x="740" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1260" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1235" y="135" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="740" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmount_di" bpmnElement="GwAmount" isMarkerVisible="true">
        <dc:Bounds x="900" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="865" y="242" width="120" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveDirect_di" bpmnElement="TaskApproveDirect">
        <dc:Bounds x="1010" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment_di" bpmnElement="TaskInitiatePayment">
        <dc:Bounds x="1160" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1410" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1380" y="355" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrder_di" bpmnElement="TaskSendOrder">
        <dc:Bounds x="1010" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWait_di" bpmnElement="GwWait">
        <dc:Bounds x="1170" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReport_di" bpmnElement="CatchReport">
        <dc:Bounds x="1260" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1230" y="235" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline_di" bpmnElement="CatchDeadline">
        <dc:Bounds x="1260" y="300" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1228" y="343" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1350" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalDecision_di" bpmnElement="GwFinalDecision" isMarkerVisible="true">
        <dc:Bounds x="1510" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1505" y="242" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment2_di" bpmnElement="TaskInitiatePayment2">
        <dc:Bounds x="1620" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectAssessment_di" bpmnElement="TaskRejectAssessment">
        <dc:Bounds x="1620" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedDeadline_di" bpmnElement="EndRejectedDeadline">
        <dc:Bounds x="1410" y="300" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1360" y="343" width="136" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="470" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="570" y="170" />
        <di:waypoint x="620" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_Covered_di" bpmnElement="Flow_4_Covered">
        <di:waypoint x="670" y="170" />
        <di:waypoint x="705" y="170" />
        <di:waypoint x="705" y="210" />
        <di:waypoint x="740" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="686" y="186" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_NotCovered_di" bpmnElement="Flow_4_NotCovered">
        <di:waypoint x="645" y="145" />
        <di:waypoint x="645" y="110" />
        <di:waypoint x="740" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="653" y="118" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_ToEndRejected_di" bpmnElement="Flow_5_ToEndRejected">
        <di:waypoint x="840" y="110" />
        <di:waypoint x="1260" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="840" y="210" />
        <di:waypoint x="900" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Below_di" bpmnElement="Flow_7_Below">
        <di:waypoint x="925" y="185" />
        <di:waypoint x="925" y="110" />
        <di:waypoint x="1010" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="931" y="146" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Above_di" bpmnElement="Flow_7_Above">
        <di:waypoint x="950" y="210" />
        <di:waypoint x="1010" y="230" />
        <bpmndi:BPMNLabel><dc:Bounds x="970" y="214" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1110" y="110" />
        <di:waypoint x="1140" y="110" />
        <di:waypoint x="1140" y="330" />
        <di:waypoint x="1160" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_ToEndApproved_di" bpmnElement="Flow_9_ToEndApproved">
        <di:waypoint x="1260" y="330" />
        <di:waypoint x="1410" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1110" y="230" />
        <di:waypoint x="1170" y="230" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_Report_di" bpmnElement="Flow_11_Report">
        <di:waypoint x="1220" y="230" />
        <di:waypoint x="1260" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_Timeout_di" bpmnElement="Flow_11_Timeout">
        <di:waypoint x="1195" y="255" />
        <di:waypoint x="1195" y="318" />
        <di:waypoint x="1260" y="318" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1296" y="210" />
        <di:waypoint x="1350" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_ToEndDeadline_di" bpmnElement="Flow_13_ToEndDeadline">
        <di:waypoint x="1296" y="318" />
        <di:waypoint x="1410" y="318" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1450" y="210" />
        <di:waypoint x="1510" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_Approved_di" bpmnElement="Flow_15_Approved">
        <di:waypoint x="1560" y="210" />
        <di:waypoint x="1620" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="1584" y="192" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_Rejected_di" bpmnElement="Flow_15_Rejected">
        <di:waypoint x="1535" y="185" />
        <di:waypoint x="1535" y="100" />
        <di:waypoint x="1620" y="100" />
        <bpmndi:BPMNLabel><dc:Bounds x="1542" y="122" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_ToEndApproved_di" bpmnElement="Flow_16_ToEndApproved">
        <di:waypoint x="1720" y="210" />
        <di:waypoint x="1760" y="210" />
        <di:waypoint x="1760" y="330" />
        <di:waypoint x="1446" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_ToEndRejected_di" bpmnElement="Flow_17_ToEndRejected">
        <di:waypoint x="1720" y="100" />
        <di:waypoint x="1760" y="100" />
        <di:waypoint x="1760" y="110" />
        <di:waypoint x="1296" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_DamageReport_di" bpmnElement="MF_DamageReport">
        <di:waypoint x="860" y="490" />
        <di:waypoint x="240" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Commission_di" bpmnElement="MF_Commission">
        <di:waypoint x="1060" y="270" />
        <di:waypoint x="1060" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Report_di" bpmnElement="MF_Report">
        <di:waypoint x="940" y="490" />
        <di:waypoint x="940" y="400" />
        <di:waypoint x="1278" y="400" />
        <di:waypoint x="1278" y="228" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>