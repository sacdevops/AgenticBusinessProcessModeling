        <di:waypoint x="1520" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitApplication_di" bpmnElement="MF_SubmitApplication">
        <di:waypoint x="600" y="490" />
        <di:waypoint x="600" y="60" />
        <di:waypoint x="238" y="60" />
        <di:waypoint x="238" y="152" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestMissingDocs_di" bpmnElement="MF_RequestMissingDocs">
        <di:waypoint x="670" y="210" />
        <di:waypoint x="670" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitMissingDocs_di" bpmnElement="MF_SubmitMissingDocs">
        <di:waypoint x="820" y="490" />
        <di:waypoint x="820" y="120" />
        <di:waypoint x="918" y="132" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SendToAgency_di" bpmnElement="MF_SendToAgency">
        <di:waypoint x="1090" y="210" />
        <di:waypoint x="1090" y="600" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_AgencyFeedback_di" bpmnElement="MF_AgencyFeedback">
        <di:waypoint x="1220" y="600" />
        <di:waypoint x="1220" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_InformApproved_di" bpmnElement="MF_InformApproved">
        <di:waypoint x="1818" y="292" />
        <di:waypoint x="1818" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_InformRejected_di" bpmnElement="MF_InformRejected">
        <di:waypoint x="1538" y="132" />
        <di:waypoint x="1538" y="490" />
      </bpmndi:BPMNEdge>

