        <di:waypoint x="900" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="936" y="150" />
        <di:waypoint x="1040" y="170" />
      </bpmndi:BPMNEdge>

