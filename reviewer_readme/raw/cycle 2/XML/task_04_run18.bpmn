          <dc:Bounds x="868" y="265" width="100" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedLate_di" bpmnElement="EndInformRejectedLate">
        <dc:Bounds x="1040" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1018" y="265" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToAgency_di" bpmnElement="TaskSendToAgency">
        <dc:Bounds x="1040" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAgencyOpinion_di" bpmnElement="CatchAgencyOpinion">
        <dc:Bounds x="1200" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1174" y="195" width="88" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOpinionPositive_di" bpmnElement="GwOpinionPositive" isMarkerVisible="true">
        <dc:Bounds x="1280" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1258" y="202" width="95" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectAfterOpinion_di" bpmnElement="TaskRejectAfterOpinion">
        <dc:Bounds x="1400" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejected_di" bpmnElement="EndInformRejected">
        <dc:Bounds x="1520" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1502" y="175" width="72" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskTechnicalCheck_di" bpmnElement="TaskTechnicalCheck">
        <dc:Bounds x="1400" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechOk_di" bpmnElement="GwTechOk" isMarkerVisible="true">
        <dc:Bounds x="1530" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1506" y="372" width="98" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1660" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectAfterTech_di" bpmnElement="TaskRejectAfterTech">
        <dc:Bounds x="1660" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformApproved_di" bpmnElement="EndInformApproved">
        <dc:Bounds x="1800" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1782" y="335" width="72" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

