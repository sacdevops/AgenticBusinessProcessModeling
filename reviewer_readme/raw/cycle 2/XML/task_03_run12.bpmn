<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHR" name="HR Department" processRef="Process_HR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />

    <bpmn:messageFlow id="MF_RequestApproval" name="Approval request" sourceRef="TaskSendToSupervisor" targetRef="TaskSupervisorReview" />
    <bpmn:messageFlow id="MF_SupervisorApprove" name="Approved" sourceRef="TaskSupervisorApprove" targetRef="CatchSupervisorApproved" />
    <bpmn:messageFlow id="MF_SupervisorReject" name="Rejected" sourceRef="TaskSupervisorReject" targetRef="CatchSupervisorRejected" />

    <bpmn:messageFlow id="MF_InformApproved" name="Approved" sourceRef="EndInformApproved" targetRef="CatchDecisionApproved" />
    <bpmn:messageFlow id="MF_InformRejectedBalance" name="Rejected" sourceRef="EndInformRejectedBalance" targetRef="CatchDecisionRejected" />
    <bpmn:messageFlow id="MF_InformRejectedSupervisor" name="Rejected" sourceRef="EndInformRejectedSupervisor" targetRef="CatchDecisionRejected" />
    <bpmn:messageFlow id="MF_InformRejectedHR" name="Rejected" sourceRef="EndInformRejectedHR" targetRef="CatchDecisionRejected" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartNeedVacation" name="Need vacation">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchDecisionApproved" name="Approval received">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_Approved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejected" name="Rejection received">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_Rejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndVacationPlanned" name="Vacation planned">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndVacationCancelled" name="Request closed">
      <bpmn:incoming>Flow_E4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartNeedVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="CatchDecisionApproved" />
    <bpmn:sequenceFlow id="Flow_E2b" sourceRef="TaskSubmitRequest" targetRef="CatchDecisionRejected" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="CatchDecisionApproved" targetRef="EndVacationPlanned" />
    <bpmn:sequenceFlow id="Flow_E4" sourceRef="CatchDecisionRejected" targetRef="EndVacationCancelled" />
  </bpmn:process>

  <bpmn:process id="Process_HR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskAutoReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout5Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedHR</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskSupervisorReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSupervisorApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSupervisorReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorDone</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskHRManagerDecide</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRManagerApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_HR_Request" />
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_H3_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskAutoReject" name="Auto reject">
      <bpmn:incoming>Flow_H3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndInformRejectedBalance" name="Rejection sent">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_HR_RejectBalance" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Request approval">
      <bpmn:incoming>Flow_H3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:outgoing>Flow_H6a</bpmn:outgoing>
      <bpmn:outgoing>Flow_H6b</bpmn:outgoing>
      <bpmn:outgoing>Flow_H6c</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorApproved" name="Approval received">
      <bpmn:incoming>Flow_H6a</bpmn:incoming>
      <bpmn:outgoing>Flow_H7a</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_HR_SupApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchSupervisorRejected" name="Rejection received">
      <bpmn:incoming>Flow_H6b</bpmn:incoming>
      <bpmn:outgoing>Flow_H7b</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_HR_SupRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout5Days" name="5 days exceeded">
      <bpmn:incoming>Flow_H6c</bpmn:incoming>
      <bpmn:outgoing>Flow_H7c</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskHRManagerDecide" name="Make decision">
      <bpmn:incoming>Flow_H7c</bpmn:incoming>
      <bpmn:outgoing>Flow_H8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?">
      <bpmn:incoming>Flow_H8</bpmn:incoming>
      <bpmn:outgoing>Flow_H9_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_H9_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_H7a</bpmn:incoming>
      <bpmn:incoming>Flow_H9_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_H10</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndInformApproved" name="Approval sent">
      <bpmn:incoming>Flow_H10</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_HR_InformApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejectedSupervisor" name="Rejection sent">
      <bpmn:incoming>Flow_H7b</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_HR_InformRejectedSup" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejectedHR" name="Rejection sent">
      <bpmn:incoming>Flow_H9_No</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_HR_InformRejectedHR" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskSupervisorReview" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approved?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSupervisorApprove" name="Send approval">
      <bpmn:incoming>Flow_S3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSupervisorReject" name="Send rejection">
      <bpmn:incoming>Flow_S3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndSupervisorDone" name="Feedback sent">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:incoming>Flow_S5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_H1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_H3_No" name="No" sourceRef="GwEnoughDays" targetRef="TaskAutoReject" />
    <bpmn:sequenceFlow id="Flow_H3_Yes" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_H4" sourceRef="TaskAutoReject" targetRef="EndInformRejectedBalance" />
    <bpmn:sequenceFlow id="Flow_H5" sourceRef="TaskSendToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_H6a" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_H6b" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_H6c" sourceRef="GwWaitFeedback" targetRef="CatchTimeout5Days" />
    <bpmn:sequenceFlow id="Flow_H7a" sourceRef="CatchSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H7b" sourceRef="CatchSupervisorRejected" targetRef="EndInformRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_H7c" sourceRef="CatchTimeout5Days" targetRef="TaskHRManagerDecide" />
    <bpmn:sequenceFlow id="Flow_H8" sourceRef="TaskHRManagerDecide" targetRef="GwHRManagerApproved" />
    <bpmn:sequenceFlow id="Flow_H9_Yes" name="Yes" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H9_No" name="No" sourceRef="GwHRManagerApproved" targetRef="EndInformRejectedHR" />
    <bpmn:sequenceFlow id="Flow_H10" sourceRef="TaskBookVacation" targetRef="EndInformApproved" />

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="TaskSupervisorReview" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="GwSupervisorDecision" targetRef="TaskSupervisorApprove" name="Yes" />
    <bpmn:sequenceFlow id="Flow_S3" sourceRef="GwSupervisorDecision" targetRef="TaskSupervisorReject" name="No" />
    <bpmn:sequenceFlow id="Flow_S4" sourceRef="TaskSupervisorApprove" targetRef="EndSupervisorDone" />
    <bpmn:sequenceFlow id="Flow_S5" sourceRef="TaskSupervisorReject" targetRef="EndSupervisorDone" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartNeedVacation_di" bpmnElement="StartNeedVacation">
        <dc:Bounds x="230" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="215" y="215" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="330" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionApproved_di" bpmnElement="CatchDecisionApproved">
        <dc:Bounds x="560" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="535" y="84" width="86" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejected_di" bpmnElement="CatchDecisionRejected">
        <dc:Bounds x="560" y="220" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="534" y="263" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndVacationPlanned_di" bpmnElement="EndVacationPlanned">
        <dc:Bounds x="720" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="695" y="163" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndVacationCancelled_di" bpmnElement="EndVacationCancelled">
        <dc:Bounds x="720" y="220" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="698" y="263" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="350" width="1400" height="400" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="350" width="1400" height="133" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="483" width="1400" height="133" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="616" width="1400" height="134" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="230" y="399" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="214" y="442" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="330" y="377" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="500" y="392" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="480" y="449" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAutoReject_di" bpmnElement="TaskAutoReject">
        <dc:Bounds x="610" y="365" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedBalance_di" bpmnElement="EndInformRejectedBalance">
        <dc:Bounds x="770" y="387" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="748" y="430" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToSupervisor_di" bpmnElement="TaskSendToSupervisor">
        <dc:Bounds x="610" y="450" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="780" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorApproved_di" bpmnElement="CatchSupervisorApproved">
        <dc:Bounds x="910" y="377" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="882" y="341" width="92" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorRejected_di" bpmnElement="CatchSupervisorRejected">
        <dc:Bounds x="910" y="444" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="882" y="487" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout5Days_di" bpmnElement="CatchTimeout5Days">
        <dc:Bounds x="910" y="650" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="880" y="693" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1030" y="355" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformApproved_di" bpmnElement="EndInformApproved">
        <dc:Bounds x="1190" y="377" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1168" y="420" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedSupervisor_di" bpmnElement="EndInformRejectedSupervisor">
        <dc:Bounds x="1030" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="998" y="505" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskHRManagerDecide_di" bpmnElement="TaskHRManagerDecide">
        <dc:Bounds x="1030" y="628" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRManagerApproved_di" bpmnElement="GwHRManagerApproved" isMarkerVisible="true">
        <dc:Bounds x="1190" y="643" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1178" y="700" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedHR_di" bpmnElement="EndInformRejectedHR">
        <dc:Bounds x="1320" y="650" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1290" y="693" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSupervisorReview_di" bpmnElement="TaskSupervisorReview">
        <dc:Bounds x="770" y="510" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="930" y="525" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="918" y="582" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSupervisorApprove_di" bpmnElement="TaskSupervisorApprove">
        <dc:Bounds x="1030" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSupervisorReject_di" bpmnElement="TaskSupervisorReject">
        <dc:Bounds x="1030" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndSupervisorDone_di" bpmnElement="EndSupervisorDone">
        <dc:Bounds x="1190" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1169" y="585" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_E1_di" bpmnElement="Flow_E1">
        <di:waypoint x="266" y="190" />
        <di:waypoint x="330" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_di" bpmnElement="Flow_E2">
        <di:waypoint x="430" y="190" />
        <di:waypoint x="500" y="190" />
        <di:waypoint x="500" y="138" />
        <di:waypoint x="560" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2b_di" bpmnElement="Flow_E2b">
        <di:waypoint x="430" y="190" />
        <di:waypoint x="500" y="190" />
        <di:waypoint x="500" y="238" />
        <di:waypoint x="560" y="238" />
      </bpmndi:BPMNEdge>
