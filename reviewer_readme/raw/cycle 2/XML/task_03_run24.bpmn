<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHR" name="HR Department" processRef="Process_HR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_RequestApproval" name="Approval request" sourceRef="TaskSendApprovalRequest" targetRef="CatchApprovalRequest" />
    <bpmn:messageFlow id="MF_SupervisorApproved" name="Approved" sourceRef="ThrowSupervisorApproved" targetRef="CatchSupervisorApproved" />
    <bpmn:messageFlow id="MF_SupervisorRejected" name="Rejected" sourceRef="ThrowSupervisorRejected" targetRef="CatchSupervisorRejected" />
    <bpmn:messageFlow id="MF_ManagerApproved" name="Approved" sourceRef="ThrowManagerApproved" targetRef="CatchManagerApproved" />
    <bpmn:messageFlow id="MF_ManagerRejected" name="Rejected" sourceRef="ThrowManagerRejected" targetRef="CatchManagerRejected" />
    <bpmn:messageFlow id="MF_NotifyApproved" name="Decision" sourceRef="TaskNotifyApproved" targetRef="CatchDecision" />
    <bpmn:messageFlow id="MF_NotifyRejectedDays" name="Decision" sourceRef="TaskNotifyRejectedDays" targetRef="CatchDecision" />
    <bpmn:messageFlow id="MF_NotifyRejectedSupervisor" name="Decision" sourceRef="TaskNotifyRejectedSupervisor" targetRef="CatchDecision" />
    <bpmn:messageFlow id="MF_NotifyRejectedManager" name="Decision" sourceRef="TaskNotifyRejectedManager" targetRef="CatchDecision" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartEmployee" name="Request needed">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="CatchDecision" name="Decision received">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchDecision" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEmployee" name="Notified">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartEmployee" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="CatchDecision" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="CatchDecision" targetRef="EndEmployee" />
  </bpmn:process>

  <bpmn:process id="Process_HR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejectedDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejectedManager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedManager</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>CatchApprovalRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskManagerDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwManagerDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowManagerApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndManagerApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowManagerRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndManagerRejected</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequestReceived" />
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_H3_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskNotifyRejectedDays" name="Notify rejected">
      <bpmn:incoming>Flow_H3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedDays" name="Rejected">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendApprovalRequest" name="Send approval">
      <bpmn:incoming>Flow_H3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:outgoing>Flow_H6A</bpmn:outgoing>
      <bpmn:outgoing>Flow_H6R</bpmn:outgoing>
      <bpmn:outgoing>Flow_H6T</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorApproved" name="Approved received">
      <bpmn:incoming>Flow_H6A</bpmn:incoming>
      <bpmn:outgoing>Flow_H7A</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchSupervisorRejected" name="Rejected received">
      <bpmn:incoming>Flow_H6R</bpmn:incoming>
      <bpmn:outgoing>Flow_H7R</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_H6T</bpmn:incoming>
      <bpmn:outgoing>Flow_H7T</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_CatchTimeout" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_H7A</bpmn:incoming>
      <bpmn:outgoing>Flow_H8</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskNotifyApproved" name="Notify approved">
      <bpmn:incoming>Flow_H8</bpmn:incoming>
      <bpmn:outgoing>Flow_H9</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_H9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskNotifyRejectedSupervisor" name="Notify rejected">
      <bpmn:incoming>Flow_H7R</bpmn:incoming>
      <bpmn:outgoing>Flow_H10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Rejected">
      <bpmn:incoming>Flow_H10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskManagerDecision" name="Decide request">
      <bpmn:incoming>Flow_H7T</bpmn:incoming>
      <bpmn:outgoing>Flow_H11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwManagerDecision" name="Approved?">
      <bpmn:incoming>Flow_H11</bpmn:incoming>
      <bpmn:outgoing>Flow_H12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_H12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacationEsc" name="Book vacation">
      <bpmn:incoming>Flow_H12_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_H13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskNotifyRejectedManager" name="Notify rejected">
      <bpmn:incoming>Flow_H12_No</bpmn:incoming>
      <bpmn:outgoing>Flow_H14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedManager" name="Rejected">
      <bpmn:incoming>Flow_H14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskNotifyApprovedEsc" name="Notify approved">
      <bpmn:incoming>Flow_H13</bpmn:incoming>
      <bpmn:outgoing>Flow_H15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApprovedEsc" name="Approved">
      <bpmn:incoming>Flow_H15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartSupervisor" name="Available">
      <bpmn:outgoing>Flow_S0</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="CatchApprovalRequest" name="Receive approval">
      <bpmn:incoming>Flow_S0</bpmn:incoming>
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approved?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorApproved" name="Approved sent">
      <bpmn:incoming>Flow_S3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_S4A</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupervisorApproved" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndSupervisorApproved" name="Sent">
      <bpmn:incoming>Flow_S4A</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorRejected" name="Rejected sent">
      <bpmn:incoming>Flow_S3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_S4R</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupervisorRejected" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndSupervisorRejected" name="Sent">
      <bpmn:incoming>Flow_S4R</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartManager" name="Available">
      <bpmn:outgoing>Flow_M0</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskManagerReview" name="Review escalated">
      <bpmn:incoming>Flow_M0</bpmn:incoming>
      <bpmn:outgoing>Flow_M1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwManagerDecision2" name="Approved?">
      <bpmn:incoming>Flow_M1</bpmn:incoming>
      <bpmn:outgoing>Flow_M2_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_M2_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="ThrowManagerApproved" name="Approved sent">
      <bpmn:incoming>Flow_M2_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_M3A</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowManagerApproved" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndManagerApproved" name="Sent">
      <bpmn:incoming>Flow_M3A</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="ThrowManagerRejected" name="Rejected sent">
      <bpmn:incoming>Flow_M2_No</bpmn:incoming>
      <bpmn:outgoing>Flow_M3R</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowManagerRejected" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndManagerRejected" name="Sent">
      <bpmn:incoming>Flow_M3R</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_H1" sourceRef="StartRequestReceived" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_H3_No" name="No" sourceRef="GwEnoughDays" targetRef="TaskNotifyRejectedDays" />
    <bpmn:sequenceFlow id="Flow_H3_Yes" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApprovalRequest" />
    <bpmn:sequenceFlow id="Flow_H4" sourceRef="TaskNotifyRejectedDays" targetRef="EndRejectedDays" />
    <bpmn:sequenceFlow id="Flow_H5" sourceRef="TaskSendApprovalRequest" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_H6A" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_H6R" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_H6T" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />
    <bpmn:sequenceFlow id="Flow_H7A" sourceRef="CatchSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H8" sourceRef="TaskBookVacation" targetRef="TaskNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_H9" sourceRef="TaskNotifyApproved" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_H7R" sourceRef="CatchSupervisorRejected" targetRef="TaskNotifyRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_H10" sourceRef="TaskNotifyRejectedSupervisor" targetRef="EndRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_H7T" sourceRef="CatchTimeout" targetRef="TaskManagerDecision" />
    <bpmn:sequenceFlow id="Flow_H11" sourceRef="TaskManagerDecision" targetRef="GwManagerDecision" />
    <bpmn:sequenceFlow id="Flow_H12_Yes" name="Yes" sourceRef="GwManagerDecision" targetRef="TaskBookVacationEsc" />
    <bpmn:sequenceFlow id="Flow_H12_No" name="No" sourceRef="GwManagerDecision" targetRef="TaskNotifyRejectedManager" />
    <bpmn:sequenceFlow id="Flow_H13" sourceRef="TaskBookVacationEsc" targetRef="TaskNotifyApprovedEsc" />
    <bpmn:sequenceFlow id="Flow_H15" sourceRef="TaskNotifyApprovedEsc" targetRef="EndApprovedEsc" />
    <bpmn:sequenceFlow id="Flow_H14" sourceRef="TaskNotifyRejectedManager" targetRef="EndRejectedManager" />

    <bpmn:sequenceFlow id="Flow_S0" sourceRef="StartSupervisor" targetRef="CatchApprovalRequest" />
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="CatchApprovalRequest" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S3_Yes" name="Yes" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_S3_No" name="No" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_S4A" sourceRef="ThrowSupervisorApproved" targetRef="EndSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_S4R" sourceRef="ThrowSupervisorRejected" targetRef="EndSupervisorRejected" />

    <bpmn:sequenceFlow id="Flow_M0" sourceRef="StartManager" targetRef="TaskManagerReview" />
    <bpmn:sequenceFlow id="Flow_M1" sourceRef="TaskManagerReview" targetRef="GwManagerDecision2" />
    <bpmn:sequenceFlow id="Flow_M2_Yes" name="Yes" sourceRef="GwManagerDecision2" targetRef="ThrowManagerApproved" />
    <bpmn:sequenceFlow id="Flow_M2_No" name="No" sourceRef="GwManagerDecision2" targetRef="ThrowManagerRejected" />
    <bpmn:sequenceFlow id="Flow_M3A" sourceRef="ThrowManagerApproved" targetRef="EndManagerApproved" />
    <bpmn:sequenceFlow id="Flow_M3R" sourceRef="ThrowManagerRejected" targetRef="EndManagerRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">
      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEmployee_di" bpmnElement="StartEmployee">
        <dc:Bounds x="232" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="211" y="215" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="340" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchDecision_di" bpmnElement="CatchDecision">
        <dc:Bounds x="560" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="532" y="215" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEmployee_di" bpmnElement="EndEmployee">
        <dc:Bounds x="700" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="693" y="215" width="50" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="350" width="1400" height="420" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="350" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="630" width="1400" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="232" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="213" y="445" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCheckDays_di" bpmnElement="TaskCheckDays">
        <dc:Bounds x="340" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="500" y="395" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="480" y="452" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejectedDays_di" bpmnElement="TaskNotifyRejectedDays">
        <dc:Bounds x="620" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejectedDays_di" bpmnElement="EndRejectedDays">
        <dc:Bounds x="760" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="746" y="375" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalRequest_di" bpmnElement="TaskSendApprovalRequest">
        <dc:Bounds x="620" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="770" y="435" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorApproved_di" bpmnElement="CatchSupervisorApproved">
        <dc:Bounds x="900" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="876" y="445" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1020" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskNotifyApproved_di" bpmnElement="TaskNotifyApproved">
        <dc:Bounds x="1160" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1310" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1299" y="445" width="58" height="14" /></bpmndi:BPMNLabel>
