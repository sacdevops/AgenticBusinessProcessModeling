<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_OfficeSupplyProcurement\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_OfficeSupplyProcurement\">\n    <bpmn:participant id=\"PoolCompany\" name=\"Company\" processRef=\"Process_PoolCompany\" />\n    <bpmn:participant id=\"PoolStandardSupplier\" name=\"Standard Supplier\" processRef=\"Process_PoolStandardSupplier\" />\n    <bpmn:participant id=\"PoolAlternativeSupplier\" name=\"Alternative Supplier\" processRef=\"Process_PoolAlternativeSupplier\" />\n\n    <bpmn:messageFlow id=\"MF_OrderRequest_Standard\" name=\"Order request\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"CatchOrderRequestStandard\" />\n    <bpmn:messageFlow id=\"MF_Standard_Confirmation\" name=\"Confirmation\" sourceRef=\"ThrowStandardConfirmation\" targetRef=\"CatchStandardConfirmation\" />\n    <bpmn:messageFlow id=\"MF_Standard_Rejection\" name=\"Rejection\" sourceRef=\"ThrowStandardRejection\" targetRef=\"CatchStandardRejection\" />\n\n    <bpmn:messageFlow id=\"MF_OrderRequest_Alternative\" name=\"Order request\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"CatchOrderRequestAlternative\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_PoolCompany\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Company\">\n      <bpmn:lane id=\"LaneSystem\" name=\"System\">\n        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchNoResponse3Days</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndOrderConfirmed</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneAdministration\" name=\"Administration\">\n        <bpmn:flowNodeRef>TaskManualIntervene</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndOrderCancelled</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndOrderSentAlternative</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartQuarterDay\" name=\"Quarter start\">\n      <bpmn:outgoing>Flow_C1</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_QuarterStart\" />\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckInventory\" name=\"Check inventory\">\n      <bpmn:incoming>Flow_C1</bpmn:incoming>\n      <bpmn:outgoing>Flow_C2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwLowInventory\" name=\"Low stock?\">\n      <bpmn:incoming>Flow_C2</bpmn:incoming>\n      <bpmn:outgoing>Flow_C3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndStockSufficient\" name=\"No order\">\n      <bpmn:incoming>Flow_C4</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderRequestStandard\" name=\"Send request\">\n      <bpmn:incoming>Flow_C3</bpmn:incoming>\n      <bpmn:outgoing>Flow_C5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitResponse\">\n      <bpmn:incoming>Flow_C5</bpmn:incoming>\n      <bpmn:outgoing>Flow_C6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C7</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C8</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchStandardConfirmation\" name=\"Confirmation received\">\n      <bpmn:incoming>Flow_C6</bpmn:incoming>\n      <bpmn:outgoing>Flow_C9</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_StandardConfirmation\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndOrderConfirmed\" name=\"Order confirmed\">\n      <bpmn:incoming>Flow_C9</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchStandardRejection\" name=\"Rejection received\">\n      <bpmn:incoming>Flow_C7</bpmn:incoming>\n      <bpmn:outgoing>Flow_C10</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_StandardRejection\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchNoResponse3Days\" name=\"3 days passed\">\n      <bpmn:incoming>Flow_C8</bpmn:incoming>\n      <bpmn:outgoing>Flow_C11</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_3BusinessDays\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:userTask id=\"TaskManualIntervene\" name=\"Manual review\">\n      <bpmn:incoming>Flow_C10</bpmn:incoming>\n      <bpmn:incoming>Flow_C11</bpmn:incoming>\n      <bpmn:outgoing>Flow_C12</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwUseAlternative\" name=\"Alternative?\">\n      <bpmn:incoming>Flow_C12</bpmn:incoming>\n      <bpmn:outgoing>Flow_C13</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C14</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndOrderCancelled\" name=\"Order cancelled\">\n      <bpmn:incoming>Flow_C13</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderAlternative\" name=\"Send alternative\">\n      <bpmn:incoming>Flow_C14</bpmn:incoming>\n      <bpmn:outgoing>Flow_C15</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndOrderSentAlternative\" name=\"Order sent\">\n      <bpmn:incoming>Flow_C15</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_C1\" sourceRef=\"StartQuarterDay\" targetRef=\"TaskCheckInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_C2\" sourceRef=\"TaskCheckInventory\" targetRef=\"GwLowInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_C3\" name=\"Yes\" sourceRef=\"GwLowInventory\" targetRef=\"TaskSendOrderRequestStandard\" />\n    <bpmn:sequenceFlow id=\"Flow_C4\" name=\"No\" sourceRef=\"GwLowInventory\" targetRef=\"EndStockSufficient\" />\n    <bpmn:sequenceFlow id=\"Flow_C5\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"GwWaitResponse\" />\n    <bpmn:sequenceFlow id=\"Flow_C6\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchStandardConfirmation\" />\n    <bpmn:sequenceFlow id=\"Flow_C7\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchStandardRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_C8\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchNoResponse3Days\" />\n    <bpmn:sequenceFlow id=\"Flow_C9\" sourceRef=\"CatchStandardConfirmation\" targetRef=\"EndOrderConfirmed\" />\n    <bpmn:sequenceFlow id=\"Flow_C10\" sourceRef=\"CatchStandardRejection\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_C11\" sourceRef=\"CatchNoResponse3Days\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_C12\" sourceRef=\"TaskManualIntervene\" targetRef=\"GwUseAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_C13\" name=\"No\" sourceRef=\"GwUseAlternative\" targetRef=\"EndOrderCancelled\" />\n    <bpmn:sequenceFlow id=\"Flow_C14\" name=\"Yes\" sourceRef=\"GwUseAlternative\" targetRef=\"TaskSendOrderAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_C15\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"EndOrderSentAlternative\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_PoolStandardSupplier\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartStandardSupplier\" name=\"Start\">\n      <bpmn:outgoing>Flow_S0</bpmn:outgoing>\n    </bpmn:startEvent>\n    <bpmn:intermediateCatchEvent id=\"CatchOrderRequestStandard\" name=\"Request received\">\n      <bpmn:incoming>Flow_S0</bpmn:incoming>\n      <bpmn:outgoing>Flow_S1</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_OrderRequestStandard\" />\n    </bpmn:intermediateCatchEvent>\n    <bpmn:serviceTask id=\"TaskDecideStandard\" name=\"Check supply\">\n      <bpmn:incoming>Flow_S1</bpmn:incoming>\n      <bpmn:outgoing>Flow_S2</bpmn:outgoing>\n    </bpmn:serviceTask>\n    <bpmn:exclusiveGateway id=\"GwStandardDeliverable\" name=\"Deliverable?\">\n      <bpmn:incoming>Flow_S2</bpmn:incoming>\n      <bpmn:outgoing>Flow_S3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_S4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:intermediateThrowEvent id=\"ThrowStandardConfirmation\" name=\"Send confirm\">\n      <bpmn:incoming>Flow_S3</bpmn:incoming>\n      <bpmn:outgoing>Flow_S5</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_ThrowStandardConfirmation\" />\n    </bpmn:intermediateThrowEvent>\n    <bpmn:intermediateThrowEvent id=\"ThrowStandardRejection\" name=\"Send reject\">\n      <bpmn:incoming>Flow_S4</bpmn:incoming>\n      <bpmn:outgoing>Flow_S6</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_ThrowStandardRejection\" />\n    </bpmn:intermediateThrowEvent>\n    <bpmn:endEvent id=\"EndStandardSupplierDone\" name=\"Done\">\n      <bpmn:incoming>Flow_S5</bpmn:incoming>\n      <bpmn:incoming>Flow_S6</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_S0\" sourceRef=\"StartStandardSupplier\" targetRef=\"CatchOrderRequestStandard\" />\n    <bpmn:sequenceFlow id=\"Flow_S1\" sourceRef=\"CatchOrderRequestStandard\" targetRef=\"TaskDecideStandard\" />\n    <bpmn:sequenceFlow id=\"Flow_S2\" sourceRef=\"TaskDecideStandard\" targetRef=\"GwStandardDeliverable\" />\n    <bpmn:sequenceFlow id=\"Flow_S3\" name=\"Yes\" sourceRef=\"GwStandardDeliverable\" targetRef=\"ThrowStandardConfirmation\" />\n    <bpmn:sequenceFlow id=\"Flow_S4\" name=\"No\" sourceRef=\"GwStandardDeliverable\" targetRef=\"ThrowStandardRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_S5\" sourceRef=\"ThrowStandardConfirmation\" targetRef=\"EndStandardSupplierDone\" />\n    <bpmn:sequenceFlow id=\"Flow_S6\" sourceRef=\"ThrowStandardRejection\" targetRef=\"EndStandardSupplierDone\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_PoolAlternativeSupplier\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartAlternativeSupplier\" name=\"Start\">\n      <bpmn:outgoing>Flow_A0</bpmn:outgoing>\n    </bpmn:startEvent>\n    <bpmn:intermediateCatchEvent id=\"CatchOrderRequestAlternative\" name=\"Request received\">\n      <bpmn:incoming>Flow_A0</bpmn:incoming>\n      <bpmn:outgoing>Flow_A1</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_OrderRequestAlternative\" />\n    </bpmn:intermediateCatchEvent>\n    <bpmn:endEvent id=\"EndAlternativeSupplierDone\" name=\"Done\">\n      <bpmn:incoming>Flow_A1</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_A0\" sourceRef=\"StartAlternativeSupplier\" targetRef=\"CatchOrderRequestAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_A1\" sourceRef=\"CatchOrderRequestAlternative\" targetRef=\"EndAlternativeSupplierDone\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_OfficeSupplyProcurement\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_OfficeSupplyProcurement\" bpmnElement=\"Collaboration_OfficeSupplyProcurement\">\n\n      <bpmndi:BPMNShape id=\"PoolCompany_di\" bpmnElement=\"PoolCompany\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneSystem_di\" bpmnElement=\"LaneSystem\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneAdministration_di\" bpmnElement=\"LaneAdministration\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartQuarterDay_di\" bpmnElement=\"StartQuarterDay\">\n        <dc:Bounds x=\"240\" y=\"152\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckInventory_di\" bpmnElement=\"TaskCheckInventory\">\n        <dc:Bounds x=\"360\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwLowInventory_di\" bpmnElement=\"GwLowInventory\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"520\" y=\"145\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndStockSufficient_di\" bpmnElement=\"EndStockSufficient\">\n        <dc:Bounds x=\"660\" y=\"152\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderRequestStandard_di\" bpmnElement=\"TaskSendOrderRequestStandard\">\n        <dc:Bounds x=\"660\" y=\"30\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitResponse_di\" bpmnElement=\"GwWaitResponse\">\n        <dc:Bounds x=\"820\" y=\"45\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchStandardConfirmation_di\" bpmnElement=\"CatchStandardConfirmation\">\n        <dc:Bounds x=\"970\" y=\"22\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndOrderConfirmed_di\" bpmnElement=\"EndOrderConfirmed\">\n        <dc:Bounds x=\"1110\" y=\"22\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchStandardRejection_di\" bpmnElement=\"CatchStandardRejection\">\n        <dc:Bounds x=\"970\" y=\"130\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchNoResponse3Days_di\" bpmnElement=\"CatchNoResponse3Days\">\n        <dc:Bounds x=\"970\" y=\"210\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskManualIntervene_di\" bpmnElement=\"TaskManualIntervene\">\n        <dc:Bounds x=\"1120\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwUseAlternative_di\" bpmnElement=\"GwUseAlternative\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1280\" y=\"325\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndOrderCancelled_di\" bpmnElement=\"EndOrderCancelled\">\n        <dc:Bounds x=\"1435\" y=\"332\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskSendOrderAlternative_di\" bpmnElement=\"TaskSendOrderAlternative\">\n        <dc:Bounds x=\"1430\" y=\"250\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndOrderSentAlternative_di\" bpmnElement=\"EndOrderSentAlternative\">\n        <dc:Bounds x=\"1544\" y=\"272\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolStandardSupplier_di\" bpmnElement=\"PoolStandardSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"240\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"StartStandardSupplier_di\" bpmnElement=\"StartStandardSupplier\">\n        <dc:Bounds x=\"240\" y=\"592\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchOrderRequestStandard_di\" bpmnElement=\"CatchOrderRequestStandard\">\n        <dc:Bounds x=\"360\" y=\"592\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskDecideStandard_di\" bpmnElement=\"TaskDecideStandard\">\n        <dc:Bounds x=\"460\" y=\"570\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwStandardDeliverable_di\" bpmnElement=\"GwStandardDeliverable\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"620\" y=\"585\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"ThrowStandardConfirmation_di\" bpmnElement=\"ThrowStandardConfirmation\">\n        <dc:Bounds x=\"760\" y=\"552\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"ThrowStandardRejection_di\" bpmnElement=\"ThrowStandardRejection\">\n        <dc:Bounds x=\"760\" y=\"652\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndStandardSupplierDone_di\" bpmnElement=\"EndStandardSupplierDone\">\n        <dc:Bounds x=\"920\" y=\"602\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolAlternativeSupplier_di\" bpmnElement=\"PoolAlternativeSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"780\" width=\"1400\" height=\"200\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"StartAlternativeSupplier_di\" bpmnElement=\"StartAlternativeSupplier\">\n        <dc:Bounds x=\"240\" y=\"862\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchOrderRequestAlternative_di\" bpmnElement=\"CatchOrderRequestAlternative\">\n        <dc:Bounds x=\"360\" y=\"862\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndAlternativeSupplierDone_di\" bpmnElement=\"EndAlternativeSupplierDone\">\n        <dc:Bounds x=\"480\" y=\"862\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_C1_di\" bpmnElement=\"Flow_C1\">\n        <di:waypoint x=\"276\" y=\"170\" />\n        <di:waypoint x=\"360\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C2_di\" bpmnElement=\"Flow_C2\">\n        <di:waypoint x=\"460\" y=\"170\" />\n        <di:waypoint x=\"520\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C3_di\" bpmnElement=\"Flow_C3\">\n        <di:waypoint x=\"545\" y=\"145\" />\n        <di:waypoint x=\"545\" y=\"70\" />\n        <di:waypoint x=\"660\" y=\"70\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"552\" y=\"92\" width=\"24\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C4_di\" bpmnElement=\"Flow_C4\">\n        <di:waypoint x=\"570\" y=\"170\" />\n        <di:waypoint x=\"660\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"600\" y=\"150\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C5_di\" bpmnElement=\"Flow_C5\">\n        <di:waypoint x=\"760\" y=\"70\" />\n        <di:waypoint x=\"820\" y=\"70\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C6_di\" bpmnElement=\"Flow_C6\">\n        <di:waypoint x=\"845\" y=\"45\" />\n        <di:waypoint x=\"845\" y=\"40\" />\n        <di:waypoint x=\"970\" y=\"40\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C7_di\" bpmnElement=\"Flow_C7\">\n        <di:waypoint x=\"870\" y=\"70\" />\n        <di:waypoint x=\"900\" y=\"70\" />\n        <di:waypoint x=\"900\" y=\"148\" />\n        <di:waypoint x=\"970\" y=\"148\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C8_di\" bpmnElement=\"Flow_C8\">\n        <di:waypoint x=\"845\" y=\"95\" />\n        <di:waypoint x=\"845\" y=\"228\" />\n        <di:waypoint x=\"970\" y=\"228\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C9_di\" bpmnElement=\"Flow_C9\">\n        <di:waypoint x=\"1006\" y=\"40\" />\n        <di:waypoint x=\"1110\" y=\"40\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C10_di\" bpmnElement=\"Flow_C10\">\n        <di:waypoint x=\"988\" y=\"166\" />\n        <di:waypoint x=\"988\" y=\"350\" />\n        <di:waypoint x=\"1120\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C11_di\" bpmnElement=\"Flow_C11\">\n        <di:waypoint x=\"988\" y=\"228\" />\n        <di:waypoint x=\"988\" y=\"350\" />\n        <di:waypoint x=\"1120\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_C12_di\" bpmnElement=\"Flow_C12\">\n        <di:waypoint x=\"1220\" y=\"350