<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="Assessor" processRef="Process_Assessor" />
    <bpmn:participant id="PoolCustomer" name="Customer" />

    <bpmn:messageFlow id="MF_DamageReport" name="Damage report" sourceRef="PoolCustomer" targetRef="StartDamageReport" />
    <bpmn:messageFlow id="MF_AssessorOrder" name="Assessment order" sourceRef="TaskSendAssessmentOrder" targetRef="StartOrderReceived" />
    <bpmn:messageFlow id="MF_AssessmentReport" name="Assessment report" sourceRef="TaskSendAssessmentReport" targetRef="CatchAssessmentReceived" />

    <bpmn:messageFlow id="MF_NotifyRejectionNotCovered" name="Rejection" sourceRef="EndRejectedNotCovered" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyApproved" name="Approval" sourceRef="EndApprovedNotPaid" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyRejectedFinal" name="Rejection" sourceRef="EndRejectedFinal" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyRejectedDeadline" name="Rejection" sourceRef="EndRejectedDeadline" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" name="Insurance Claim Processing" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckEstimate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmountOver1500</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveSmall</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendAssessmentOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitForReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAssessmentReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline10Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApprovedNotPaid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePayment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:outgoing>Flow_I1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartDamageReport" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_I1</bpmn:incoming>
      <bpmn:outgoing>Flow_I2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_I2</bpmn:incoming>
      <bpmn:outgoing>Flow_I3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?">
      <bpmn:incoming>Flow_I3</bpmn:incoming>
      <bpmn:outgoing>Flow_I4</bpmn:outgoing>
      <bpmn:outgoing>Flow_I5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRejectNotCovered" name="Send rejection">
      <bpmn:incoming>Flow_I5</bpmn:incoming>
      <bpmn:outgoing>Flow_I6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedNotCovered" name="Case closed">
      <bpmn:incoming>Flow_I6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedNotCovered" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckEstimate" name="Check estimate">
      <bpmn:incoming>Flow_I4</bpmn:incoming>
      <bpmn:outgoing>Flow_I7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmountOver1500" name="> €1500?">
      <bpmn:incoming>Flow_I7</bpmn:incoming>
      <bpmn:outgoing>Flow_I8</bpmn:outgoing>
      <bpmn:outgoing>Flow_I9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveSmall" name="Approve claim">
      <bpmn:incoming>Flow_I9</bpmn:incoming>
      <bpmn:outgoing>Flow_I10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePayment" name="Initiate payment">
      <bpmn:incoming>Flow_I10</bpmn:incoming>
      <bpmn:outgoing>Flow_I11</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndApprovedNotPaid" name="Customer informed">
      <bpmn:incoming>Flow_I11</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApproved" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendAssessmentOrder" name="Send order">
      <bpmn:incoming>Flow_I8</bpmn:incoming>
      <bpmn:outgoing>Flow_I12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitForReport">
      <bpmn:incoming>Flow_I12</bpmn:incoming>
      <bpmn:outgoing>Flow_I13</bpmn:outgoing>
      <bpmn:outgoing>Flow_I14</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchAssessmentReceived" name="Assessment received">
      <bpmn:incoming>Flow_I13</bpmn:incoming>
      <bpmn:outgoing>Flow_I15</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AssessmentReceived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline10Days" name="10 days exceeded">
      <bpmn:incoming>Flow_I14</bpmn:incoming>
      <bpmn:outgoing>Flow_I16</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_I15</bpmn:incoming>
      <bpmn:outgoing>Flow_I17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalApproved" name="Approved?">
      <bpmn:incoming>Flow_I17</bpmn:incoming>
      <bpmn:outgoing>Flow_I18</bpmn:outgoing>
      <bpmn:outgoing>Flow_I19</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePayment2" name="Initiate payment">
      <bpmn:incoming>Flow_I18</bpmn:incoming>
      <bpmn:outgoing>Flow_I20</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndApprovedAfterAssessment" name="Customer informed">
      <bpmn:incoming>Flow_I20</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApproved2" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskRejectFinal" name="Send rejection">
      <bpmn:incoming>Flow_I19</bpmn:incoming>
      <bpmn:outgoing>Flow_I21</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedFinal" name="Customer informed">
      <bpmn:incoming>Flow_I21</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedFinal" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskRejectDeadline" name="Send rejection">
      <bpmn:incoming>Flow_I16</bpmn:incoming>
      <bpmn:outgoing>Flow_I22</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedDeadline" name="Customer informed">
      <bpmn:incoming>Flow_I22</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedDeadline" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_I1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_I2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_I3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_I4" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckEstimate" />
    <bpmn:sequenceFlow id="Flow_I5" name="No" sourceRef="GwCovered" targetRef="TaskRejectNotCovered" />
    <bpmn:sequenceFlow id="Flow_I6" sourceRef="TaskRejectNotCovered" targetRef="EndRejectedNotCovered" />
    <bpmn:sequenceFlow id="Flow_I7" sourceRef="TaskCheckEstimate" targetRef="GwAmountOver1500" />
    <bpmn:sequenceFlow id="Flow_I8" name="Yes" sourceRef="GwAmountOver1500" targetRef="TaskSendAssessmentOrder" />
    <bpmn:sequenceFlow id="Flow_I9" name="No" sourceRef="GwAmountOver1500" targetRef="TaskApproveSmall" />
    <bpmn:sequenceFlow id="Flow_I10" sourceRef="TaskApproveSmall" targetRef="TaskInitiatePayment" />
    <bpmn:sequenceFlow id="Flow_I11" sourceRef="TaskInitiatePayment" targetRef="EndApprovedNotPaid" />
    <bpmn:sequenceFlow id="Flow_I12" sourceRef="TaskSendAssessmentOrder" targetRef="GwWaitForReport" />
    <bpmn:sequenceFlow id="Flow_I13" sourceRef="GwWaitForReport" targetRef="CatchAssessmentReceived" />
    <bpmn:sequenceFlow id="Flow_I14" sourceRef="GwWaitForReport" targetRef="CatchDeadline10Days" />
    <bpmn:sequenceFlow id="Flow_I15" sourceRef="CatchAssessmentReceived" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_I16" sourceRef="CatchDeadline10Days" targetRef="TaskRejectDeadline" />
    <bpmn:sequenceFlow id="Flow_I17" sourceRef="TaskReviewAssessment" targetRef="GwFinalApproved" />
    <bpmn:sequenceFlow id="Flow_I18" name="Yes" sourceRef="GwFinalApproved" targetRef="TaskInitiatePayment2" />
    <bpmn:sequenceFlow id="Flow_I19" name="No" sourceRef="GwFinalApproved" targetRef="TaskRejectFinal" />
    <bpmn:sequenceFlow id="Flow_I20" sourceRef="TaskInitiatePayment2" targetRef="EndApprovedAfterAssessment" />
    <bpmn:sequenceFlow id="Flow_I21" sourceRef="TaskRejectFinal" targetRef="EndRejectedFinal" />
    <bpmn:sequenceFlow id="Flow_I22" sourceRef="TaskRejectDeadline" targetRef="EndRejectedDeadline" />
  </bpmn:process>

  <bpmn:process id="Process_Assessor" isExecutable="false">
    <bpmn:startEvent id="StartAssessor" name="Assessor available">
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:startEvent id="StartOrderReceived" name="Order received">
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartOrder" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskAssessDamage" name="Assess damage">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:outgoing>Flow_A3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskSendAssessmentReport" name="Send report">
      <bpmn:incoming>Flow_A3</bpmn:incoming>
      <bpmn:outgoing>Flow_A4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndReportSent" name="Report sent">
      <bpmn:incoming>Flow_A4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndIdle" name="Idle">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAssessor" targetRef="EndIdle" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="StartOrderReceived" targetRef="TaskAssessDamage" />
    <bpmn:sequenceFlow id="Flow_A3" sourceRef="TaskAssessDamage" targetRef="TaskSendAssessmentReport" />
    <bpmn:sequenceFlow id="Flow_A4" sourceRef="TaskSendAssessmentReport" targetRef="EndReportSent" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">

      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="196" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="470" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="630" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="622" y="202" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectNotCovered_di" bpmnElement="TaskRejectNotCovered">
        <dc:Bounds x="740" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedNotCovered_di" bpmnElement="EndRejectedNotCovered">
        <dc:Bounds x="900" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="105" width="98" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckEstimate_di" bpmnElement="TaskCheckEstimate">
        <dc:Bounds x="740" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmountOver1500_di" bpmnElement="GwAmountOver1500" isMarkerVisible="true">
        <dc:Bounds x="900" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="882" y="202" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveSmall_di" bpmnElement="TaskApproveSmall">
        <dc:Bounds x="1010" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment_di" bpmnElement="TaskInitiatePayment">
        <dc:Bounds x="1160" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApprovedNotPaid_di" bpmnElement="EndApprovedNotPaid">
        <dc:Bounds x="1320" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1290" y="375" width="98" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendAssessmentOrder_di" bpmnElement="TaskSendAssessmentOrder">
        <dc:Bounds x="1010" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitForReport_di" bpmnElement="GwWaitForReport">
        <dc:Bounds x="1160" y="55" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAssessmentReceived_di" bpmnElement="CatchAssessmentReceived">
        <dc:Bounds x="1270" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1240" y="16" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline10Days_di" bpmnElement="CatchDeadline10Days">
        <dc:Bounds x="1270" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1235" y="185" width="106" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1360" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalApproved_di" bpmnElement="GwFinalApproved" isMarkerVisible="true">
        <dc:Bounds x="1510" y="45" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1500" y="102" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePayment2_di" bpmnElement="TaskInitiatePayment2">
        <dc:Bounds x="1510" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApprovedAfterAssessment_di" bpmnElement="EndApprovedAfterAssessment">
        <dc:Bounds x="1660" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectFinal_di" bpmnElement="TaskRejectFinal">
        <dc:Bounds x="1620" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedFinal_di" bpmnElement="EndRejectedFinal">
        <dc:Bounds x="1780" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectDeadline_di" bpmnElement="TaskRejectDeadline">
        <dc:Bounds x="1360" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedDeadline_di" bpmnElement="EndRejectedDeadline">
        <dc:Bounds x="1510" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="260" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartAssessor_di" bpmnElement="StartAssessor">
        <dc:Bounds x="220" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndIdle_di" bpmnElement="EndIdle">
        <dc:Bounds x="320" y="602" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartOrderReceived_di" bpmnElement="StartOrderReceived">
        <dc:Bounds x="220" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="196" y="565" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAssessDamage_di" bpmnElement="TaskAssessDamage">
        <dc:Bounds x="320" y="500" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendAssessmentReport_di" bpmnElement="TaskSendAssessmentReport">
        <dc:Bounds x="470" y="500" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndReportSent_di" bpmnElement="EndReportSent">
        <dc:Bounds x="630" y="522" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="800" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_I1_di" bpmnElement="Flow_I1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I2_di" bpmnElement="Flow_I2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="470" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I3_di" bpmnElement="Flow_I3">
        <di:waypoint x="570" y="170" />
        <di:waypoint x="630" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I4_di" bpmnElement="Flow_I4">
        <di:waypoint x="680" y="170" />
        <di:waypoint x="740" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="698" y="152" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I5_di" bpmnElement="Flow_I5">
        <di:waypoint x="655" y="145" />
        <di:waypoint x="655" y="80" />
        <di:waypoint x="740" y="80" />
        <bpmndi:BPMNLabel><dc:Bounds x="660" y="98" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I6_di" bpmnElement="Flow_I6">
        <di:waypoint x="840" y="80" />
        <di:waypoint x="900" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I7_di" bpmnElement="Flow_I7">
        <di:waypoint x="840" y="170" />
        <di:waypoint x="900" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I8_di" bpmnElement="Flow_I8">
        <di:waypoint x="925" y="145" />
