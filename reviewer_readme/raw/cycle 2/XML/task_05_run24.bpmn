        <di:waypoint x="970" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5c_di" bpmnElement="Flow_5c">
        <di:waypoint x="865" y="305" />
        <di:waypoint x="865" y="200" />
        <di:waypoint x="970" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6a_di" bpmnElement="Flow_6a">
        <di:waypoint x="1006" y="320" />
        <di:waypoint x="1100" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6b_di" bpmnElement="Flow_6b">
        <di:waypoint x="1006" y="420" />
        <di:waypoint x="1100" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6c_di" bpmnElement="Flow_6c">
        <di:waypoint x="1006" y="200" />
        <di:waypoint x="1050" y="200" />
        <di:waypoint x="1050" y="420" />
        <di:waypoint x="1100" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1200" y="420" />
        <di:waypoint x="1250" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8a_di" bpmnElement="Flow_8a">
        <di:waypoint x="1300" y="420" />
        <di:waypoint x="1360" y="400" />
        <bpmndi:BPMNLabel><dc:Bounds x="1312" y="392" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8b_di" bpmnElement="Flow_8b">
        <di:waypoint x="1275" y="445" />
        <di:waypoint x="1275" y="488" />
        <di:waypoint x="1360" y="488" />
        <bpmndi:BPMNLabel><dc:Bounds x="1282" y="468" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9a_di" bpmnElement="Flow_9a">
        <di:waypoint x="1460" y="400" />
        <di:waypoint x="1490" y="400" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S0_di" bpmnElement="Flow_S0">
        <di:waypoint x="286" y="600" />
        <di:waypoint x="370" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="470" y="600" />
        <di:waypoint x="540" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2a_di" bpmnElement="Flow_S2a">
        <di:waypoint x="590" y="600" />
        <di:waypoint x="690" y="580" />
        <bpmndi:BPMNLabel><dc:Bounds x="615" y="575" width="20" height="14" /></bpmndi:BPMNLabel>
