<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupply" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_OfficeSupply">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_StandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_AlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderReq_Standard" name="Order request" sourceRef="TaskSendOrderReqStandard" targetRef="StartStdOrderReceived" />
    <bpmn:messageFlow id="MF_Confirm_Standard" name="Confirmation" sourceRef="EndStdConfirmed" targetRef="CatchStdConfirmation" />
    <bpmn:messageFlow id="MF_Reject_Standard" name="Rejection" sourceRef="EndStdRejected" targetRef="CatchStdRejection" />

    <bpmn:messageFlow id="MF_OrderReq_Alternative" name="Order request" sourceRef="TaskSendOrderReqAlternative" targetRef="StartAltOrderReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderReqStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStdConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStdRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndAltOrdered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskManualIntervene</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderReqAlternative</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterStart" name="Quarter start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterStart" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowStock" name="Low stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3a</bpmn:outgoing>
      <bpmn:outgoing>Flow_3b</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndNoOrder" name="No order">
      <bpmn:incoming>Flow_3b</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderReqStandard" name="Send request">
      <bpmn:incoming>Flow_3a</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5a</bpmn:outgoing>
      <bpmn:outgoing>Flow_5b</bpmn:outgoing>
      <bpmn:outgoing>Flow_5c</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStdConfirmation" name="Confirmation received">
      <bpmn:incoming>Flow_5a</bpmn:incoming>
      <bpmn:outgoing>Flow_6a</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchConfirm" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_6a</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStdRejection" name="Rejection received">
      <bpmn:incoming>Flow_5b</bpmn:incoming>
      <bpmn:outgoing>Flow_6b</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchReject" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch3Days" name="3 days exceeded">
      <bpmn:incoming>Flow_5c</bpmn:incoming>
      <bpmn:outgoing>Flow_6c</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervene" name="Manual intervene">
      <bpmn:incoming>Flow_6b</bpmn:incoming>
      <bpmn:incoming>Flow_6c</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Alternative?">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8a</bpmn:outgoing>
      <bpmn:outgoing>Flow_8b</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendOrderReqAlternative" name="Send request">
      <bpmn:incoming>Flow_8a</bpmn:incoming>
      <bpmn:outgoing>Flow_9a</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAltOrdered" name="Alt ordered">
      <bpmn:incoming>Flow_9a</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndCancelled" name="Cancelled">
      <bpmn:incoming>Flow_8b</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartQuarterStart" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckInventory" targetRef="GwLowStock" />
    <bpmn:sequenceFlow id="Flow_3a" name="Yes" sourceRef="GwLowStock" targetRef="TaskSendOrderReqStandard" />
    <bpmn:sequenceFlow id="Flow_3b" name="No" sourceRef="GwLowStock" targetRef="EndNoOrder" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="TaskSendOrderReqStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_5a" sourceRef="GwWaitResponse" targetRef="CatchStdConfirmation" />
    <bpmn:sequenceFlow id="Flow_5b" sourceRef="GwWaitResponse" targetRef="CatchStdRejection" />
    <bpmn:sequenceFlow id="Flow_5c" sourceRef="GwWaitResponse" targetRef="Catch3Days" />
    <bpmn:sequenceFlow id="Flow_6a" sourceRef="CatchStdConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_6b" sourceRef="CatchStdRejection" targetRef="TaskManualIntervene" />
    <bpmn:sequenceFlow id="Flow_6c" sourceRef="Catch3Days" targetRef="TaskManualIntervene" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="TaskManualIntervene" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_8a" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderReqAlternative" />
    <bpmn:sequenceFlow id="Flow_8b" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_9a" sourceRef="TaskSendOrderReqAlternative" targetRef="EndAltOrdered" />
  </bpmn:process>

  <bpmn:process id="Process_StandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStdQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_S0</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_StdQuarter" />
    </bpmn:startEvent>
    <bpmn:receiveTask id="TaskStdReceiveOrder" name="Receive request">
      <bpmn:incoming>Flow_S0</bpmn:incoming>
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="GwStdDeliverable" name="Deliverable?">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2a</bpmn:outgoing>
      <bpmn:outgoing>Flow_S2b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndStdConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_S2a</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdConfirm" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndStdRejected" name="Rejected">
      <bpmn:incoming>Flow_S2b</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdReject" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S0" sourceRef="StartStdQuarter" targetRef="TaskStdReceiveOrder" />
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="TaskStdReceiveOrder" targetRef="GwStdDeliverable" />
    <bpmn:sequenceFlow id="Flow_S2a" name="Yes" sourceRef="GwStdDeliverable" targetRef="EndStdConfirmed" />
    <bpmn:sequenceFlow id="Flow_S2b" name="No" sourceRef="GwStdDeliverable" targetRef="EndStdRejected" />
  </bpmn:process>

  <bpmn:process id="Process_AlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAltQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_A0</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_AltQuarter" />
    </bpmn:startEvent>
    <bpmn:receiveTask id="TaskAltReceiveOrder" name="Receive request">
      <bpmn:incoming>Flow_A0</bpmn:incoming>
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="EndAltReceived" name="Request received">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A0" sourceRef="StartAltQuarter" targetRef="TaskAltReceiveOrder" />
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="TaskAltReceiveOrder" targetRef="EndAltReceived" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupply">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupply" bpmnElement="Collaboration_OfficeSupply">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
