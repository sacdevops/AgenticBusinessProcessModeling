      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderReqStandard_di" bpmnElement="TaskSendOrderReqStandard">
        <dc:Bounds x="690" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitResponse_di" bpmnElement="GwWaitResponse">
        <dc:Bounds x="840" y="305" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStdConfirmation_di" bpmnElement="CatchStdConfirmation">
        <dc:Bounds x="970" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="934" y="270" width="108" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1100" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1072" y="345" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStdRejection_di" bpmnElement="CatchStdRejection">
        <dc:Bounds x="970" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="938" y="445" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch3Days_di" bpmnElement="Catch3Days">
        <dc:Bounds x="970" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="937" y="150" width="102" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervene_di" bpmnElement="TaskManualIntervene">
        <dc:Bounds x="1100" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1250" y="395" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1231" y="452" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderReqAlternative_di" bpmnElement="TaskSendOrderReqAlternative">
        <dc:Bounds x="1360" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndAltOrdered_di" bpmnElement="EndAltOrdered">
        <dc:Bounds x="1490" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1470" y="425" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1360" y="470" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1346" y="513" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartStdQuarter_di" bpmnElement="StartStdQuarter">
        <dc:Bounds x="250" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="232" y="625" width="73" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskStdReceiveOrder_di" bpmnElement="TaskStdReceiveOrder">
        <dc:Bounds x="370" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwStdDeliverable_di" bpmnElement="GwStdDeliverable" isMarkerVisible="true">
        <dc:Bounds x="540" y="575" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="522" y="632" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStdConfirmed_di" bpmnElement="EndStdConfirmed">
        <dc:Bounds x="690" y="562" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="675" y="605" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStdRejected_di" bpmnElement="EndStdRejected">
        <dc:Bounds x="690" y="642" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="678" y="685" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="760" width="1400" height="200" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartAltQuarter_di" bpmnElement="StartAltQuarter">
        <dc:Bounds x="250" y="842" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="232" y="885" width="73" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskAltReceiveOrder_di" bpmnElement="TaskAltReceiveOrder">
        <dc:Bounds x="370" y="820" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAltReceived_di" bpmnElement="EndAltReceived">
        <dc:Bounds x="520" y="842" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="486" y="885" width="104" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="286" y="170" />
        <di:waypoint x="370" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="470" y="170" />
        <di:waypoint x="540" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3a_di" bpmnElement="Flow_3a">
        <di:waypoint x="565" y="195" />
        <di:waypoint x="565" y="330" />
        <di:waypoint x="690" y="330" />
        <bpmndi:BPMNLabel><dc:Bounds x="572" y="210" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3b_di" bpmnElement="Flow_3b">
        <di:waypoint x="590" y="170" />
        <di:waypoint x="690" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="623" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="790" y="330" />
        <di:waypoint x="840" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5a_di" bpmnElement="Flow_5a">
        <di:waypoint x="890" y="330" />
        <di:waypoint x="970" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5b_di" bpmnElement="Flow_5b">
        <di:waypoint x="865" y="355" />
