<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits"
  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolBuildingAuthority" name="Building Authority" processRef="Process_BuildingAuthority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvironmentalAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissingDocs" name="Missing documents" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_ResubmitDocs" name="Documents" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_SendToEnvAgency" name="Application" sourceRef="TaskSendToEnvAgency" targetRef="PoolEnvironmentalAgency" />
    <bpmn:messageFlow id="MF_EnvOpinion" name="Opinion" sourceRef="PoolEnvironmentalAgency" targetRef="CatchEnvOpinion" />

    <bpmn:messageFlow id="MF_NotifyApproval" name="Permit" sourceRef="TaskNotifyApproval" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_NotifyRejection" name="Rejection" sourceRef="TaskNotifyRejection" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_BuildingAuthority" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BuildingAuthority">
      <bpmn:lane id="LanePermitOffice" name="Permit Office">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadlineExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToEnvAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnvPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskPrepareRejectionEnv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAfterDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskPrepareRejectionTech</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwInformCitizen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedTimeout</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechOk</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartApplication" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?" isMarkerVisible="true">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs" name="" >
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadlineExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskSendToEnvAgency" name="Send to agency">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:intermediateCatchEvent id="CatchEnvOpinion" name="Opinion received">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_EnvOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwEnvPositive" name="Positive?" isMarkerVisible="true">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechOk" name="Ok?" isMarkerVisible="true">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskPrepareRejectionEnv" name="Prepare rejection">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskPrepareRejectionTech" name="Prepare rejection">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndRejectedTimeout" name="Application rejected">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="GwAfterDecision" name="Decision?" isMarkerVisible="true">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GwInformCitizen" name="Result?" isMarkerVisible="true">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskNotifyApproval" name="Notify citizen">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskNotifyRejection" name="Notify citizen">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Permit issued">
      <bpmn:incoming>Flow_24</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejected" name="Application rejected">
      <bpmn:incoming>Flow_25</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="GwComplete" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_4" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="GwWaitDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="GwWaitDocs" targetRef="CatchDeadlineExceeded" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="CatchMissingDocs" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchDeadlineExceeded" targetRef="EndRejectedTimeout" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendToEnvAgency" targetRef="CatchEnvOpinion" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="CatchEnvOpinion" targetRef="GwEnvPositive" />
    <bpmn:sequenceFlow id="Flow_12" name="Yes" sourceRef="GwEnvPositive" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_13" name="No" sourceRef="GwEnvPositive" targetRef="TaskPrepareRejectionEnv" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskCheckTechnical" targetRef="GwTechOk" />
    <bpmn:sequenceFlow id="Flow_15" name="Yes" sourceRef="GwTechOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_16" name="No" sourceRef="GwTechOk" targetRef="TaskPrepareRejectionTech" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="TaskIssuePermit" targetRef="GwAfterDecision" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="TaskPrepareRejectionEnv" targetRef="GwAfterDecision" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="TaskPrepareRejectionTech" targetRef="GwAfterDecision" />
    <bpmn:sequenceFlow id="Flow_20" name="Approved" sourceRef="GwAfterDecision" targetRef="GwInformCitizen" />
    <bpmn:sequenceFlow id="Flow_21" name="Rejected" sourceRef="GwAfterDecision" targetRef="GwInformCitizen" />
    <bpmn:sequenceFlow id="Flow_22" name="Approve" sourceRef="GwInformCitizen" targetRef="TaskNotifyApproval" />
    <bpmn:sequenceFlow id="Flow_23" name="Reject" sourceRef="GwInformCitizen" targetRef="TaskNotifyRejection" />
    <bpmn:sequenceFlow id="Flow_24" sourceRef="TaskNotifyApproval" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_25" sourceRef="TaskNotifyRejection" targetRef="EndRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">
      <bpmndi:BPMNShape id="PoolBuildingAuthority_di" bpmnElement="PoolBuildingAuthority" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LanePermitOffice_di" bpmnElement="LanePermitOffice" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolEnvironmentalAgency_di" bpmnElement="PoolEnvironmentalAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="197" y="195" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwComplete_di" bpmnElement="GwComplete" isMarkerVisible="true">
        <dc:Bounds x="480" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="470" y="202" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocs_di" bpmnElement="TaskRequestMissingDocs">
        <dc:Bounds x="600" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDocs_di" bpmnElement="GwWaitDocs">
        <dc:Bounds x="760" y="245" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocs_di" bpmnElement="CatchMissingDocs">
        <dc:Bounds x="870" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="842" y="285" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadlineExceeded_di" bpmnElement="CatchDeadlineExceeded">
        <dc:Bounds x="870" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="840" y="355" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedTimeout_di" bpmnElement="EndRejectedTimeout">
        <dc:Bounds x="1000" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="970" y="355" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToEnvAgency_di" bpmnElement="TaskSendToEnvAgency">
        <dc:Bounds x="600" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchEnvOpinion_di" bpmnElement="CatchEnvOpinion">
        <dc:Bounds x="760" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="732" y="195" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnvPositive_di" bpmnElement="GwEnvPositive" isMarkerVisible="true">
        <dc:Bounds x="870" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="865" y="202" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskPrepareRejectionEnv_di" bpmnElement="TaskPrepareRejectionEnv">
        <dc:Bounds x="1000" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="1000" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechOk_di" bpmnElement="GwTechOk" isMarkerVisible="true">
        <dc:Bounds x="1160" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1170" y="372" width="30" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1280" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskPrepareRejectionTech_di" bpmnElement="TaskPrepareRejectionTech">
        <dc:Bounds x="1280" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAfterDecision_di" bpmnElement="GwAfterDecision" isMarkerVisible="true">
        <dc:Bounds x="1410" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1405" y="372" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwInformCitizen_di" bpmnElement="GwInformCitizen" isMarkerVisible="true">
        <dc:Bounds x="1530" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1528" y="372" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyApproval_di" bpmnElement="TaskNotifyApproval">
        <dc:Bounds x="1650" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejection_di" bpmnElement="TaskNotifyRejection">
        <dc:Bounds x="1650" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1790" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1767" y="325" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1790" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1760" y="425" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="480" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="530" y="170" />
        <di:waypoint x="600" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="560" y="152" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="505" y="195" />
        <di:waypoint x="505" y="270" />
        <di:waypoint x="600" y="270" />
        <bpmndi:BPMNLabel><dc:Bounds x="510" y="230" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="700" y="270" />
        <di:waypoint x="760" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="810" y="270" />
        <di:waypoint x="870" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="810" y="270" />
        <di:waypoint x="840" y="330" />
        <di:waypoint x="870" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="906" y="260" />
        <di:waypoint x="950" y="260" />
        <di:waypoint x="950" y="170" />
        <di:waypoint x="600" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="906" y="330" />
        <di:waypoint x="1000" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="700" y="170" />
        <di:waypoint x="760" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="796" y="170" />
        <di:waypoint x="870" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="895" y="195" />
        <di:waypoint x="895" y="340" />
        <di:waypoint x="1000" y="340" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="255" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="920" y="170" />
        <di:waypoint x="960" y="170" />
        <di:waypoint x="960" y="120" />
        <di:waypoint x="1000" y="120" />
        <bpmndi:BPMNLabel><dc:Bounds x="935" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1100" y="340" />
        <di:waypoint x="1160" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1210" y="340" />
        <di:waypoint x="1280" y="300" />
        <bpmndi:BPMNLabel><dc:Bounds x="1230" y="312" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
