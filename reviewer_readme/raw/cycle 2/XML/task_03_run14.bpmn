<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_Vacation\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n\n  <bpmn:collaboration id=\"Collaboration_Vacation\">\n    <bpmn:participant id=\"PoolEmployee\" name=\"Employee\" processRef=\"Process_Employee\" />\n    <bpmn:participant id=\"PoolHR\" name=\"HR Portal &amp; HR\" processRef=\"Process_HR\" />\n    <bpmn:participant id=\"PoolApprovers\" name=\"Supervisor &amp; HR Manager\" processRef=\"Process_Approvers\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitRequest\" name=\"Request\" sourceRef=\"TaskSubmitRequest\" targetRef=\"StartRequestArrived\" />\n    <bpmn:messageFlow id=\"MF_SendForApproval\" name=\"Approval request\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"StartApprovalRequested\" />\n    <bpmn:messageFlow id=\"MF_SupervisorDecision\" name=\"Decision\" sourceRef=\"EndSupervisorDecisionSent\" targetRef=\"CatchSupervisorDecision\" />\n    <bpmn:messageFlow id=\"MF_Escalation\" name=\"Escalation\" sourceRef=\"TaskEscalate\" targetRef=\"StartEscalationArrived\" />\n    <bpmn:messageFlow id=\"MF_HRManagerDecision\" name=\"Decision\" sourceRef=\"EndHRManagerDecisionSent\" targetRef=\"CatchHRManagerDecision\" />\n    <bpmn:messageFlow id=\"MF_NotifyApproved\" name=\"Approved\" sourceRef=\"TaskNotifyApproved\" targetRef=\"CatchApproved\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejected\" name=\"Rejected\" sourceRef=\"TaskNotifyRejected\" targetRef=\"CatchRejected\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_Employee\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartEmployeeNeedsVacation\" name=\"Need vacation\">\n      <bpmn:outgoing>Flow_E1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:sendTask id=\"TaskSubmitRequest\" name=\"Submit request\">\n      <bpmn:incoming>Flow_E1</bpmn:incoming>\n      <bpmn:outgoing>Flow_E2</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitDecision\" name=\"\">\n      <bpmn:incoming>Flow_E2</bpmn:incoming>\n      <bpmn:outgoing>Flow_E3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_E4</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchApproved\" name=\"Approved received\">\n      <bpmn:incoming>Flow_E3</bpmn:incoming>\n      <bpmn:outgoing>Flow_E5</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchApproved\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchRejected\" name=\"Rejected received\">\n      <bpmn:incoming>Flow_E4</bpmn:incoming>\n      <bpmn:outgoing>Flow_E6</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchRejected\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndEmployeeInformedApproved\" name=\"Informed\">\n      <bpmn:incoming>Flow_E5</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndEmployeeInformedRejected\" name=\"Informed\">\n      <bpmn:incoming>Flow_E6</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_E1\" sourceRef=\"StartEmployeeNeedsVacation\" targetRef=\"TaskSubmitRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_E2\" sourceRef=\"TaskSubmitRequest\" targetRef=\"GwWaitDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_E3\" sourceRef=\"GwWaitDecision\" targetRef=\"CatchApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_E4\" sourceRef=\"GwWaitDecision\" targetRef=\"CatchRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_E5\" sourceRef=\"CatchApproved\" targetRef=\"EndEmployeeInformedApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_E6\" sourceRef=\"CatchRejected\" targetRef=\"EndEmployeeInformedRejected\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_HR\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_HR\">\n      <bpmn:lane id=\"LaneHRPortal\" name=\"HR Portal\">\n        <bpmn:flowNodeRef>StartRequestArrived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendApprovalRequest</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchSupervisorDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskEscalate</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchHRManagerDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwApprovedFinal</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyRejected</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndHRApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndHRRejected</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneHRDepartment\" name=\"HR Department\">\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartRequestArrived\" name=\"Request received\">\n      <bpmn:messageEventDefinition id=\"MED_StartRequestArrived\" />\n      <bpmn:outgoing>Flow_H1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:businessRuleTask id=\"TaskCheckBalance\" name=\"Check balance\">\n      <bpmn:incoming>Flow_H1</bpmn:incoming>\n      <bpmn:outgoing>Flow_H2</bpmn:outgoing>\n    </bpmn:businessRuleTask>\n\n    <bpmn:exclusiveGateway id=\"GwEnoughDays\" name=\"Enough days?\">\n      <bpmn:incoming>Flow_H2</bpmn:incoming>\n      <bpmn:outgoing>Flow_H3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendApprovalRequest\" name=\"Request approval\">\n      <bpmn:incoming>Flow_H3</bpmn:incoming>\n      <bpmn:outgoing>Flow_H5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitFeedback\" name=\"\">\n      <bpmn:incoming>Flow_H5</bpmn:incoming>\n      <bpmn:outgoing>Flow_H6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H7</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorDecision\" name=\"Feedback received\">\n      <bpmn:incoming>Flow_H6</bpmn:incoming>\n      <bpmn:outgoing>Flow_H8</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchSupervisorDecision\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"5 days exceeded\">\n      <bpmn:incoming>Flow_H7</bpmn:incoming>\n      <bpmn:outgoing>Flow_H9</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_5Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:sendTask id=\"TaskEscalate\" name=\"Escalate case\">\n      <bpmn:incoming>Flow_H9</bpmn:incoming>\n      <bpmn:outgoing>Flow_H10</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:intermediateCatchEvent id=\"CatchHRManagerDecision\" name=\"Decision received\">\n      <bpmn:incoming>Flow_H10</bpmn:incoming>\n      <bpmn:outgoing>Flow_H11</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchHRManagerDecision\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwApprovedFinal\" name=\"Approved?\">\n      <bpmn:incoming>Flow_H11</bpmn:incoming>\n      <bpmn:incoming>Flow_H8</bpmn:incoming>\n      <bpmn:incoming>Flow_H4</bpmn:incoming>\n      <bpmn:outgoing>Flow_H12</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H13</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:serviceTask id=\"TaskBookVacation\" name=\"Book vacation\">\n      <bpmn:incoming>Flow_H12</bpmn:incoming>\n      <bpmn:outgoing>Flow_H14</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskNotifyApproved\" name=\"Notify employee\">\n      <bpmn:incoming>Flow_H14</bpmn:incoming>\n      <bpmn:outgoing>Flow_H15</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:sendTask id=\"TaskNotifyRejected\" name=\"Notify employee\">\n      <bpmn:incoming>Flow_H13</bpmn:incoming>\n      <bpmn:outgoing>Flow_H16</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndHRApproved\" name=\"Completed\">\n      <bpmn:incoming>Flow_H15</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndHRRejected\" name=\"Completed\">\n      <bpmn:incoming>Flow_H16</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_H1\" sourceRef=\"StartRequestArrived\" targetRef=\"TaskCheckBalance\" />\n    <bpmn:sequenceFlow id=\"Flow_H2\" sourceRef=\"TaskCheckBalance\" targetRef=\"GwEnoughDays\" />\n    <bpmn:sequenceFlow id=\"Flow_H3\" name=\"Yes\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskSendApprovalRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_H4\" name=\"No\" sourceRef=\"GwEnoughDays\" targetRef=\"GwApprovedFinal\" />\n    <bpmn:sequenceFlow id=\"Flow_H5\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"GwWaitFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_H6\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_H7\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_H8\" sourceRef=\"CatchSupervisorDecision\" targetRef=\"GwApprovedFinal\" />\n    <bpmn:sequenceFlow id=\"Flow_H9\" sourceRef=\"CatchTimeout\" targetRef=\"TaskEscalate\" />\n    <bpmn:sequenceFlow id=\"Flow_H10\" sourceRef=\"TaskEscalate\" targetRef=\"CatchHRManagerDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_H11\" sourceRef=\"CatchHRManagerDecision\" targetRef=\"GwApprovedFinal\" />\n    <bpmn:sequenceFlow id=\"Flow_H12\" name=\"Yes\" sourceRef=\"GwApprovedFinal\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_H13\" name=\"No\" sourceRef=\"GwApprovedFinal\" targetRef=\"TaskNotifyRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_H14\" sourceRef=\"TaskBookVacation\" targetRef=\"TaskNotifyApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_H15\" sourceRef=\"TaskNotifyApproved\" targetRef=\"EndHRApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_H16\" sourceRef=\"TaskNotifyRejected\" targetRef=\"EndHRRejected\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_Approvers\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Approvers\">\n      <bpmn:lane id=\"LaneSupervisor\" name=\"Supervisor\">\n        <bpmn:flowNodeRef>StartApprovalRequested</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwSupervisorApprove</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndSupervisorDecisionSent</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneHRManager\" name=\"HR Manager\">\n        <bpmn:flowNodeRef>StartEscalationArrived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskDecideEscalation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwHRManagerApprove</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndHRManagerDecisionSent</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartApprovalRequested\" name=\"Approval requested\">\n      <bpmn:messageEventDefinition id=\"MED_StartApprovalRequested\" />\n      <bpmn:outgoing>Flow_A1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskReviewRequest\" name=\"Review request\">\n      <bpmn:incoming>Flow_A1</bpmn:incoming>\n      <bpmn:outgoing>Flow_A2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwSupervisorApprove\" name=\"Approve?\">\n      <bpmn:incoming>Flow_A2</bpmn:incoming>\n      <bpmn:outgoing>Flow_A3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_A4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndSupervisorDecisionSent\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_A3</bpmn:incoming>\n      <bpmn:incoming>Flow_A4</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndSupervisorDecisionSent\" />\n    </bpmn:endEvent>\n\n    <bpmn:startEvent id=\"StartEscalationArrived\" name=\"Escalation received\">\n      <bpmn:messageEventDefinition id=\"MED_StartEscalationArrived\" />\n      <bpmn:outgoing>Flow_A5</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskDecideEscalation\" name=\"Make decision\">\n      <bpmn:incoming>Flow_A5</bpmn:incoming>\n      <bpmn:outgoing>Flow_A6</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwHRManagerApprove\" name=\"Approve?\">\n      <bpmn:incoming>Flow_A6</bpmn:incoming>\n      <bpmn:outgoing>Flow_A7</bpmn:outgoing>\n      <bpmn:outgoing>Flow_A8</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndHRManagerDecisionSent\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_A7</bpmn:incoming>\n      <bpmn:incoming>Flow_A8</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndHRManagerDecisionSent\" />\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_A1\" sourceRef=\"StartApprovalRequested\" targetRef=\"TaskReviewRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_A2\" sourceRef=\"TaskReviewRequest\" targetRef=\"GwSupervisorApprove\" />\n    <bpmn:sequenceFlow id=\"Flow_A3\" name=\"Yes\" sourceRef=\"GwSupervisorApprove\" targetRef=\"EndSupervisorDecisionSent\" />\n    <bpmn:sequenceFlow id=\"Flow_A4\" name=\"No\" sourceRef=\"GwSupervisorApprove\" targetRef=\"EndSupervisorDecisionSent\" />\n    <bpmn:sequenceFlow id=\"Flow_A5\" sourceRef=\"StartEscalationArrived\" targetRef=\"TaskDecideEscalation\" />\n    <bpmn:sequenceFlow id=\"Flow_A6\" sourceRef=\"TaskDecideEscalation\" targetRef=\"GwHRManagerApprove\" />\n    <bpmn:sequenceFlow id=\"Flow_A7\" name=\"Yes\" sourceRef=\"GwHRManagerApprove\" targetRef=\"EndHRManagerDecisionSent\" />\n    <bpmn:sequenceFlow id=\"Flow_A8\" name=\"No\" sourceRef=\"GwHRManagerApprove\" targetRef=\"EndHRManagerDecisionSent\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_Vacation\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_Vacation\" bpmnElement=\"Collaboration_Vacation\">\n\n      <bpmndi:BPMNShape id=\"PoolEmployee_di\" bpmnElement=\"PoolEmployee\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"250\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartEmployeeNeedsVacation_di\" bpmnElement=\"StartEmployeeNeedsVacation\">\n        <dc:Bounds x=\"220\" y=\"192\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"200\" y=\"235\" width=\"85\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSubmitRequest_di\" bpmnElement=\"TaskSubmitRequest\">\n        <dc:Bounds x=\"320\" y=\"170\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitDecision_di\" bpmnElement=\"GwWaitDecision\">\n        <dc:Bounds x=\"480\" y=\"185\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchApproved_di\" bpmnElement=\"CatchApproved\">\n        <dc:Bounds x=\"600\" y=\"130\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"575\" y=\"100\" width=\"90\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchRejected_di\" bpmnElement=\"CatchRejected\">\n        <dc:Bounds x=\"600\" y=\"260\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"575\" y=\"300\" width=\"95\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndEmployeeInformedApproved_di\" bpmnElement=\"EndEmployeeInformedApproved\">\n        <dc:Bounds x=\"720\" y=\"130\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"710\" y=\"173\" width=\"55\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndEmployeeInformedRejected_di\" bpmnElement=\"EndEmployeeInformedRejected\">\n        <dc:Bounds x=\"720\" y=\"260\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"710\" y=\"303\" width=\"55\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolHR_di\" bpmnElement=\"PoolHR\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"380\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneHRPortal_di\" bpmnElement=\"LaneHRPortal\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"380\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneHRDepartment_di\" bpmnElement=\"LaneHRDepartment\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"560\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartRequestArrived_di\" bpmnElement=\"StartRequestArrived\">\n        <dc:Bounds x=\"220\" y=\"452\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"195\" y=\"495\" width=\"98\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckBalance_di\" bpmnElement=\"TaskCheckBalance\">\n        <dc:Bounds x=\"320\" y=\"430\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwEnoughDays_di\" bpmnElement=\"GwEnoughDays\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"470\" y=\"445\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"450\" y=\"502\" width=\"95\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendApprovalRequest_di\" bpmnElement=\"TaskSendApprovalRequest\">\n        <dc:Bounds x=\"600\" y=\"430\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitFeedback_di\" bpmnElement=\"GwWaitFeedback\">\n        <dc:Bounds x=\"750\" y=\"445\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorDecision_di\" bpmnElement=\"CatchSupervisorDecision\">\n        <dc:Bounds x=\"860\" y=\"390\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"835\" y=\"360\" width=\"100\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"860\" y=\"520\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"830\" y=\"560\" width=\"110\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskEscalate_di\" bpmnElement=\"TaskEscalate\">\n        <dc:Bounds x=\"980\" y=\"500\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchHRManagerDecision_di\" bpmnElement=\"CatchHRManagerDecision\">\n        <dc:Bounds x=\"1120\" y=\"520\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1090\" y=\"560\" width=\"115\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwApprovedFinal_di\" bpmnElement=\"GwApprovedFinal\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"980\" y=\"385\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"965\" y=\"442\" width=\"65\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskBookVacation_di\" bpmnElement=\"TaskBookVacation\">\n        <dc:Bounds x=\"1120\" y=\"350\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyApproved_di\" bpmnElement=\"TaskNotifyApproved\">\n        <dc:Bounds x=\"1270\" y=\"350\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejected_di\" bpmnElement=\"TaskNotifyRejected\">\n        <dc:Bounds x=\"1120\" y=\"450\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndHRApproved_di\" bpmnElement=\"EndHRApproved\">\n        <dc:Bounds x=\"1420\" y=\"372\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1405\" y=\"415\" width=\"