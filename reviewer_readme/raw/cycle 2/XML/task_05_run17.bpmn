      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="960" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="948" y="265" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchNoResponse3Days_di" bpmnElement="CatchNoResponse3Days">
        <dc:Bounds x="960" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="950" y="365" width="58" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAlternativeSupplier_di" bpmnElement="TaskReviewAlternativeSupplier">
        <dc:Bounds x="1120" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwOrderAlternative_di" bpmnElement="GwOrderAlternative" isMarkerVisible="true">
        <dc:Bounds x="1280" y="275" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1250" y="332" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1440" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1428" y="185" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderRequestAlternative_di" bpmnElement="TaskSendOrderRequestAlternative">
        <dc:Bounds x="1440" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeOrdered_di" bpmnElement="EndAlternativeOrdered">
        <dc:Bounds x="1600" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1582" y="325" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="266" y="160" />
        <di:waypoint x="340" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="440" y="160" />
        <di:waypoint x="500" y="160" />
      </bpmndi:BPMNEdge>
