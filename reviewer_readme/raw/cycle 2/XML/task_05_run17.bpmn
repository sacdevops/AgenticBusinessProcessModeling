        <bpmndi:BPMNLabel><dc:Bounds x="551" y="615" width="54" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="266" y="550" />
        <di:waypoint x="380" y="550" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="430" y="550" />
        <di:waypoint x="470" y="510" />
        <di:waypoint x="560" y="510" />
        <bpmndi:BPMNLabel><dc:Bounds x="462" y="522" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="430" y="550" />
        <di:waypoint x="470" y="590" />
        <di:waypoint x="560" y="590" />
        <bpmndi:BPMNLabel><dc:Bounds x="462" y="572" width="18" height="14" /></bpmndi:BPMNLabel>
