        <di:waypoint x="978" y="322" />
        <di:waypoint x="978" y="300" />
        <di:waypoint x="1120" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C12_di" bpmnElement="Flow_C12">
        <di:waypoint x="1220" y="300" />
        <di:waypoint x="1280" y="300" />
      </bpmndi:BPMNEdge>
