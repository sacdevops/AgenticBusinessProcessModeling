      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="650" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
