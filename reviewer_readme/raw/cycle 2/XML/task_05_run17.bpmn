        <di:waypoint x="1540" y="300" />
        <di:waypoint x="1600" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="450" width="1400" height="200" />
      </bpmndi:BPMNShape>
