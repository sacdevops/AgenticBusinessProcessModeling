<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_OfficeSupply" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_OfficeSupply">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_PoolCompany" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_PoolStandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_PoolAlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="StartStandardOrderReceived" />
    <bpmn:messageFlow id="MF_StandardConfirmation" name="Confirmation" sourceRef="EndStandardConfirmed" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_StandardRejection" name="Rejection" sourceRef="EndStandardRejected" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_OrderRequest_Alternative" name="Order request" sourceRef="TaskSendOrderRequestAlternative" targetRef="StartAlternativeOrderReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolCompany" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitStandardResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchNoResponse3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStandardSuccess</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskReviewAlternativeSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndAlternativeOrdered</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterDay" name="Quarter day">
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterDay" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low inventory?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitStandardResponse">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmation">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdConfirm" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndStandardSuccess" name="Order confirmed">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejection">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdReject" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchNoResponse3Days" name="3 days">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAlternativeSupplier" name="Check alternative">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwOrderAlternative" name="Order alternative?">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndCancelled" name="Cancelled">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestAlternative" name="Send order">
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAlternativeOrdered" name="Order sent">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartQuarterDay" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwLowInventory" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitStandardResponse" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="GwWaitStandardResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitStandardResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitStandardResponse" targetRef="CatchNoResponse3Days" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchStandardConfirmation" targetRef="EndStandardSuccess" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchStandardRejection" targetRef="TaskReviewAlternativeSupplier" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="CatchNoResponse3Days" targetRef="TaskReviewAlternativeSupplier" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskReviewAlternativeSupplier" targetRef="GwOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_C13" name="Yes" sourceRef="GwOrderAlternative" targetRef="TaskSendOrderRequestAlternative" />
    <bpmn:sequenceFlow id="Flow_C14" name="No" sourceRef="GwOrderAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_C15" sourceRef="TaskSendOrderRequestAlternative" targetRef="EndAlternativeOrdered" />
  </bpmn:process>

  <bpmn:process id="Process_PoolStandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStandardOrderReceived" name="Request received">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdStart" />
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GwStandardDeliverable" name="Deliverable?">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStandardConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdConfirm_Send" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndStandardRejected" name="Rejected">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_StdReject_Send" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartStandardOrderReceived" targetRef="GwStandardDeliverable" />
    <bpmn:sequenceFlow id="Flow_S2" name="Yes" sourceRef="GwStandardDeliverable" targetRef="EndStandardConfirmed" />
    <bpmn:sequenceFlow id="Flow_S3" name="No" sourceRef="GwStandardDeliverable" targetRef="EndStandardRejected" />
  </bpmn:process>

  <bpmn:process id="Process_PoolAlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAlternativeOrderReceived" name="Order received">
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AltStart" />
    </bpmn:startEvent>
    <bpmn:endEvent id="EndAlternativeReceived" name="Order logged">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAlternativeOrderReceived" targetRef="EndAlternativeReceived" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupply">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupply" bpmnElement="Collaboration_OfficeSupply">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="320" />
      </bpmndi:BPMNShape>
