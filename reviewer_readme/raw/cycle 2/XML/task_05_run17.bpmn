      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="700" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartAlternativeOrderReceived_di" bpmnElement="StartAlternativeOrderReceived">
        <dc:Bounds x="230" y="772" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="208" y="815" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeReceived_di" bpmnElement="EndAlternativeReceived">
        <dc:Bounds x="380" y="772" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="362" y="815" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1">
        <di:waypoint x="266" y="790" />
        <di:waypoint x="380" y="790" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Standard_di" bpmnElement="MF_OrderRequest_Standard">
        <di:waypoint x="700" y="260" />
        <di:waypoint x="700" y="430" />
        <di:waypoint x="248" y="430" />
        <di:waypoint x="248" y="532" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_StandardConfirmation_di" bpmnElement="MF_StandardConfirmation">
