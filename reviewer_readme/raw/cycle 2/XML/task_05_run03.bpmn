<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_PoolCompany" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_PoolStandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_PoolAlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="PoolStandardSupplier" />
    <bpmn:messageFlow id="MF_StandardConfirmation" name="Confirmation" sourceRef="PoolStandardSupplier" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_StandardRejection" name="Rejection" sourceRef="PoolStandardSupplier" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_OrderRequest_Alternative" name="Order request" sourceRef="TaskSendOrderRequestAlternative" targetRef="PoolAlternativeSupplier" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolCompany" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterlyCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitSupplierResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchNoResponse3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskManualIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderedAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterlyCheck" name="Quarter start">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Quarterly" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low stock?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order">
      <bpmn:incoming>Flow_S3_No</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_S3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitSupplierResponse">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_Confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_S5_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_S5_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmation">
      <bpmn:incoming>Flow_S5_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardConfirm" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndOrderConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_S6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejection">
      <bpmn:incoming>Flow_S5_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_S7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardReject" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchNoResponse3Days" name="3 days">
      <bpmn:incoming>Flow_S5_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_S8</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervention" name="Manual review">
      <bpmn:incoming>Flow_S7</bpmn:incoming>
      <bpmn:incoming>Flow_S8</bpmn:incoming>
      <bpmn:outgoing>Flow_S9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwOrderAlternative" name="Alternative?">
      <bpmn:incoming>Flow_S9</bpmn:incoming>
      <bpmn:outgoing>Flow_S10_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_S10_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndOrderCancelled" name="Cancelled">
      <bpmn:incoming>Flow_S10_No</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestAlternative" name="Send order">
      <bpmn:incoming>Flow_S10_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_S11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndOrderedAlternative" name="Ordered">
      <bpmn:incoming>Flow_S11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartQuarterlyCheck" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_S3_Yes" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_S3_No" name="No" sourceRef="GwLowInventory" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_S4" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitSupplierResponse" />
    <bpmn:sequenceFlow id="Flow_S5_Confirm" sourceRef="GwWaitSupplierResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_S5_Reject" sourceRef="GwWaitSupplierResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_S5_Timeout" sourceRef="GwWaitSupplierResponse" targetRef="CatchNoResponse3Days" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="CatchStandardConfirmation" targetRef="EndOrderConfirmed" />
    <bpmn:sequenceFlow id="Flow_S7" sourceRef="CatchStandardRejection" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_S8" sourceRef="CatchNoResponse3Days" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_S9" sourceRef="TaskManualIntervention" targetRef="GwOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_S10_Yes" name="Yes" sourceRef="GwOrderAlternative" targetRef="TaskSendOrderRequestAlternative" />
    <bpmn:sequenceFlow id="Flow_S10_No" name="No" sourceRef="GwOrderAlternative" targetRef="EndOrderCancelled" />
    <bpmn:sequenceFlow id="Flow_S11" sourceRef="TaskSendOrderRequestAlternative" targetRef="EndOrderedAlternative" />
  </bpmn:process>

  <bpmn:process id="Process_PoolStandardSupplier" isExecutable="false" />
  <bpmn:process id="Process_PoolAlternativeSupplier" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarterlyCheck_di" bpmnElement="StartQuarterlyCheck">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="203" y="195" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="340" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwLowInventory_di" bpmnElement="GwLowInventory" isMarkerVisible="true">
        <dc:Bounds x="520" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="502" y="202" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndStockSufficient_di" bpmnElement="EndStockSufficient">
        <dc:Bounds x="660" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="642" y="195" width="55" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="660" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitSupplierResponse_di" bpmnElement="GwWaitSupplierResponse">
        <dc:Bounds x="820" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardConfirmation_di" bpmnElement="CatchStandardConfirmation">
        <dc:Bounds x="960" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="942" y="120" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndOrderConfirmed_di" bpmnElement="EndOrderConfirmed">
        <dc:Bounds x="1100" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1074" y="120" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="960" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="952" y="280" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchNoResponse3Days_di" bpmnElement="CatchNoResponse3Days">
        <dc:Bounds x="960" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="952" y="420" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervention_di" bpmnElement="TaskManualIntervention">
        <dc:Bounds x="1100" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOrderAlternative_di" bpmnElement="GwOrderAlternative" isMarkerVisible="true">
        <dc:Bounds x="1260" y="355" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1246" y="412" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndOrderCancelled_di" bpmnElement="EndOrderCancelled">
        <dc:Bounds x="1420" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1402" y="385" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestAlternative_di" bpmnElement="TaskSendOrderRequestAlternative">
        <dc:Bounds x="1420" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndOrderedAlternative_di" bpmnElement="EndOrderedAlternative">
        <dc:Bounds x="1540" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1528" y="325" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="340" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="440" y="170" />
        <di:waypoint x="520" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S3_Yes_di" bpmnElement="Flow_S3_Yes">
        <di:waypoint x="545" y="195" />
        <di:waypoint x="545" y="320" />
        <di:waypoint x="660" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="553" y="248" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S3_No_di" bpmnElement="Flow_S3_No">
        <di:waypoint x="570" y="170" />
        <di:waypoint x="660" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="605" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S4_di" bpmnElement="Flow_S4">
        <di:waypoint x="760" y="320" />
        <di:waypoint x="820" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S5_Confirm_di" bpmnElement="Flow_S5_Confirm">
        <di:waypoint x="845" y="295" />
        <di:waypoint x="845" y="160" />
        <di:waypoint x="960" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S5_Reject_di" bpmnElement="Flow_S5_Reject">
        <di:waypoint x="870" y="320" />
        <di:waypoint x="960" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S5_Timeout_di" bpmnElement="Flow_S5_Timeout">
        <di:waypoint x="845" y="345" />
        <di:waypoint x="845" y="400" />
        <di:waypoint x="960" y="400" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S6_di" bpmnElement="Flow_S6">
        <di:waypoint x="996" y="160" />
        <di:waypoint x="1100" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S7_di" bpmnElement="Flow_S7">
        <di:waypoint x="996" y="320" />
        <di:waypoint x="1100" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S8_di" bpmnElement="Flow_S8">
        <di:waypoint x="978" y="418" />
        <di:waypoint x="978" y="470" />
        <di:waypoint x="1100" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S9_di" bpmnElement="Flow_S9">
        <di:waypoint x="1200" y="380" />
        <di:waypoint x="1260" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S10_Yes_di" bpmnElement="Flow_S10_Yes">
        <di:waypoint x="1285" y="355" />
        <di:waypoint x="1285" y="300" />
        <di:waypoint x="1420" y="300" />
        <bpmndi:BPMNLabel><dc:Bounds x="1293" y="320" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S10_No_di" bpmnElement="Flow_S10_No">
        <di:waypoint x="1310" y="380" />
        <di:waypoint x="1420" y="360" />
        <bpmndi:BPMNLabel><dc:Bounds x="1354" y="365" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S11_di" bpmnElement="Flow_S11">
        <di:waypoint x="1520" y="300" />
        <di:waypoint x="1540" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Standard_di" bpmnElement="MF_OrderRequest_Standard">
        <di:waypoint x="710" y="360" />
        <di:waypoint x="710" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_StandardConfirmation_di" bpmnElement="MF_StandardConfirmation">
        <di:waypoint x="980" y="490" />
        <di:waypoint x="978" y="178" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_StandardRejection_di" bpmnElement="MF_StandardRejection">
        <di:waypoint x="1040" y="490" />
        <di:waypoint x="1040" y="420" />
        <di:waypoint x="978" y="338" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Alternative_di" bpmnElement="MF_OrderRequest_Alternative">
        <di:waypoint x="1470" y="260" />
        <di:waypoint x="1470" y="600" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>