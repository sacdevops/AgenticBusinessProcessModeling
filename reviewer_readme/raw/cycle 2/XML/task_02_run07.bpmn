<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_InsuranceClaim\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_InsuranceClaim\">\n    <bpmn:participant id=\"PoolInsurance\" name=\"Insurance Company\" processRef=\"Process_Insurance\" />\n    <bpmn:participant id=\"PoolAssessor\" name=\"Assessor\" />\n\n    <bpmn:messageFlow id=\"MF_CommissionAssessor\" name=\"Assessment order\" sourceRef=\"TaskCommissionAssessor\" targetRef=\"PoolAssessor\" />\n    <bpmn:messageFlow id=\"MF_AssessmentReport\" name=\"Assessment report\" sourceRef=\"PoolAssessor\" targetRef=\"CatchAssessmentReport\" />\n\n    <bpmn:messageFlow id=\"MF_InformCoveredLow\" name=\"Decision\" sourceRef=\"TaskInformApprovedLow\" targetRef=\"PoolAssessor\" />\n    <bpmn:messageFlow id=\"MF_InformApprovedFinal\" name=\"Decision\" sourceRef=\"TaskInformApprovedFinal\" targetRef=\"PoolAssessor\" />\n    <bpmn:messageFlow id=\"MF_InformRejectedNotCovered\" name=\"Decision\" sourceRef=\"TaskInformRejectedNotCovered\" targetRef=\"PoolAssessor\" />\n    <bpmn:messageFlow id=\"MF_InformRejectedFinal\" name=\"Decision\" sourceRef=\"TaskInformRejectedFinal\" targetRef=\"PoolAssessor\" />\n    <bpmn:messageFlow id=\"MF_InformRejectedDeadline\" name=\"Decision\" sourceRef=\"TaskInformRejectedDeadline\" targetRef=\"PoolAssessor\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_Insurance\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Insurance\">\n      <bpmn:lane id=\"LaneClaimsHandler\" name=\"Claims Handler\">\n        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwBelow1500</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskApproveLow</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCommissionAssessor</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitReport</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchAssessmentReport</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwFinalDecision</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneClaimsSystem\" name=\"Claims System\">\n        <bpmn:flowNodeRef>TaskInitiatePaymentLow</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformApprovedLow</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInitiatePaymentFinal</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformApprovedFinal</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformRejectedNotCovered</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskAutoRejectDeadline</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformRejectedDeadline</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformRejectedFinal</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchReportDeadline</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndCaseClosed</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartDamageReport\" name=\"Damage report received\">\n      <bpmn:outgoing>Flow_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskCreateCase\" name=\"Create case\">\n      <bpmn:incoming>Flow_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:userTask id=\"TaskCheckCoverage\" name=\"Check coverage\">\n      <bpmn:incoming>Flow_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_3</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwCovered\" name=\"Covered?\">\n      <bpmn:incoming>Flow_3</bpmn:incoming>\n      <bpmn:outgoing>Flow_4_Covered</bpmn:outgoing>\n      <bpmn:outgoing>Flow_4_NotCovered</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskInformRejectedNotCovered\" name=\"Inform rejection\">\n      <bpmn:incoming>Flow_4_NotCovered</bpmn:incoming>\n      <bpmn:outgoing>Flow_5_EndNotCovered</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:userTask id=\"TaskCheckAmount\" name=\"Check amount\">\n      <bpmn:incoming>Flow_4_Covered</bpmn:incoming>\n      <bpmn:outgoing>Flow_6</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwBelow1500\" name=\"Amount < €1500?\">\n      <bpmn:incoming>Flow_6</bpmn:incoming>\n      <bpmn:outgoing>Flow_7_Below</bpmn:outgoing>\n      <bpmn:outgoing>Flow_7_Above</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:userTask id=\"TaskApproveLow\" name=\"Approve case\">\n      <bpmn:incoming>Flow_7_Below</bpmn:incoming>\n      <bpmn:outgoing>Flow_8</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:serviceTask id=\"TaskInitiatePaymentLow\" name=\"Initiate payment\">\n      <bpmn:incoming>Flow_8</bpmn:incoming>\n      <bpmn:outgoing>Flow_9</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskInformApprovedLow\" name=\"Inform approval\">\n      <bpmn:incoming>Flow_9</bpmn:incoming>\n      <bpmn:outgoing>Flow_10_EndApprovedLow</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:sendTask id=\"TaskCommissionAssessor\" name=\"Commission assessor\">\n      <bpmn:incoming>Flow_7_Above</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitReport\" name=\"\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n      <bpmn:outgoing>Flow_12_Report</bpmn:outgoing>\n      <bpmn:outgoing>Flow_12_Timeout</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchAssessmentReport\" name=\"Assessment report received\">\n      <bpmn:incoming>Flow_12_Report</bpmn:incoming>\n      <bpmn:outgoing>Flow_13</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_AssessmentReport\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchReportDeadline\" name=\"10 days exceeded\">\n      <bpmn:incoming>Flow_12_Timeout</bpmn:incoming>\n      <bpmn:outgoing>Flow_14</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_10Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:serviceTask id=\"TaskAutoRejectDeadline\" name=\"Auto reject\">\n      <bpmn:incoming>Flow_14</bpmn:incoming>\n      <bpmn:outgoing>Flow_15</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskInformRejectedDeadline\" name=\"Inform rejection\">\n      <bpmn:incoming>Flow_15</bpmn:incoming>\n      <bpmn:outgoing>Flow_16_EndDeadline</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:userTask id=\"TaskReviewAssessment\" name=\"Review assessment\">\n      <bpmn:incoming>Flow_13</bpmn:incoming>\n      <bpmn:outgoing>Flow_17</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwFinalDecision\" name=\"Approve?\">\n      <bpmn:incoming>Flow_17</bpmn:incoming>\n      <bpmn:outgoing>Flow_18_Approved</bpmn:outgoing>\n      <bpmn:outgoing>Flow_18_Rejected</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:serviceTask id=\"TaskInitiatePaymentFinal\" name=\"Initiate payment\">\n      <bpmn:incoming>Flow_18_Approved</bpmn:incoming>\n      <bpmn:outgoing>Flow_19</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskInformApprovedFinal\" name=\"Inform approval\">\n      <bpmn:incoming>Flow_19</bpmn:incoming>\n      <bpmn:outgoing>Flow_20_EndApprovedFinal</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:sendTask id=\"TaskInformRejectedFinal\" name=\"Inform rejection\">\n      <bpmn:incoming>Flow_18_Rejected</bpmn:incoming>\n      <bpmn:outgoing>Flow_21_EndRejectedFinal</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndCaseClosed\" name=\"Case closed\">\n      <bpmn:incoming>Flow_5_EndNotCovered</bpmn:incoming>\n      <bpmn:incoming>Flow_10_EndApprovedLow</bpmn:incoming>\n      <bpmn:incoming>Flow_16_EndDeadline</bpmn:incoming>\n      <bpmn:incoming>Flow_20_EndApprovedFinal</bpmn:incoming>\n      <bpmn:incoming>Flow_21_EndRejectedFinal</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_1\" sourceRef=\"StartDamageReport\" targetRef=\"TaskCreateCase\" />\n    <bpmn:sequenceFlow id=\"Flow_2\" sourceRef=\"TaskCreateCase\" targetRef=\"TaskCheckCoverage\" />\n    <bpmn:sequenceFlow id=\"Flow_3\" sourceRef=\"TaskCheckCoverage\" targetRef=\"GwCovered\" />\n\n    <bpmn:sequenceFlow id=\"Flow_4_NotCovered\" name=\"No\" sourceRef=\"GwCovered\" targetRef=\"TaskInformRejectedNotCovered\" />\n    <bpmn:sequenceFlow id=\"Flow_4_Covered\" name=\"Yes\" sourceRef=\"GwCovered\" targetRef=\"TaskCheckAmount\" />\n    <bpmn:sequenceFlow id=\"Flow_5_EndNotCovered\" sourceRef=\"TaskInformRejectedNotCovered\" targetRef=\"EndCaseClosed\" />\n\n    <bpmn:sequenceFlow id=\"Flow_6\" sourceRef=\"TaskCheckAmount\" targetRef=\"GwBelow1500\" />\n    <bpmn:sequenceFlow id=\"Flow_7_Below\" name=\"Below\" sourceRef=\"GwBelow1500\" targetRef=\"TaskApproveLow\" />\n    <bpmn:sequenceFlow id=\"Flow_7_Above\" name=\"Above\" sourceRef=\"GwBelow1500\" targetRef=\"TaskCommissionAssessor\" />\n\n    <bpmn:sequenceFlow id=\"Flow_8\" sourceRef=\"TaskApproveLow\" targetRef=\"TaskInitiatePaymentLow\" />\n    <bpmn:sequenceFlow id=\"Flow_9\" sourceRef=\"TaskInitiatePaymentLow\" targetRef=\"TaskInformApprovedLow\" />\n    <bpmn:sequenceFlow id=\"Flow_10_EndApprovedLow\" sourceRef=\"TaskInformApprovedLow\" targetRef=\"EndCaseClosed\" />\n\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"TaskCommissionAssessor\" targetRef=\"GwWaitReport\" />\n    <bpmn:sequenceFlow id=\"Flow_12_Report\" sourceRef=\"GwWaitReport\" targetRef=\"CatchAssessmentReport\" />\n    <bpmn:sequenceFlow id=\"Flow_12_Timeout\" sourceRef=\"GwWaitReport\" targetRef=\"CatchReportDeadline\" />\n\n    <bpmn:sequenceFlow id=\"Flow_13\" sourceRef=\"CatchAssessmentReport\" targetRef=\"TaskReviewAssessment\" />\n    <bpmn:sequenceFlow id=\"Flow_14\" sourceRef=\"CatchReportDeadline\" targetRef=\"TaskAutoRejectDeadline\" />\n    <bpmn:sequenceFlow id=\"Flow_15\" sourceRef=\"TaskAutoRejectDeadline\" targetRef=\"TaskInformRejectedDeadline\" />\n    <bpmn:sequenceFlow id=\"Flow_16_EndDeadline\" sourceRef=\"TaskInformRejectedDeadline\" targetRef=\"EndCaseClosed\" />\n\n    <bpmn:sequenceFlow id=\"Flow_17\" sourceRef=\"TaskReviewAssessment\" targetRef=\"GwFinalDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_18_Approved\" name=\"Yes\" sourceRef=\"GwFinalDecision\" targetRef=\"TaskInitiatePaymentFinal\" />\n    <bpmn:sequenceFlow id=\"Flow_18_Rejected\" name=\"No\" sourceRef=\"GwFinalDecision\" targetRef=\"TaskInformRejectedFinal\" />\n\n    <bpmn:sequenceFlow id=\"Flow_19\" sourceRef=\"TaskInitiatePaymentFinal\" targetRef=\"TaskInformApprovedFinal\" />\n    <bpmn:sequenceFlow id=\"Flow_20_EndApprovedFinal\" sourceRef=\"TaskInformApprovedFinal\" targetRef=\"EndCaseClosed\" />\n    <bpmn:sequenceFlow id=\"Flow_21_EndRejectedFinal\" sourceRef=\"TaskInformRejectedFinal\" targetRef=\"EndCaseClosed\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_InsuranceClaim\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_InsuranceClaim\" bpmnElement=\"Collaboration_InsuranceClaim\">\n      <bpmndi:BPMNShape id=\"PoolInsurance_di\" bpmnElement=\"PoolInsurance\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneClaimsHandler_di\" bpmnElement=\"LaneClaimsHandler\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneClaimsSystem_di\" bpmnElement=\"LaneClaimsSystem\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolAssessor_di\" bpmnElement=\"PoolAssessor\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartDamageReport_di\" bpmnElement=\"StartDamageReport\">\n        <dc:Bounds x=\"230\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"200\" y=\"195\" width=\"96\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCreateCase_di\" bpmnElement=\"TaskCreateCase\">\n        <dc:Bounds x=\"330\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckCoverage_di\" bpmnElement=\"TaskCheckCoverage\">\n        <dc:Bounds x=\"490\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwCovered_di\" bpmnElement=\"GwCovered\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"650\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"643\" y=\"202\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformRejectedNotCovered_di\" bpmnElement=\"TaskInformRejectedNotCovered\">\n        <dc:Bounds x=\"820\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckAmount_di\" bpmnElement=\"TaskCheckAmount\">\n        <dc:Bounds x=\"820\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwBelow1500_di\" bpmnElement=\"GwBelow1500\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"990\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"962\" y=\"202\" width=\"106\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskApproveLow_di\" bpmnElement=\"TaskApproveLow\">\n        <dc:Bounds x=\"1160\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInitiatePaymentLow_di\" bpmnElement=\"TaskInitiatePaymentLow\">\n        <dc:Bounds x=\"1320\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformApprovedLow_di\" bpmnElement=\"TaskInformApprovedLow\">\n        <dc:Bounds x=\"1480\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCommissionAssessor_di\" bpmnElement=\"TaskCommissionAssessor\">\n        <dc:Bounds x=\"1160\" y=\"200\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitReport_di\" bpmnElement=\"GwWaitReport\">\n        <dc:Bounds x=\"1325\" y=\"215\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchAssessmentReport_di\" bpmnElement=\"CatchAssessmentReport\">\n        <dc:Bounds x=\"1450\" y=\"162\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1418\" y=\"126\" width=\"100\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskReviewAssessment_di\" bpmnElement=\"TaskReviewAssessment\">\n        <dc:Bounds x=\"1520\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwFinalDecision_di\" bpmnElement=\"GwFinalDecision\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1670\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1662\" y=\"202\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInitiatePaymentFinal_di\" bpmnElement=\"TaskInitiatePaymentFinal\">\n        <dc:Bounds x=\"1840\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformApprovedFinal_di\" bpmnElement=\"TaskInformApprovedFinal\">\n        <dc:Bounds x=\"2000\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformRejectedFinal_di\" bpmnElement=\"TaskInformRejectedFinal\">\n        <dc:Bounds x=\"1840\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchReportDeadline_di\" bpmnElement=\"CatchReportDeadline\">\n        <dc:Bounds x=\"1450\" y=\"252\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1422\" y=\"295\" width=\"92\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskAutoRejectDeadline_di\" bpmnElement=\"TaskAutoRejectDeadline\">\n        <dc:Bounds x=\"1520\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformRejectedDeadline_di\" bpmnElement=\"TaskInformRejectedDeadline\">\n        <dc:Bounds x=\"1680\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndCaseClosed_di\" bpmnElement=\"EndCaseClosed\">\n        <dc:Bounds x=\"2160\" y=\"332\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"2143\" y=\"375\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_1_di\" bpmnElement=\"Flow_1\">\n        <di:waypoint x=\"266\" y=\"170\" />\n        <di:waypoint x=\"330\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_2_di\" bpmnElement=\"Flow_2\">\n        <di:waypoint x=\"430\" y=\"170\" />\n        <di:waypoint x=\"490\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_3_di\" bpmnElement=\"Flow_3\">\n        <di:waypoint x=\"590\" y=\"170\" />\n        <di:waypoint x=\"650\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_4_Covered_di\" bpmnElement=\"Flow_4_Covered\">\n        <di:waypoint x=\"700\" y=\"170\" />\n        <di:waypoint x=\"820\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"742\" y=\"152\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_4_NotCovered_di\" bpmnElement=\"Flow_4_NotCovered\">\n        <di:waypoint x=\"675\" y=\"195\" />\n        <di:waypoint x=\"675\" y=\"330\" />\n        <di:waypoint x=\"820\" y=\"330\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"682\" y=\"250\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_5_EndNotCovered_di\" bpmnElement=\"Flow_5_EndNotCovered\">\n        <di:waypoint x=\"920\" y=\"330\" />\n        <di:waypoint x=\"2178\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_6_di\" bpmnElement=\"Flow_6\">\n        <di:waypoint x=\"920\" y=\"170\" />\n        <di:waypoint x=\"990\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_7_Below_di\" bpmnElement=\"Flow_7_Below\">\n        <di:waypoint x=\"1040\" y=\"170\" />\n        <di:waypoint x=\"1160\" y=\"150\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1068\" y=\"152\" width=\"34\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_7_Above_di\" bpmnElement=\"Flow_7_Above\">\n        <di:waypoint x=\"1015\" y=\"195\" />\n        <di:waypoint x=\"1015\" y=\"240\" />\n        <di:waypoint x=\"1160\" y=\"240\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1021\" y=\"214\" width=\"36\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_8_di\" bpmnElement=\"Flow_8\">\n        <di:waypoint x=\"1260\" y=\"150\" />\n        <di:waypoint x=\"1320\" y=\"150\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_9_di\" bpmnElement=\"Flow_9\">\n        <di:waypoint x=\"1420\" y=\"150\" />\n        <di:waypoint x=\"1480\" y=\"150\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_10_EndApprovedLow_di\" bpmnElement=\"Flow_10_EndApprovedLow\">\n        <di:waypoint x=