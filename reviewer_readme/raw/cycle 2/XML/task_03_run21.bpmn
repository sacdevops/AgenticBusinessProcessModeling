<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolSupervisorHR" name="Supervisor & HR" processRef="Process_SupervisorHR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_SendForApproval" name="Approval request" sourceRef="TaskSendApprovalRequest" targetRef="StartApprovalRequested" />

    <bpmn:messageFlow id="MF_SupervisorFeedback" name="Decision" sourceRef="EndSupervisorFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:messageFlow id="MF_Escalation" name="Escalation" sourceRef="TaskEscalateCase" targetRef="StartEscalationReceived" />
    <bpmn:messageFlow id="MF_HRManagerDecision" name="Decision" sourceRef="EndHRManagerDecision" targetRef="CatchHRManagerDecision" />

    <bpmn:messageFlow id="MF_FinalDecision" name="Decision" sourceRef="EndDecisionSent" targetRef="CatchDecisionReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartNeedVacation" name="Vacation needed">
      <bpmn:outgoing>Flow_E_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E_1</bpmn:incoming>
      <bpmn:outgoing>Flow_E_2</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="CatchDecisionReceived" name="Receive decision">
      <bpmn:incoming>Flow_E_2</bpmn:incoming>
      <bpmn:outgoing>Flow_E_3</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:endEvent id="EndEmployeeInformed" name="Employee informed">
      <bpmn:incoming>Flow_E_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E_1" sourceRef="StartNeedVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E_2" sourceRef="TaskSubmitRequest" targetRef="CatchDecisionReceived" />
    <bpmn:sequenceFlow id="Flow_E_3" sourceRef="CatchDecisionReceived" targetRef="EndEmployeeInformed" />
  </bpmn:process>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequestReceived" />
      <bpmn:outgoing>Flow_P_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_P_1</bpmn:incoming>
      <bpmn:outgoing>Flow_P_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_P_2</bpmn:incoming>
      <bpmn:outgoing>Flow_P_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionNoDays" name="Send rejection">
      <bpmn:incoming>Flow_P_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_4B</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndDecisionSent" name="Decision sent">
      <bpmn:incoming>Flow_P_9A</bpmn:incoming>
      <bpmn:incoming>Flow_P_4B</bpmn:incoming>
      <bpmn:incoming>Flow_P_9C</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndDecisionSent" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendApprovalRequest" name="Send request">
      <bpmn:incoming>Flow_P_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_P_4A</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback" >
      <bpmn:incoming>Flow_P_4A</bpmn:incoming>
      <bpmn:outgoing>Flow_P_5A</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_5B</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorFeedback" name="Feedback received">
      <bpmn:incoming>Flow_P_5A</bpmn:incoming>
      <bpmn:outgoing>Flow_P_6A</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorFeedback" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_P_6A</bpmn:incoming>
      <bpmn:outgoing>Flow_P_7A</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_7B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_P_7A</bpmn:incoming>
      <bpmn:incoming>Flow_P_8A</bpmn:incoming>
      <bpmn:outgoing>Flow_P_9B</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApproval" name="Send approval">
      <bpmn:incoming>Flow_P_9B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_9A</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendRejectionSupervisor" name="Send rejection">
      <bpmn:incoming>Flow_P_7B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_9C</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_P_5B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_6B</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_CatchTimeout" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskEscalateCase" name="Escalate case">
      <bpmn:incoming>Flow_P_6B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_7C</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchHRManagerDecision" name="Decision received">
      <bpmn:incoming>Flow_P_7C</bpmn:incoming>
      <bpmn:outgoing>Flow_P_8B</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchHRManagerDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwHRApproved" name="Approved?">
      <bpmn:incoming>Flow_P_8B</bpmn:incoming>
      <bpmn:outgoing>Flow_P_8A</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_8C</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionHR" name="Send rejection">
      <bpmn:incoming>Flow_P_8C</bpmn:incoming>
      <bpmn:outgoing>Flow_P_9D</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sequenceFlow id="Flow_P_1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_P_2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_P_3A" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApprovalRequest" />
    <bpmn:sequenceFlow id="Flow_P_3B" name="No" sourceRef="GwEnoughDays" targetRef="TaskSendRejectionNoDays" />
    <bpmn:sequenceFlow id="Flow_P_4B" sourceRef="TaskSendRejectionNoDays" targetRef="EndDecisionSent" />

    <bpmn:sequenceFlow id="Flow_P_4A" sourceRef="TaskSendApprovalRequest" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_P_5A" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_P_5B" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />

    <bpmn:sequenceFlow id="Flow_P_6A" sourceRef="CatchSupervisorFeedback" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_P_7A" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P_7B" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskSendRejectionSupervisor" />

    <bpmn:sequenceFlow id="Flow_P_6B" sourceRef="CatchTimeout" targetRef="TaskEscalateCase" />
    <bpmn:sequenceFlow id="Flow_P_7C" sourceRef="TaskEscalateCase" targetRef="CatchHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_P_8B" sourceRef="CatchHRManagerDecision" targetRef="GwHRApproved" />
    <bpmn:sequenceFlow id="Flow_P_8A" name="Yes" sourceRef="GwHRApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P_8C" name="No" sourceRef="GwHRApproved" targetRef="TaskSendRejectionHR" />

    <bpmn:sequenceFlow id="Flow_P_9B" sourceRef="TaskBookVacation" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_P_9A" sourceRef="TaskSendApproval" targetRef="EndDecisionSent" />
    <bpmn:sequenceFlow id="Flow_P_9C" sourceRef="TaskSendRejectionSupervisor" targetRef="EndDecisionSent" />
    <bpmn:sequenceFlow id="Flow_P_9D" sourceRef="TaskSendRejectionHR" targetRef="EndDecisionSent" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisorHR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_SupervisorHR">
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>StartApprovalRequested</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendSupervisorApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendSupervisorRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorFeedback</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>StartEscalationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendHRApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendHRRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndHRManagerDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApprovalRequested" name="Approval requested">
      <bpmn:messageEventDefinition id="MED_StartApprovalRequested" />
      <bpmn:outgoing>Flow_S_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_S_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approve?">
      <bpmn:incoming>Flow_S_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_S_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendSupervisorApproval" name="Send approval">
      <bpmn:incoming>Flow_S_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_S_4A</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendSupervisorRejection" name="Send rejection">
      <bpmn:incoming>Flow_S_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_S_4B</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndSupervisorFeedback" name="Feedback sent">
      <bpmn:incoming>Flow_S_4A</bpmn:incoming>
      <bpmn:incoming>Flow_S_4B</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndSupervisorFeedback" />
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEscalationReceived" name="Escalation received">
      <bpmn:messageEventDefinition id="MED_StartEscalationReceived" />
      <bpmn:outgoing>Flow_H_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewEscalation" name="Review case">
      <bpmn:incoming>Flow_H_1</bpmn:incoming>
      <bpmn:outgoing>Flow_H_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRDecision" name="Approve?">
      <bpmn:incoming>Flow_H_2</bpmn:incoming>
      <bpmn:outgoing>Flow_H_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_H_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendHRApproval" name="Send approval">
      <bpmn:incoming>Flow_H_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_H_4A</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendHRRejection" name="Send rejection">
      <bpmn:incoming>Flow_H_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_H_4B</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndHRManagerDecision" name="Decision sent">
      <bpmn:incoming>Flow_H_4A</bpmn:incoming>
      <bpmn:incoming>Flow_H_4B</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndHRManagerDecision" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S_1" sourceRef="StartApprovalRequested" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_S_2" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S_3A" name="Yes" sourceRef="GwSupervisorDecision" targetRef="TaskSendSupervisorApproval" />
    <bpmn:sequenceFlow id="Flow_S_3B" name="No" sourceRef="GwSupervisorDecision" targetRef="TaskSendSupervisorRejection" />
    <bpmn:sequenceFlow id="Flow_S_4A" sourceRef="TaskSendSupervisorApproval" targetRef="EndSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_S_4B" sourceRef="TaskSendSupervisorRejection" targetRef="EndSupervisorFeedback" />

    <bpmn:sequenceFlow id="Flow_H_1" sourceRef="StartEscalationReceived" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_H_2" sourceRef="TaskReviewEscalation" targetRef="GwHRDecision" />
    <bpmn:sequenceFlow id="Flow_H_3A" name="Yes" sourceRef="GwHRDecision" targetRef="TaskSendHRApproval" />
    <bpmn:sequenceFlow id="Flow_H_3B" name="No" sourceRef="GwHRDecision" targetRef="TaskSendHRRejection" />
    <bpmn:sequenceFlow id="Flow_H_4A" sourceRef="TaskSendHRApproval" targetRef="EndHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_H_4B" sourceRef="TaskSendHRRejection" targetRef="EndHRManagerDecision" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="240" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartNeedVacation_di" bpmnElement="StartNeedVacation">
        <dc:Bounds x="230" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="205" y="225" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="330" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionReceived_di" bpmnElement="CatchDecisionReceived">
        <dc:Bounds x="510" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeInformed_di" bpmnElement="EndEmployeeInformed">
        <dc:Bounds x="690" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="665" y="225" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="370" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="230" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="205" y="565" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="330" y="500" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="500" y="515" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="483" y="572" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalRequest_di" bpmnElement="TaskSendApprovalRequest">
        <dc:Bounds x="610" y="460" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="770" y="475" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorFeedback_di" bpmnElement="CatchSupervisorFeedback">
        <dc:Bounds x="885" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="850" y="399" width="106" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="960" y="425" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="952" y="482" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1080" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproval_di" bpmnElement="TaskSendApproval">
        <dc:Bounds x="1240" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionSupervisor_di" bpmnElement="TaskSendRejectionSupervisor">
        <dc:Bounds x="1080" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout_di" bpmnElement="CatchTimeout">
        <dc:Bounds x="885" y="612" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="852" y="655" width="102" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskEscalateCase_di" bpmnElement="TaskEscalateCase">
        <dc:Bounds x="960" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchHRManagerDecision_di" bpmnElement="CatchHRManagerDecision">
        <dc:Bounds x="1110" y="612" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1074" y="655" width="108" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRApproved_di" bpmnElement="GwHRApproved" isMarkerVisible="true">
        <dc:Bounds x="1185" y="605" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1177" y="662" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionHR_di" bpmnElement="TaskSendRejectionHR">
        <dc:Bounds x="1260" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionNoDays_di" bpmnElement="TaskSendRejectionNoDays">
        <dc:Bounds x="610" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndDecisionSent_di" bpmnElement="EndDecisionSent">
        <dc:Bounds x="1410" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1390" y="565" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolSupervisorHR_di" bpmnElement="PoolSupervisorHR" isHorizontal="true">
        <dc:Bounds x="160" y="780" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="780" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="960" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApprovalRequested_di" bpmnElement="StartApprovalRequested">
        <dc:Bounds x="230" y="852" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="895" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="330" y="830" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="500" y="845" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="499" y="902" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendSupervisorApproval_di" bpmnElement="TaskSendSupervisorApproval">
