        <di:waypoint x="266" y="175" />
        <di:waypoint x="340" y="175" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="175" />
        <di:waypoint x="520" y="175" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="570" y="175" />
        <di:waypoint x="1090" y="175" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="780" y="155" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="545" y="150" />
        <di:waypoint x="545" y="145" />
        <di:waypoint x="650" y="145" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="600" y="125" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

