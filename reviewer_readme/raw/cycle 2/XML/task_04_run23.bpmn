<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolAuthority" name="Building Authority" processRef="Process_Authority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissing" name="Missing docs" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissing" name="Documents" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_RequestOpinion" name="Review request" sourceRef="TaskRequestOpinion" targetRef="PoolEnvAgency" />
    <bpmn:messageFlow id="MF_Opinion" name="Opinion" sourceRef="PoolEnvAgency" targetRef="CatchOpinion" />

    <bpmn:messageFlow id="MF_InformRejectedTimeout" name="Result" sourceRef="EndRejectedTimeout" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejectedEnv" name="Result" sourceRef="EndRejectedEnv" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejectedTech" name="Result" sourceRef="EndRejectedTech" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformApproved" name="Result" sourceRef="EndPermitIssued" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Authority" name="Processing of building permits" isExecutable="false">

    <bpmn:laneSet id="LaneSet_Authority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadlineExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardEnv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOpinionPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardEngineer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedEnv</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndPermitIssued</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedTech</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartApplication" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadlineExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskForwardEnv" name="Forward application">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskRequestOpinion" name="Request opinion">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchOpinion" name="Opinion received">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Opinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwOpinionPositive" name="Positive?">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskForwardEngineer" name="Forward engineer">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechOk" name="OK?">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndPermitIssued" name="Permit issued">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_ResultApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedTimeout" name="Rejected">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_ResultRejectedTimeout" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedEnv" name="Rejected">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_ResultRejectedEnv" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedTech" name="Rejected">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_ResultRejectedTech" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="GwComplete" targetRef="TaskForwardEnv" />
    <bpmn:sequenceFlow id="Flow_4" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="GwWaitDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="GwWaitDocs" targetRef="CatchDeadlineExceeded" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="CatchMissingDocs" targetRef="TaskForwardEnv" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchDeadlineExceeded" targetRef="EndRejectedTimeout" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskForwardEnv" targetRef="TaskRequestOpinion" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskRequestOpinion" targetRef="CatchOpinion" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="CatchOpinion" targetRef="GwOpinionPositive" />
    <bpmn:sequenceFlow id="Flow_13" name="Yes" sourceRef="GwOpinionPositive" targetRef="TaskForwardEngineer" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="GwOpinionPositive" targetRef="EndRejectedEnv" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskForwardEngineer" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskCheckTechnical" targetRef="GwTechOk" />
    <bpmn:sequenceFlow id="Flow_17" name="Yes" sourceRef="GwTechOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_18" name="No" sourceRef="GwTechOk" targetRef="EndRejectedTech" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="TaskIssuePermit" targetRef="EndPermitIssued" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolAuthority_di" bpmnElement="PoolAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="380" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="270" width="1500" height="190" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEnvAgency_di" bpmnElement="PoolEnvAgency" isHorizontal="true">
        <dc:Bounds x="160" y="620" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
