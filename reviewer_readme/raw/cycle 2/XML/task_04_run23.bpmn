        <di:waypoint x="440" y="365" />
        <di:waypoint x="520" y="365" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_di" bpmnElement="Flow_17">
        <di:waypoint x="570" y="365" />
        <di:waypoint x="650" y="340" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="600" y="330" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_18_di" bpmnElement="Flow_18">
