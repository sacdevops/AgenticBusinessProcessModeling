          <dc:Bounds x="915" y="262" width="106" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardEnv_di" bpmnElement="TaskForwardEnv">
        <dc:Bounds x="1090" y="135" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestOpinion_di" bpmnElement="TaskRequestOpinion">
        <dc:Bounds x="1240" y="135" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchOpinion_di" bpmnElement="CatchOpinion">
        <dc:Bounds x="1400" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1372" y="196" width="92" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOpinionPositive_di" bpmnElement="GwOpinionPositive" isMarkerVisible="true">
        <dc:Bounds x="1495" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1485" y="205" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardEngineer_di" bpmnElement="TaskForwardEngineer">
        <dc:Bounds x="1580" y="255" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="340" y="325" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechOk_di" bpmnElement="GwTechOk" isMarkerVisible="true">
        <dc:Bounds x="520" y="340" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="530" y="395" width="30" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="650" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndPermitIssued_di" bpmnElement="EndPermitIssued">
        <dc:Bounds x="820" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="362" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedTimeout_di" bpmnElement="EndRejectedTimeout">
        <dc:Bounds x="1090" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1083" y="262" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedEnv_di" bpmnElement="EndRejectedEnv">
        <dc:Bounds x="1580" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1573" y="196" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedTech_di" bpmnElement="EndRejectedTech">
        <dc:Bounds x="820" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="813" y="442" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

