        <bpmndi:BPMNLabel>
          <dc:Bounds x="650" y="400" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_19_di" bpmnElement="Flow_19">
        <di:waypoint x="750" y="340" />
        <di:waypoint x="820" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitApplication_di" bpmnElement="MF_SubmitApplication">
        <di:waypoint x="520" y="510" />
        <di:waypoint x="520" y="60" />
        <di:waypoint x="248" y="60" />
        <di:waypoint x="248" y="157" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestMissing_di" bpmnElement="MF_RequestMissing">
        <di:waypoint x="700" y="105" />
        <di:waypoint x="700" y="510" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitMissing_di" bpmnElement="MF_SubmitMissing">
        <di:waypoint x="840" y="510" />
        <di:waypoint x="840" y="120" />
        <di:waypoint x="950" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestOpinion_di" bpmnElement="MF_RequestOpinion">
        <di:waypoint x="1290" y="215" />
