        <di:waypoint x="545" y="145" />
        <di:waypoint x="545" y="130" />
        <di:waypoint x="640" y="130" />
        <bpmndi:BPMNLabel><dc:Bounds x="570" y="118" width="18" height="14" /></bpmndi:BPMNLabel>
