      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="800" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorResponse_di" bpmnElement="CatchSupervisorResponse">
        <dc:Bounds x="930" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="95" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

