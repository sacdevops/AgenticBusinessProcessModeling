        <di:waypoint x="1420" y="120" />
        <di:waypoint x="1480" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1260" y="210" />
