        <bpmndi:BPMNLabel><dc:Bounds x="1378" y="326" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_20_di" bpmnElement="Flow_20">
        <di:waypoint x="1370" y="350" />
        <di:waypoint x="1370" y="410" />
        <di:waypoint x="1410" y="410" />
