<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolEmployee" name="Employee" />
    <bpmn:participant id="PoolSupervisor" name="Direct Supervisor" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="PoolEmployee" targetRef="StartRequestSubmitted" />
    <bpmn:messageFlow id="MF_RequestApproval" name="Approval" sourceRef="TaskSendApproval" targetRef="PoolSupervisor" />
    <bpmn:messageFlow id="MF_SupervisorResponse" name="Response" sourceRef="PoolSupervisor" targetRef="CatchSupervisorResponse" />

    <bpmn:messageFlow id="MF_NotifyNoDays" name="Rejected" sourceRef="TaskNotifyNoDays" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyRejectedSup" name="Rejected" sourceRef="TaskNotifyRejectedSup" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyRejectedHR" name="Rejected" sourceRef="TaskNotifyRejectedHR" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyApproved" name="Approved" sourceRef="TaskNotifyApproved" targetRef="PoolEmployee" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" name="Vacation Request Process" isExecutable="false">

    <bpmn:laneSet id="LaneSet_HRPortal">
      <bpmn:lane id="LanePortalAutomation" name="Portal Automation">
        <bpmn:flowNodeRef>StartRequestSubmitted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch5Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacationSup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejectedSup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowEscalate</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskHRDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacationHR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskNotifyRejectedHR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedHR</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestSubmitted" name="Request submitted">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?" isMarkerVisible="true">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskNotifyNoDays" name="Notify rejection">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedNoDays" name="Rejected">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendApproval" name="Request approval">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorResponse" name="Response received">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorResponse" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch5Days" name="5 days">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacationSup" name="Book vacation">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskNotifyApproved" name="Notify approval">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskNotifyRejectedSup" name="Notify rejection">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedSup" name="Rejected">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="ThrowEscalate" name="Escalated">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SED_Escalated" />
    </bpmn:intermediateThrowEvent>

    <bpmn:userTask id="TaskHRDecision" name="Make decision">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacationHR" name="Book vacation">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskNotifyRejectedHR" name="Notify rejection">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedHR" name="Rejected">
      <bpmn:incoming>Flow_21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartRequestSubmitted" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_3" name="No" sourceRef="GwEnoughDays" targetRef="TaskNotifyNoDays" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskNotifyNoDays" targetRef="EndRejectedNoDays" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskSendApproval" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorResponse" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="GwWaitFeedback" targetRef="Catch5Days" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchSupervisorResponse" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Catch5Days" targetRef="ThrowEscalate" />
    <bpmn:sequenceFlow id="Flow_11" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacationSup" />
    <bpmn:sequenceFlow id="Flow_12" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskNotifyRejectedSup" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskBookVacationSup" targetRef="TaskNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskNotifyApproved" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskNotifyRejectedSup" targetRef="EndRejectedSup" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="ThrowEscalate" targetRef="TaskHRDecision" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="TaskBookVacationHR" targetRef="TaskNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="TaskHRDecision" targetRef="GwHRApproved" />
    <bpmn:sequenceFlow id="Flow_19" name="Yes" sourceRef="GwHRApproved" targetRef="TaskBookVacationHR" />
    <bpmn:sequenceFlow id="Flow_20" name="No" sourceRef="GwHRApproved" targetRef="TaskNotifyRejectedHR" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="TaskNotifyRejectedHR" targetRef="EndRejectedHR" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

