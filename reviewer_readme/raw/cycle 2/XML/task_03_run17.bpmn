      <bpmndi:BPMNShape id="TaskNotifyRejectedSup_di" bpmnElement="TaskNotifyRejectedSup">
        <dc:Bounds x="1160" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSup_di" bpmnElement="EndRejectedSup">
        <dc:Bounds x="1480" y="192" width="36" height="36" />
