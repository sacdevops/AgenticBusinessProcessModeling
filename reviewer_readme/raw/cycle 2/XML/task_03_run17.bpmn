        <dc:Bounds x="1048" y="334" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1035" y="377" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskHRDecision_di" bpmnElement="TaskHRDecision">
        <dc:Bounds x="1160" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRApproved_di" bpmnElement="GwHRApproved" isMarkerVisible="true">
        <dc:Bounds x="1320" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1308" y="382" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacationHR_di" bpmnElement="TaskBookVacationHR">
        <dc:Bounds x="1410" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejectedHR_di" bpmnElement="TaskNotifyRejectedHR">
        <dc:Bounds x="1410" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHR_di" bpmnElement="EndRejectedHR">
        <dc:Bounds x="1560" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1550" y="435" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="276" y="170" />
        <di:waypoint x="360" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="460" y="170" />
        <di:waypoint x="520" y="170" />
      </bpmndi:BPMNEdge>
