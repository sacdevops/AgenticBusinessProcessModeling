        <di:waypoint x="1170" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BA_15_di" bpmnElement="Flow_BA_15">
        <di:waypoint x="1220" y="340" />
