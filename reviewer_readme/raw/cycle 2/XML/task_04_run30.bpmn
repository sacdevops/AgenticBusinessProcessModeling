<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits_1" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolBuildingAuthority" name="Building Authority" processRef="Process_BuildingAuthority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" processRef="Process_Citizen" />
    <bpmn:participant id="PoolEnvironmentalAgency" name="Environmental Agency" processRef="Process_EnvironmentalAgency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissing" name="Missing docs" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissing" name="Missing docs" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_SendToEnv" name="Application" sourceRef="TaskSendToEnvAgency" targetRef="StartEnvReview" />
    <bpmn:messageFlow id="MF_EnvOpinion" name="Opinion" sourceRef="EndSendOpinion" targetRef="CatchEnvOpinion" />

    <bpmn:messageFlow id="MF_InformApproved" name="Approved" sourceRef="EndInformApproved" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejected" name="Rejected" sourceRef="EndInformRejected" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_BuildingAuthority" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BuildingAuthority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitMissing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToEnvAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnvPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskPrepareRejectionEnv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskPrepareRejectionTech</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:messageEventDefinition id="MED_StartApplication" />
      <bpmn:outgoing>Flow_BA_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_BA_1</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?" isMarkerVisible="true">
      <bpmn:incoming>Flow_BA_2</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_BA_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_BA_4</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitMissing">
      <bpmn:incoming>Flow_BA_5</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_BA_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_BA_6</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="14 days exceeded">
      <bpmn:incoming>Flow_BA_7</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendToEnvAgency" name="Send for review">
      <bpmn:incoming>Flow_BA_3</bpmn:incoming>
      <bpmn:incoming>Flow_BA_8</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchEnvOpinion" name="Opinion received">
      <bpmn:incoming>Flow_BA_10</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_EnvOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwEnvPositive" name="Positive?" isMarkerVisible="true">
      <bpmn:incoming>Flow_BA_11</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_BA_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_BA_12</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechOk" name="OK?" isMarkerVisible="true">
      <bpmn:incoming>Flow_BA_14</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_BA_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_BA_15</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskPrepareRejectionTech" name="Prepare rejection">
      <bpmn:incoming>Flow_BA_16</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskPrepareRejectionEnv" name="Prepare rejection">
      <bpmn:incoming>Flow_BA_13</bpmn:incoming>
      <bpmn:outgoing>Flow_BA_19</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndInformApproved" name="Result sent">
      <bpmn:incoming>Flow_BA_17</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_InformApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejected" name="Result sent">
      <bpmn:incoming>Flow_BA_9</bpmn:incoming>
      <bpmn:incoming>Flow_BA_18</bpmn:incoming>
      <bpmn:incoming>Flow_BA_19</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_InformRejected" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_BA_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_BA_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />
    <bpmn:sequenceFlow id="Flow_BA_3" name="Yes" sourceRef="GwComplete" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_BA_4" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_BA_5" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitMissing" />
    <bpmn:sequenceFlow id="Flow_BA_6" sourceRef="GwWaitMissing" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_BA_7" sourceRef="GwWaitMissing" targetRef="CatchDeadline" />
    <bpmn:sequenceFlow id="Flow_BA_8" sourceRef="CatchMissingDocs" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_BA_9" sourceRef="CatchDeadline" targetRef="EndInformRejected" />
    <bpmn:sequenceFlow id="Flow_BA_10" sourceRef="TaskSendToEnvAgency" targetRef="CatchEnvOpinion" />
    <bpmn:sequenceFlow id="Flow_BA_11" sourceRef="CatchEnvOpinion" targetRef="GwEnvPositive" />
    <bpmn:sequenceFlow id="Flow_BA_12" name="Yes" sourceRef="GwEnvPositive" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_BA_13" name="No" sourceRef="GwEnvPositive" targetRef="TaskPrepareRejectionEnv" />
    <bpmn:sequenceFlow id="Flow_BA_14" sourceRef="TaskCheckTechnical" targetRef="GwTechOk" />
    <bpmn:sequenceFlow id="Flow_BA_15" name="Yes" sourceRef="GwTechOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_BA_16" name="No" sourceRef="GwTechOk" targetRef="TaskPrepareRejectionTech" />
    <bpmn:sequenceFlow id="Flow_BA_17" sourceRef="TaskIssuePermit" targetRef="EndInformApproved" />
    <bpmn:sequenceFlow id="Flow_BA_18" sourceRef="TaskPrepareRejectionTech" targetRef="EndInformRejected" />
    <bpmn:sequenceFlow id="Flow_BA_19" sourceRef="TaskPrepareRejectionEnv" targetRef="EndInformRejected" />
  </bpmn:process>

  <bpmn:process id="Process_Citizen" isExecutable="false" />

  <bpmn:process id="Process_EnvironmentalAgency" isExecutable="false">
    <bpmn:startEvent id="StartEnvReview" name="Application received">
      <bpmn:messageEventDefinition id="MED_StartEnv" />
      <bpmn:outgoing>Flow_EA_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewEnv" name="Review application">
      <bpmn:incoming>Flow_EA_1</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwOpinion" name="Positive?" isMarkerVisible="true">
      <bpmn:incoming>Flow_EA_2</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_EA_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndSendOpinion" name="Opinion sent">
      <bpmn:incoming>Flow_EA_3</bpmn:incoming>
      <bpmn:incoming>Flow_EA_4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_SendOpinion" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_EA_1" sourceRef="StartEnvReview" targetRef="TaskReviewEnv" />
    <bpmn:sequenceFlow id="Flow_EA_2" sourceRef="TaskReviewEnv" targetRef="GwOpinion" />
    <bpmn:sequenceFlow id="Flow_EA_3" name="Yes" sourceRef="GwOpinion" targetRef="EndSendOpinion" />
    <bpmn:sequenceFlow id="Flow_EA_4" name="No" sourceRef="GwOpinion" targetRef="EndSendOpinion" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolBuildingAuthority_di" bpmnElement="PoolBuildingAuthority" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
