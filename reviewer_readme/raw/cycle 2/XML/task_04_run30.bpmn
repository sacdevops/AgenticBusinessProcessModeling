        <di:waypoint x="886" y="170" />
        <di:waypoint x="1460" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BA_10_di" bpmnElement="Flow_BA_10">
        <di:waypoint x="740" y="260" />
        <di:waypoint x="800" y="260" />
      </bpmndi:BPMNEdge>
