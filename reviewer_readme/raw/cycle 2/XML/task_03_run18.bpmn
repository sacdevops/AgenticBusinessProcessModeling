<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="StartPortal" targetRef="StartSupervisor" />
    <bpmn:messageFlow id="MF_ApprovalRequest" name="Approval" sourceRef="TaskSendToSupervisor" targetRef="TaskReviewRequest" />

    <bpmn:messageFlow id="MF_SupervisorApproved" name="Approved" sourceRef="TaskApprove" targetRef="CatchSupervisorApproved" />
    <bpmn:messageFlow id="MF_SupervisorRejected" name="Rejected" sourceRef="TaskReject" targetRef="CatchSupervisorRejected" />

    <bpmn:messageFlow id="MF_Escalation" name="Escalation" sourceRef="TaskEscalate" targetRef="TaskManagerReview" />
    <bpmn:messageFlow id="MF_ManagerApproved" name="Approved" sourceRef="TaskManagerApprove" targetRef="CatchManagerApproved" />
    <bpmn:messageFlow id="MF_ManagerRejected" name="Rejected" sourceRef="TaskManagerReject" targetRef="CatchManagerRejected" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:startEvent id="StartPortal" name="Request submitted">
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:outgoing>Flow_P3</bpmn:outgoing>
      <bpmn:outgoing>Flow_P4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectInsufficient" name="Send rejection">
      <bpmn:incoming>Flow_P4</bpmn:incoming>
      <bpmn:outgoing>Flow_P5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedInsufficient" name="Rejected">
      <bpmn:incoming>Flow_P5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Send request">
      <bpmn:incoming>Flow_P3</bpmn:incoming>
      <bpmn:outgoing>Flow_P6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_P6</bpmn:incoming>
      <bpmn:outgoing>Flow_P7</bpmn:outgoing>
      <bpmn:outgoing>Flow_P8</bpmn:outgoing>
      <bpmn:outgoing>Flow_P9</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorApproved" name="Approval received">
      <bpmn:incoming>Flow_P7</bpmn:incoming>
      <bpmn:outgoing>Flow_P10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchSupervisorRejected" name="Rejection received">
      <bpmn:incoming>Flow_P8</bpmn:incoming>
      <bpmn:outgoing>Flow_P11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days elapsed">
      <bpmn:incoming>Flow_P9</bpmn:incoming>
      <bpmn:outgoing>Flow_P12</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskEscalate" name="Send escalation">
      <bpmn:incoming>Flow_P12</bpmn:incoming>
      <bpmn:outgoing>Flow_P13</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitManager">
      <bpmn:incoming>Flow_P13</bpmn:incoming>
      <bpmn:outgoing>Flow_P14</bpmn:outgoing>
      <bpmn:outgoing>Flow_P15</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchManagerApproved" name="Approval received">
      <bpmn:incoming>Flow_P14</bpmn:incoming>
      <bpmn:outgoing>Flow_P16</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MgrApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchManagerRejected" name="Rejection received">
      <bpmn:incoming>Flow_P15</bpmn:incoming>
      <bpmn:outgoing>Flow_P17</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MgrRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_P10</bpmn:incoming>
      <bpmn:incoming>Flow_P16</bpmn:incoming>
      <bpmn:outgoing>Flow_P18</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApproval" name="Send approval">
      <bpmn:incoming>Flow_P18</bpmn:incoming>
      <bpmn:outgoing>Flow_P19</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_P19</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectSupervisor" name="Send rejection">
      <bpmn:incoming>Flow_P11</bpmn:incoming>
      <bpmn:outgoing>Flow_P20</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Rejected">
      <bpmn:incoming>Flow_P20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectManager" name="Send rejection">
      <bpmn:incoming>Flow_P17</bpmn:incoming>
      <bpmn:outgoing>Flow_P21</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedManager" name="Rejected">
      <bpmn:incoming>Flow_P21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_P1" sourceRef="StartPortal" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_P3" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_P4" name="No" sourceRef="GwEnoughDays" targetRef="TaskSendRejectInsufficient" />
    <bpmn:sequenceFlow id="Flow_P5" sourceRef="TaskSendRejectInsufficient" targetRef="EndRejectedInsufficient" />
    <bpmn:sequenceFlow id="Flow_P6" sourceRef="TaskSendToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_P7" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_P8" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_P9" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />
    <bpmn:sequenceFlow id="Flow_P10" sourceRef="CatchSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P11" sourceRef="CatchSupervisorRejected" targetRef="TaskSendRejectSupervisor" />
    <bpmn:sequenceFlow id="Flow_P12" sourceRef="CatchTimeout" targetRef="TaskEscalate" />
    <bpmn:sequenceFlow id="Flow_P13" sourceRef="TaskEscalate" targetRef="GwWaitManager" />
    <bpmn:sequenceFlow id="Flow_P14" sourceRef="GwWaitManager" targetRef="CatchManagerApproved" />
    <bpmn:sequenceFlow id="Flow_P15" sourceRef="GwWaitManager" targetRef="CatchManagerRejected" />
    <bpmn:sequenceFlow id="Flow_P16" sourceRef="CatchManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P17" sourceRef="CatchManagerRejected" targetRef="TaskSendRejectManager" />
    <bpmn:sequenceFlow id="Flow_P18" sourceRef="TaskBookVacation" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_P19" sourceRef="TaskSendApproval" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_P20" sourceRef="TaskSendRejectSupervisor" targetRef="EndRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_P21" sourceRef="TaskSendRejectManager" targetRef="EndRejectedManager" />
  </bpmn:process>

  <bpmn:process id="Process_Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>StartSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReject</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskManagerReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwManagerDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskManagerApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskManagerReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCompanyDone</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartSupervisor" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartSup" />
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approved?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskApprove" name="Send approval">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskReject" name="Send rejection">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:userTask id="TaskManagerReview" name="Review request">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwManagerDecision" name="Approved?">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskManagerApprove" name="Send approval">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskManagerReject" name="Send rejection">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndCompanyDone" name="Done">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:incoming>Flow_C12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartSupervisor" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwSupervisorDecision" targetRef="TaskApprove" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwSupervisorDecision" targetRef="TaskReject" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskApprove" targetRef="EndCompanyDone" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="TaskReject" targetRef="EndCompanyDone" />

    <bpmn:sequenceFlow id="Flow_C7" sourceRef="StartSupervisor" targetRef="TaskManagerReview" />

    <bpmn:sequenceFlow id="Flow_C8" sourceRef="TaskManagerReview" targetRef="GwManagerDecision" />
    <bpmn:sequenceFlow id="Flow_C9" name="Yes" sourceRef="GwManagerDecision" targetRef="TaskManagerApprove" />
    <bpmn:sequenceFlow id="Flow_C10" name="No" sourceRef="GwManagerDecision" targetRef="TaskManagerReject" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="TaskManagerApprove" targetRef="EndCompanyDone" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskManagerReject" targetRef="EndCompanyDone" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartPortal_di" bpmnElement="StartPortal">
        <dc:Bounds x="220" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="275" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckDays_di" bpmnElement="TaskCheckDays">
        <dc:Bounds x="320" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="480" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="462" y="282" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectInsufficient_di" bpmnElement="TaskSendRejectInsufficient">
        <dc:Bounds x="600" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedInsufficient_di" bpmnElement="EndRejectedInsufficient">
        <dc:Bounds x="780" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="762" y="175" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToSupervisor_di" bpmnElement="TaskSendToSupervisor">
        <dc:Bounds x="600" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="760" y="305" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorApproved_di" bpmnElement="CatchSupervisorApproved">
        <dc:Bounds x="900" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="146" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorRejected_di" bpmnElement="CatchSupervisorRejected">
        <dc:Bounds x="900" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="305" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout_di" bpmnElement="CatchTimeout">
        <dc:Bounds x="900" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="872" y="385" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskEscalate_di" bpmnElement="TaskEscalate">
        <dc:Bounds x="1040" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitManager_di" bpmnElement="GwWaitManager">
        <dc:Bounds x="1200" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchManagerApproved_di" bpmnElement="CatchManagerApproved">
        <dc:Bounds x="1340" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1310" y="266" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchManagerRejected_di" bpmnElement="CatchManagerRejected">
        <dc:Bounds x="1340" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1310" y="425" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1100" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproval_di" bpmnElement="TaskSendApproval">
        <dc:Bounds x="1260" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1420" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1404" y="235" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectSupervisor_di" bpmnElement="TaskSendRejectSupervisor">
        <dc:Bounds x="1100" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisor_di" bpmnElement="EndRejectedSupervisor">
        <dc:Bounds x="1260" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1244" y="315" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectManager_di" bpmnElement="TaskSendRejectManager">
        <dc:Bounds x="1480" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedManager_di" bpmnElement="EndRejectedManager">
        <dc:Bounds x="1600" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1584" y="425" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="490" width="1500" height="320" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="160" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="650" width="1500" height="160" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartSupervisor_di" bpmnElement="StartSupervisor">
        <dc:Bounds x="220" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="194" y="595" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="320" y="530" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="480" y="545" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="474" y="602" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApprove_di" bpmnElement="TaskApprove">
        <dc:Bounds x="600" y="500" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReject_di" bpmnElement="TaskReject">
        <dc:Bounds x="600" y="600" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManagerReview_di" bpmnElement="TaskManagerReview">
        <dc:Bounds x="1040" y="690" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwManagerDecision_di" bpmnElement="GwManagerDecision" isMarkerVisible="true">
        <dc:Bounds x="1200" y="705" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1194" y="762" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManagerApprove_di" bpmnElement="TaskManagerApprove">
        <dc:Bounds x="1340" y="670" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManagerReject_di" bpmnElement="TaskManagerReject">
        <dc:Bounds x="1340" y="750" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCompanyDone_di" bpmnElement="EndCompanyDone">
        <dc:Bounds x="1520" y="712" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1510" y="755" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <di:waypoint x="256" y="250" />
        <di:waypoint x="320" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <di:waypoint x="420" y="250" />
        <di:waypoint x="480" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P3_di" bpmnElement="Flow_P3">
