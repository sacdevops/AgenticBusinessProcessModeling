<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolAuthority" name="Building authority" processRef="Process_Authority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvAgency" name="Environmental agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissing" name="Missing docs" sourceRef="TaskRequestMissingDocuments" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissing" name="Documents" sourceRef="PoolCitizen" targetRef="CatchMissingDocumentsReceived" />

    <bpmn:messageFlow id="MF_SendToEnv" name="Application" sourceRef="TaskSendToEnvironmentalAgency" targetRef="PoolEnvAgency" />
    <bpmn:messageFlow id="MF_EnvFeedback" name="Opinion" sourceRef="PoolEnvAgency" targetRef="CatchEnvironmentalOpinion" />

    <bpmn:messageFlow id="MF_InformApproval" name="Permit" sourceRef="TaskInformCitizenApproval" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejection" name="Rejection" sourceRef="TaskInformCitizenRejection" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Authority" isExecutable="false">

    <bpmn:laneSet id="LaneSet_Authority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwDocumentsComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocumentsReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDocsDeadlineExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToEnvironmentalAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvironmentalOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnvironmentalPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectAfterEnv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectNoDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformCitizenApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformCitizenRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndPermitIssued</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApplicationRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test engineer">
        <bpmn:flowNodeRef>TaskCheckTechnicalDetails</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechnicalOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectAfterTechnical</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:messageEventDefinition id="MED_StartApplication" />
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwDocumentsComplete" name="Complete?">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:outgoing>Flow_A3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_A3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocuments" name="Request documents">
      <bpmn:incoming>Flow_A3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_A4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs">
      <bpmn:incoming>Flow_A4</bpmn:incoming>
      <bpmn:outgoing>Flow_A5_Msg</bpmn:outgoing>
      <bpmn:outgoing>Flow_A5_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocumentsReceived" name="Documents received">
      <bpmn:incoming>Flow_A5_Msg</bpmn:incoming>
      <bpmn:outgoing>Flow_A6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDocsDeadlineExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_A5_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_A7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskRejectNoDocs" name="Reject application">
      <bpmn:incoming>Flow_A7</bpmn:incoming>
      <bpmn:outgoing>Flow_A8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskInformCitizenRejection" name="Inform citizen">
      <bpmn:incoming>Flow_A8</bpmn:incoming>
      <bpmn:incoming>Flow_A14</bpmn:incoming>
      <bpmn:incoming>Flow_A19</bpmn:incoming>
      <bpmn:outgoing>Flow_A20</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApplicationRejected" name="Application rejected">
      <bpmn:incoming>Flow_A20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendToEnvironmentalAgency" name="Send to agency">
      <bpmn:incoming>Flow_A3_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_A6</bpmn:incoming>
      <bpmn:outgoing>Flow_A9</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchEnvironmentalOpinion" name="Opinion received">
      <bpmn:incoming>Flow_A9</bpmn:incoming>
      <bpmn:outgoing>Flow_A10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_EnvOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwEnvironmentalPositive" name="Positive?">
      <bpmn:incoming>Flow_A10</bpmn:incoming>
      <bpmn:outgoing>Flow_A11_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_A11_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskRejectAfterEnv" name="Reject application">
      <bpmn:incoming>Flow_A11_No</bpmn:incoming>
      <bpmn:outgoing>Flow_A14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckTechnicalDetails" name="Check technical">
      <bpmn:incoming>Flow_A11_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_A15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechnicalOk" name="Approved?">
      <bpmn:incoming>Flow_A15</bpmn:incoming>
      <bpmn:outgoing>Flow_A16_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_A16_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_A16_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_A17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskInformCitizenApproval" name="Inform citizen">
      <bpmn:incoming>Flow_A17</bpmn:incoming>
      <bpmn:outgoing>Flow_A18</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndPermitIssued" name="Permit issued">
      <bpmn:incoming>Flow_A18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskRejectAfterTechnical" name="Reject application">
      <bpmn:incoming>Flow_A16_No</bpmn:incoming>
      <bpmn:outgoing>Flow_A19</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="TaskCheckCompleteness" targetRef="GwDocumentsComplete" />
    <bpmn:sequenceFlow id="Flow_A3_Yes" name="Yes" sourceRef="GwDocumentsComplete" targetRef="TaskSendToEnvironmentalAgency" />
    <bpmn:sequenceFlow id="Flow_A3_No" name="No" sourceRef="GwDocumentsComplete" targetRef="TaskRequestMissingDocuments" />
    <bpmn:sequenceFlow id="Flow_A4" sourceRef="TaskRequestMissingDocuments" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_A5_Msg" sourceRef="GwWaitDocs" targetRef="CatchMissingDocumentsReceived" />
    <bpmn:sequenceFlow id="Flow_A5_Timer" sourceRef="GwWaitDocs" targetRef="CatchDocsDeadlineExceeded" />
    <bpmn:sequenceFlow id="Flow_A6" sourceRef="CatchMissingDocumentsReceived" targetRef="TaskSendToEnvironmentalAgency" />
    <bpmn:sequenceFlow id="Flow_A7" sourceRef="CatchDocsDeadlineExceeded" targetRef="TaskRejectNoDocs" />
    <bpmn:sequenceFlow id="Flow_A8" sourceRef="TaskRejectNoDocs" targetRef="TaskInformCitizenRejection" />
    <bpmn:sequenceFlow id="Flow_A9" sourceRef="TaskSendToEnvironmentalAgency" targetRef="CatchEnvironmentalOpinion" />
    <bpmn:sequenceFlow id="Flow_A10" sourceRef="CatchEnvironmentalOpinion" targetRef="GwEnvironmentalPositive" />
    <bpmn:sequenceFlow id="Flow_A11_Yes" name="Yes" sourceRef="GwEnvironmentalPositive" targetRef="TaskCheckTechnicalDetails" />
    <bpmn:sequenceFlow id="Flow_A11_No" name="No" sourceRef="GwEnvironmentalPositive" targetRef="TaskRejectAfterEnv" />
    <bpmn:sequenceFlow id="Flow_A14" sourceRef="TaskRejectAfterEnv" targetRef="TaskInformCitizenRejection" />
    <bpmn:sequenceFlow id="Flow_A15" sourceRef="TaskCheckTechnicalDetails" targetRef="GwTechnicalOk" />
    <bpmn:sequenceFlow id="Flow_A16_Yes" name="Yes" sourceRef="GwTechnicalOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_A16_No" name="No" sourceRef="GwTechnicalOk" targetRef="TaskRejectAfterTechnical" />
    <bpmn:sequenceFlow id="Flow_A17" sourceRef="TaskIssuePermit" targetRef="TaskInformCitizenApproval" />
    <bpmn:sequenceFlow id="Flow_A18" sourceRef="TaskInformCitizenApproval" targetRef="EndPermitIssued" />
    <bpmn:sequenceFlow id="Flow_A19" sourceRef="TaskRejectAfterTechnical" targetRef="TaskInformCitizenRejection" />
    <bpmn:sequenceFlow id="Flow_A20" sourceRef="TaskInformCitizenRejection" targetRef="EndApplicationRejected" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolAuthority_di" bpmnElement="PoolAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEnvAgency_di" bpmnElement="PoolEnvAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="230" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="195" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwDocumentsComplete_di" bpmnElement="GwDocumentsComplete" isMarkerVisible="true">
        <dc:Bounds x="500" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="500" y="202" width="65" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToEnvironmentalAgency_di" bpmnElement="TaskSendToEnvironmentalAgency">
        <dc:Bounds x="620" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchEnvironmentalOpinion_di" bpmnElement="CatchEnvironmentalOpinion">
        <dc:Bounds x="790" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="760" y="60" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnvironmentalPositive_di" bpmnElement="GwEnvironmentalPositive" isMarkerVisible="true">
        <dc:Bounds x="890" y="85" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="882" y="60" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectAfterEnv_di" bpmnElement="TaskRejectAfterEnv">
        <dc:Bounds x="1010" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocuments_di" bpmnElement="TaskRequestMissingDocuments">
        <dc:Bounds x="620" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDocs_di" bpmnElement="GwWaitDocs">
        <dc:Bounds x="790" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocumentsReceived_di" bpmnElement="CatchMissingDocumentsReceived">
        <dc:Bounds x="900" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="110" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDocsDeadlineExceeded_di" bpmnElement="CatchDocsDeadlineExceeded">
        <dc:Bounds x="900" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="862" y="275" width="112" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectNoDocs_di" bpmnElement="TaskRejectNoDocs">
        <dc:Bounds x="1010" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnicalDetails_di" bpmnElement="TaskCheckTechnicalDetails">
        <dc:Bounds x="1010" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechnicalOk_di" bpmnElement="GwTechnicalOk" isMarkerVisible="true">
        <dc:Bounds x="1180" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1168" y="372" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1300" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformCitizenApproval_di" bpmnElement="TaskInformCitizenApproval">
        <dc:Bounds x="1450" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndPermitIssued_di" bpmnElement="EndPermitIssued">
        <dc:Bounds x="1600" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1578" y="335" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectAfterTechnical_di" bpmnElement="TaskRejectAfterTechnical">
        <dc:Bounds x="1300" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformCitizenRejection_di" bpmnElement="TaskInformCitizenRejection">
        <dc:Bounds x="1450" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApplicationRejected_di" bpmnElement="EndApplicationRejected">
        <dc:Bounds x="1600" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1568" y="435" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1">
        <di:waypoint x="266" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A2_di" bpmnElement="Flow_A2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A3_Yes_di" bpmnElement="Flow_A3_Yes">
        <di:waypoint x="525" y="145" />
        <di:waypoint x="525" y="110" />
        <di:waypoint x="620" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="540" y="118" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A3_No_di" bpmnElement="Flow_A3_No">
        <di:waypoint x="550" y="170" />
        <di:waypoint x="620" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="570" y="195" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A4_di" bpmnElement="Flow_A4">
        <di:waypoint x="720" y="210" />
        <di:waypoint x="790" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A5_Msg_di" bpmnElement="Flow_A5_Msg">
        <di:waypoint x="815" y="185" />
        <di:waypoint x="815" y="150" />
        <di:waypoint x="900" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A5_Timer_di" bpmnElement="Flow_A5_Timer">
        <di:waypoint x="815" y="235" />
        <di:waypoint x="815" y="250" />
        <di:waypoint x="900" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A6_di" bpmnElement="Flow_A6">
        <di:waypoint x="936" y="150" />
        <di:waypoint x="970" y="150" />
        <di:waypoint x="970" y="110" />
        <di:waypoint x="620" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A7_di" bpmnElement="Flow_A7">
        <di:waypoint x="936" y="250" />
        <di:waypoint x="1010" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A8_di" bpmnElement="Flow_A8">
        <di:waypoint x="1110" y="250" />
        <di:waypoint x="1410" y="250" />
        <di:waypoint x="1410" y="410" />
        <di:waypoint x="1450" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A9_di" bpmnElement="Flow_A9">
        <di:waypoint x="720" y="110" />
        <di:waypoint x="790" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A10_di" bpmnElement="Flow_A10">
        <di:waypoint x="826" y="110" />
        <di:waypoint x="890" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A11_Yes_di" bpmnElement="Flow_A11_Yes">
        <di:waypoint x="915" y="135" />
        <di:waypoint x="915" y="340" />
        <di:waypoint x="1010" y="340" />
        <bpmndi:BPMNLabel><dc:Bounds x="928" y="230" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A11_No_di" bpmnElement="Flow_A11_No">
        <di:waypoint x="940" y="110" />
        <di:waypoint x="1010" y="80" />
        <bpmndi:BPMNLabel><dc:Bounds x="958" y="86" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A14_di" bpmnElement="Flow_A14">
        <di:waypoint x="1110" y="80" />
        <di:waypoint x="1410" y="80" />
        <di:waypoint x="1410" y="410" />
        <di:waypoint x="1450" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A15_di" bpmnElement="Flow_A15">
        <di:waypoint x="1110" y="340" />
        <di:waypoint x="1180" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A16_Yes_di" bpmnElement="Flow_A16_Yes">
        <di:waypoint x="1230" y="340" />
        <di:waypoint x="1300" y="310" />
        <bpmndi:BPMNLabel><dc:Bounds x="1245" y="320" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A16_No_di" bpmnElement="Flow_A16_No">
        <di:waypoint x="1205" y="365" />
        <di:waypoint x="1205" y="410" />
        <di:waypoint x="1300" y="410" />
        <bpmndi:BPMNLabel><dc:Bounds x="1215" y="390" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A17_di" bpmnElement="Flow_A17">
        <di:waypoint x="1400" y="310" />
        <di:waypoint x="1450" y="310" />
      </bpmndi:BPMNEdge>
