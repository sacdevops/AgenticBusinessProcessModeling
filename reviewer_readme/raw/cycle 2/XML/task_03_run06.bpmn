<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_VacationRequest\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_Vacation\">\n    <bpmn:participant id=\"PoolHRPortal\" name=\"HR Portal\" processRef=\"Process_HRPortal\" />\n    <bpmn:participant id=\"PoolEmployee\" name=\"Employee\" />\n    <bpmn:participant id=\"PoolSupervisor\" name=\"Supervisor\" />\n    <bpmn:participant id=\"PoolHRManager\" name=\"HR Manager\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitRequest\" name=\"Request\" sourceRef=\"PoolEmployee\" targetRef=\"StartRequestReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestApproval\" name=\"Approval request\" sourceRef=\"TaskSendToSupervisor\" targetRef=\"PoolSupervisor\" />\n    <bpmn:messageFlow id=\"MF_SupervisorDecision\" name=\"Decision\" sourceRef=\"PoolSupervisor\" targetRef=\"CatchSupervisorFeedback\" />\n    <bpmn:messageFlow id=\"MF_EscalateToHRManager\" name=\"Escalation\" sourceRef=\"TaskEscalateToHRManager\" targetRef=\"PoolHRManager\" />\n    <bpmn:messageFlow id=\"MF_HRManagerDecision\" name=\"Decision\" sourceRef=\"PoolHRManager\" targetRef=\"CatchHRManagerDecision\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedDays\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedDays\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedSupervisor\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedSupervisor\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedHRManager\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedHRManager\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyApproved\" name=\"Approved\" sourceRef=\"TaskNotifyApproved\" targetRef=\"PoolEmployee\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_HRPortal\" name=\"Vacation Request Process\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartRequestReceived\" name=\"Request received\">\n      <bpmn:messageEventDefinition id=\"MED_StartRequestReceived\" />\n      <bpmn:outgoing>Flow_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckBalance\" name=\"Check balance\">\n      <bpmn:incoming>Flow_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwEnoughDays\" name=\"Enough days?\">\n      <bpmn:incoming>Flow_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>\n      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedDays\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_3_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_4</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedDays\" name=\"Rejected\">\n      <bpmn:incoming>Flow_4</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendToSupervisor\" name=\"Request approval\">\n      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitFeedback\">\n      <bpmn:incoming>Flow_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_6_Msg</bpmn:outgoing>\n      <bpmn:outgoing>Flow_6_Timer</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorFeedback\" name=\"Feedback received\">\n      <bpmn:incoming>Flow_6_Msg</bpmn:incoming>\n      <bpmn:outgoing>Flow_7</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchSupervisorFeedback\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwSupervisorApproved\" name=\"Approved?\">\n      <bpmn:incoming>Flow_7</bpmn:incoming>\n      <bpmn:outgoing>Flow_8_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_8_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:serviceTask id=\"TaskBookVacation\" name=\"Book vacation\">\n      <bpmn:incoming>Flow_8_Yes</bpmn:incoming>\n      <bpmn:incoming>Flow_12_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_13</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskNotifyApproved\" name=\"Notify approval\">\n      <bpmn:incoming>Flow_13</bpmn:incoming>\n      <bpmn:outgoing>Flow_14</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_14</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedSupervisor\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_8_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_10</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedSupervisor\" name=\"Rejected\">\n      <bpmn:incoming>Flow_10</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"5 days exceeded\">\n      <bpmn:incoming>Flow_6_Timer</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_CatchTimeout\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:sendTask id=\"TaskEscalateToHRManager\" name=\"Escalate case\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n      <bpmn:outgoing>Flow_11b</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:intermediateCatchEvent id=\"CatchHRManagerDecision\" name=\"Decision received\">\n      <bpmn:incoming>Flow_11b</bpmn:incoming>\n      <bpmn:outgoing>Flow_12</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchHRManagerDecision\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwHRManagerApproved\" name=\"Approved?\">\n      <bpmn:incoming>Flow_12</bpmn:incoming>\n      <bpmn:outgoing>Flow_12_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_12_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedHRManager\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_12_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_16</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedHRManager\" name=\"Rejected\">\n      <bpmn:incoming>Flow_16</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_1\" sourceRef=\"StartRequestReceived\" targetRef=\"TaskCheckBalance\" />\n    <bpmn:sequenceFlow id=\"Flow_2\" sourceRef=\"TaskCheckBalance\" targetRef=\"GwEnoughDays\" />\n    <bpmn:sequenceFlow id=\"Flow_3_No\" name=\"No\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskNotifyRejectedDays\" />\n    <bpmn:sequenceFlow id=\"Flow_3_Yes\" name=\"Yes\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskSendToSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_4\" sourceRef=\"TaskNotifyRejectedDays\" targetRef=\"EndRejectedDays\" />\n    <bpmn:sequenceFlow id=\"Flow_5\" sourceRef=\"TaskSendToSupervisor\" targetRef=\"GwWaitFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_6_Msg\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_6_Timer\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_7\" sourceRef=\"CatchSupervisorFeedback\" targetRef=\"GwSupervisorApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_8_Yes\" name=\"Yes\" sourceRef=\"GwSupervisorApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_8_No\" name=\"No\" sourceRef=\"GwSupervisorApproved\" targetRef=\"TaskNotifyRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_10\" sourceRef=\"TaskNotifyRejectedSupervisor\" targetRef=\"EndRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"CatchTimeout\" targetRef=\"TaskEscalateToHRManager\" />\n    <bpmn:sequenceFlow id=\"Flow_11b\" sourceRef=\"TaskEscalateToHRManager\" targetRef=\"CatchHRManagerDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_12\" sourceRef=\"CatchHRManagerDecision\" targetRef=\"GwHRManagerApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_12_Yes\" name=\"Yes\" sourceRef=\"GwHRManagerApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_12_No\" name=\"No\" sourceRef=\"GwHRManagerApproved\" targetRef=\"TaskNotifyRejectedHRManager\" />\n    <bpmn:sequenceFlow id=\"Flow_13\" sourceRef=\"TaskBookVacation\" targetRef=\"TaskNotifyApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_14\" sourceRef=\"TaskNotifyApproved\" targetRef=\"EndApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_16\" sourceRef=\"TaskNotifyRejectedHRManager\" targetRef=\"EndRejectedHRManager\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_Vacation\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_Vacation\" bpmnElement=\"Collaboration_Vacation\">\n      <bpmndi:BPMNShape id=\"PoolHRPortal_di\" bpmnElement=\"PoolHRPortal\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"PoolEmployee_di\" bpmnElement=\"PoolEmployee\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"PoolSupervisor_di\" bpmnElement=\"PoolSupervisor\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"PoolHRManager_di\" bpmnElement=\"PoolHRManager\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"710\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartRequestReceived_di\" bpmnElement=\"StartRequestReceived\">\n        <dc:Bounds x=\"232\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"208\" y=\"245\" width=\"86\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckBalance_di\" bpmnElement=\"TaskCheckBalance\">\n        <dc:Bounds x=\"340\" y=\"180\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwEnoughDays_di\" bpmnElement=\"GwEnoughDays\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"500\" y=\"195\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"485\" y=\"252\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedDays_di\" bpmnElement=\"TaskNotifyRejectedDays\">\n        <dc:Bounds x=\"620\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedDays_di\" bpmnElement=\"EndRejectedDays\">\n        <dc:Bounds x=\"780\" y=\"132\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"765\" y=\"175\" width=\"58\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendToSupervisor_di\" bpmnElement=\"TaskSendToSupervisor\">\n        <dc:Bounds x=\"620\" y=\"260\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitFeedback_di\" bpmnElement=\"GwWaitFeedback\">\n        <dc:Bounds x=\"780\" y=\"275\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorFeedback_di\" bpmnElement=\"CatchSupervisorFeedback\">\n        <dc:Bounds x=\"910\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"882\" y=\"245\" width=\"92\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwSupervisorApproved_di\" bpmnElement=\"GwSupervisorApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1010\" y=\"195\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1006\" y=\"252\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskBookVacation_di\" bpmnElement=\"TaskBookVacation\">\n        <dc:Bounds x=\"1120\" y=\"160\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskNotifyApproved_di\" bpmnElement=\"TaskNotifyApproved\">\n        <dc:Bounds x=\"1280\" y=\"160\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndApproved_di\" bpmnElement=\"EndApproved\">\n        <dc:Bounds x=\"1430\" y=\"182\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1417\" y=\"225\" width=\"62\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedSupervisor_di\" bpmnElement=\"TaskNotifyRejectedSupervisor\">\n        <dc:Bounds x=\"1120\" y=\"260\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedSupervisor_di\" bpmnElement=\"EndRejectedSupervisor\">\n        <dc:Bounds x=\"1430\" y=\"282\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1415\" y=\"325\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"910\" y=\"322\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"886\" y=\"365\" width=\"88\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskEscalateToHRManager_di\" bpmnElement=\"TaskEscalateToHRManager\">\n        <dc:Bounds x=\"1010\" y=\"300\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchHRManagerDecision_di\" bpmnElement=\"CatchHRManagerDecision\">\n        <dc:Bounds x=\"1160\" y=\"322\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1132\" y=\"365\" width=\"92\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwHRManagerApproved_di\" bpmnElement=\"GwHRManagerApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1250\" y=\"315\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1246\" y=\"372\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedHRManager_di\" bpmnElement=\"TaskNotifyRejectedHRManager\">\n        <dc:Bounds x=\"1340\" y=\"300\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedHRManager_di\" bpmnElement=\"EndRejectedHRManager\">\n        <dc:Bounds x=\"1470\" y=\"322\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1455\" y=\"365\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_1_di\" bpmnElement=\"Flow_1\">\n        <di:waypoint x=\"268\" y=\"220\" />\n        <di:waypoint x=\"340\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_2_di\" bpmnElement=\"Flow_2\">\n        <di:waypoint x=\"440\" y=\"220\" />\n        <di:waypoint x=\"500\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_3_No_di\" bpmnElement=\"Flow_3_No\">\n        <di:waypoint x=\"525\" y=\"195\" />\n        <di:waypoint x=\"525\" y=\"150\" />\n        <di:waypoint x=\"620\" y=\"150\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"532\" y=\"164\" width=\"18\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_3_Yes_di\" bpmnElement=\"Flow_3_Yes\">\n        <di:waypoint x=\"525\" y=\"245\" />\n        <di:waypoint x=\"525\" y=\"300\" />\n        <di:waypoint x=\"620\" y=\"300\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"532\" y=\"270\" width=\"20\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_4_di\" bpmnElement=\"Flow_4\">\n        <di:waypoint x=\"720\" y=\"150\" />\n        <di:waypoint x=\"780\" y=\"150\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_5_di\" bpmnElement=\"Flow_5\">\n        <di:waypoint x=\"720\" y=\"300\" />\n        <di:waypoint x=\"780\" y=\"300\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_6_Msg_di\" bpmnElement=\"Flow_6_Msg\">\n        <di:waypoint x=\"805\" y=\"275\" />\n        <di:waypoint x=\"805\" y=\"220\" />\n        <di:waypoint x=\"910\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_6_Timer_di\" bpmnElement=\"Flow_6_Timer\">\n        <di:waypoint x=\"805\" y=\"325\" />\n        <di:waypoint x=\"805\" y=\"340\" />\n        <di:waypoint x=\"910\" y=\"340\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_7_di\" bpmnElement=\"Flow_7\">\n        <di:waypoint x=\"946\" y=\"220\" />\n        <di:waypoint x=\"1010\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_8_Yes_di\" bpmnElement=\"Flow_8_Yes\">\n        <di:waypoint x=\"1060\" y=\"220\" />\n        <di:waypoint x=\"1120\" y=\"200\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1082\" y=\"205\" width=\"20\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_8_No_di\" bpmnElement=\"Flow_8_No\">\n        <di:waypoint x=\"1035\" y=\"245\" />\n        <di:waypoint x=\"1035\" y=\"300\" />\n        <di:waypoint x=\"1120\" y=\"300\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1042\" y=\"270\" width=\"18\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_10_di\" bpmnElement=\"Flow_10\">\n        <di:waypoint x=\"1220\" y=\"300\" />\n        <di:waypoint x=\"1430\" y=\"300\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_11_di\" bpmnElement=\"Flow_11\">\n        <di:waypoint x=\"946\" y=\"340\" />\n        <di:waypoint x=\"1010\" y=\"340\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_11b_di\" bpmnElement=\"Flow_11b\">\n        <di:waypoint x=\"1110\" y=\"340\" />\n        <di:waypoint x=\"1160\" y=\"340\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_12_di\" bpmnElement=\"Flow_12\">\n        <di:waypoint x=\"1196\" y=\"340\" />\n        <di:waypoint x=\"1250\" y=\"340\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_12_Yes_di\" bpmnElement=\"Flow_12_Yes\">\n        <di:waypoint x=\"1250\" y=\"340\" />\n        <di:waypoint x=\"1210\" y=\"340\" />\n        <di:waypoint x=\"1210\" y=\"240\" />\n        <di:waypoint x=\"1120\" y=\"240\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1220\" y=\"327\" width=\"20\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_12_No_di\" bpmnElement=\"Flow_12_No\">\n        <di:waypoint x=\"1300\" y=\"340\" />\n        <di:waypoint x=\"1340\" y=\"340\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1310\" y=\"327\" width=\"18\" height=\"14\" /></bpmndi:BPMNEdge>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_13_di\" bpmnElement=\"Flow_13\">\n        <di:waypoint x=\"1220\" y=\"200\" />\n        <di:waypoint x=\"1280\" y=\"200\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_14_di\" bpmnElement=\"Flow_14\">\n        <di:waypoint x=\"1380\" y=\"200\" />\n        <di:waypoint x=\"1430\" y=\"200\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_16_di\" bpmnElement=\"Flow_16\">\n        <di:waypoint x=\"1440\" y=\"340\" />\n        <di:waypoint x=\"1470\" y=\"340\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_SubmitRequest_di\" bpmnElement=\"MF_SubmitRequest\">\n        <di:waypoint x=\"900\" y=\"490\" />\n        <di:waypoint x=\"900\" y=\"60\" />\n        <di:waypoint x=\"250\" y=\"60\" />\n        <di:waypoint x=\"250\" y=\"202\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_RequestApproval_di\" bpmnElement=\"MF_RequestApproval\">\n        <di:waypoint x=\"670\" y=\"340\" />\n        <di:waypoint x=\"670\" y=\"600\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_SupervisorDecision_di\" bpmnElement=\"MF_SupervisorDecision\">\n        <di:waypoint x=\"920\" y=\"600\" />\n        <di:waypoint x=\"928\" y=\"238\" />\n      </bpmndi:B