<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" />

    <bpmn:messageFlow id="MF_OrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="PoolStandardSupplier" />
    <bpmn:messageFlow id="MF_Confirmation" name="Confirmation" sourceRef="PoolStandardSupplier" targetRef="CatchConfirmation" />
    <bpmn:messageFlow id="MF_Rejection" name="Rejection" sourceRef="PoolStandardSupplier" targetRef="CatchRejection" />
    <bpmn:messageFlow id="MF_OrderRequest_Alternative" name="Order request" sourceRef="TaskSendOrderAlternative" targetRef="PoolAlternativeSupplier" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" isExecutable="false">

    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskManualIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAlternativeSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndAlternativeOrdered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterDay" name="Quarter start">
      <bpmn:outgoing>Flow_Start_To_CheckInventory</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterStart" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_Start_To_CheckInventory</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckInventory_To_GwLowInventory</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low stock?" isMarkerVisible="true">
      <bpmn:incoming>Flow_CheckInventory_To_GwLowInventory</bpmn:incoming>
      <bpmn:outgoing>Flow_GwLowInventory_No_To_EndStockSufficient</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwLowInventory_Yes_To_SendOrderStandard</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order needed">
      <bpmn:incoming>Flow_GwLowInventory_No_To_EndStockSufficient</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send order request">
      <bpmn:incoming>Flow_GwLowInventory_Yes_To_SendOrderStandard</bpmn:incoming>
      <bpmn:outgoing>Flow_SendOrderStandard_To_GwWaitResponse</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse" name="" >
      <bpmn:incoming>Flow_SendOrderStandard_To_GwWaitResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_GwWaitResponse_To_CatchConfirmation</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwWaitResponse_To_CatchRejection</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwWaitResponse_To_CatchTimeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchConfirmation" name="Confirmation">
      <bpmn:incoming>Flow_GwWaitResponse_To_CatchConfirmation</bpmn:incoming>
      <bpmn:outgoing>Flow_CatchConfirmation_To_EndConfirmed</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Confirmation" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_CatchConfirmation_To_EndConfirmed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchRejection" name="Rejection">
      <bpmn:incoming>Flow_GwWaitResponse_To_CatchRejection</bpmn:incoming>
      <bpmn:outgoing>Flow_CatchRejection_To_TaskManualIntervention</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Rejection" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout3Days" name="3 days">
      <bpmn:incoming>Flow_GwWaitResponse_To_CatchTimeout</bpmn:incoming>
      <bpmn:outgoing>Flow_CatchTimeout_To_TaskManualIntervention</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervention" name="Manual intervene">
      <bpmn:incoming>Flow_CatchRejection_To_TaskManualIntervention</bpmn:incoming>
      <bpmn:incoming>Flow_CatchTimeout_To_TaskManualIntervention</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualIntervention_To_CheckAlternative</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckAlternativeSupplier" name="Check alternative">
      <bpmn:incoming>Flow_ManualIntervention_To_CheckAlternative</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckAlternative_To_GwOrderAlternative</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwOrderAlternative" name="Order alternative?" isMarkerVisible="true">
      <bpmn:incoming>Flow_CheckAlternative_To_GwOrderAlternative</bpmn:incoming>
      <bpmn:outgoing>Flow_GwOrderAlternative_Yes_To_SendOrderAlternative</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwOrderAlternative_No_To_EndCancelled</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendOrderAlternative" name="Send alternative order">
      <bpmn:incoming>Flow_GwOrderAlternative_Yes_To_SendOrderAlternative</bpmn:incoming>
      <bpmn:outgoing>Flow_SendOrderAlternative_To_EndAlternativeOrdered</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAlternativeOrdered" name="Alternative ordered">
      <bpmn:incoming>Flow_SendOrderAlternative_To_EndAlternativeOrdered</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndCancelled" name="Order cancelled">
      <bpmn:incoming>Flow_GwOrderAlternative_No_To_EndCancelled</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_CheckInventory" sourceRef="StartQuarterDay" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_CheckInventory_To_GwLowInventory" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_GwLowInventory_No_To_EndStockSufficient" name="No" sourceRef="GwLowInventory" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_GwLowInventory_Yes_To_SendOrderStandard" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_SendOrderStandard_To_GwWaitResponse" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_GwWaitResponse_To_CatchConfirmation" sourceRef="GwWaitResponse" targetRef="CatchConfirmation" />
    <bpmn:sequenceFlow id="Flow_GwWaitResponse_To_CatchRejection" sourceRef="GwWaitResponse" targetRef="CatchRejection" />
    <bpmn:sequenceFlow id="Flow_GwWaitResponse_To_CatchTimeout" sourceRef="GwWaitResponse" targetRef="CatchTimeout3Days" />
    <bpmn:sequenceFlow id="Flow_CatchConfirmation_To_EndConfirmed" sourceRef="CatchConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_CatchRejection_To_TaskManualIntervention" sourceRef="CatchRejection" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_CatchTimeout_To_TaskManualIntervention" sourceRef="CatchTimeout3Days" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_ManualIntervention_To_CheckAlternative" sourceRef="TaskManualIntervention" targetRef="TaskCheckAlternativeSupplier" />
    <bpmn:sequenceFlow id="Flow_CheckAlternative_To_GwOrderAlternative" sourceRef="TaskCheckAlternativeSupplier" targetRef="GwOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_GwOrderAlternative_Yes_To_SendOrderAlternative" name="Yes" sourceRef="GwOrderAlternative" targetRef="TaskSendOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_GwOrderAlternative_No_To_EndCancelled" name="No" sourceRef="GwOrderAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_SendOrderAlternative_To_EndAlternativeOrdered" sourceRef="TaskSendOrderAlternative" targetRef="EndAlternativeOrdered" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarterDay_di" bpmnElement="StartQuarterDay">
        <dc:Bounds x="212" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="194" y="195" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwLowInventory_di" bpmnElement="GwLowInventory" isMarkerVisible="true">
        <dc:Bounds x="490" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="478" y="202" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndStockSufficient_di" bpmnElement="EndStockSufficient">
        <dc:Bounds x="610" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="585" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="610" y="50" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitResponse_di" bpmnElement="GwWaitResponse">
        <dc:Bounds x="770" y="65" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchConfirmation_di" bpmnElement="CatchConfirmation">
        <dc:Bounds x="900" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="880" y="28" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchRejection_di" bpmnElement="CatchRejection">
        <dc:Bounds x="900" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="888" y="160" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout3Days_di" bpmnElement="CatchTimeout3Days">
        <dc:Bounds x="900" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="884" y="220" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1020" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="996" y="28" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervention_di" bpmnElement="TaskManualIntervention">
        <dc:Bounds x="1020" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAlternativeSupplier_di" bpmnElement="TaskCheckAlternativeSupplier">
        <dc:Bounds x="1180" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOrderAlternative_di" bpmnElement="GwOrderAlternative" isMarkerVisible="true">
        <dc:Bounds x="1335" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1312" y="372" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderAlternative_di" bpmnElement="TaskSendOrderAlternative">
        <dc:Bounds x="1450" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndAlternativeOrdered_di" bpmnElement="EndAlternativeOrdered">
        <dc:Bounds x="1568" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1532" y="335" width="108" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1452" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1428" y="405" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_CheckInventory_di" bpmnElement="Flow_Start_To_CheckInventory">
        <di:waypoint x="248" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CheckInventory_To_GwLowInventory_di" bpmnElement="Flow_CheckInventory_To_GwLowInventory">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="490" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwLowInventory_No_To_EndStockSufficient_di" bpmnElement="Flow_GwLowInventory_No_To_EndStockSufficient">
        <di:waypoint x="540" y="170" />
        <di:waypoint x="610" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="569" y="152" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwLowInventory_Yes_To_SendOrderStandard_di" bpmnElement="Flow_GwLowInventory_Yes_To_SendOrderStandard">
        <di:waypoint x="515" y="145" />
        <di:waypoint x="515" y="90" />
        <di:waypoint x="610" y="90" />
        <bpmndi:BPMNLabel><dc:Bounds x="523" y="107" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SendOrderStandard_To_GwWaitResponse_di" bpmnElement="Flow_SendOrderStandard_To_GwWaitResponse">
        <di:waypoint x="710" y="90" />
        <di:waypoint x="770" y="90" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwWaitResponse_To_CatchConfirmation_di" bpmnElement="Flow_GwWaitResponse_To_CatchConfirmation">
        <di:waypoint x="820" y="90" />
        <di:waypoint x="900" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwWaitResponse_To_CatchRejection_di" bpmnElement="Flow_GwWaitResponse_To_CatchRejection">
        <di:waypoint x="795" y="115" />
        <di:waypoint x="795" y="140" />
        <di:waypoint x="900" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwWaitResponse_To_CatchTimeout_di" bpmnElement="Flow_GwWaitResponse_To_CatchTimeout">
        <di:waypoint x="795" y="115" />
        <di:waypoint x="795" y="200" />
        <di:waypoint x="900" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CatchConfirmation_To_EndConfirmed_di" bpmnElement="Flow_CatchConfirmation_To_EndConfirmed">
        <di:waypoint x="936" y="80" />
        <di:waypoint x="1020" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CatchRejection_To_TaskManualIntervention_di" bpmnElement="Flow_CatchRejection_To_TaskManualIntervention">
        <di:waypoint x="918" y="158" />
        <di:waypoint x="918" y="340" />
        <di:waypoint x="1020" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CatchTimeout_To_TaskManualIntervention_di" bpmnElement="Flow_CatchTimeout_To_TaskManualIntervention">
        <di:waypoint x="918" y="218" />
        <di:waypoint x="918" y="340" />
        <di:waypoint x="1020" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_ManualIntervention_To_CheckAlternative_di" bpmnElement="Flow_ManualIntervention_To_CheckAlternative">
        <di:waypoint x="1120" y="340" />
        <di:waypoint x="1180" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CheckAlternative_To_GwOrderAlternative_di" bpmnElement="Flow_CheckAlternative_To_GwOrderAlternative">
        <di:waypoint x="1280" y="340" />
        <di:waypoint x="1335" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwOrderAlternative_Yes_To_SendOrderAlternative_di" bpmnElement="Flow_GwOrderAlternative_Yes_To_SendOrderAlternative">
        <di:waypoint x="1385" y="340" />
        <di:waypoint x="1418" y="340" />
        <di:waypoint x="1418" y="310" />
        <di:waypoint x="1450" y="310" />
        <bpmndi:BPMNLabel><dc:Bounds x="1401" y="322" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwOrderAlternative_No_To_EndCancelled_di" bpmnElement="Flow_GwOrderAlternative_No_To_EndCancelled">
        <di:waypoint x="1360" y="365" />
        <di:waypoint x="1360" y="380" />
        <di:waypoint x="1452" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="1370" y="365" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SendOrderAlternative_To_EndAlternativeOrdered_di" bpmnElement="Flow_SendOrderAlternative_To_EndAlternativeOrdered">
        <di:waypoint x="1550" y="310" />
        <di:waypoint x="1568" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Standard_di" bpmnElement="MF_OrderRequest_Standard">
        <di:waypoint x="660" y="50" />
        <di:waypoint x="660" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Confirmation_di" bpmnElement="MF_Confirmation">
        <di:waypoint x="980" y="490" />
        <di:waypoint x="980" y="400" />
        <di:waypoint x="918" y="400" />
        <di:waypoint x="918" y="98" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Rejection_di" bpmnElement="MF_Rejection">
        <di:waypoint x="1040" y="490" />
        <di:waypoint x="1040" y="420" />
        <di:waypoint x="918" y="420" />
        <di:waypoint x="918" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Alternative_di" bpmnElement="MF_OrderRequest_Alternative">
        <di:waypoint x="1500" y="270" />
        <di:waypoint x="1500" y="600" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>