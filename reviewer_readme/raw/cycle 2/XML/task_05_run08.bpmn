<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" />

    <bpmn:messageFlow id="MF_SendOrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="PoolStandardSupplier" />
    <bpmn:messageFlow id="MF_Confirmation_FromStandard" name="Confirmation" sourceRef="PoolStandardSupplier" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_Rejection_FromStandard" name="Rejection" sourceRef="PoolStandardSupplier" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_SendOrder_Alternative" name="Order" sourceRef="TaskSendOrderAlternative" targetRef="PoolAlternativeSupplier" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" name="Office Supply Procurement" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitSupplierResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchNoResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskManualIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSentAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterDay" name="Quarter day">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterDay" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowStock" name="Low stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_Low</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Ok</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order">
      <bpmn:incoming>Flow_4_Ok</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_3_Low</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitSupplierResponse">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_Confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_8_Timeout</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmation">
      <bpmn:incoming>Flow_6_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardConfirm" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejection">
      <bpmn:incoming>Flow_7_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardReject" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchNoResponse" name="3 days">
      <bpmn:incoming>Flow_8_Timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervention" name="Manual intervene">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckAlternative" name="Check alternative">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Use alternative?">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_15_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendOrderAlternative" name="Send order">
      <bpmn:incoming>Flow_14_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndSentAlternative" name="Sent">
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndCancelled" name="Cancelled">
      <bpmn:incoming>Flow_15_No</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartQuarterDay" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckInventory" targetRef="GwLowStock" />
    <bpmn:sequenceFlow id="Flow_3_Low" name="Yes" sourceRef="GwLowStock" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_4_Ok" name="No" sourceRef="GwLowStock" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitSupplierResponse" />
    <bpmn:sequenceFlow id="Flow_6_Confirm" sourceRef="GwWaitSupplierResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_7_Reject" sourceRef="GwWaitSupplierResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_8_Timeout" sourceRef="GwWaitSupplierResponse" targetRef="CatchNoResponse" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchStandardConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="CatchStandardRejection" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="CatchNoResponse" targetRef="TaskManualIntervention" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskManualIntervention" targetRef="TaskCheckAlternative" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskCheckAlternative" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_14_Yes" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_15_No" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskSendOrderAlternative" targetRef="EndSentAlternative" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarterDay_di" bpmnElement="StartQuarterDay">
        <dc:Bounds x="230" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="212" y="195" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="350" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwLowStock_di" bpmnElement="GwLowStock" isMarkerVisible="true">
        <dc:Bounds x="520" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="501" y="202" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndStockSufficient_di" bpmnElement="EndStockSufficient">
        <dc:Bounds x="650" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="635" y="195" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="650" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitSupplierResponse_di" bpmnElement="GwWaitSupplierResponse">
        <dc:Bounds x="820" y="325" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardConfirmation_di" bpmnElement="CatchStandardConfirmation">
        <dc:Bounds x="940" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="920" y="262" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1080" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1067" y="335" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="940" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="928" y="395" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchNoResponse_di" bpmnElement="CatchNoResponse">
        <dc:Bounds x="940" y="412" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="926" y="455" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervention_di" bpmnElement="TaskManualIntervention">
        <dc:Bounds x="1080" y="385" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAlternative_di" bpmnElement="TaskCheckAlternative">
        <dc:Bounds x="1230" y="385" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1395" y="400" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1374" y="457" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderAlternative_di" bpmnElement="TaskSendOrderAlternative">
        <dc:Bounds x="1510" y="355" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndSentAlternative_di" bpmnElement="EndSentAlternative">
        <dc:Bounds x="1630" y="377" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1621" y="420" width="54" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1510" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1497" y="505" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="266" y="170" />
        <di:waypoint x="350" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="450" y="170" />
        <di:waypoint x="520" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_Low_di" bpmnElement="Flow_3_Low">
        <di:waypoint x="545" y="195" />
        <di:waypoint x="545" y="350" />
        <di:waypoint x="650" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="555" y="260" width="24" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_Ok_di" bpmnElement="Flow_4_Ok">
        <di:waypoint x="570" y="170" />
        <di:waypoint x="650" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="602" y="150" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="750" y="350" />
        <di:waypoint x="820" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_Confirm_di" bpmnElement="Flow_6_Confirm">
        <di:waypoint x="845" y="325" />
        <di:waypoint x="845" y="310" />
        <di:waypoint x="940" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_Reject_di" bpmnElement="Flow_7_Reject">
        <di:waypoint x="870" y="350" />
        <di:waypoint x="940" y="370" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_Timeout_di" bpmnElement="Flow_8_Timeout">
        <di:waypoint x="845" y="375" />
        <di:waypoint x="845" y="430" />
        <di:waypoint x="940" y="430" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="976" y="310" />
        <di:waypoint x="1080" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="976" y="370" />
        <di:waypoint x="1030" y="370" />
        <di:waypoint x="1030" y="425" />
        <di:waypoint x="1080" y="425" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="976" y="430" />
        <di:waypoint x="1080" y="425" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1180" y="425" />
        <di:waypoint x="1230" y="425" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1330" y="425" />
        <di:waypoint x="1395" y="425" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_Yes_di" bpmnElement="Flow_14_Yes">
        <di:waypoint x="1445" y="425" />
        <di:waypoint x="1510" y="395" />
        <bpmndi:BPMNLabel><dc:Bounds x="1460" y="394" width="24" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_No_di" bpmnElement="Flow_15_No">
        <di:waypoint x="1420" y="450" />
        <di:waypoint x="1420" y="480" />
        <di:waypoint x="1510" y="480" />
        <bpmndi:BPMNLabel><dc:Bounds x="1430" y="462" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1610" y="395" />
        <di:waypoint x="1630" y="395" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SendOrderRequest_Standard_di" bpmnElement="MF_SendOrderRequest_Standard">
        <di:waypoint x="700" y="310" />
        <di:waypoint x="700" y="520" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Confirmation_FromStandard_di" bpmnElement="MF_Confirmation_FromStandard">
        <di:waypoint x="980" y="520" />
        <di:waypoint x="980" y="310" />
        <di:waypoint x="958" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Rejection_FromStandard_di" bpmnElement="MF_Rejection_FromStandard">
        <di:waypoint x="980" y="520" />
        <di:waypoint x="980" y="370" />
        <di:waypoint x="958" y="370" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SendOrder_Alternative_di" bpmnElement="MF_SendOrder_Alternative">
        <di:waypoint x="1560" y="435" />
        <di:waypoint x="1560" y="630" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>