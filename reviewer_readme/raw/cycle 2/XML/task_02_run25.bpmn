<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolCustomer" name="Customer" />
    <bpmn:participant id="PoolAssessor" name="External Assessor" />

    <bpmn:messageFlow id="MF_DamageReport" name="Damage report" sourceRef="PoolCustomer" targetRef="StartDamageReport" />
    <bpmn:messageFlow id="MF_Rejection_NotCovered" name="Rejection" sourceRef="TaskSendRejectionNotCovered" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_Approval_LowAmount" name="Approval" sourceRef="TaskSendApprovalLow" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_DeadlineRejection" name="Rejection" sourceRef="TaskSendDeadlineRejection" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_FinalApproval" name="Approval" sourceRef="TaskSendFinalApproval" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_FinalRejection" name="Rejection" sourceRef="TaskSendFinalRejection" targetRef="PoolCustomer" />

    <bpmn:messageFlow id="MF_AssessorOrder" name="Order" sourceRef="TaskSendAssessorOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_AssessorReport" name="Report" sourceRef="PoolAssessor" targetRef="CatchAssessorReport" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCaseClosedNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmountHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveLowAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApprovedLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCommissionAssessor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendAssessorOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAssessorReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline10Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendFinalApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendFinalRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndFinalRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskAutoRejectDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendDeadlineRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndDeadlineRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePaymentLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInitiatePaymentFinal</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartDamageReport" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionNotCovered" name="Send rejection">
      <bpmn:incoming>Flow_4_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndCaseClosedNotCovered" name="Case closed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_4_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmountHigh" name="> €1500?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveLowAmount" name="Approve case">
      <bpmn:incoming>Flow_7_No</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePaymentLow" name="Initiate payment">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalLow" name="Send approval">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApprovedLow" name="Process ended">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCommissionAssessor" name="Commission assessor">
      <bpmn:incoming>Flow_7_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskSendAssessorOrder" name="Send order">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitReport">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13_Report</bpmn:outgoing>
      <bpmn:outgoing>Flow_13_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchAssessorReport" name="Report received">
      <bpmn:incoming>Flow_13_Report</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AssessorReport" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline10Days" name="10 days exceeded">
      <bpmn:incoming>Flow_13_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalApproved" name="Approved?">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_17_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePaymentFinal" name="Initiate payment">
      <bpmn:incoming>Flow_17_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendFinalApproval" name="Send approval">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndFinalApproved" name="Process ended">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendFinalRejection" name="Send rejection">
      <bpmn:incoming>Flow_17_No</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndFinalRejected" name="Process ended">
      <bpmn:incoming>Flow_20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="TaskAutoRejectDeadline" name="Reject case">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendDeadlineRejection" name="Send rejection">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndDeadlineRejected" name="Process ended">
      <bpmn:incoming>Flow_22</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_4_No" name="No" sourceRef="GwCovered" targetRef="TaskSendRejectionNotCovered" />
    <bpmn:sequenceFlow id="Flow_4_Yes" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendRejectionNotCovered" targetRef="EndCaseClosedNotCovered" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskCheckAmount" targetRef="GwAmountHigh" />
    <bpmn:sequenceFlow id="Flow_7_No" name="No" sourceRef="GwAmountHigh" targetRef="TaskApproveLowAmount" />
    <bpmn:sequenceFlow id="Flow_7_Yes" name="Yes" sourceRef="GwAmountHigh" targetRef="TaskCommissionAssessor" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskApproveLowAmount" targetRef="TaskInitiatePaymentLow" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInitiatePaymentLow" targetRef="TaskSendApprovalLow" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendApprovalLow" targetRef="EndApprovedLow" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskCommissionAssessor" targetRef="TaskSendAssessorOrder" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskSendAssessorOrder" targetRef="GwWaitReport" />
    <bpmn:sequenceFlow id="Flow_13_Report" sourceRef="GwWaitReport" targetRef="CatchAssessorReport" />
    <bpmn:sequenceFlow id="Flow_13_Timer" sourceRef="GwWaitReport" targetRef="CatchDeadline10Days" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="CatchAssessorReport" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="CatchDeadline10Days" targetRef="TaskAutoRejectDeadline" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskReviewAssessment" targetRef="GwFinalApproved" />
    <bpmn:sequenceFlow id="Flow_17_Yes" name="Yes" sourceRef="GwFinalApproved" targetRef="TaskInitiatePaymentFinal" />
    <bpmn:sequenceFlow id="Flow_17_No" name="No" sourceRef="GwFinalApproved" targetRef="TaskSendFinalRejection" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="TaskInitiatePaymentFinal" targetRef="TaskSendFinalApproval" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="TaskSendFinalApproval" targetRef="EndFinalApproved" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="TaskSendFinalRejection" targetRef="EndFinalRejected" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="TaskAutoRejectDeadline" targetRef="TaskSendDeadlineRejection" />
    <bpmn:sequenceFlow id="Flow_22" sourceRef="TaskSendDeadlineRejection" targetRef="EndDeadlineRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">

      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="380" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="270" width="1500" height="190" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1500" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="620" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="240" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="200" width="104" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="340" y="135" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="500" y="135" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="660" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="655" y="207" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionNotCovered_di" bpmnElement="TaskSendRejectionNotCovered">
        <dc:Bounds x="780" y="95" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCaseClosedNotCovered_di" bpmnElement="EndCaseClosedNotCovered">
        <dc:Bounds x="940" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="920" y="160" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="780" y="195" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwAmountHigh_di" bpmnElement="GwAmountHigh" isMarkerVisible="true">
        <dc:Bounds x="940" y="210" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="923" y="267" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveLowAmount_di" bpmnElement="TaskApproveLowAmount">
        <dc:Bounds x="1060" y="165" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskInitiatePaymentLow_di" bpmnElement="TaskInitiatePaymentLow">
        <dc:Bounds x="1220" y="295" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendApprovalLow_di" bpmnElement="TaskSendApprovalLow">
        <dc:Bounds x="1380" y="165" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndApprovedLow_di" bpmnElement="EndApprovedLow">
        <dc:Bounds x="1540" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1520" y="230" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCommissionAssessor_di" bpmnElement="TaskCommissionAssessor">
        <dc:Bounds x="1060" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendAssessorOrder_di" bpmnElement="TaskSendAssessorOrder">
        <dc:Bounds x="1220" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitReport_di" bpmnElement="GwWaitReport">
        <dc:Bounds x="1385" y="280" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAssessorReport_di" bpmnElement="CatchAssessorReport">
        <dc:Bounds x="1505" y="267" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1475" y="310" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchDeadline10Days_di" bpmnElement="CatchDeadline10Days">
        <dc:Bounds x="1505" y="347" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1468" y="390" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1600" y="245" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwFinalApproved_di" bpmnElement="GwFinalApproved" isMarkerVisible="true">
        <dc:Bounds x="1760" y="260" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1752" y="317" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePaymentFinal_di" bpmnElement="TaskInitiatePaymentFinal">
        <dc:Bounds x="1920" y="295" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendFinalApproval_di" bpmnElement="TaskSendFinalApproval">
        <dc:Bounds x="2080" y="245" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndFinalApproved_di" bpmnElement="EndFinalApproved">
        <dc:Bounds x="2240" y="267" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2220" y="310" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendFinalRejection_di" bpmnElement="TaskSendFinalRejection">
        <dc:Bounds x="1920" y="155" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndFinalRejected_di" bpmnElement="EndFinalRejected">
        <dc:Bounds x="2080" y="177" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2060" y="220" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAutoRejectDeadline_di" bpmnElement="TaskAutoRejectDeadline">
        <dc:Bounds x="1600" y="335" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendDeadlineRejection_di" bpmnElement="TaskSendDeadlineRejection">
        <dc:Bounds x="1760" y="335" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndDeadlineRejected_di" bpmnElement="EndDeadlineRejected">
        <dc:Bounds x="1920" y="357" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1900" y="400" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="276" y="175" />
        <di:waypoint x="340" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="175" />
        <di:waypoint x="500" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="175" />
        <di:waypoint x="660" y="175" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_No_di" bpmnElement="Flow_4_No">
        <di:waypoint x="685" y="150" />
        <di:waypoint x="685" y="135" />
        <di:waypoint x="780" y="135" />
        <bpmndi:BPMNLabel><dc:Bounds x="700" y="122" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_Yes_di" bpmnElement="Flow_4_Yes">
        <di:waypoint x="710" y="175" />
        <di:waypoint x="780" y="235" />
        <bpmndi:BPMNLabel><dc:Bounds x="736" y="205" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="880" y="135" />
        <di:waypoint x="940" y="135" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="880" y="235" />
        <di:waypoint x="940" y="235" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_No_di" bpmnElement="Flow_7_No">
        <di:waypoint x="965" y="210" />
        <di:waypoint x="965" y="205" />
        <di:waypoint x="1060" y="205" />
        <bpmndi:BPMNLabel><dc:Bounds x="980" y="192" width="20" height="14" /></bpmndi:BPMNLabel>
