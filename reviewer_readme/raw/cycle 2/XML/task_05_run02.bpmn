<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_PoolCompany" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_PoolStandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_PoolAlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderToStandard" name="Order request" sourceRef="TaskSendOrderStandard" targetRef="StartStandardOrderReceived" />
    <bpmn:messageFlow id="MF_StdConfirm" name="Confirmation" sourceRef="EndStdConfirmed" targetRef="CatchStdConfirmation" />
    <bpmn:messageFlow id="MF_StdReject" name="Rejection" sourceRef="EndStdRejected" targetRef="CatchStdRejection" />

    <bpmn:messageFlow id="MF_OrderToAlternative" name="Order request" sourceRef="TaskSendOrderAlternative" targetRef="StartAlternativeOrderReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolCompany" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStdConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStdRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch3Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskDecideAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderedAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterDay" name="Quarter day">
      <bpmn:timerEventDefinition id="TED_QuarterDay" />
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low inventory?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockOk" name="Stock ok">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderStandard" name="Send request">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStdConfirmation" name="Confirmation received">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdConfirmation" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStdRejection" name="Rejection received">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StdRejection" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch3Days" name="3 days exceeded">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskDecideAlternative" name="Check alternative">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Use alternative?">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndCancelled" name="Order cancelled">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderAlternative" name="Send request">
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndOrderedAlternative" name="Order sent">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartQuarterDay" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderStandard" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwLowInventory" targetRef="EndStockOk" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskSendOrderStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="GwWaitResponse" targetRef="CatchStdConfirmation" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitResponse" targetRef="CatchStdRejection" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitResponse" targetRef="Catch3Days" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchStdConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchStdRejection" targetRef="TaskDecideAlternative" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="Catch3Days" targetRef="TaskDecideAlternative" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskDecideAlternative" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_C13" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_C14" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_C15" sourceRef="TaskSendOrderAlternative" targetRef="EndOrderedAlternative" />
  </bpmn:process>

  <bpmn:process id="Process_PoolStandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStandardOrderReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartStd" />
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GwStdDeliverable" name="Deliverable?">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStdConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStdConf" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndStdRejected" name="Rejected">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStdRej" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartStandardOrderReceived" targetRef="GwStdDeliverable" />
    <bpmn:sequenceFlow id="Flow_S2" name="Yes" sourceRef="GwStdDeliverable" targetRef="EndStdConfirmed" />
    <bpmn:sequenceFlow id="Flow_S3" name="No" sourceRef="GwStdDeliverable" targetRef="EndStdRejected" />
  </bpmn:process>

  <bpmn:process id="Process_PoolAlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAlternativeOrderReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartAlt" />
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndAltReceived" name="Request logged">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAlternativeOrderReceived" targetRef="EndAltReceived" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
