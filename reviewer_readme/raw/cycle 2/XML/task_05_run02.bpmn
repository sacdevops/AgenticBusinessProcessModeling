      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <di:waypoint x="550" y="170" />
        <di:waypoint x="620" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="585" y="152" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
