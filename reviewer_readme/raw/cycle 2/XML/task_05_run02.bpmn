      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartStandardOrderReceived_di" bpmnElement="StartStandardOrderReceived">
        <dc:Bounds x="220" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="625" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwStdDeliverable_di" bpmnElement="GwStdDeliverable" isMarkerVisible="true">
        <dc:Bounds x="350" y="575" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="338" y="632" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
