      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderAlternative_di" bpmnElement="TaskSendOrderAlternative">
        <dc:Bounds x="1320" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>
