        <di:waypoint x="1120" y="350" />
        <di:waypoint x="1180" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C13_di" bpmnElement="Flow_C13">
        <di:waypoint x="1230" y="350" />
        <di:waypoint x="1320" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="1265" y="353" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C14_di" bpmnElement="Flow_C14">
        <di:waypoint x="1205" y="325" />
        <di:waypoint x="1205" y="300" />
        <di:waypoint x="1320" y="300" />
        <bpmndi:BPMNLabel><dc:Bounds x="1215" y="303" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C15_di" bpmnElement="Flow_C15">
        <di:waypoint x="1420" y="380" />
        <di:waypoint x="1460" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="256" y="600" />
        <di:waypoint x="350" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="375" y="575" />
        <di:waypoint x="375" y="560" />
        <di:waypoint x="480" y="560" />
        <bpmndi:BPMNLabel><dc:Bounds x="384" y="562" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="375" y="625" />
        <di:waypoint x="375" y="640" />
        <di:waypoint x="480" y="640" />
        <bpmndi:BPMNLabel><dc:Bounds x="384" y="644" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_A1_di" bpmnElement="Flow_A1">
        <di:waypoint x="256" y="845" />
        <di:waypoint x="350" y="845" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_OrderToStandard_di" bpmnElement="MF_OrderToStandard">
        <di:waypoint x="670" y="40" />
        <di:waypoint x="670" y="470" />
        <di:waypoint x="238" y="470" />
        <di:waypoint x="238" y="582" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_StdConfirm_di" bpmnElement="MF_StdConfirm">
        <di:waypoint x="498" y="542" />
