        <dc:Bounds x="160" y="760" width="1400" height="170" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartAlternativeOrderReceived_di" bpmnElement="StartAlternativeOrderReceived">
        <dc:Bounds x="220" y="827" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="870" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
