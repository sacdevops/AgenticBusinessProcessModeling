      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStdRejection_di" bpmnElement="CatchStdRejection">
        <dc:Bounds x="900" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="868" y="175" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch3Days_di" bpmnElement="Catch3Days">
        <dc:Bounds x="900" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="874" y="275" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskDecideAlternative_di" bpmnElement="TaskDecideAlternative">
        <dc:Bounds x="1020" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1180" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1155" y="382" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1320" y="282" width="36" height="36" />
