        <di:waypoint x="1230" y="710" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_HRManagerDecision_di" bpmnElement="MF_HRManagerDecision">
        <di:waypoint x="1340" y="710" />
        <di:waypoint x="1340" y="368" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyRejectedNoDays_di" bpmnElement="MF_NotifyRejectedNoDays">
        <di:waypoint x="808" y="72" />
        <di:waypoint x="808" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyRejectedSupervisor_di" bpmnElement="MF_NotifyRejectedSupervisor">
        <di:waypoint x="1498" y="268" />
        <di:waypoint x="1498" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NotifyRejectedHRManager_di" bpmnElement="MF_NotifyRejectedHRManager">
        <di:waypoint x="1498" y="428" />
