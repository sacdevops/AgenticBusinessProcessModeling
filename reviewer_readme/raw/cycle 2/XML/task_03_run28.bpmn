        <dc:Bounds x="1480" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1466" y="435" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

