<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_VacationRequest" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_VacationRequest">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolSupervisor" name="Supervisor" processRef="Process_Supervisor" />
    <bpmn:participant id="PoolHRManager" name="HR Manager" processRef="Process_HRManager" />

    <bpmn:messageFlow id="MF_SubmitRequest" sourceRef="PoolEmployee" targetRef="StartRequestReceived" name="Vacation request" />

    <bpmn:messageFlow id="MF_RequestApproval" sourceRef="TaskSendToSupervisor" targetRef="PoolSupervisor" name="Approval request" />
    <bpmn:messageFlow id="MF_SupervisorFeedback" sourceRef="PoolSupervisor" targetRef="CatchSupervisorFeedback" name="Feedback" />

    <bpmn:messageFlow id="MF_EscalateToHRManager" sourceRef="TaskEscalate" targetRef="PoolHRManager" name="Escalation" />
    <bpmn:messageFlow id="MF_HRManagerDecision" sourceRef="PoolHRManager" targetRef="CatchHRManagerDecision" name="Decision" />

    <bpmn:messageFlow id="MF_NotifyRejectedNoDays" sourceRef="EndRejectedNoDays" targetRef="PoolEmployee" name="Rejected" />
    <bpmn:messageFlow id="MF_NotifyRejectedSupervisor" sourceRef="EndRejectedSupervisor" targetRef="PoolEmployee" name="Rejected" />
    <bpmn:messageFlow id="MF_NotifyRejectedHRManager" sourceRef="EndRejectedHRManager" targetRef="PoolEmployee" name="Rejected" />
    <bpmn:messageFlow id="MF_NotifyApproved" sourceRef="EndApproved" targetRef="PoolEmployee" name="Approved" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HRPortal">
      <bpmn:lane id="LanePortalAutomation" name="Portal Automation">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskEscalate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchHRManagerDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRManagerApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedHRManager</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRReview" name="HR Review">
        <bpmn:flowNodeRef>TaskRecordCase</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskRecordCase" name="Record request">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndRejectedNoDays" name="Rejected">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectedNoDays" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Request approval">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorFeedback" name="Feedback received">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorFeedback" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Approved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Rejected">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectedSupervisor" />
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskEscalate" name="Escalate case">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchHRManagerDecision" name="Decision received">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_HRManagerDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndRejectedHRManager" name="Rejected">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectedHRManager" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartRequestReceived" targetRef="TaskRecordCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskRecordCase" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_5" name="No" sourceRef="GwEnoughDays" targetRef="EndRejectedNoDays" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskSendToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="GwWaitFeedback" targetRef="CatchTimeout" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchSupervisorFeedback" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_10" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_11" name="No" sourceRef="GwSupervisorApproved" targetRef="EndRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskBookVacation" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="CatchTimeout" targetRef="TaskEscalate" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskEscalate" targetRef="CatchHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="CatchHRManagerDecision" targetRef="GwHRManagerApproved" />
    <bpmn:sequenceFlow id="Flow_16" name="Yes" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_17" name="No" sourceRef="GwHRManagerApproved" targetRef="EndRejectedHRManager" />
  </bpmn:process>

  <bpmn:process id="Process_Employee" isExecutable="false" />
  <bpmn:process id="Process_Supervisor" isExecutable="false" />
  <bpmn:process id="Process_HRManager" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_VacationRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_VacationRequest" bpmnElement="Collaboration_VacationRequest">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
