<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_ReturnProcessing"
  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_ReturnProcessing">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_Retailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" processRef="Process_Customer" />
    <bpmn:messageFlow id="MF_Label" name="Return label" sourceRef="TaskSendLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_CloseNoArrival" name="Closed" sourceRef="EndClosedNoArrival" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NoRefundDamaged" name="No refund" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_Credit" name="Credit" sourceRef="TaskSendCredit" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitArrival</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchPackageArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout14Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCloseNoArrival</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoArrival</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoRefundDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardAccounting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCredit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRefunded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendLabel" name="Send label">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitArrival">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchPackageArrived" name="Package arrived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PackageArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout14Days" name="14 days exceeded">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskCloseNoArrival" name="Close return">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndClosedNoArrival" name="Closed no refund">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Closed" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskInspectGoods" name="Inspect goods">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods ok?" isMarkerVisible="true">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformNoRefund" name="Inform no refund">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndNoRefundDamaged" name="No refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskForwardAccounting" name="Forward accounting">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendCredit" name="Send credit">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRefunded" name="Refunded">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateLabel" targetRef="TaskSendLabel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskSendLabel" targetRef="GwWaitArrival" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitArrival" targetRef="CatchPackageArrived" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitArrival" targetRef="CatchTimeout14Days" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchPackageArrived" targetRef="TaskInspectGoods" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="CatchTimeout14Days" targetRef="TaskCloseNoArrival" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskCloseNoArrival" targetRef="EndClosedNoArrival" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInspectGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="Flow_11" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardAccounting" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskInformNoRefund" targetRef="EndNoRefundDamaged" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskForwardAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskInitiateRefund" targetRef="TaskSendCredit" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskSendCredit" targetRef="EndRefunded" />
  </bpmn:process>

  <bpmn:process id="Process_Customer" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_ReturnProcessing">
    <bpmndi:BPMNPlane id="BPMNPlane_ReturnProcessing" bpmnElement="Collaboration_ReturnProcessing">
      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouse_di" bpmnElement="LaneWarehouse" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAccounting_di" bpmnElement="LaneAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="230" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="207" y="165" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskGenerateLabel_di" bpmnElement="TaskGenerateLabel">
        <dc:Bounds x="330" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendLabel_di" bpmnElement="TaskSendLabel">
        <dc:Bounds x="480" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitArrival_di" bpmnElement="GwWaitArrival">
        <dc:Bounds x="650" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout14Days_di" bpmnElement="CatchTimeout14Days">
        <dc:Bounds x="780" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="746" y="58" width="104" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCloseNoArrival_di" bpmnElement="TaskCloseNoArrival">
        <dc:Bounds x="870" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoArrival_di" bpmnElement="EndClosedNoArrival">
        <dc:Bounds x="1030" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1004" y="135" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchPackageArrived_di" bpmnElement="CatchPackageArrived">
        <dc:Bounds x="780" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="754" y="295" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInspectGoods_di" bpmnElement="TaskInspectGoods">
        <dc:Bounds x="870" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="1030" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1015" y="292" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformNoRefund_di" bpmnElement="TaskInformNoRefund">
        <dc:Bounds x="1160" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNoRefundDamaged_di" bpmnElement="EndNoRefundDamaged">
        <dc:Bounds x="1320" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1308" y="265" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardAccounting_di" bpmnElement="TaskForwardAccounting">
        <dc:Bounds x="1160" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="1320" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendCredit_di" bpmnElement="TaskSendCredit">
        <dc:Bounds x="1470" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRefunded_di" bpmnElement="EndRefunded">
        <dc:Bounds x="1630" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1614" y="405" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="266" y="140" />
        <di:waypoint x="330" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="140" />
        <di:waypoint x="480" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="580" y="140" />
        <di:waypoint x="650" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="675" y="165" />
        <di:waypoint x="675" y="270" />
        <di:waypoint x="780" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="675" y="115" />
        <di:waypoint x="675" y="110" />
        <di:waypoint x="780" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="816" y="110" />
        <di:waypoint x="870" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="970" y="110" />
        <di:waypoint x="1030" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="816" y="270" />
        <di:waypoint x="870" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="970" y="260" />
        <di:waypoint x="1030" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1080" y="260" />
        <di:waypoint x="1160" y="240" />
        <bpmndi:BPMNLabel><dc:Bounds x="1110" y="238" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1260" y="240" />
        <di:waypoint x="1320" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1055" y="285" />
        <di:waypoint x="1055" y="360" />
        <di:waypoint x="1160" y="360" />
        <bpmndi:BPMNLabel><dc:Bounds x="1062" y="322" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1260" y="360" />
        <di:waypoint x="1320" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1420" y="380" />
        <di:waypoint x="1470" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1570" y="380" />
        <di:waypoint x="1630" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Label_di" bpmnElement="MF_Label">
        <di:waypoint x="530" y="180" />
        <di:waypoint x="530" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_CloseNoArrival_di" bpmnElement="MF_CloseNoArrival">
        <di:waypoint x="1048" y="128" />
        <di:waypoint x="1048" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_NoRefundDamaged_di" bpmnElement="MF_NoRefundDamaged">
        <di:waypoint x="1210" y="200" />
        <di:waypoint x="1210" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Credit_di" bpmnElement="MF_Credit">
        <di:waypoint x="1520" y="340" />
        <di:waypoint x="1520" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>