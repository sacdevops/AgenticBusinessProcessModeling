<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_OfficeSupplyProcurement\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_OfficeSupplyProcurement\">\n    <bpmn:participant id=\"PoolCompany\" name=\"Company\" processRef=\"Process_PoolCompany\" />\n    <bpmn:participant id=\"PoolStandardSupplier\" name=\"Standard Supplier\" processRef=\"Process_PoolStandardSupplier\" />\n    <bpmn:participant id=\"PoolAlternativeSupplier\" name=\"Alternative Supplier\" processRef=\"Process_PoolAlternativeSupplier\" />\n\n    <bpmn:messageFlow id=\"MF_OrderRequest_Standard\" name=\"Order request\" sourceRef=\"TaskSendOrderRequest\" targetRef=\"PoolStandardSupplier\" />\n    <bpmn:messageFlow id=\"MF_OrderRequest_Alternative\" name=\"Order request\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"PoolAlternativeSupplier\" />\n\n    <bpmn:messageFlow id=\"MF_StandardConfirmation\" name=\"Confirmation\" sourceRef=\"PoolStandardSupplier\" targetRef=\"CatchConfirmation\" />\n    <bpmn:messageFlow id=\"MF_StandardRejection\" name=\"Rejection\" sourceRef=\"PoolStandardSupplier\" targetRef=\"CatchRejection\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_PoolCompany\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Company\">\n      <bpmn:lane id=\"LaneSystem\" name=\"System\">\n        <bpmn:flowNodeRef>StartQuarterDay</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderRequest</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchConfirmation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchRejection</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndAlternativeSent</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneAdministration\" name=\"Administration\">\n        <bpmn:flowNodeRef>TaskManualIntervene</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartQuarterDay\" name=\"Quarter day\">\n      <bpmn:timerEventDefinition id=\"TED_QuarterCycle\" />\n      <bpmn:outgoing>Flow_01</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckInventory\" name=\"Check inventory\">\n      <bpmn:incoming>Flow_01</bpmn:incoming>\n      <bpmn:outgoing>Flow_02</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwLowInventory\" name=\"Low stock?\">\n      <bpmn:incoming>Flow_02</bpmn:incoming>\n      <bpmn:outgoing>Flow_03_Low</bpmn:outgoing>\n      <bpmn:outgoing>Flow_03_Ok</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndStockSufficient\" name=\"No order\">\n      <bpmn:incoming>Flow_03_Ok</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderRequest\" name=\"Send request\">\n      <bpmn:incoming>Flow_03_Low</bpmn:incoming>\n      <bpmn:outgoing>Flow_04</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitResponse\">\n      <bpmn:incoming>Flow_04</bpmn:incoming>\n      <bpmn:outgoing>Flow_05_Conf</bpmn:outgoing>\n      <bpmn:outgoing>Flow_05_Rej</bpmn:outgoing>\n      <bpmn:outgoing>Flow_05_Time</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchConfirmation\" name=\"Confirmation\">\n      <bpmn:incoming>Flow_05_Conf</bpmn:incoming>\n      <bpmn:outgoing>Flow_06</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Confirm\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndConfirmed\" name=\"Order confirmed\">\n      <bpmn:incoming>Flow_06</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchRejection\" name=\"Rejection\">\n      <bpmn:incoming>Flow_05_Rej</bpmn:incoming>\n      <bpmn:outgoing>Flow_07</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Reject\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"3 days\">\n      <bpmn:incoming>Flow_05_Time</bpmn:incoming>\n      <bpmn:outgoing>Flow_08</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_3BusinessDays\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:userTask id=\"TaskManualIntervene\" name=\"Manual review\">\n      <bpmn:incoming>Flow_07</bpmn:incoming>\n      <bpmn:incoming>Flow_08</bpmn:incoming>\n      <bpmn:outgoing>Flow_09</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwUseAlternative\" name=\"Alternative?\">\n      <bpmn:incoming>Flow_09</bpmn:incoming>\n      <bpmn:outgoing>Flow_10_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_10_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndCancelled\" name=\"Cancelled\">\n      <bpmn:incoming>Flow_10_No</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderAlternative\" name=\"Send order\">\n      <bpmn:incoming>Flow_10_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndAlternativeSent\" name=\"Order sent\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_01\" sourceRef=\"StartQuarterDay\" targetRef=\"TaskCheckInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_02\" sourceRef=\"TaskCheckInventory\" targetRef=\"GwLowInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_03_Low\" name=\"Yes\" sourceRef=\"GwLowInventory\" targetRef=\"TaskSendOrderRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_03_Ok\" name=\"No\" sourceRef=\"GwLowInventory\" targetRef=\"EndStockSufficient\" />\n    <bpmn:sequenceFlow id=\"Flow_04\" sourceRef=\"TaskSendOrderRequest\" targetRef=\"GwWaitResponse\" />\n    <bpmn:sequenceFlow id=\"Flow_05_Conf\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchConfirmation\" />\n    <bpmn:sequenceFlow id=\"Flow_05_Rej\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_05_Time\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_06\" sourceRef=\"CatchConfirmation\" targetRef=\"EndConfirmed\" />\n    <bpmn:sequenceFlow id=\"Flow_07\" sourceRef=\"CatchRejection\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_08\" sourceRef=\"CatchTimeout\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_09\" sourceRef=\"TaskManualIntervene\" targetRef=\"GwUseAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_10_Yes\" name=\"Yes\" sourceRef=\"GwUseAlternative\" targetRef=\"TaskSendOrderAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_10_No\" name=\"No\" sourceRef=\"GwUseAlternative\" targetRef=\"EndCancelled\" />\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"EndAlternativeSent\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_PoolStandardSupplier\" isExecutable=\"false\" />\n  <bpmn:process id=\"Process_PoolAlternativeSupplier\" isExecutable=\"false\" />\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_OfficeSupplyProcurement\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_OfficeSupplyProcurement\" bpmnElement=\"Collaboration_OfficeSupplyProcurement\">\n\n      <bpmndi:BPMNShape id=\"PoolCompany_di\" bpmnElement=\"PoolCompany\" isHorizontal=\"true\" isExpanded=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneSystem_di\" bpmnElement=\"LaneSystem\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneAdministration_di\" bpmnElement=\"LaneAdministration\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartQuarterDay_di\" bpmnElement=\"StartQuarterDay\">\n        <dc:Bounds x=\"230\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"215\" y=\"195\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckInventory_di\" bpmnElement=\"TaskCheckInventory\">\n        <dc:Bounds x=\"330\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwLowInventory_di\" bpmnElement=\"GwLowInventory\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"495\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"480\" y=\"202\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndStockSufficient_di\" bpmnElement=\"EndStockSufficient\">\n        <dc:Bounds x=\"620\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"606\" y=\"195\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderRequest_di\" bpmnElement=\"TaskSendOrderRequest\">\n        <dc:Bounds x=\"620\" y=\"40\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitResponse_di\" bpmnElement=\"GwWaitResponse\">\n        <dc:Bounds x=\"775\" y=\"55\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchConfirmation_di\" bpmnElement=\"CatchConfirmation\">\n        <dc:Bounds x=\"900\" y=\"40\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"878\" y=\"10\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndConfirmed_di\" bpmnElement=\"EndConfirmed\">\n        <dc:Bounds x=\"1020\" y=\"40\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"995\" y=\"83\" width=\"90\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchRejection_di\" bpmnElement=\"CatchRejection\">\n        <dc:Bounds x=\"900\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"890\" y=\"195\" width=\"55\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"900\" y=\"272\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"885\" y=\"315\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskManualIntervene_di\" bpmnElement=\"TaskManualIntervene\">\n        <dc:Bounds x=\"1040\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwUseAlternative_di\" bpmnElement=\"GwUseAlternative\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1205\" y=\"305\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1190\" y=\"362\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndCancelled_di\" bpmnElement=\"EndCancelled\">\n        <dc:Bounds x=\"1340\" y=\"312\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1328\" y=\"355\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderAlternative_di\" bpmnElement=\"TaskSendOrderAlternative\">\n        <dc:Bounds x=\"1340\" y=\"210\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndAlternativeSent_di\" bpmnElement=\"EndAlternativeSent\">\n        <dc:Bounds x=\"1480\" y=\"232\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1455\" y=\"275\" width=\"90\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolStandardSupplier_di\" bpmnElement=\"PoolStandardSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolAlternativeSupplier_di\" bpmnElement=\"PoolAlternativeSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_01_di\" bpmnElement=\"Flow_01\">\n        <di:waypoint x=\"266\" y=\"170\" />\n        <di:waypoint x=\"330\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_02_di\" bpmnElement=\"Flow_02\">\n        <di:waypoint x=\"430\" y=\"170\" />\n        <di:waypoint x=\"495\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_03_Ok_di\" bpmnElement=\"Flow_03_Ok\">\n        <di:waypoint x=\"545\" y=\"170\" />\n        <di:waypoint x=\"620\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"572\" y=\"152\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_03_Low_di\" bpmnElement=\"Flow_03_Low\">\n        <di:waypoint x=\"520\" y=\"145\" />\n        <di:waypoint x=\"520\" y=\"80\" />\n        <di:waypoint x=\"620\" y=\"80\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"535\" y=\"105\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_04_di\" bpmnElement=\"Flow_04\">\n        <di:waypoint x=\"720\" y=\"80\" />\n        <di:waypoint x=\"775\" y=\"80\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_05_Conf_di\" bpmnElement=\"Flow_05_Conf\">\n        <di:waypoint x=\"825\" y=\"80\" />\n        <di:waypoint x=\"860\" y=\"80\" />\n        <di:waypoint x=\"860\" y=\"58\" />\n        <di:waypoint x=\"900\" y=\"58\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_05_Rej_di\" bpmnElement=\"Flow_05_Rej\">\n        <di:waypoint x=\"800\" y=\"105\" />\n        <di:waypoint x=\"800\" y=\"170\" />\n        <di:waypoint x=\"900\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_05_Time_di\" bpmnElement=\"Flow_05_Time\">\n        <di:waypoint x=\"800\" y=\"105\" />\n        <di:waypoint x=\"800\" y=\"290\" />\n        <di:waypoint x=\"900\" y=\"290\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_06_di\" bpmnElement=\"Flow_06\">\n        <di:waypoint x=\"936\" y=\"58\" />\n        <di:waypoint x=\"1020\" y=\"58\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_07_di\" bpmnElement=\"Flow_07\">\n        <di:waypoint x=\"918\" y=\"188\" />\n        <di:waypoint x=\"918\" y=\"330\" />\n        <di:waypoint x=\"1040\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_08_di\" bpmnElement=\"Flow_08\">\n        <di:waypoint x=\"936\" y=\"290\" />\n        <di:waypoint x=\"1040\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_09_di\" bpmnElement=\"Flow_09\">\n        <di:waypoint x=\"1140\" y=\"330\" />\n        <di:waypoint x=\"1205\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_10_No_di\" bpmnElement=\"Flow_10_No\">\n        <di:waypoint x=\"1255\" y=\"330\" />\n        <di:waypoint x=\"1340\" y=\"330\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1294\" y=\"312\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_10_Yes_di\" bpmnElement=\"Flow_10_Yes\">\n        <di:waypoint x=\"1230\" y=\"305\" />\n        <di:waypoint x=\"1230\" y=\"250\" />\n        <di:waypoint x=\"1340\" y=\"250\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1243\" y=\"275\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_11_di\" bpmnElement=\"Flow_11\">\n        <di:waypoint x=\"1440\" y=\"250\" />\n        <di:waypoint x=\"1480\" y=\"250\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderRequest_Standard_di\" bpmnElement=\"MF_OrderRequest_Standard\">\n        <di:waypoint x=\"670\" y=\"40\" />\n        <di:waypoint x=\"670\" y=\"490\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_StandardConfirmation_di\" bpmnElement=\"MF_StandardConfirmation\">\n        <di:waypoint x=\"980\" y=\"490\" />\n        <di:waypoint x=\"980\" y=\"400\" />\n        <di:waypoint x=\"918\" y=\"400\" />\n        <di:waypoint x=\"918\" y=\"76\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_StandardRejection_di\" bpmnElement=\"MF_StandardRejection\">\n        <di:waypoint x=\"1040\" y=\"490\" />\n        <di:waypoint x=\"1040\" y=\"420\" />\n        <di:waypoint x=\"918\" y=\"420\" />\n        <di:waypoint x=\"918\" y=\"188\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderRequest_Alternative_di\" bpmnElement=\"MF_OrderRequest_Alternative\">\n        <di:waypoint x=\"1390\" y=\"210\" />\n        <di:waypoint x=\"1390\" y=\"600\" />\n      </bpmndi:BPMNEdge>\n\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</bpmn:definitions>\"\n}