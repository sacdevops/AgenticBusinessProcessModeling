<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolAuthority" name="Building Authority" processRef="Process_Authority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissingDocs" name="Missing docs" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissingDocs" name="Missing docs" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_SendToEnvAgency" name="Application" sourceRef="TaskSendToEnvAgency" targetRef="PoolEnvAgency" />
    <bpmn:messageFlow id="MF_EnvOpinion" name="Opinion" sourceRef="PoolEnvAgency" targetRef="CatchEnvOpinion" />

    <bpmn:messageFlow id="MF_InformApproval" name="Approval" sourceRef="TaskInformApproval" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejection" name="Rejection" sourceRef="TaskInformRejection" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Authority" name="Processing of building permits" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Authority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadlineExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardInternally</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToEnvAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnvPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRejectApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechPositive</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartApplication" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_YesComplete</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoComplete</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_NoComplete</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitMissingDocs">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4a</bpmn:outgoing>
      <bpmn:outgoing>Flow_4b</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_4a</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadlineExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_4b</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectTimeout</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskForwardInternally" name="Forward application">
      <bpmn:incoming>Flow_YesComplete</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskSendToEnvAgency" name="Request review">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="CatchEnvOpinion" name="Receive opinion">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="GwEnvPositive" name="Positive?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_EnvYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_EnvNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_EnvYes</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechPositive" name="OK?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_TechYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_TechNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_TechYes</bpmn:incoming>
      <bpmn:outgoing>Flow_10a</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskRejectApplication" name="Reject application">
      <bpmn:incoming>Flow_EnvNo</bpmn:incoming>
      <bpmn:incoming>Flow_TechNo</bpmn:incoming>
      <bpmn:incoming>Flow_RejectTimeout</bpmn:incoming>
      <bpmn:outgoing>Flow_10b</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwResult" name="Outcome?">
      <bpmn:incoming>Flow_10a</bpmn:incoming>
      <bpmn:incoming>Flow_10b</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformApproval" name="Inform citizen">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_11a</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskInformRejection" name="Inform citizen">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_11b</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Permit issued">
      <bpmn:incoming>Flow_11a</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejected" name="Application rejected">
      <bpmn:incoming>Flow_11b</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />

    <bpmn:sequenceFlow id="Flow_YesComplete" name="Yes" sourceRef="GwComplete" targetRef="TaskForwardInternally" />
    <bpmn:sequenceFlow id="Flow_NoComplete" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />

    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitMissingDocs" />
    <bpmn:sequenceFlow id="Flow_4a" sourceRef="GwWaitMissingDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_4b" sourceRef="GwWaitMissingDocs" targetRef="CatchDeadlineExceeded" />

    <bpmn:sequenceFlow id="Flow_5" sourceRef="CatchMissingDocs" targetRef="TaskForwardInternally" />
    <bpmn:sequenceFlow id="Flow_RejectTimeout" sourceRef="CatchDeadlineExceeded" targetRef="TaskRejectApplication" />

    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskForwardInternally" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="TaskSendToEnvAgency" targetRef="CatchEnvOpinion" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="CatchEnvOpinion" targetRef="GwEnvPositive" />

    <bpmn:sequenceFlow id="Flow_EnvYes" name="Yes" sourceRef="GwEnvPositive" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_EnvNo" name="No" sourceRef="GwEnvPositive" targetRef="TaskRejectApplication" />

    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskCheckTechnical" targetRef="GwTechPositive" />
    <bpmn:sequenceFlow id="Flow_TechYes" name="Yes" sourceRef="GwTechPositive" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_TechNo" name="No" sourceRef="GwTechPositive" targetRef="TaskRejectApplication" />

    <bpmn:sequenceFlow id="Flow_10a" sourceRef="TaskIssuePermit" targetRef="GwResult" />
    <bpmn:sequenceFlow id="Flow_10b" sourceRef="TaskRejectApplication" targetRef="GwResult" />

    <bpmn:sequenceFlow id="Flow_Approved" name="Approved" sourceRef="GwResult" targetRef="TaskInformApproval" />
    <bpmn:sequenceFlow id="Flow_Rejected" name="Rejected" sourceRef="GwResult" targetRef="TaskInformRejection" />

    <bpmn:sequenceFlow id="Flow_11a" sourceRef="TaskInformApproval" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_11b" sourceRef="TaskInformRejection" targetRef="EndRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolAuthority_di" bpmnElement="PoolAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneEngineer_di" bpmnElement="LaneEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEnvAgency_di" bpmnElement="PoolEnvAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="190" y="195" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwComplete_di" bpmnElement="GwComplete" isMarkerVisible="true">
        <dc:Bounds x="490" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="485" y="202" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocs_di" bpmnElement="TaskRequestMissingDocs">
        <dc:Bounds x="610" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitMissingDocs_di" bpmnElement="GwWaitMissingDocs">
        <dc:Bounds x="780" y="85" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocs_di" bpmnElement="CatchMissingDocs">
        <dc:Bounds x="900" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="868" y="62" width="100" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadlineExceeded_di" bpmnElement="CatchDeadlineExceeded">
        <dc:Bounds x="900" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="235" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardInternally_di" bpmnElement="TaskForwardInternally">
        <dc:Bounds x="1020" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToEnvAgency_di" bpmnElement="TaskSendToEnvAgency">
        <dc:Bounds x="1180" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchEnvOpinion_di" bpmnElement="CatchEnvOpinion">
        <dc:Bounds x="1340" y="152" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnvPositive_di" bpmnElement="GwEnvPositive" isMarkerVisible="true">
        <dc:Bounds x="1460" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1450" y="202" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="620" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechPositive_di" bpmnElement="GwTechPositive" isMarkerVisible="true">
        <dc:Bounds x="780" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="792" y="382" width="30" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="900" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRejectApplication_di" bpmnElement="TaskRejectApplication">
        <dc:Bounds x="1180" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwResult_di" bpmnElement="GwResult" isMarkerVisible="true">
        <dc:Bounds x="1340" y="305" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1328" y="362" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformApproval_di" bpmnElement="TaskInformApproval">
        <dc:Bounds x="1460" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformRejection_di" bpmnElement="TaskInformRejection">
        <dc:Bounds x="1460" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1610" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1590" y="315" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1610" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1578" y="415" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="490" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_YesComplete_di" bpmnElement="Flow_YesComplete">
        <di:waypoint x="540" y="170" />
        <di:waypoint x="1020" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="730" y="152" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NoComplete_di" bpmnElement="Flow_NoComplete">
        <di:waypoint x="515" y="145" />
        <di:waypoint x="515" y="110" />
        <di:waypoint x="610" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="530" y="96" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="710" y="110" />
        <di:waypoint x="780" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4a_di" bpmnElement="Flow_4a">
        <di:waypoint x="830" y="110" />
        <di:waypoint x="900" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4b_di" bpmnElement="Flow_4b">
        <di:waypoint x="805" y="135" />
        <di:waypoint x="805" y="210" />
        <di:waypoint x="900" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="936" y="110" />
        <di:waypoint x="978" y="110" />
        <di:waypoint x="978" y="170" />
        <di:waypoint x="1020" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_RejectTimeout_di" bpmnElement="Flow_RejectTimeout">
        <di:waypoint x="918" y="228" />
        <di:waypoint x="918" y="330" />
        <di:waypoint x="1180" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1120" y="170" />
        <di:waypoint x="1180" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1280" y="170" />
        <di:waypoint x="1340" y="192" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1440" y="192" />
        <di:waypoint x="1460" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_EnvYes_di" bpmnElement="Flow_EnvYes">
        <di:waypoint x="1485" y="195" />
        <di:waypoint x="1485" y="270" />
        <di:waypoint x="670" y="270" />
        <di:waypoint x="670" y="310" />
        <bpmndi:BPMNLabel><dc:Bounds x="1470" y="222" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_EnvNo_di" bpmnElement="Flow_EnvNo">
        <di:waypoint x="1510" y="170" />
        <di:waypoint x="1540" y="170" />
        <di:waypoint x="1540" y="330" />
        <di:waypoint x="1280" y="330" />
        <bpmndi:BPMNLabel><dc:Bounds x="1522" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="720" y="350" />
        <di:waypoint x="780" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_TechYes_di" bpmnElement="Flow_TechYes">
        <di:waypoint x="830" y="350" />
        <di:waypoint x="900" y="330" />
        <bpmndi:BPMNLabel><dc:Bounds x="846" y="332" width="20" height="14" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_TechNo_di" bpmnElement="Flow_TechNo">
        <di:waypoint x="805" y="375" />
        <di:waypoint x="805" y="430" />
        <di:waypoint x="1230" y="430" />
        <di:waypoint x="1230" y="370" />
        <bpmndi:BPMNLabel><dc:Bounds x="820" y="408" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10a_di" bpmnElement="Flow_10a">
        <di:waypoint x="1000" y="330" />
        <di:waypoint x="1340" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10b_di" bpmnElement="Flow_10b">
        <di:waypoint x="1280" y="330" />
        <di:waypoint x="1340" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Approved_di" bpmnElement="Flow_Approved">
        <di:waypoint x="1390" y="330" />
        <di:waypoint x="1425" y="330" />
        <di:waypoint x="1425" y="290" />
        <di:waypoint x="1460" y="290" />
        <bpmndi:BPMNLabel><dc:Bounds x="1402" y="300" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

