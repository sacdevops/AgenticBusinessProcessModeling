<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="External Assessor" />
    <bpmn:messageFlow id="MF_OrderToAssessor" name="Order" sourceRef="TaskSendOrder" targetRef="PoolAssessor" />
    <bpmn:messageFlow id="MF_ReportToInsurance" name="Report" sourceRef="PoolAssessor" targetRef="CatchReport" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskApproveLowAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch10Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedApprovedHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedRejectedHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneCoreSystem" name="Core System">
        <bpmn:flowNodeRef>TaskInitiatePaymentLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedApprovedLow</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Report received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionNotCovered" name="Send rejection">
      <bpmn:incoming>Flow_4_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedNotCovered" name="Case closed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_4_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmount" name=">≤1500?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Low</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_High</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskApproveLowAmount" name="Approve case">
      <bpmn:incoming>Flow_7_Low</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiatePaymentLow" name="Initiate payment">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalLow" name="Send approval">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedApprovedLow" name="Case closed">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrder" name="Send order">
      <bpmn:incoming>Flow_7_High</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitReport">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12_Report</bpmn:outgoing>
      <bpmn:outgoing>Flow_12_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReport" name="Report received">
      <bpmn:incoming>Flow_12_Report</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Report" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch10Days" name="10 days exceeded">
      <bpmn:incoming>Flow_12_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendRejectionDeadline" name="Send rejection">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedDeadline" name="Case closed">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review report">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalDecision" name="Approved?">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_17_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendApprovalHigh" name="Send approval">
      <bpmn:incoming>Flow_17_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedApprovedHigh" name="Case closed">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectionHigh" name="Send rejection">
      <bpmn:incoming>Flow_17_No</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedRejectedHigh" name="Case closed">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_4_No" name="No" sourceRef="GwCovered" targetRef="TaskSendRejectionNotCovered" />
    <bpmn:sequenceFlow id="Flow_4_Yes" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="TaskSendRejectionNotCovered" targetRef="EndClosedNotCovered" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="TaskCheckAmount" targetRef="GwAmount" />
    <bpmn:sequenceFlow id="Flow_7_Low" name="Yes" sourceRef="GwAmount" targetRef="TaskApproveLowAmount" />
    <bpmn:sequenceFlow id="Flow_7_High" name="No" sourceRef="GwAmount" targetRef="TaskSendOrder" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskApproveLowAmount" targetRef="TaskInitiatePaymentLow" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInitiatePaymentLow" targetRef="TaskSendApprovalLow" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="TaskSendApprovalLow" targetRef="EndClosedApprovedLow" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskSendOrder" targetRef="GwWaitReport" />
    <bpmn:sequenceFlow id="Flow_12_Report" sourceRef="GwWaitReport" targetRef="CatchReport" />
    <bpmn:sequenceFlow id="Flow_12_Timer" sourceRef="GwWaitReport" targetRef="Catch10Days" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="CatchReport" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Catch10Days" targetRef="TaskSendRejectionDeadline" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskSendRejectionDeadline" targetRef="EndClosedDeadline" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskReviewAssessment" targetRef="GwFinalDecision" />
    <bpmn:sequenceFlow id="Flow_17_Yes" name="Yes" sourceRef="GwFinalDecision" targetRef="TaskSendApprovalHigh" />
    <bpmn:sequenceFlow id="Flow_17_No" name="No" sourceRef="GwFinalDecision" targetRef="TaskSendRejectionHigh" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="TaskSendApprovalHigh" targetRef="EndClosedApprovedHigh" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="TaskSendRejectionHigh" targetRef="EndClosedRejectedHigh" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">
      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneCoreSystem_di" bpmnElement="LaneCoreSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="230" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="205" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="500" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="650" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="640" y="202" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionNotCovered_di" bpmnElement="TaskSendRejectionNotCovered">
        <dc:Bounds x="770" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNotCovered_di" bpmnElement="EndClosedNotCovered">
        <dc:Bounds x="920" y="92" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="901" y="135" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="770" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmount_di" bpmnElement="GwAmount" isMarkerVisible="true">
        <dc:Bounds x="920" y="205" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="902" y="262" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskApproveLowAmount_di" bpmnElement="TaskApproveLowAmount">
        <dc:Bounds x="1040" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePaymentLow_di" bpmnElement="TaskInitiatePaymentLow">
        <dc:Bounds x="1200" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalLow_di" bpmnElement="TaskSendApprovalLow">
        <dc:Bounds x="1360" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedApprovedLow_di" bpmnElement="EndClosedApprovedLow">
        <dc:Bounds x="1520" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1501" y="375" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrder_di" bpmnElement="TaskSendOrder">
        <dc:Bounds x="1040" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitReport_di" bpmnElement="GwWaitReport">
        <dc:Bounds x="1205" y="145" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReport_di" bpmnElement="CatchReport">
        <dc:Bounds x="1320" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1294" y="46" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch10Days_di" bpmnElement="Catch10Days">
        <dc:Bounds x="1320" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1288" y="255" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1420" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalDecision_di" bpmnElement="GwFinalDecision" isMarkerVisible="true">
        <dc:Bounds x="1555" y="75" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1540" y="132" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalHigh_di" bpmnElement="TaskSendApprovalHigh">
        <dc:Bounds x="1660" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedApprovedHigh_di" bpmnElement="EndClosedApprovedHigh">
        <dc:Bounds x="1810" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1791" y="95" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionHigh_di" bpmnElement="TaskSendRejectionHigh">
        <dc:Bounds x="1660" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedRejectedHigh_di" bpmnElement="EndClosedRejectedHigh">
        <dc:Bounds x="1810" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1791" y="185" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionDeadline_di" bpmnElement="TaskSendRejectionDeadline">
        <dc:Bounds x="1420" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedDeadline_di" bpmnElement="EndClosedDeadline">
        <dc:Bounds x="1550" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1529" y="255" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="266" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="170" />
        <di:waypoint x="650" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_No_di" bpmnElement="Flow_4_No">
        <di:waypoint x="675" y="145" />
        <di:waypoint x="675" y="110" />
        <di:waypoint x="770" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="686" y="116" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_Yes_di" bpmnElement="Flow_4_Yes">
        <di:waypoint x="700" y="170" />
        <di:waypoint x="770" y="230" />
        <bpmndi:BPMNLabel><dc:Bounds x="716" y="196" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="870" y="110" />
        <di:waypoint x="920" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="870" y="230" />
        <di:waypoint x="920" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_Low_di" bpmnElement="Flow_7_Low">
        <di:waypoint x="945" y="255" />
