<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_BuildingPermits\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_BuildingPermits\">\n    <bpmn:participant id=\"PoolBuildingAuthority\" name=\"Building Authority\" processRef=\"Process_BuildingAuthority\" />\n    <bpmn:participant id=\"PoolCitizen\" name=\"Citizen\" />\n    <bpmn:participant id=\"PoolEnvironmentalAgency\" name=\"Environmental Agency\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitApplication\" name=\"Application\" sourceRef=\"PoolCitizen\" targetRef=\"StartApplicationReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestMissingDocs\" name=\"Missing docs\" sourceRef=\"TaskRequestMissingDocs\" targetRef=\"PoolCitizen\" />\n    <bpmn:messageFlow id=\"MF_SubmitMissingDocs\" name=\"Documents\" sourceRef=\"PoolCitizen\" targetRef=\"CatchMissingDocsReceived\" />\n\n    <bpmn:messageFlow id=\"MF_SendToEnvironmental\" name=\"Application\" sourceRef=\"TaskSendToEnvironmental\" targetRef=\"PoolEnvironmentalAgency\" />\n    <bpmn:messageFlow id=\"MF_EnvironmentalOpinion\" name=\"Opinion\" sourceRef=\"PoolEnvironmentalAgency\" targetRef=\"CatchEnvironmentalOpinion\" />\n\n    <bpmn:messageFlow id=\"MF_NotifyResult\" name=\"Result\" sourceRef=\"TaskNotifyCitizen\" targetRef=\"PoolCitizen\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_BuildingAuthority\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_BuildingAuthority\">\n      <bpmn:lane id=\"LaneOfficial\" name=\"Official\">\n        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchMissingDocsReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchDeadlineExceeded</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendToEnvironmental</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchEnvironmentalOpinion</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwOpinionPositive</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneTestEngineer\" name=\"Test Engineer\">\n        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwTechOk</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneAdministration\" name=\"Administration\">\n        <bpmn:flowNodeRef>TaskReject</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyCitizen</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndDone</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartApplicationReceived\" name=\"Application received\">\n      <bpmn:messageEventDefinition id=\"MED_StartApplicationReceived\" />\n      <bpmn:outgoing>Flow_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskCheckCompleteness\" name=\"Check completeness\">\n      <bpmn:incoming>Flow_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwComplete\" name=\"Complete?\">\n      <bpmn:incoming>Flow_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskRequestMissingDocs\" name=\"Request documents\">\n      <bpmn:incoming>Flow_4</bpmn:incoming>\n      <bpmn:outgoing>Flow_5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitDocs\">\n      <bpmn:incoming>Flow_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_7</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchMissingDocsReceived\" name=\"Documents received\">\n      <bpmn:incoming>Flow_6</bpmn:incoming>\n      <bpmn:outgoing>Flow_8</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchMissingDocsReceived\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchDeadlineExceeded\" name=\"14 days exceeded\">\n      <bpmn:incoming>Flow_7</bpmn:incoming>\n      <bpmn:outgoing>Flow_9</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_CatchDeadlineExceeded\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:sendTask id=\"TaskSendToEnvironmental\" name=\"Send for review\">\n      <bpmn:incoming>Flow_3</bpmn:incoming>\n      <bpmn:incoming>Flow_8</bpmn:incoming>\n      <bpmn:outgoing>Flow_10</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:intermediateCatchEvent id=\"CatchEnvironmentalOpinion\" name=\"Opinion received\">\n      <bpmn:incoming>Flow_10</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchEnvironmentalOpinion\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwOpinionPositive\" name=\"Positive?\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n      <bpmn:outgoing>Flow_12</bpmn:outgoing>\n      <bpmn:outgoing>Flow_13</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:userTask id=\"TaskCheckTechnical\" name=\"Check technical\">\n      <bpmn:incoming>Flow_12</bpmn:incoming>\n      <bpmn:outgoing>Flow_14</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwTechOk\" name=\"OK?\">\n      <bpmn:incoming>Flow_14</bpmn:incoming>\n      <bpmn:outgoing>Flow_15</bpmn:outgoing>\n      <bpmn:outgoing>Flow_16</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:userTask id=\"TaskIssuePermit\" name=\"Issue permit\">\n      <bpmn:incoming>Flow_15</bpmn:incoming>\n      <bpmn:outgoing>Flow_17</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:userTask id=\"TaskReject\" name=\"Reject application\">\n      <bpmn:incoming>Flow_9</bpmn:incoming>\n      <bpmn:incoming>Flow_13</bpmn:incoming>\n      <bpmn:incoming>Flow_16</bpmn:incoming>\n      <bpmn:outgoing>Flow_18</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:sendTask id=\"TaskNotifyCitizen\" name=\"Notify citizen\">\n      <bpmn:incoming>Flow_17</bpmn:incoming>\n      <bpmn:incoming>Flow_18</bpmn:incoming>\n      <bpmn:outgoing>Flow_19</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndDone\" name=\"Completed\">\n      <bpmn:incoming>Flow_19</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_1\" sourceRef=\"StartApplicationReceived\" targetRef=\"TaskCheckCompleteness\" />\n    <bpmn:sequenceFlow id=\"Flow_2\" sourceRef=\"TaskCheckCompleteness\" targetRef=\"GwComplete\" />\n    <bpmn:sequenceFlow id=\"Flow_3\" name=\"Yes\" sourceRef=\"GwComplete\" targetRef=\"TaskSendToEnvironmental\" />\n    <bpmn:sequenceFlow id=\"Flow_4\" name=\"No\" sourceRef=\"GwComplete\" targetRef=\"TaskRequestMissingDocs\" />\n    <bpmn:sequenceFlow id=\"Flow_5\" sourceRef=\"TaskRequestMissingDocs\" targetRef=\"GwWaitDocs\" />\n    <bpmn:sequenceFlow id=\"Flow_6\" sourceRef=\"GwWaitDocs\" targetRef=\"CatchMissingDocsReceived\" />\n    <bpmn:sequenceFlow id=\"Flow_7\" sourceRef=\"GwWaitDocs\" targetRef=\"CatchDeadlineExceeded\" />\n    <bpmn:sequenceFlow id=\"Flow_8\" sourceRef=\"CatchMissingDocsReceived\" targetRef=\"TaskSendToEnvironmental\" />\n    <bpmn:sequenceFlow id=\"Flow_9\" sourceRef=\"CatchDeadlineExceeded\" targetRef=\"TaskReject\" />\n    <bpmn:sequenceFlow id=\"Flow_10\" sourceRef=\"TaskSendToEnvironmental\" targetRef=\"CatchEnvironmentalOpinion\" />\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"CatchEnvironmentalOpinion\" targetRef=\"GwOpinionPositive\" />\n    <bpmn:sequenceFlow id=\"Flow_12\" name=\"Yes\" sourceRef=\"GwOpinionPositive\" targetRef=\"TaskCheckTechnical\" />\n    <bpmn:sequenceFlow id=\"Flow_13\" name=\"No\" sourceRef=\"GwOpinionPositive\" targetRef=\"TaskReject\" />\n    <bpmn:sequenceFlow id=\"Flow_14\" sourceRef=\"TaskCheckTechnical\" targetRef=\"GwTechOk\" />\n    <bpmn:sequenceFlow id=\"Flow_15\" name=\"Yes\" sourceRef=\"GwTechOk\" targetRef=\"TaskIssuePermit\" />\n    <bpmn:sequenceFlow id=\"Flow_16\" name=\"No\" sourceRef=\"GwTechOk\" targetRef=\"TaskReject\" />\n    <bpmn:sequenceFlow id=\"Flow_17\" sourceRef=\"TaskIssuePermit\" targetRef=\"TaskNotifyCitizen\" />\n    <bpmn:sequenceFlow id=\"Flow_18\" sourceRef=\"TaskReject\" targetRef=\"TaskNotifyCitizen\" />\n    <bpmn:sequenceFlow id=\"Flow_19\" sourceRef=\"TaskNotifyCitizen\" targetRef=\"EndDone\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_BuildingPermits\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_BuildingPermits\" bpmnElement=\"Collaboration_BuildingPermits\">\n\n      <bpmndi:BPMNShape id=\"PoolBuildingAuthority_di\" bpmnElement=\"PoolBuildingAuthority\" isHorizontal=\"true\" isExpanded=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneOfficial_di\" bpmnElement=\"LaneOfficial\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"120\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneTestEngineer_di\" bpmnElement=\"LaneTestEngineer\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"200\" width=\"1400\" height=\"120\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneAdministration_di\" bpmnElement=\"LaneAdministration\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"320\" width=\"1400\" height=\"120\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolCitizen_di\" bpmnElement=\"PoolCitizen\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolEnvironmentalAgency_di\" bpmnElement=\"PoolEnvironmentalAgency\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartApplicationReceived_di\" bpmnElement=\"StartApplicationReceived\">\n        <dc:Bounds x=\"230\" y=\"122\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"205\" y=\"165\" width=\"86\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckCompleteness_di\" bpmnElement=\"TaskCheckCompleteness\">\n        <dc:Bounds x=\"330\" y=\"100\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwComplete_di\" bpmnElement=\"GwComplete\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"500\" y=\"115\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"492\" y=\"170\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskRequestMissingDocs_di\" bpmnElement=\"TaskRequestMissingDocs\">\n        <dc:Bounds x=\"620\" y=\"100\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitDocs_di\" bpmnElement=\"GwWaitDocs\">\n        <dc:Bounds x=\"770\" y=\"115\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchMissingDocsReceived_di\" bpmnElement=\"CatchMissingDocsReceived\">\n        <dc:Bounds x=\"900\" y=\"122\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"874\" y=\"165\" width=\"88\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchDeadlineExceeded_di\" bpmnElement=\"CatchDeadlineExceeded\">\n        <dc:Bounds x=\"900\" y=\"362\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"862\" y=\"405\" width=\"112\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendToEnvironmental_di\" bpmnElement=\"TaskSendToEnvironmental\">\n        <dc:Bounds x=\"1040\" y=\"100\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchEnvironmentalOpinion_di\" bpmnElement=\"CatchEnvironmentalOpinion\">\n        <dc:Bounds x=\"1210\" y=\"122\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1186\" y=\"165\" width=\"84\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwOpinionPositive_di\" bpmnElement=\"GwOpinionPositive\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1320\" y=\"115\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1312\" y=\"170\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckTechnical_di\" bpmnElement=\"TaskCheckTechnical\">\n        <dc:Bounds x=\"1390\" y=\"220\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwTechOk_di\" bpmnElement=\"GwTechOk\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1510\" y=\"235\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1518\" y=\"290\" width=\"30\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskIssuePermit_di\" bpmnElement=\"TaskIssuePermit\">\n        <dc:Bounds x=\"1630\" y=\"340\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskReject_di\" bpmnElement=\"TaskReject\">\n        <dc:Bounds x=\"1040\" y=\"340\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyCitizen_di\" bpmnElement=\"TaskNotifyCitizen\">\n        <dc:Bounds x=\"1220\" y=\"340\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndDone_di\" bpmnElement=\"EndDone\">\n        <dc:Bounds x=\"1360\" y=\"362\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1346\" y=\"405\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_1_di\" bpmnElement=\"Flow_1\">\n        <di:waypoint x=\"266\" y=\"140\" />\n        <di:waypoint x=\"330\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_2_di\" bpmnElement=\"Flow_2\">\n        <di:waypoint x=\"430\" y=\"140\" />\n        <di:waypoint x=\"500\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_3_di\" bpmnElement=\"Flow_3\">\n        <di:waypoint x=\"550\" y=\"140\" />\n        <di:waypoint x=\"1040\" y=\"140\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"780\" y=\"122\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_4_di\" bpmnElement=\"Flow_4\">\n        <di:waypoint x=\"525\" y=\"165\" />\n        <di:waypoint x=\"525\" y=\"180\" />\n        <di:waypoint x=\"620\" y=\"140\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"548\" y=\"171\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_5_di\" bpmnElement=\"Flow_5\">\n        <di:waypoint x=\"720\" y=\"140\" />\n        <di:waypoint x=\"770\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_6_di\" bpmnElement=\"Flow_6\">\n        <di:waypoint x=\"820\" y=\"140\" />\n        <di:waypoint x=\"900\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_7_di\" bpmnElement=\"Flow_7\">\n        <di:waypoint x=\"795\" y=\"165\" />\n        <di:waypoint x=\"795\" y=\"380\" />\n        <di:waypoint x=\"900\" y=\"380\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_8_di\" bpmnElement=\"Flow_8\">\n        <di:waypoint x=\"936\" y=\"140\" />\n        <di:waypoint x=\"1040\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_9_di\" bpmnElement=\"Flow_9\">\n        <di:waypoint x=\"936\" y=\"380\" />\n        <di:waypoint x=\"1040\" y=\"380\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_10_di\" bpmnElement=\"Flow_10\">\n        <di:waypoint x=\"1140\" y=\"140\" />\n        <di:waypoint x=\"1210\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_11_di\" bpmnElement=\"Flow_11\">\n        <di:waypoint x=\"1246\" y=\"140\" />\n        <di:waypoint x=\"1320\" y=\"140\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_12_di\" bpmnElement=\"Flow_12\">\n        <di:waypoint x=\"1345\" y=\"165\" />\n        <di:waypoint x=\"1345\" y=\"260\" />\n        <di:waypoint x=\"1390\" y=\"260\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1352\" y=\"205\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_13_di\" bpmnElement=\"Flow_13\">\n        <di:waypoint x=\"1345\" y=\"115\" />\n        <di:waypoint x=\"1345\" y=\"80\" />\n        <di:waypoint x=\"990\" y=\"80\" />\n        <di:waypoint x=\"990\" y=\"380\" />\n        <di:waypoint x=\"1040\" y=\"380\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1332\" y=\"92\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_14_di\" bpmnElement=\"Flow_14\">\n        <di:waypoint x=\"1490\" y=\"260\" />\n        <di:waypoint x=\"1510\" y=\"260\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_15_di\" bpmnElement=\"Flow_15\">\n        <di:waypoint x=\"1560\" y=\"260\" />\n        <di:waypoint x=\"1595\" y=\"260\" />\n        <di:waypoint x=\"1595\" y=\"380\" />\n        <di:waypoint x=\"1630\" y=\"380\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1585\" y=\"304\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_16_di\" bpmnElement=\"Flow_16\">\n        <di:waypoint x=\"1535\" y=\"235\" />\n        <di:waypoint x=\"1535\" y=\"210\" />\n        <di:waypoint x=\"1000\" y=\"210\" />\n        <di:waypoint x=\"1000\" y=\"380\" />\n        <di:waypoint x=\"1040\" y=\"380\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1516\" y=\"214\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_17_di\" bpmnElement=\"Flow_17\">\n        <di:waypoint x=\"1730\" y=\"380\" />\n        <di:waypoint x=\"1760\" y=\"380\" />\n        <di:waypoint x=\"1760\" y=\"520\" />\n        <di:waypoint x=\"1270\" y=\"520\" />\n        <di:waypoint x=\"1270\" y=\"420\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_18_di\" bpmnElement=\"Flow_18\">\n        <di:waypoint x=\"1140\" y=\"380\" />\n        <di:waypoint x=\"1220\" y=\"380\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_19_di\" bpmnElement=\"Flow_19\">\n        <di:waypoint x=\"1320\" y=\"380\" />\n        <di:waypoint x=\"1360\" y=\"380\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_SubmitApplication_di\" bpmnElement=\"MF_SubmitApplication\">\n        <di:waypoint x=\"460\" y=\"490\" />\n        <di:waypoint x=\"248\" y=\"158\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_RequestMissingDocs_di\" bpmnElement=\"MF_RequestMissingDocs\">\n        <di:waypoint x=\"670\" y=\"180\" />\n        <di:waypoint x=\"670\" y=\"490\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_SubmitMissingDocs_di\" bpmnElement=\"MF_SubmitMissingDocs\">\n        <di:waypoint x=\"760\" y=\"490\" />\n        <di:waypoint x=\"918\" y=\"158\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_SendToEnvironmental_di\" bpmnElement=\"MF_SendToEnvironmental\">\n        <di:waypoint x=\"1090\" y=\"180\" />\n        <di:waypoint x=\"1090\" y=\"600\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_EnvironmentalOpinion_di\" bpmnElement=\"MF_EnvironmentalOpinion\">\n        <di:waypoint x=\"1260\" y=\"600\" />\n        <di:waypoint x=\"1228\" y=\"158\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_NotifyResult_di\" bpmnElement=\"MF_NotifyResult\">\n        <di:waypoint x=\"1270\" y=\"340\" />\n        <di:waypoint x=\"1270\" y=\"520\" />\n      </bpmndi:BPMNEdge>\n\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</bpmn:definitions>\"\n}