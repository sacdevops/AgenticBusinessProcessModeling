      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="650" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitResponse_di" bpmnElement="GwWaitResponse">
        <dc:Bounds x="830" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardConfirmation_di" bpmnElement="CatchStandardConfirmation">
        <dc:Bounds x="982" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="968" y="195" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndConfirmed_di" bpmnElement="EndConfirmed">
        <dc:Bounds x="1110" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1088" y="195" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="970" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="961" y="435" width="54" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchNoResponse3Days_di" bpmnElement="CatchNoResponse3Days">
        <dc:Bounds x="820" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="808" y="435" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervene_di" bpmnElement="TaskManualIntervene">
        <dc:Bounds x="1080" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAlternative_di" bpmnElement="TaskCheckAlternative">
        <dc:Bounds x="1230" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1380" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1360" y="372" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrderAlternative_di" bpmnElement="TaskSendOrderAlternative">
        <dc:Bounds x="1470" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndOrderedAlternative_di" bpmnElement="EndOrderedAlternative">
        <dc:Bounds x="1640" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1618" y="335" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1470" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1448" y="435" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="268" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="510" y="170" />
      </bpmndi:BPMNEdge>
