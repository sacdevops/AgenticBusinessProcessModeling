        <di:waypoint x="1470" y="310" />
        <bpmndi:BPMNLabel><dc:Bounds x="1415" y="292" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C15_di" bpmnElement="Flow_C15">
        <di:waypoint x="1405" y="365" />
        <di:waypoint x="1405" y="410" />
        <di:waypoint x="1470" y="410" />
        <bpmndi:BPMNLabel><dc:Bounds x="1415" y="388" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C16_di" bpmnElement="Flow_C16">
        <di:waypoint x="1570" y="310" />
        <di:waypoint x="1640" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartStandardOrderRequest_di" bpmnElement="StartStandardOrderRequest">
        <dc:Bounds x="232" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="214" y="625" width="72" height="14" /></bpmndi:BPMNShape>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskStandardReview_di" bpmnElement="TaskStandardReview">
        <dc:Bounds x="340" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwStandardConfirm_di" bpmnElement="GwStandardConfirm" isMarkerVisible="true">
        <dc:Bounds x="510" y="575" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="494" y="632" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndStandardConfirmed_di" bpmnElement="EndStandardConfirmed">
        <dc:Bounds x="650" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="627" y="585" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndStandardRejected_di" bpmnElement="EndStandardRejected">
        <dc:Bounds x="650" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="633" y="665" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="268" y="600" />
        <di:waypoint x="340" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="440" y="600" />
        <di:waypoint x="510" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="560" y="600" />
        <di:waypoint x="605" y="600" />
