<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_Company" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_StandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_AlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderRequestToStandard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="StartStandardOrderRequest" />
    <bpmn:messageFlow id="MF_StandardConfirmation" name="Confirmation" sourceRef="EndStandardConfirmed" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_StandardRejection" name="Rejection" sourceRef="EndStandardRejected" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_OrderToAlternative" name="Order" sourceRef="TaskSendOrderAlternative" targetRef="StartAlternativeOrder" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarterlyCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchNoResponse3Days</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskManualIntervene</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderedAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarterlyCheck" name="Quarter start">
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Quarterly" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowStock" name="Low stock?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No action">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitResponse">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmed">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardConfirmed" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndConfirmed" name="Order confirmed">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejected">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StandardRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchNoResponse3Days" name="3 days">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskManualIntervene" name="Manual intervene">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckAlternative" name="Check alternative">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Use alternative?">
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndCancelled" name="Order cancelled">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderAlternative" name="Send order">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
      <bpmn:outgoing>Flow_C16</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndOrderedAlternative" name="Ordered alternative">
      <bpmn:incoming>Flow_C16</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartQuarterlyCheck" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckInventory" targetRef="GwLowStock" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwLowStock" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwLowStock" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitResponse" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="GwWaitResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitResponse" targetRef="CatchNoResponse3Days" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchStandardConfirmation" targetRef="EndConfirmed" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchStandardRejection" targetRef="TaskManualIntervene" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="CatchNoResponse3Days" targetRef="TaskManualIntervene" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskManualIntervene" targetRef="TaskCheckAlternative" />
    <bpmn:sequenceFlow id="Flow_C13" sourceRef="TaskCheckAlternative" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_C14" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderAlternative" />
    <bpmn:sequenceFlow id="Flow_C15" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_C16" sourceRef="TaskSendOrderAlternative" targetRef="EndOrderedAlternative" />
  </bpmn:process>

  <bpmn:process id="Process_StandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStandardOrderRequest" name="Request received">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartStandard" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskStandardReview" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwStandardConfirm" name="Deliverable?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStandardConfirmed" name="Send confirm">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStandardConfirmed" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndStandardRejected" name="Send reject">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStandardRejected" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartStandardOrderRequest" targetRef="TaskStandardReview" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskStandardReview" targetRef="GwStandardConfirm" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwStandardConfirm" targetRef="EndStandardConfirmed" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwStandardConfirm" targetRef="EndStandardRejected" />
  </bpmn:process>

  <bpmn:process id="Process_AlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAlternativeOrder" name="Order received">
      <bpmn:messageEventDefinition id="MED_StartAlternative" />
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="TaskAlternativeProcess" name="Process order">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndAlternativeDone" name="Order logged">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAlternativeOrder" targetRef="TaskAlternativeProcess" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="TaskAlternativeProcess" targetRef="EndAlternativeDone" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarterlyCheck_di" bpmnElement="StartQuarterlyCheck">
        <dc:Bounds x="232" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="215" y="195" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwLowStock_di" bpmnElement="GwLowStock" isMarkerVisible="true">
        <dc:Bounds x="510" y="145" width="50" height="50" />
