        <di:waypoint x="535" y="195" />
        <di:waypoint x="535" y="310" />
        <di:waypoint x="650" y="310" />
        <bpmndi:BPMNLabel><dc:Bounds x="545" y="250" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <di:waypoint x="560" y="170" />
        <di:waypoint x="650" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="595" y="150" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C5_di" bpmnElement="Flow_C5">
        <di:waypoint x="750" y="310" />
        <di:waypoint x="830" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C6_di" bpmnElement="Flow_C6">
        <di:waypoint x="855" y="285" />
        <di:waypoint x="855" y="170" />
        <di:waypoint x="982" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C7_di" bpmnElement="Flow_C7">
        <di:waypoint x="880" y="310" />
        <di:waypoint x="900" y="310" />
        <di:waypoint x="900" y="410" />
        <di:waypoint x="970" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8_di" bpmnElement="Flow_C8">
        <di:waypoint x="855" y="335" />
        <di:waypoint x="855" y="392" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C9_di" bpmnElement="Flow_C9">
        <di:waypoint x="1018" y="170" />
        <di:waypoint x="1110" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C10_di" bpmnElement="Flow_C10">
        <di:waypoint x="1006" y="410" />
        <di:waypoint x="1060" y="410" />
        <di:waypoint x="1060" y="340" />
        <di:waypoint x="1080" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C11_di" bpmnElement="Flow_C11">
        <di:waypoint x="838" y="428" />
        <di:waypoint x="838" y="460" />
        <di:waypoint x="1060" y="460" />
        <di:waypoint x="1060" y="340" />
        <di:waypoint x="1080" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C12_di" bpmnElement="Flow_C12">
        <di:waypoint x="1180" y="340" />
        <di:waypoint x="1230" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C13_di" bpmnElement="Flow_C13">
        <di:waypoint x="1330" y="340" />
        <di:waypoint x="1380" y="340" />
      </bpmndi:BPMNEdge>
