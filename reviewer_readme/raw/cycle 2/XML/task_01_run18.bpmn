<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_ReturnProcessing"
  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_ReturnProcessing">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_PoolRetailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" />

    <bpmn:messageFlow id="MF_RegisterReturn" name="Return registration" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
    <bpmn:messageFlow id="MF_ReturnLabel" name="Return label" sourceRef="TaskSendLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NoRefundTimeout" name="No refund" sourceRef="TaskInformTimeout" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NoRefundDamaged" name="No refund" sourceRef="TaskInformDamaged" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_RefundConfirmation" name="Credit confirmation" sourceRef="TaskSendConfirmation" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolRetailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitArrival</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReturnArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout14Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouseAccounting" name="Warehouse & Accounting">
        <bpmn:flowNodeRef>TaskCheckGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoRefundDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardAccounting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRefunded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartReturnRegistered" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendLabel" name="Send label">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitArrival">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReturnArrived" name="Return arrived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ReturnArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout14Days" name="14 days exceeded">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskInformTimeout" name="Inform closure">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedNoRefund" name="Closed no refund">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckGoods" name="Check goods">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods OK?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformDamaged" name="Inform issue">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndNoRefundDamaged" name="No refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="TaskForwardAccounting" name="Forward accounting">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendConfirmation" name="Send confirmation">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRefunded" name="Refunded">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateLabel" targetRef="TaskSendLabel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskSendLabel" targetRef="GwWaitArrival" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitArrival" targetRef="CatchReturnArrived" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitArrival" targetRef="CatchTimeout14Days" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchReturnArrived" targetRef="TaskCheckGoods" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="CatchTimeout14Days" targetRef="TaskInformTimeout" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskInformTimeout" targetRef="EndClosedNoRefund" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskCheckGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_10" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardAccounting" />
    <bpmn:sequenceFlow id="Flow_11" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformDamaged" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskInformDamaged" targetRef="EndNoRefundDamaged" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskForwardAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskInitiateRefund" targetRef="TaskSendConfirmation" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskSendConfirmation" targetRef="EndRefunded" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ReturnProcessing">
    <bpmndi:BPMNPlane id="BPMNPlane_ReturnProcessing" bpmnElement="Collaboration_ReturnProcessing">

      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouseAccounting_di" bpmnElement="LaneWarehouseAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="222" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="197" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskGenerateLabel_di" bpmnElement="TaskGenerateLabel">
        <dc:Bounds x="340" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendLabel_di" bpmnElement="TaskSendLabel">
        <dc:Bounds x="500" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitArrival_di" bpmnElement="GwWaitArrival">
        <dc:Bounds x="660" y="145" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout14Days_di" bpmnElement="CatchTimeout14Days">
        <dc:Bounds x="800" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="770" y="70" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformTimeout_di" bpmnElement="TaskInformTimeout">
        <dc:Bounds x="910" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoRefund_di" bpmnElement="EndClosedNoRefund">
        <dc:Bounds x="1052" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1025" y="145" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReturnArrived_di" bpmnElement="CatchReturnArrived">
        <dc:Bounds x="800" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="774" y="245" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckGoods_di" bpmnElement="TaskCheckGoods">
        <dc:Bounds x="910" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="1070" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1055" y="382" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardAccounting_di" bpmnElement="TaskForwardAccounting">
        <dc:Bounds x="1200" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="1360" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendConfirmation_di" bpmnElement="TaskSendConfirmation">
        <dc:Bounds x="1520" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRefunded_di" bpmnElement="EndRefunded">
        <dc:Bounds x="1670" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1652" y="345" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformDamaged_di" bpmnElement="TaskInformDamaged">
        <dc:Bounds x="1200" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNoRefundDamaged_di" bpmnElement="EndNoRefundDamaged">
        <dc:Bounds x="1362" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1339" y="425" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="258" y="170" />
        <di:waypoint x="340" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="170" />
        <di:waypoint x="660" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="685" y="195" />
        <di:waypoint x="685" y="220" />
        <di:waypoint x="800" y="220" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="685" y="145" />
        <di:waypoint x="685" y="120" />
        <di:waypoint x="800" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="836" y="120" />
        <di:waypoint x="910" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1010" y="120" />
        <di:waypoint x="1052" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="818" y="238" />
        <di:waypoint x="818" y="350" />
        <di:waypoint x="910" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1010" y="350" />
        <di:waypoint x="1070" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1120" y="350" />
        <di:waypoint x="1160" y="320" />
        <di:waypoint x="1200" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="1154" y="310" width="20" height="14" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1120" y="350" />
        <di:waypoint x="1160" y="400" />
        <di:waypoint x="1200" y="400" />
        <bpmndi:BPMNLabel><dc:Bounds x="1154" y="388" width="18" height="14" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1300" y="320" />
        <di:waypoint x="1360" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1460" y="320" />
        <di:waypoint x="1520" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1620" y="320" />
        <di:waypoint x="1670" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1300" y="400" />
        <di:waypoint x="1362" y="400" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RegisterReturn_di" bpmnElement="MF_RegisterReturn">
        <di:waypoint x="860" y="520" />
        <di:waypoint x="240" y="520" />
        <di:waypoint x="240" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_ReturnLabel_di" bpmnElement="MF_ReturnLabel">
        <di:waypoint x="550" y="210" />
        <di:waypoint x="550" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NoRefundTimeout_di" bpmnElement="MF_NoRefundTimeout">
        <di:waypoint x="960" y="80" />
        <di:waypoint x="960" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_NoRefundDamaged_di" bpmnElement="MF_NoRefundDamaged">
        <di:waypoint x="1250" y="440" />
        <di:waypoint x="1250" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RefundConfirmation_di" bpmnElement="MF_RefundConfirmation">
        <di:waypoint x="1570" y="280" />
        <di:waypoint x="1570" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>