<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_OfficeSupply\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_OfficeSupply\">\n    <bpmn:participant id=\"PoolCompany\" name=\"Company\" processRef=\"Process_Company\" />\n    <bpmn:participant id=\"PoolStandardSupplier\" name=\"Standard Supplier\" processRef=\"Process_StandardSupplier\" />\n    <bpmn:participant id=\"PoolAlternativeSupplier\" name=\"Alternative Supplier\" processRef=\"Process_AlternativeSupplier\" />\n\n    <bpmn:messageFlow id=\"MF_OrderRequest_Standard\" name=\"Order request\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"StartStandardOrderReceived\" />\n    <bpmn:messageFlow id=\"MF_OrderConfirm\" name=\"Confirmation\" sourceRef=\"EndStandardConfirmed\" targetRef=\"CatchConfirmation\" />\n    <bpmn:messageFlow id=\"MF_OrderReject\" name=\"Rejection\" sourceRef=\"EndStandardRejected\" targetRef=\"CatchRejection\" />\n\n    <bpmn:messageFlow id=\"MF_OrderRequest_Alternative\" name=\"Order request\" sourceRef=\"TaskSendOrderRequestAlternative\" targetRef=\"PoolAlternativeSupplier\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_Company\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Company\">\n      <bpmn:lane id=\"LaneSystem\" name=\"System\">\n        <bpmn:flowNodeRef>StartQuarterly</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitForSupplier</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchConfirmation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchRejection</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndNoAction</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneAdministration\" name=\"Administration\">\n        <bpmn:flowNodeRef>TaskManualIntervention</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderRequestAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndAlternativeSent</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartQuarterly\" name=\"Quarter start\">\n      <bpmn:outgoing>Flow_C1</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_Quarterly\" />\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckInventory\" name=\"Check inventory\">\n      <bpmn:incoming>Flow_C1</bpmn:incoming>\n      <bpmn:outgoing>Flow_C2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwLowInventory\" name=\"Low stock?\">\n      <bpmn:incoming>Flow_C2</bpmn:incoming>\n      <bpmn:outgoing>Flow_C3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndNoAction\" name=\"No order\">\n      <bpmn:incoming>Flow_C4</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderRequestStandard\" name=\"Send request\">\n      <bpmn:incoming>Flow_C3</bpmn:incoming>\n      <bpmn:outgoing>Flow_C5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitForSupplier\">\n      <bpmn:incoming>Flow_C5</bpmn:incoming>\n      <bpmn:outgoing>Flow_C6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C7</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C8</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchConfirmation\" name=\"Confirmation received\">\n      <bpmn:incoming>Flow_C6</bpmn:incoming>\n      <bpmn:outgoing>Flow_C9</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Confirm\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndConfirmed\" name=\"Order confirmed\">\n      <bpmn:incoming>Flow_C9</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchRejection\" name=\"Rejection received\">\n      <bpmn:incoming>Flow_C7</bpmn:incoming>\n      <bpmn:outgoing>Flow_C10</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Reject\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"3 days exceeded\">\n      <bpmn:incoming>Flow_C8</bpmn:incoming>\n      <bpmn:outgoing>Flow_C11</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_3Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:userTask id=\"TaskManualIntervention\" name=\"Manual review\">\n      <bpmn:incoming>Flow_C10</bpmn:incoming>\n      <bpmn:incoming>Flow_C11</bpmn:incoming>\n      <bpmn:outgoing>Flow_C12</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwUseAlternative\" name=\"Alternative supplier?\">\n      <bpmn:incoming>Flow_C12</bpmn:incoming>\n      <bpmn:outgoing>Flow_C13</bpmn:outgoing>\n      <bpmn:outgoing>Flow_C14</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendOrderRequestAlternative\" name=\"Send order\">\n      <bpmn:incoming>Flow_C13</bpmn:incoming>\n      <bpmn:outgoing>Flow_C15</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndAlternativeSent\" name=\"Order sent\">\n      <bpmn:incoming>Flow_C15</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndCancelled\" name=\"Order cancelled\">\n      <bpmn:incoming>Flow_C14</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_C1\" sourceRef=\"StartQuarterly\" targetRef=\"TaskCheckInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_C2\" sourceRef=\"TaskCheckInventory\" targetRef=\"GwLowInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_C3\" name=\"Yes\" sourceRef=\"GwLowInventory\" targetRef=\"TaskSendOrderRequestStandard\" />\n    <bpmn:sequenceFlow id=\"Flow_C4\" name=\"No\" sourceRef=\"GwLowInventory\" targetRef=\"EndNoAction\" />\n    <bpmn:sequenceFlow id=\"Flow_C5\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"GwWaitForSupplier\" />\n    <bpmn:sequenceFlow id=\"Flow_C6\" sourceRef=\"GwWaitForSupplier\" targetRef=\"CatchConfirmation\" />\n    <bpmn:sequenceFlow id=\"Flow_C7\" sourceRef=\"GwWaitForSupplier\" targetRef=\"CatchRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_C8\" sourceRef=\"GwWaitForSupplier\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_C9\" sourceRef=\"CatchConfirmation\" targetRef=\"EndConfirmed\" />\n    <bpmn:sequenceFlow id=\"Flow_C10\" sourceRef=\"CatchRejection\" targetRef=\"TaskManualIntervention\" />\n    <bpmn:sequenceFlow id=\"Flow_C11\" sourceRef=\"CatchTimeout\" targetRef=\"TaskManualIntervention\" />\n    <bpmn:sequenceFlow id=\"Flow_C12\" sourceRef=\"TaskManualIntervention\" targetRef=\"GwUseAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_C13\" name=\"Yes\" sourceRef=\"GwUseAlternative\" targetRef=\"TaskSendOrderRequestAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_C14\" name=\"No\" sourceRef=\"GwUseAlternative\" targetRef=\"EndCancelled\" />\n    <bpmn:sequenceFlow id=\"Flow_C15\" sourceRef=\"TaskSendOrderRequestAlternative\" targetRef=\"EndAlternativeSent\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_StandardSupplier\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartStandardOrderReceived\" name=\"Request received\">\n      <bpmn:outgoing>Flow_S1</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_StartStd\" />\n    </bpmn:startEvent>\n\n    <bpmn:exclusiveGateway id=\"GwStandardDecision\" name=\"Deliverable?\">\n      <bpmn:incoming>Flow_S1</bpmn:incoming>\n      <bpmn:outgoing>Flow_S2</bpmn:outgoing>\n      <bpmn:outgoing>Flow_S3</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndStandardConfirmed\" name=\"Confirmed\">\n      <bpmn:incoming>Flow_S2</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndStdConfirm\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndStandardRejected\" name=\"Rejected\">\n      <bpmn:incoming>Flow_S3</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndStdReject\" />\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_S1\" sourceRef=\"StartStandardOrderReceived\" targetRef=\"GwStandardDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_S2\" name=\"Yes\" sourceRef=\"GwStandardDecision\" targetRef=\"EndStandardConfirmed\" />\n    <bpmn:sequenceFlow id=\"Flow_S3\" name=\"No\" sourceRef=\"GwStandardDecision\" targetRef=\"EndStandardRejected\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_AlternativeSupplier\" isExecutable=\"false\" />\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_OfficeSupply\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_OfficeSupply\" bpmnElement=\"Collaboration_OfficeSupply\">\n\n      <bpmndi:BPMNShape id=\"PoolCompany_di\" bpmnElement=\"PoolCompany\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneSystem_di\" bpmnElement=\"LaneSystem\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneAdministration_di\" bpmnElement=\"LaneAdministration\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartQuarterly_di\" bpmnElement=\"StartQuarterly\">\n        <dc:Bounds x=\"220\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"203\" y=\"195\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckInventory_di\" bpmnElement=\"TaskCheckInventory\">\n        <dc:Bounds x=\"320\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwLowInventory_di\" bpmnElement=\"GwLowInventory\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"480\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"465\" y=\"202\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndNoAction_di\" bpmnElement=\"EndNoAction\">\n        <dc:Bounds x=\"640\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"628\" y=\"195\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderRequestStandard_di\" bpmnElement=\"TaskSendOrderRequestStandard\">\n        <dc:Bounds x=\"640\" y=\"40\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitForSupplier_di\" bpmnElement=\"GwWaitForSupplier\">\n        <dc:Bounds x=\"800\" y=\"55\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchConfirmation_di\" bpmnElement=\"CatchConfirmation\">\n        <dc:Bounds x=\"920\" y=\"40\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"890\" y=\"10\" width=\"96\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndConfirmed_di\" bpmnElement=\"EndConfirmed\">\n        <dc:Bounds x=\"1040\" y=\"40\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1018\" y=\"83\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchRejection_di\" bpmnElement=\"CatchRejection\">\n        <dc:Bounds x=\"920\" y=\"140\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"900\" y=\"183\" width=\"78\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"920\" y=\"240\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"894\" y=\"283\" width=\"88\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskManualIntervention_di\" bpmnElement=\"TaskManualIntervention\">\n        <dc:Bounds x=\"1040\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwUseAlternative_di\" bpmnElement=\"GwUseAlternative\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1200\" y=\"305\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1170\" y=\"362\" width=\"110\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderRequestAlternative_di\" bpmnElement=\"TaskSendOrderRequestAlternative\">\n        <dc:Bounds x=\"1320\" y=\"250\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndAlternativeSent_di\" bpmnElement=\"EndAlternativeSent\">\n        <dc:Bounds x=\"1460\" y=\"272\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1442\" y=\"315\" width=\"72\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndCancelled_di\" bpmnElement=\"EndCancelled\">\n        <dc:Bounds x=\"1320\" y=\"352\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1298\" y=\"395\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolStandardSupplier_di\" bpmnElement=\"PoolStandardSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"260\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartStandardOrderReceived_di\" bpmnElement=\"StartStandardOrderReceived\">\n        <dc:Bounds x=\"220\" y=\"602\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"202\" y=\"645\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwStandardDecision_di\" bpmnElement=\"GwStandardDecision\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"360\" y=\"595\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"345\" y=\"652\" width=\"80\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndStandardConfirmed_di\" bpmnElement=\"EndStandardConfirmed\">\n        <dc:Bounds x=\"520\" y=\"552\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"507\" y=\"595\" width=\"62\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndStandardRejected_di\" bpmnElement=\"EndStandardRejected\">\n        <dc:Bounds x=\"520\" y=\"652\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"508\" y=\"695\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolAlternativeSupplier_di\" bpmnElement=\"PoolAlternativeSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"800\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_C1_di\" bpmnElement=\"Flow_C1\">\n        <di:waypoint x=\"256\" y=\"170\" />\n        <di:waypoint x=\"320\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C2_di\" bpmnElement=\"Flow_C2\">\n        <di:waypoint x=\"420\" y=\"170\" />\n        <di:waypoint x=\"480\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C3_di\" bpmnElement=\"Flow_C3\">\n        <di:waypoint x=\"505\" y=\"145\" />\n        <di:waypoint x=\"505\" y=\"80\" />\n        <di:waypoint x=\"640\" y=\"80\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"512\" y=\"105\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C4_di\" bpmnElement=\"Flow_C4\">\n        <di:waypoint x=\"530\" y=\"170\" />\n        <di:waypoint x=\"640\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"585\" y=\"152\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C5_di\" bpmnElement=\"Flow_C5\">\n        <di:waypoint x=\"740\" y=\"80\" />\n        <di:waypoint x=\"800\" y=\"80\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C6_di\" bpmnElement=\"Flow_C6\">\n        <di:waypoint x=\"850\" y=\"80\" />\n        <di:waypoint x=\"920\" y=\"58\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C7_di\" bpmnElement=\"Flow_C7\">\n        <di:waypoint x=\"825\" y=\"105\" />\n        <di:waypoint x=\"825\" y=\"158\" />\n        <di:waypoint x=\"920\" y=\"158\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C8_di\" bpmnElement=\"Flow_C8\">\n        <di:waypoint x=\"825\" y=\"105\" />\n        <di:waypoint x=\"825\" y=\"258\" />\n        <di:waypoint x=\"920\" y=\"258\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C9_di\" bpmnElement=\"Flow_C9\">\n        <di:waypoint x=\"956\" y=\"58\" />\n        <di:waypoint x=\"1040\" y=\"58\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C10_di\" bpmnElement=\"Flow_C10\">\n        <di:waypoint x=\"956\" y=\"158\" />\n        <di:waypoint x=\"990\" y=\"158\" />\n        <di:waypoint x=\"990\" y=\"330\" />\n        <di:waypoint x=\"1040\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C11_di\" bpmnElement=\"Flow_C11\">\n        <di:waypoint x=\"956\" y=\"258\" />\n        <di:waypoint x=\"990\" y=\"258\" />\n        <di:waypoint x=\"990\" y=\"330\" />\n        <di:waypoint x=\"1040\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C12_di\" bpmnElement=\"Flow_C12\">\n        <di:waypoint x=\"1140\" y=\"330\" />\n        <di:waypoint x=\"1200\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C13_di\" bpmnElement=\"Flow_C13\">\n        <di:waypoint x=\"1225\" y=\"305\" />\n        <di:waypoint x=\"1225\" y=\"290\" />\n        <di:waypoint x=\"1320\" y=\"290\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1260\" y=\"272\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C14_di\" bpmnElement=\"Flow_C14\">\n        <di:waypoint x=\"1250\" y=\"330\" />\n        <di:waypoint x=\"1320\" y=\"370\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1278\" y=\"352\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_C15_di\" bpmnElement=\"Flow_C15\">\n        <di:waypoint x=\"1420\" y=\"290\" />\n        <di:waypoint x=\"1460\" y=\"290\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_S1_di\" bpmnElement=\"Flow_S1\">\n        <di:waypoint x=\"256\" y=\"620\" />\n        <di:waypoint x=\"360\" y=\"620\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_S2_di\" bpmnElement=\"Flow_S2\">\n        <di:waypoint x=\"410\" y=\"620\" />\n        <di:waypoint x=\"455\" y=\"620\" />\n        <di:waypoint x=\"455\" y=\"570\" />\n        <di:waypoint x=\"520\" y=\"570\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"438\" y=\"580\" width=\"20\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_S3_di\" bpmnElement=\"Flow_S3\">\n        <di:waypoint x=\"410\" y=\"620\" />\n        <di:waypoint x=\"455\" y=\"620\" />\n        <di:waypoint x=\"455\" y=\"670\" />\n        <di:waypoint x=\"520\" y=\"670\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"441\" y=\"650\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderRequest_Standard_di\" bpmnElement=\"MF_OrderRequest_Standard\">\n        <di:waypoint x=\"690\" y=\"120\" />\n        <di:waypoint x=\"690\" y=\"470\" />\n        <di:waypoint x=\"238\" y=\"470\" />\n        <di:waypoint x=\"238\" y=\"602\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderConfirm_di\" bpmnElement=\"MF_OrderConfirm\">\n        <di:waypoint x=\"538\" y=\"552\" />\n        <di:waypoint x=\"538\" y=\"420\" />\n        <di:waypoint x=\"938\" y=\"420\" />\n        <di:waypoint x=\"938\" y=\"76\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderReject_di\" bpmnElement=\"MF_OrderReject\">\n        <di:waypoint x=\"538\" y=\"688\" />\n        <di:waypoint x=\"538\" y=\"460\" />\n        <di:waypoint x=\"938\" y=\"460\" />\n        <di:waypoint x=\"938\" y=\"176\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderRequest_Alternative_di\" bpmnElement=\"MF_OrderRequest_Alternative\">\n        <di:waypoint x=\"1370\" y=\"250\" />\n        <di:waypoint x=\"1370\" y=\"780\" />\n        <di:waypoint x=\"860\" y=\"780\" />\n        <di:waypoint x=\"860\" y=\"800\" />\n      </bpmndi:BPMNEdge>\n\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</bpmn:definitions>\"\n}