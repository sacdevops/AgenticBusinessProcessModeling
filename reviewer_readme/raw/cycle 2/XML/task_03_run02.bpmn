<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_VacationRequest\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_VacationRequest\">\n    <bpmn:participant id=\"PoolHRPortal\" name=\"HR Portal\" processRef=\"Process_HRPortal\" />\n    <bpmn:participant id=\"PoolEmployee\" name=\"Employee\" />\n    <bpmn:participant id=\"PoolSupervisor\" name=\"Supervisor\" />\n    <bpmn:messageFlow id=\"MF_SubmitRequest\" name=\"Vacation request\" sourceRef=\"PoolEmployee\" targetRef=\"StartRequestReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestApproval\" name=\"Approval request\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"PoolSupervisor\" />\n    <bpmn:messageFlow id=\"MF_SupervisorFeedback\" name=\"Decision\" sourceRef=\"PoolSupervisor\" targetRef=\"CatchSupervisorFeedback\" />\n    <bpmn:messageFlow id=\"MF_NotifyApproved\" name=\"Approved\" sourceRef=\"TaskNotifyApproved\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedDays\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedDays\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedSupervisor\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedSupervisor\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedHR\" name=\"Rejected\" sourceRef=\"TaskNotifyRejectedHR\" targetRef=\"PoolEmployee\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_HRPortal\" name=\"Vacation Request Process\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_HRPortal\">\n      <bpmn:lane id=\"LanePortalAutomation\" name=\"Portal Automation\">\n        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckDays</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyRejectedDays</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndRejectedDays</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendApprovalRequest</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchSupervisorFeedback</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchTimeout5Days</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyRejectedSupervisor</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndRejectedSupervisor</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskNotifyRejectedHR</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndRejectedHR</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneHRManager\" name=\"HR Manager\">\n        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwHRApproved</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartRequestReceived\" name=\"Request received\">\n      <bpmn:messageEventDefinition id=\"MED_StartRequestReceived\" />\n      <bpmn:outgoing>Flow_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckDays\" name=\"Check days\">\n      <bpmn:incoming>Flow_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwEnoughDays\" name=\"Enough days?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>\n      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedDays\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_3_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_4</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedDays\" name=\"Rejected\">\n      <bpmn:incoming>Flow_4</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendApprovalRequest\" name=\"Request approval\">\n      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitFeedback\" name=\"\" >\n      <bpmn:incoming>Flow_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_6_Msg</bpmn:outgoing>\n      <bpmn:outgoing>Flow_6_Timer</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorFeedback\" name=\"Feedback received\">\n      <bpmn:incoming>Flow_6_Msg</bpmn:incoming>\n      <bpmn:outgoing>Flow_7</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchSupervisorFeedback\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwSupervisorApproved\" name=\"Approved?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_7</bpmn:incoming>\n      <bpmn:outgoing>Flow_8_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_8_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:serviceTask id=\"TaskBookVacation\" name=\"Book vacation\">\n      <bpmn:incoming>Flow_8_Yes</bpmn:incoming>\n      <bpmn:incoming>Flow_12_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_9</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:sendTask id=\"TaskNotifyApproved\" name=\"Notify approval\">\n      <bpmn:incoming>Flow_9</bpmn:incoming>\n      <bpmn:outgoing>Flow_10</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_10</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedSupervisor\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_8_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedSupervisor\" name=\"Rejected\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout5Days\" name=\"5 days exceeded\">\n      <bpmn:incoming>Flow_6_Timer</bpmn:incoming>\n      <bpmn:outgoing>Flow_20</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_CatchTimeout5Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:userTask id=\"TaskReviewEscalation\" name=\"Review escalation\">\n      <bpmn:incoming>Flow_20</bpmn:incoming>\n      <bpmn:outgoing>Flow_21</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwHRApproved\" name=\"Approved?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_21</bpmn:incoming>\n      <bpmn:outgoing>Flow_12_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_12_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskNotifyRejectedHR\" name=\"Notify rejection\">\n      <bpmn:incoming>Flow_12_No</bpmn:incoming>\n      <bpmn:outgoing>Flow_13</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndRejectedHR\" name=\"Rejected\">\n      <bpmn:incoming>Flow_13</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_1\" sourceRef=\"StartRequestReceived\" targetRef=\"TaskCheckDays\" />\n    <bpmn:sequenceFlow id=\"Flow_2\" sourceRef=\"TaskCheckDays\" targetRef=\"GwEnoughDays\" />\n    <bpmn:sequenceFlow id=\"Flow_3_No\" name=\"No\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskNotifyRejectedDays\" />\n    <bpmn:sequenceFlow id=\"Flow_3_Yes\" name=\"Yes\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskSendApprovalRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_4\" sourceRef=\"TaskNotifyRejectedDays\" targetRef=\"EndRejectedDays\" />\n    <bpmn:sequenceFlow id=\"Flow_5\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"GwWaitFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_6_Msg\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_6_Timer\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchTimeout5Days\" />\n    <bpmn:sequenceFlow id=\"Flow_7\" sourceRef=\"CatchSupervisorFeedback\" targetRef=\"GwSupervisorApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_8_Yes\" name=\"Yes\" sourceRef=\"GwSupervisorApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_8_No\" name=\"No\" sourceRef=\"GwSupervisorApproved\" targetRef=\"TaskNotifyRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_9\" sourceRef=\"TaskBookVacation\" targetRef=\"TaskNotifyApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_10\" sourceRef=\"TaskNotifyApproved\" targetRef=\"EndApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"TaskNotifyRejectedSupervisor\" targetRef=\"EndRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_20\" sourceRef=\"CatchTimeout5Days\" targetRef=\"TaskReviewEscalation\" />\n    <bpmn:sequenceFlow id=\"Flow_21\" sourceRef=\"TaskReviewEscalation\" targetRef=\"GwHRApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_12_Yes\" name=\"Yes\" sourceRef=\"GwHRApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_12_No\" name=\"No\" sourceRef=\"GwHRApproved\" targetRef=\"TaskNotifyRejectedHR\" />\n    <bpmn:sequenceFlow id=\"Flow_13\" sourceRef=\"TaskNotifyRejectedHR\" targetRef=\"EndRejectedHR\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_VacationRequest\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_VacationRequest\" bpmnElement=\"Collaboration_VacationRequest\">\n      <bpmndi:BPMNShape id=\"PoolHRPortal_di\" bpmnElement=\"PoolHRPortal\" isHorizontal=\"true\" isExpanded=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LanePortalAutomation_di\" bpmnElement=\"LanePortalAutomation\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneHRManager_di\" bpmnElement=\"LaneHRManager\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolEmployee_di\" bpmnElement=\"PoolEmployee\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"PoolSupervisor_di\" bpmnElement=\"PoolSupervisor\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartRequestReceived_di\" bpmnElement=\"StartRequestReceived\">\n        <dc:Bounds x=\"220\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"200\" y=\"195\" width=\"78\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckDays_di\" bpmnElement=\"TaskCheckDays\">\n        <dc:Bounds x=\"320\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwEnoughDays_di\" bpmnElement=\"GwEnoughDays\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"470\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"446\" y=\"202\" width=\"98\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedDays_di\" bpmnElement=\"TaskNotifyRejectedDays\">\n        <dc:Bounds x=\"590\" y=\"60\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedDays_di\" bpmnElement=\"EndRejectedDays\">\n        <dc:Bounds x=\"750\" y=\"82\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"736\" y=\"125\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendApprovalRequest_di\" bpmnElement=\"TaskSendApprovalRequest\">\n        <dc:Bounds x=\"590\" y=\"200\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitFeedback_di\" bpmnElement=\"GwWaitFeedback\">\n        <dc:Bounds x=\"740\" y=\"215\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorFeedback_di\" bpmnElement=\"CatchSupervisorFeedback\">\n        <dc:Bounds x=\"860\" y=\"142\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"834\" y=\"105\" width=\"88\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwSupervisorApproved_di\" bpmnElement=\"GwSupervisorApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"950\" y=\"135\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"940\" y=\"110\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskBookVacation_di\" bpmnElement=\"TaskBookVacation\">\n        <dc:Bounds x=\"1080\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskNotifyApproved_di\" bpmnElement=\"TaskNotifyApproved\">\n        <dc:Bounds x=\"1230\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndApproved_di\" bpmnElement=\"EndApproved\">\n        <dc:Bounds x=\"1390\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1376\" y=\"195\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedSupervisor_di\" bpmnElement=\"TaskNotifyRejectedSupervisor\">\n        <dc:Bounds x=\"1080\" y=\"30\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedSupervisor_di\" bpmnElement=\"EndRejectedSupervisor\">\n        <dc:Bounds x=\"1390\" y=\"52\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1376\" y=\"95\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout5Days_di\" bpmnElement=\"CatchTimeout5Days\">\n        <dc:Bounds x=\"860\" y=\"292\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"830\" y=\"335\" width=\"96\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskReviewEscalation_di\" bpmnElement=\"TaskReviewEscalation\">\n        <dc:Bounds x=\"950\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwHRApproved_di\" bpmnElement=\"GwHRApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1090\" y=\"325\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1080\" y=\"300\" width=\"70\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskNotifyRejectedHR_di\" bpmnElement=\"TaskNotifyRejectedHR\">\n        <dc:Bounds x=\"1230\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejectedHR_di\" bpmnElement=\"EndRejectedHR\">\n        <dc:Bounds x=\"1390\" y=\"332\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1376\" y=\"375\" width=\"64\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_1_di\" bpmnElement=\"Flow_1\">\n        <di:waypoint x=\"256\" y=\"170\" />\n        <di:waypoint x=\"320\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_2_di\" bpmnElement=\"Flow_2\">\n        <di:waypoint x=\"420\" y=\"170\" />\n        <di:waypoint x=\"470\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_3_No_di\" bpmnElement=\"Flow_3_No\">\n        <di:waypoint x=\"495\" y=\"145\" />\n        <di:waypoint x=\"495\" y=\"100\" />\n        <di:waypoint x=\"590\" y=\"100\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"505\" y=\"110\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <b