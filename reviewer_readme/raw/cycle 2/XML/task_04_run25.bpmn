<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolBuildingAuthority" name="Building Authority" processRef="Process_BuildingAuthority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvironmentalAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissingDocs" name="Missing docs" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissingDocs" name="Documents" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_SendToAgency" name="Application" sourceRef="TaskSendToAgency" targetRef="PoolEnvironmentalAgency" />
    <bpmn:messageFlow id="MF_AgencyOpinion" name="Opinion" sourceRef="PoolEnvironmentalAgency" targetRef="CatchAgencyOpinion" />

    <bpmn:messageFlow id="MF_InformApproval" name="Approved" sourceRef="TaskInformCitizenApproved" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejection" name="Rejected" sourceRef="TaskInformCitizenRejected" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_BuildingAuthority" isExecutable="false">

    <bpmn:laneSet id="LaneSet_BuildingAuthority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRecheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchAgencyOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOpinionPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformCitizenRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformCitizenApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndIssued</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechnicalOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:messageEventDefinition id="MED_StartApplication" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_YesComplete</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoIncomplete</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_NoIncomplete</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Documents received">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="14 days exceeded">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectTimeout</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskRecheckCompleteness" name="Recheck completeness">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCompleteAfter" name="Complete?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_YesComplete2</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoIncomplete2</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendToAgency" name="Send to agency">
      <bpmn:incoming>Flow_YesComplete</bpmn:incoming>
      <bpmn:incoming>Flow_YesComplete2</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchAgencyOpinion" name="Opinion received">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_AgencyOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwOpinionPositive" name="Positive?">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_OpinionYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_OpinionNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_OpinionYes</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechnicalOk" name="Valid?">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_TechYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_TechNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_TechYes</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskInformCitizenApproved" name="Inform citizen">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndIssued" name="Permit issued">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskInformCitizenRejected" name="Inform citizen">
      <bpmn:incoming>Flow_OpinionNo</bpmn:incoming>
      <bpmn:incoming>Flow_TechNo</bpmn:incoming>
      <bpmn:incoming>Flow_NoIncomplete2</bpmn:incoming>
      <bpmn:incoming>Flow_RejectTimeout</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejected" name="Application rejected">
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />
    <bpmn:sequenceFlow id="Flow_YesComplete" name="Yes" sourceRef="GwComplete" targetRef="TaskSendToAgency" />
    <bpmn:sequenceFlow id="Flow_NoIncomplete" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="GwWaitDocs" targetRef="CatchDeadline" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="CatchMissingDocs" targetRef="TaskRecheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskRecheckCompleteness" targetRef="GwCompleteAfter" />
    <bpmn:sequenceFlow id="Flow_YesComplete2" name="Yes" sourceRef="GwCompleteAfter" targetRef="TaskSendToAgency" />
    <bpmn:sequenceFlow id="Flow_NoIncomplete2" name="No" sourceRef="GwCompleteAfter" targetRef="TaskInformCitizenRejected" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskSendToAgency" targetRef="CatchAgencyOpinion" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="CatchAgencyOpinion" targetRef="GwOpinionPositive" />
    <bpmn:sequenceFlow id="Flow_OpinionYes" name="Yes" sourceRef="GwOpinionPositive" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_OpinionNo" name="No" sourceRef="GwOpinionPositive" targetRef="TaskInformCitizenRejected" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskCheckTechnical" targetRef="GwTechnicalOk" />
    <bpmn:sequenceFlow id="Flow_TechYes" name="Yes" sourceRef="GwTechnicalOk" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_TechNo" name="No" sourceRef="GwTechnicalOk" targetRef="TaskInformCitizenRejected" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskIssuePermit" targetRef="TaskInformCitizenApproved" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskInformCitizenApproved" targetRef="EndIssued" />
    <bpmn:sequenceFlow id="Flow_RejectTimeout" sourceRef="CatchDeadline" targetRef="TaskInformCitizenRejected" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="TaskInformCitizenRejected" targetRef="EndRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolBuildingAuthority_di" bpmnElement="PoolBuildingAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEnvironmentalAgency_di" bpmnElement="PoolEnvironmentalAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="196" y="195" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwComplete_di" bpmnElement="GwComplete" isMarkerVisible="true">
        <dc:Bounds x="480" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="475" y="198" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocs_di" bpmnElement="TaskRequestMissingDocs">
        <dc:Bounds x="600" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDocs_di" bpmnElement="GwWaitDocs">
        <dc:Bounds x="760" y="85" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocs_di" bpmnElement="CatchMissingDocs">
        <dc:Bounds x="900" y="70" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="872" y="33" width="92" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline_di" bpmnElement="CatchDeadline">
        <dc:Bounds x="900" y="170" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="871" y="213" width="95" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRecheckCompleteness_di" bpmnElement="TaskRecheckCompleteness">
        <dc:Bounds x="1020" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCompleteAfter_di" bpmnElement="GwCompleteAfter" isMarkerVisible="true">
        <dc:Bounds x="1180" y="45" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1175" y="98" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToAgency_di" bpmnElement="TaskSendToAgency">
        <dc:Bounds x="600" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAgencyOpinion_di" bpmnElement="CatchAgencyOpinion">
        <dc:Bounds x="760" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="732" y="235" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOpinionPositive_di" bpmnElement="GwOpinionPositive" isMarkerVisible="true">
        <dc:Bounds x="880" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="238" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="1000" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechnicalOk_di" bpmnElement="GwTechnicalOk" isMarkerVisible="true">
        <dc:Bounds x="1160" y="305" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1168" y="358" width="36" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1280" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformCitizenApproved_di" bpmnElement="TaskInformCitizenApproved">
        <dc:Bounds x="1440" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndIssued_di" bpmnElement="EndIssued">
        <dc:Bounds x="1600" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1586" y="325" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformCitizenRejected_di" bpmnElement="TaskInformCitizenRejected">
        <dc:Bounds x="1280" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1600" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1572" y="175" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="480" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_YesComplete_di" bpmnElement="Flow_YesComplete">
        <di:waypoint x="505" y="195" />
        <di:waypoint x="505" y="210" />
        <di:waypoint x="600" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="520" y="200" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NoIncomplete_di" bpmnElement="Flow_NoIncomplete">
        <di:waypoint x="505" y="145" />
        <di:waypoint x="505" y="110" />
        <di:waypoint x="600" y="110" />
        <bpmndi:BPMNLabel><dc:Bounds x="520" y="120" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="700" y="110" />
        <di:waypoint x="760" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="785" y="85" />
        <di:waypoint x="785" y="88" />
        <di:waypoint x="900" y="88" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="785" y="135" />
        <di:waypoint x="785" y="188" />
        <di:waypoint x="900" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="936" y="88" />
        <di:waypoint x="1020" y="70" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1120" y="70" />
        <di:waypoint x="1180" y="70" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_YesComplete2_di" bpmnElement="Flow_YesComplete2">
        <di:waypoint x="1205" y="95" />
        <di:waypoint x="1205" y="210" />
        <di:waypoint x="700" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="1212" y="150" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NoIncomplete2_di" bpmnElement="Flow_NoIncomplete2">
        <di:waypoint x="1230" y="70" />
        <di:waypoint x="1280" y="150" />
        <bpmndi:BPMNLabel><dc:Bounds x="1245" y="90" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="700" y="210" />
        <di:waypoint x="760" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="796" y="210" />
        <di:waypoint x="880" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_OpinionYes_di" bpmnElement="Flow_OpinionYes">
        <di:waypoint x="905" y="235" />
        <di:waypoint x="905" y="330" />
        <di:waypoint x="1000" y="330" />
        <bpmndi:BPMNLabel><dc:Bounds x="915" y="275" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_OpinionNo_di" bpmnElement="Flow_OpinionNo">
        <di:waypoint x="930" y="210" />
        <di:waypoint x="1280" y="150" />
        <bpmndi:BPMNLabel><dc:Bounds x="1100" y="170" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1100" y="330" />
        <di:waypoint x="1160" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_TechYes_di" bpmnElement="Flow_TechYes">
        <di:waypoint x="1210" y="330" />
        <di:waypoint x="1280" y="300" />
        <bpmndi:BPMNLabel><dc:Bounds x="1230" y="310" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_TechNo_di" bpmnElement="Flow_TechNo">
        <di:waypoint x="1185" y="305" />
        <di:waypoint x="1185" y="150" />
        <di:waypoint x="1280" y="150" />
        <bpmndi:BPMNLabel><dc:Bounds x="1195" y="200" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1380" y="300" />
        <di:waypoint x="1440" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1540" y="300" />
        <di:waypoint x="1600" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_RejectTimeout_di" bpmnElement="Flow_RejectTimeout">
        <di:waypoint x="936" y="188" />
        <di:waypoint x="1280" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1380" y="150" />
        <di:waypoint x="1600" y="150" />
      </bpmndi:BPMNEdge>

