        <di:waypoint x="535" y="650" />
        <di:waypoint x="660" y="650" />
        <bpmndi:BPMNLabel><dc:Bounds x="546" y="635" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="760" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="MF_OrderRequest_Standard_di" bpmnElement="MF_OrderRequest_Standard">
        <di:waypoint x="710" y="110" />
        <di:waypoint x="710" y="490" />
        <di:waypoint x="238" y="490" />
        <di:waypoint x="238" y="582" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Confirmation_FromStandard_di" bpmnElement="MF_Confirmation_FromStandard">
        <di:waypoint x="678" y="552" />
        <di:waypoint x="678" y="470" />
        <di:waypoint x="968" y="470" />
        <di:waypoint x="968" y="68" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Rejection_FromStandard_di" bpmnElement="MF_Rejection_FromStandard">
