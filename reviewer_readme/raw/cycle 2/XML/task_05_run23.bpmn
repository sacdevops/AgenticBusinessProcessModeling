      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1510" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1490" y="395" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

