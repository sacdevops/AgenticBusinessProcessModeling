      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardRejectionSent_di" bpmnElement="EndStandardRejectionSent">
        <dc:Bounds x="660" y="632" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="637" y="675" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="256" y="600" />
        <di:waypoint x="340" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="440" y="600" />
        <di:waypoint x="510" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="535" y="575" />
        <di:waypoint x="535" y="570" />
        <di:waypoint x="660" y="570" />
        <bpmndi:BPMNLabel><dc:Bounds x="546" y="556" width="22" height="14" /></bpmndi:BPMNLabel>
