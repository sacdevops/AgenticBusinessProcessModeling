      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="950" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="922" y="165" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchNoResponse3Days_di" bpmnElement="CatchNoResponse3Days">
        <dc:Bounds x="950" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="920" y="255" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskManualIntervention_di" bpmnElement="TaskManualIntervention">
        <dc:Bounds x="1100" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1260" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1241" y="372" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderRequestAlternative_di" bpmnElement="TaskSendOrderRequestAlternative">
        <dc:Bounds x="1380" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>
