<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_VacationRequest"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_VacationRequest">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHR" name="HR Department" processRef="Process_HR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_FinalDecision" name="Final decision" sourceRef="TaskSendDecision" targetRef="CatchFinalDecision" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartEmployeeNeedsVacation" name="Vacation needed">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:intermediateCatchEvent id="CatchFinalDecision" name="Decision received">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchFinalDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndEmployeeInformed" name="Employee informed">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartEmployeeNeedsVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="CatchFinalDecision" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="CatchFinalDecision" targetRef="EndEmployeeInformed" />
  </bpmn:process>

  <bpmn:process id="Process_HR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskAutoReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorReply</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEscalationTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ThrowSupervisorRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRManagerApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequestReceived" />
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?" isMarkerVisible="true">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskAutoReject" name="Auto reject">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendDecision" name="Send decision">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:outgoing>Flow_H6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosed" name="Case closed">
      <bpmn:incoming>Flow_H6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskForwardToSupervisor" name="Forward request">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H7</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_H7</bpmn:incoming>
      <bpmn:outgoing>Flow_H8</bpmn:outgoing>
      <bpmn:outgoing>Flow_H9</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorReply" name="Reply received">
      <bpmn:incoming>Flow_H8</bpmn:incoming>
      <bpmn:outgoing>Flow_H10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorReply" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchEscalationTimeout" name="5 days exceeded">
      <bpmn:incoming>Flow_H9</bpmn:incoming>
      <bpmn:outgoing>Flow_H11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_H10</bpmn:incoming>
      <bpmn:outgoing>Flow_H12</bpmn:outgoing>
      <bpmn:outgoing>Flow_H13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_H12</bpmn:incoming>
      <bpmn:outgoing>Flow_H14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approve?" isMarkerVisible="true">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorApproved" name="Approved sent">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupervisorApproved" />
    </bpmn:intermediateThrowEvent>

    <bpmn:intermediateThrowEvent id="ThrowSupervisorRejected" name="Rejected sent">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ThrowSupervisorRejected" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndSupervisorDone" name="Supervisor done">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
      <bpmn:incoming>Flow_S6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewEscalation" name="Review escalation">
      <bpmn:incoming>Flow_H11</bpmn:incoming>
      <bpmn:outgoing>Flow_M1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRManagerApproved" name="Approved?" isMarkerVisible="true">
      <bpmn:incoming>Flow_M1</bpmn:incoming>
      <bpmn:outgoing>Flow_M2</bpmn:outgoing>
      <bpmn:outgoing>Flow_M3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_H1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_H3" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskForwardToSupervisor" />
    <bpmn:sequenceFlow id="Flow_H4" name="No" sourceRef="GwEnoughDays" targetRef="TaskAutoReject" />
    <bpmn:sequenceFlow id="Flow_H5" sourceRef="TaskAutoReject" targetRef="TaskSendDecision" />
    <bpmn:sequenceFlow id="Flow_H6" sourceRef="TaskSendDecision" targetRef="EndClosed" />
    <bpmn:sequenceFlow id="Flow_H7" sourceRef="TaskForwardToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_H8" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorReply" />
    <bpmn:sequenceFlow id="Flow_H9" sourceRef="GwWaitFeedback" targetRef="CatchEscalationTimeout" />
    <bpmn:sequenceFlow id="Flow_H10" sourceRef="CatchSupervisorReply" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_H11" sourceRef="CatchEscalationTimeout" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_H12" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H13" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskSendDecision" />
    <bpmn:sequenceFlow id="Flow_H14" sourceRef="TaskBookVacation" targetRef="TaskSendDecision" />

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="TaskForwardToSupervisor" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwSupervisorDecision" targetRef="ThrowSupervisorRejected" />
    <bpmn:sequenceFlow id="Flow_S5" sourceRef="ThrowSupervisorApproved" targetRef="EndSupervisorDone" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="ThrowSupervisorRejected" targetRef="EndSupervisorDone" />

    <bpmn:sequenceFlow id="Flow_M1" sourceRef="TaskReviewEscalation" targetRef="GwHRManagerApproved" />
    <bpmn:sequenceFlow id="Flow_M2" name="Yes" sourceRef="GwHRManagerApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_M3" name="No" sourceRef="GwHRManagerApproved" targetRef="TaskSendDecision" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_VacationRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_VacationRequest" bpmnElement="Collaboration_VacationRequest">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="260" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="630" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEmployeeNeedsVacation_di" bpmnElement="StartEmployeeNeedsVacation">
        <dc:Bounds x="220" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="235" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="330" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchFinalDecision_di" bpmnElement="CatchFinalDecision">
        <dc:Bounds x="520" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="486" y="235" width="105" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEmployeeInformed_di" bpmnElement="EndEmployeeInformed">
        <dc:Bounds x="650" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="626" y="235" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="220" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="202" y="475" width="77" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="330" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="480" y="425" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="464" y="482" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskAutoReject_di" bpmnElement="TaskAutoReject">
        <dc:Bounds x="590" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskForwardToSupervisor_di" bpmnElement="TaskForwardToSupervisor">
        <dc:Bounds x="590" y="540" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="740" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchSupervisorReply_di" bpmnElement="CatchSupervisorReply">
        <dc:Bounds x="860" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="834" y="475" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchEscalationTimeout_di" bpmnElement="CatchEscalationTimeout">
        <dc:Bounds x="860" y="672" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="826" y="715" width="106" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="980" y="425" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="978" y="482" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1090" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendDecision_di" bpmnElement="TaskSendDecision">
        <dc:Bounds x="1250" y="410" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndClosed_di" bpmnElement="EndClosed">
        <dc:Bounds x="1390" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1372" y="475" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="740" y="540" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwSupervisorDecision_di" bpmnElement="GwSupervisorDecision" isMarkerVisible="true">
        <dc:Bounds x="890" y="555" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="886" y="612" width="58" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ThrowSupervisorApproved_di" bpmnElement="ThrowSupervisorApproved">
        <dc:Bounds x="1000" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="968" y="595" width="102" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ThrowSupervisorRejected_di" bpmnElement="ThrowSupervisorRejected">
        <dc:Bounds x="1000" y="600" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="968" y="643" width="104" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndSupervisorDone_di" bpmnElement="EndSupervisorDone">
        <dc:Bounds x="1120" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1098" y="635" width="83" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewEscalation_di" bpmnElement="TaskReviewEscalation">
        <dc:Bounds x="980" y="660" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwHRManagerApproved_di" bpmnElement="GwHRManagerApproved" isMarkerVisible="true">
        <dc:Bounds x="1130" y="675" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1128" y="732" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_E1_di" bpmnElement="Flow_E1">
        <di:waypoint x="256" y="210" />
        <di:waypoint x="330" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_di" bpmnElement="Flow_E2">
        <di:waypoint x="430" y="210" />
        <di:waypoint x="520" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E3_di" bpmnElement="Flow_E3">
        <di:waypoint x="556" y="210" />
        <di:waypoint x="650" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_H1_di" bpmnElement="Flow_H1">
        <di:waypoint x="256" y="450" />
        <di:waypoint x="330" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H2_di" bpmnElement="Flow_H2">
        <di:waypoint x="430" y="450" />
        <di:waypoint x="480" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H3_di" bpmnElement="Flow_H3">
        <di:waypoint x="505" y="475" />
        <di:waypoint x="505" y="580" />
        <di:waypoint x="590" y="580" />
        <bpmndi:BPMNLabel><dc:Bounds x="515" y="525" width="20" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H4_di" bpmnElement="Flow_H4">
        <di:waypoint x="530" y="450" />
        <di:waypoint x="590" y="450" />
        <bpmndi:BPMNLabel><dc:Bounds x="557" y="430" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H5_di" bpmnElement="Flow_H5">
        <di:waypoint x="690" y="450" />
        <di:waypoint x="1250" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H6_di" bpmnElement="Flow_H6">
        <di:waypoint x="1350" y="450" />
        <di:waypoint x="1390" y="450" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_H7_di" bpmnElement="Flow_H7">
        <di:waypoint x="690" y="580" />
        <di:waypoint x="765" y="580" />
        <di:waypoint x="765" y="475" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H8_di" bpmnElement="Flow_H8">
        <di:waypoint x="790" y="450" />
        <di:waypoint x="860" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H9_di" bpmnElement="Flow_H9">
        <di:waypoint x="765" y="475" />
        <di:waypoint x="765" y="690" />
        <di:waypoint x="860" y="690" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H10_di" bpmnElement="Flow_H10">
        <di:waypoint x="896" y="450" />
        <di:waypoint x="980" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H11_di" bpmnElement="Flow_H11">
        <di:waypoint x="896" y="690" />
        <di:waypoint x="980" y="700" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H12_di" bpmnElement="Flow_H12">
        <di:waypoint x="1030" y="450" />
        <di:waypoint x="1090" y="450" />
        <bpmndi:BPMNLabel><dc:Bounds x="1054" y="430" width="20" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H13_di" bpmnElement="Flow_H13">
        <di:waypoint x="1005" y="425" />
        <di:waypoint x="1005" y="370" />
        <di:waypoint x="1300" y="370" />
        <di:waypoint x="1300" y="410" />
        <bpmndi:BPMNLabel><dc:Bounds x="1013" y="392" width="18" height="14" /></bpmndi:BPMNEdge>
