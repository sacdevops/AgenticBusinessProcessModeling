<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_Vacation\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_Vacation\">\n    <bpmn:participant id=\"PoolHRPortal\" name=\"HR Portal\" processRef=\"Process_HRPortal\" />\n    <bpmn:participant id=\"PoolSupervisor\" name=\"Supervisor\" processRef=\"Process_Supervisor\" />\n    <bpmn:participant id=\"PoolHRDept\" name=\"HR Department\" processRef=\"Process_HRDept\" />\n    <bpmn:participant id=\"PoolEmployee\" name=\"Employee\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitRequest\" name=\"Request\" sourceRef=\"PoolEmployee\" targetRef=\"StartRequestReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestApproval\" name=\"Approval\" sourceRef=\"TaskSendApproval\" targetRef=\"StartApprovalRequested\" />\n\n    <bpmn:messageFlow id=\"MF_SupervisorApproved\" name=\"Approved\" sourceRef=\"EndSupervisorApproved\" targetRef=\"CatchSupervisorApproved\" />\n    <bpmn:messageFlow id=\"MF_SupervisorRejected\" name=\"Rejected\" sourceRef=\"EndSupervisorRejected\" targetRef=\"CatchSupervisorRejected\" />\n\n    <bpmn:messageFlow id=\"MF_EscalateToHR\" name=\"Escalation\" sourceRef=\"TaskEscalate\" targetRef=\"StartEscalationReceived\" />\n    <bpmn:messageFlow id=\"MF_HRApproved\" name=\"Approved\" sourceRef=\"TaskSendHRApproved\" targetRef=\"CatchHRApproved\" />\n    <bpmn:messageFlow id=\"MF_HRRejected\" name=\"Rejected\" sourceRef=\"TaskSendHRRejected\" targetRef=\"CatchHRRejected\" />\n\n    <bpmn:messageFlow id=\"MF_NotifyRejectedBalance\" name=\"Rejected\" sourceRef=\"EndRejectBalance\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyApproved\" name=\"Approved\" sourceRef=\"EndNotifyApproved\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedSupervisor\" name=\"Rejected\" sourceRef=\"EndNotifyRejectedSupervisor\" targetRef=\"PoolEmployee\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedHR\" name=\"Rejected\" sourceRef=\"EndNotifyRejectedHR\" targetRef=\"PoolEmployee\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_HRPortal\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartRequestReceived\" name=\"Request received\">\n      <bpmn:messageEventDefinition id=\"MED_StartRequest\" />\n      <bpmn:outgoing>Flow_HP_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckBalance\" name=\"Check balance\">\n      <bpmn:incoming>Flow_HP_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwEnoughDays\" name=\"Enough days?\">\n      <bpmn:incoming>Flow_HP_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_HP_4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndRejectBalance\" name=\"Rejected\">\n      <bpmn:incoming>Flow_HP_4</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndRejectBalance\" />\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendApproval\" name=\"Send approval\">\n      <bpmn:incoming>Flow_HP_3</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitFeedback\" name=\"\">\n      <bpmn:incoming>Flow_HP_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_HP_7</bpmn:outgoing>\n      <bpmn:outgoing>Flow_HP_8</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_HP_6</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_9</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchSupApproved\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorRejected\" name=\"Rejected\">\n      <bpmn:incoming>Flow_HP_7</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_10</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchSupRejected\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"5 days\">\n      <bpmn:incoming>Flow_HP_8</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_11</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_5Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:sendTask id=\"TaskEscalate\" name=\"Send escalation\">\n      <bpmn:incoming>Flow_HP_11</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_12</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitHRDecision\" name=\"\">\n      <bpmn:incoming>Flow_HP_12</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_13</bpmn:outgoing>\n      <bpmn:outgoing>Flow_HP_14</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchHRApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_HP_13</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_15</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchHRApproved\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchHRRejected\" name=\"Rejected\">\n      <bpmn:incoming>Flow_HP_14</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_16</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_CatchHRRejected\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:serviceTask id=\"TaskBookVacation\" name=\"Book vacation\">\n      <bpmn:incoming>Flow_HP_9</bpmn:incoming>\n      <bpmn:incoming>Flow_HP_15</bpmn:incoming>\n      <bpmn:outgoing>Flow_HP_17</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:endEvent id=\"EndNotifyApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_HP_17</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndNotifyApproved\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndNotifyRejectedSupervisor\" name=\"Rejected\">\n      <bpmn:incoming>Flow_HP_10</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndNotifyRejectedSup\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndNotifyRejectedHR\" name=\"Rejected\">\n      <bpmn:incoming>Flow_HP_16</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndNotifyRejectedHR\" />\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_HP_1\" sourceRef=\"StartRequestReceived\" targetRef=\"TaskCheckBalance\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_2\" sourceRef=\"TaskCheckBalance\" targetRef=\"GwEnoughDays\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_3\" name=\"Yes\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskSendApproval\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_4\" name=\"No\" sourceRef=\"GwEnoughDays\" targetRef=\"EndRejectBalance\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_5\" sourceRef=\"TaskSendApproval\" targetRef=\"GwWaitFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_6\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_7\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_8\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_9\" sourceRef=\"CatchSupervisorApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_10\" sourceRef=\"CatchSupervisorRejected\" targetRef=\"EndNotifyRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_11\" sourceRef=\"CatchTimeout\" targetRef=\"TaskEscalate\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_12\" sourceRef=\"TaskEscalate\" targetRef=\"GwWaitHRDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_13\" sourceRef=\"GwWaitHRDecision\" targetRef=\"CatchHRApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_14\" sourceRef=\"GwWaitHRDecision\" targetRef=\"CatchHRRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_15\" sourceRef=\"CatchHRApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_16\" sourceRef=\"CatchHRRejected\" targetRef=\"EndNotifyRejectedHR\" />\n    <bpmn:sequenceFlow id=\"Flow_HP_17\" sourceRef=\"TaskBookVacation\" targetRef=\"EndNotifyApproved\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_Supervisor\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartApprovalRequested\" name=\"Approval requested\">\n      <bpmn:messageEventDefinition id=\"MED_StartApproval\" />\n      <bpmn:outgoing>Flow_S_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskReviewRequest\" name=\"Review request\">\n      <bpmn:incoming>Flow_S_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_S_2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwApprove\" name=\"Approve?\">\n      <bpmn:incoming>Flow_S_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_S_3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_S_4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndSupervisorApproved\" name=\"Approved\">\n      <bpmn:incoming>Flow_S_3</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndSupApproved\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndSupervisorRejected\" name=\"Rejected\">\n      <bpmn:incoming>Flow_S_4</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_EndSupRejected\" />\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_S_1\" sourceRef=\"StartApprovalRequested\" targetRef=\"TaskReviewRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_S_2\" sourceRef=\"TaskReviewRequest\" targetRef=\"GwApprove\" />\n    <bpmn:sequenceFlow id=\"Flow_S_3\" name=\"Yes\" sourceRef=\"GwApprove\" targetRef=\"EndSupervisorApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_S_4\" name=\"No\" sourceRef=\"GwApprove\" targetRef=\"EndSupervisorRejected\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_HRDept\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_HRDept\">\n      <bpmn:lane id=\"LaneHROperations\" name=\"HR Operations\">\n        <bpmn:flowNodeRef>StartEscalationReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskAssignManager</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneHRManager\" name=\"HR Manager\">\n        <bpmn:flowNodeRef>TaskFinalReview</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwFinalApprove</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendHRApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendHRRejected</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndHRDecisionSent</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartEscalationReceived\" name=\"Escalation received\">\n      <bpmn:messageEventDefinition id=\"MED_StartEscalation\" />\n      <bpmn:outgoing>Flow_HR_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskAssignManager\" name=\"Assign manager\">\n      <bpmn:incoming>Flow_HR_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_HR_2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:userTask id=\"TaskFinalReview\" name=\"Final review\">\n      <bpmn:incoming>Flow_HR_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_HR_3</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwFinalApprove\" name=\"Approve?\">\n      <bpmn:incoming>Flow_HR_3</bpmn:incoming>\n      <bpmn:outgoing>Flow_HR_4</bpmn:outgoing>\n      <bpmn:outgoing>Flow_HR_5</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendHRApproved\" name=\"Send approval\">\n      <bpmn:incoming>Flow_HR_4</bpmn:incoming>\n      <bpmn:outgoing>Flow_HR_6</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:sendTask id=\"TaskSendHRRejected\" name=\"Send rejection\">\n      <bpmn:incoming>Flow_HR_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_HR_7</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndHRDecisionSent\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_HR_6</bpmn:incoming>\n      <bpmn:incoming>Flow_HR_7</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_HR_1\" sourceRef=\"StartEscalationReceived\" targetRef=\"TaskAssignManager\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_2\" sourceRef=\"TaskAssignManager\" targetRef=\"TaskFinalReview\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_3\" sourceRef=\"TaskFinalReview\" targetRef=\"GwFinalApprove\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_4\" name=\"Yes\" sourceRef=\"GwFinalApprove\" targetRef=\"TaskSendHRApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_5\" name=\"No\" sourceRef=\"GwFinalApprove\" targetRef=\"TaskSendHRRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_6\" sourceRef=\"TaskSendHRApproved\" targetRef=\"EndHRDecisionSent\" />\n    <bpmn:sequenceFlow id=\"Flow_HR_7\" sourceRef=\"TaskSendHRRejected\" targetRef=\"EndHRDecisionSent\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_Vacation\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_Vacation\" bpmnElement=\"Collaboration_Vacation\">\n\n      <bpmndi:BPMNShape id=\"PoolHRPortal_di\" bpmnElement=\"PoolHRPortal\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartRequestReceived_di\" bpmnElement=\"StartRequestReceived\">\n        <dc:Bounds x=\"222\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"198\" y=\"245\" width=\"86\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckBalance_di\" bpmnElement=\"TaskCheckBalance\">\n        <dc:Bounds x=\"320\" y=\"180\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwEnoughDays_di\" bpmnElement=\"GwEnoughDays\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"475\" y=\"195\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"458\" y=\"252\" width=\"84\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndRejectBalance_di\" bpmnElement=\"EndRejectBalance\">\n        <dc:Bounds x=\"622\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"612\" y=\"245\" width=\"55\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendApproval_di\" bpmnElement=\"TaskSendApproval\">\n        <dc:Bounds x=\"590\" y=\"300\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitFeedback_di\" bpmnElement=\"GwWaitFeedback\">\n        <dc:Bounds x=\"745\" y=\"315\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorApproved_di\" bpmnElement=\"CatchSupervisorApproved\">\n        <dc:Bounds x=\"860\" y=\"332\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"850\" y=\"375\" width=\"58\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorRejected_di\" bpmnElement=\"CatchSupervisorRejected\">\n        <dc:Bounds x=\"860\" y=\"212\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"848\" y=\"255\" width=\"63\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"860\" y=\"92\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"857\" y=\"65\" width=\"43\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskEscalate_di\" bpmnElement=\"TaskEscalate\">\n        <dc:Bounds x=\"960\" y=\"70\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitHRDecision_di\" bpmnElement=\"GwWaitHRDecision\">\n        <dc:Bounds x=\"1115\" y=\"85\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchHRApproved_di\" bpmnElement=\"CatchHRApproved\">\n        <dc:Bounds x=\"1230\" y=\"92\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1220\" y=\"135\" width=\"58\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchHRRejected_di\" bpmnElement=\"CatchHRRejected\">\n        <dc:Bounds x=\"1230\" y=\"212\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1218\" y=\"255\" width=\"63\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskBookVacation_di\" bpmnElement=\"TaskBookVacation\">\n        <dc:Bounds x=\"1060\" y=\"300\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndNotifyApproved_di\" bpmnElement=\"EndNotifyApproved\">\n        <dc:Bounds x=\"1232\" y=\"322\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1222\" y=\"365\" width=\"58\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndNotifyRejectedSupervisor_di\" bpmnElement=\"EndNotifyRejectedSupervisor\">\n        <dc:Bounds x=\"1062\" y=\"212\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1048\" y=\"255\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndNotifyRejectedHR_di\" bpmnElement=\"EndNotifyRejectedHR\">\n        <dc:Bounds x=\"1390\" y=\"212\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1376\" y=\"255\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolSupervisor_di\" bpmnElement=\"PoolSupervisor\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"220\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartApprovalRequested_di\" bpmnElement=\"StartApprovalRequested\">\n        <dc:Bounds x=\"222\" y=\"582\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"196\" y=\"625\" width=\"92\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskReviewRequest_di\" bpmnElement=\"TaskReviewRequest\">\n        <dc:Bounds x=\"320\" y=\"560\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwApprove_di\" bpmnElement=\"GwApprove\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"475\" y=\"575\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"478\" y=\"632\" width=\"55\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndSupervisorApproved_di\" bpmnElement=\"EndSupervisorApproved\">\n        <dc:Bounds x=\"622\" y=\"542\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"612\" y=\"585\" width=\"58\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndSupervisorRejected_di\" bpmnElement=\"EndSupervisorRejected\">\n        <dc:Bounds x=\"622\" y=\"642\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"610\" y=\"685\" width=\"63\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolHRDept_di\" bpmnElement=\"PoolHRDept\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"760\" width=\"1400\" height=\"300\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneHROperations_di\" bpmnElement=\"LaneHROperations\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"760\" width=\"1400\" height=\"150\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneHRManager_di\" bpmnElement=\"LaneHRManager\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"910\" width=\"1400\" height=\"150\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartEscalationReceived_di\" bpmnElement=\"StartEscalationReceived\">\n        <dc:Bounds x=\"222\" y=\"817\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"192\" y=\"860\" width=\"102\