<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_OfficeSupplyProcurement\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n  <bpmn:collaboration id=\"Collaboration_OfficeSupplyProcurement\">\n    <bpmn:participant id=\"PoolCompany\" name=\"Company\" processRef=\"Process_Company\" />\n    <bpmn:participant id=\"PoolStandardSupplier\" name=\"Standard Supplier\" />\n    <bpmn:participant id=\"PoolAlternativeSupplier\" name=\"Alternative Supplier\" />\n    <bpmn:messageFlow id=\"MF_OrderRequestStandard\" name=\"Order request\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"PoolStandardSupplier\" />\n    <bpmn:messageFlow id=\"MF_Confirmation\" name=\"Confirmation\" sourceRef=\"PoolStandardSupplier\" targetRef=\"CatchConfirmation\" />\n    <bpmn:messageFlow id=\"MF_Rejection\" name=\"Rejection\" sourceRef=\"PoolStandardSupplier\" targetRef=\"CatchRejection\" />\n    <bpmn:messageFlow id=\"MF_OrderRequestAlternative\" name=\"Order request\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"PoolAlternativeSupplier\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_Company\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_Company\">\n      <bpmn:lane id=\"LaneSystem\" name=\"System\">\n        <bpmn:flowNodeRef>StartQuarter</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwLowStock</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitResponse</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchConfirmation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchRejection</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchTimeout</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndConfirmed</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneAdministration\" name=\"Administration\">\n        <bpmn:flowNodeRef>TaskManualIntervene</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwOrderAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendOrderAlternative</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndAlternativeOrdered</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartQuarter\" name=\"Quarter start\">\n      <bpmn:outgoing>Flow_Q1</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_QuarterStart\" />\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckInventory\" name=\"Check inventory\">\n      <bpmn:incoming>Flow_Q1</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwLowStock\" name=\"Low stock?\">\n      <bpmn:incoming>Flow_Q2</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q3_Low</bpmn:outgoing>\n      <bpmn:outgoing>Flow_Q3_Ok</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:endEvent id=\"EndStockSufficient\" name=\"No order\">\n      <bpmn:incoming>Flow_Q3_Ok</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sendTask id=\"TaskSendOrderRequestStandard\" name=\"Send request\">\n      <bpmn:incoming>Flow_Q3_Low</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q4</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitResponse\">\n      <bpmn:incoming>Flow_Q4</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q5_Conf</bpmn:outgoing>\n      <bpmn:outgoing>Flow_Q5_Rej</bpmn:outgoing>\n      <bpmn:outgoing>Flow_Q5_Time</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchConfirmation\" name=\"Confirmation\">\n      <bpmn:incoming>Flow_Q5_Conf</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q6</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Confirmation\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndConfirmed\" name=\"Order confirmed\">\n      <bpmn:incoming>Flow_Q6</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchRejection\" name=\"Rejection\">\n      <bpmn:incoming>Flow_Q5_Rej</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q7</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_Rejection\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchTimeout\" name=\"3 days\">\n      <bpmn:incoming>Flow_Q5_Time</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q8</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_3BusinessDays\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:userTask id=\"TaskManualIntervene\" name=\"Manual intervene\">\n      <bpmn:incoming>Flow_Q7</bpmn:incoming>\n      <bpmn:incoming>Flow_Q8</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q9</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:userTask id=\"TaskCheckAlternative\" name=\"Check alternative\">\n      <bpmn:incoming>Flow_Q9</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q10</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwOrderAlternative\" name=\"Order alternative?\">\n      <bpmn:incoming>Flow_Q10</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q11_Yes</bpmn:outgoing>\n      <bpmn:outgoing>Flow_Q11_No</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendOrderAlternative\" name=\"Send order\">\n      <bpmn:incoming>Flow_Q11_Yes</bpmn:incoming>\n      <bpmn:outgoing>Flow_Q12</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndAlternativeOrdered\" name=\"Alternative ordered\">\n      <bpmn:incoming>Flow_Q12</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndCancelled\" name=\"Order cancelled\">\n      <bpmn:incoming>Flow_Q11_No</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_Q1\" sourceRef=\"StartQuarter\" targetRef=\"TaskCheckInventory\" />\n    <bpmn:sequenceFlow id=\"Flow_Q2\" sourceRef=\"TaskCheckInventory\" targetRef=\"GwLowStock\" />\n    <bpmn:sequenceFlow id=\"Flow_Q3_Low\" name=\"Yes\" sourceRef=\"GwLowStock\" targetRef=\"TaskSendOrderRequestStandard\" />\n    <bpmn:sequenceFlow id=\"Flow_Q3_Ok\" name=\"No\" sourceRef=\"GwLowStock\" targetRef=\"EndStockSufficient\" />\n    <bpmn:sequenceFlow id=\"Flow_Q4\" sourceRef=\"TaskSendOrderRequestStandard\" targetRef=\"GwWaitResponse\" />\n    <bpmn:sequenceFlow id=\"Flow_Q5_Conf\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchConfirmation\" />\n    <bpmn:sequenceFlow id=\"Flow_Q5_Rej\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_Q5_Time\" sourceRef=\"GwWaitResponse\" targetRef=\"CatchTimeout\" />\n    <bpmn:sequenceFlow id=\"Flow_Q6\" sourceRef=\"CatchConfirmation\" targetRef=\"EndConfirmed\" />\n    <bpmn:sequenceFlow id=\"Flow_Q7\" sourceRef=\"CatchRejection\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_Q8\" sourceRef=\"CatchTimeout\" targetRef=\"TaskManualIntervene\" />\n    <bpmn:sequenceFlow id=\"Flow_Q9\" sourceRef=\"TaskManualIntervene\" targetRef=\"TaskCheckAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_Q10\" sourceRef=\"TaskCheckAlternative\" targetRef=\"GwOrderAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_Q11_Yes\" name=\"Yes\" sourceRef=\"GwOrderAlternative\" targetRef=\"TaskSendOrderAlternative\" />\n    <bpmn:sequenceFlow id=\"Flow_Q11_No\" name=\"No\" sourceRef=\"GwOrderAlternative\" targetRef=\"EndCancelled\" />\n    <bpmn:sequenceFlow id=\"Flow_Q12\" sourceRef=\"TaskSendOrderAlternative\" targetRef=\"EndAlternativeOrdered\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_OfficeSupplyProcurement\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_OfficeSupplyProcurement\" bpmnElement=\"Collaboration_OfficeSupplyProcurement\">\n      <bpmndi:BPMNShape id=\"PoolCompany_di\" bpmnElement=\"PoolCompany\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1500\" height=\"360\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneSystem_di\" bpmnElement=\"LaneSystem\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1500\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneAdministration_di\" bpmnElement=\"LaneAdministration\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1500\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolStandardSupplier_di\" bpmnElement=\"PoolStandardSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1500\" height=\"60\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"PoolAlternativeSupplier_di\" bpmnElement=\"PoolAlternativeSupplier\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1500\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartQuarter_di\" bpmnElement=\"StartQuarter\">\n        <dc:Bounds x=\"250\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"232\" y=\"195\" width=\"72\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckInventory_di\" bpmnElement=\"TaskCheckInventory\">\n        <dc:Bounds x=\"370\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwLowStock_di\" bpmnElement=\"GwLowStock\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"540\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"522\" y=\"202\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndStockSufficient_di\" bpmnElement=\"EndStockSufficient\">\n        <dc:Bounds x=\"670\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"655\" y=\"195\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderRequestStandard_di\" bpmnElement=\"TaskSendOrderRequestStandard\">\n        <dc:Bounds x=\"670\" y=\"40\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitResponse_di\" bpmnElement=\"GwWaitResponse\">\n        <dc:Bounds x=\"830\" y=\"55\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchConfirmation_di\" bpmnElement=\"CatchConfirmation\">\n        <dc:Bounds x=\"950\" y=\"42\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"932\" y=\"14\" width=\"72\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndConfirmed_di\" bpmnElement=\"EndConfirmed\">\n        <dc:Bounds x=\"1090\" y=\"42\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1062\" y=\"14\" width=\"92\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchRejection_di\" bpmnElement=\"CatchRejection\">\n        <dc:Bounds x=\"950\" y=\"142\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"944\" y=\"185\" width=\"48\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchTimeout_di\" bpmnElement=\"CatchTimeout\">\n        <dc:Bounds x=\"950\" y=\"212\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"938\" y=\"255\" width=\"60\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskManualIntervene_di\" bpmnElement=\"TaskManualIntervene\">\n        <dc:Bounds x=\"1090\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckAlternative_di\" bpmnElement=\"TaskCheckAlternative\">\n        <dc:Bounds x=\"1250\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwOrderAlternative_di\" bpmnElement=\"GwOrderAlternative\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1410\" y=\"325\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1386\" y=\"382\" width=\"98\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendOrderAlternative_di\" bpmnElement=\"TaskSendOrderAlternative\">\n        <dc:Bounds x=\"1490\" y=\"260\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndAlternativeOrdered_di\" bpmnElement=\"EndAlternativeOrdered\">\n        <dc:Bounds x=\"1620\" y=\"282\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1590\" y=\"325\" width=\"96\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndCancelled_di\" bpmnElement=\"EndCancelled\">\n        <dc:Bounds x=\"1492\" y=\"362\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1472\" y=\"405\" width=\"76\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q1_di\" bpmnElement=\"Flow_Q1\">\n        <di:waypoint x=\"286\" y=\"170\" />\n        <di:waypoint x=\"370\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q2_di\" bpmnElement=\"Flow_Q2\">\n        <di:waypoint x=\"470\" y=\"170\" />\n        <di:waypoint x=\"540\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q3_Ok_di\" bpmnElement=\"Flow_Q3_Ok\">\n        <di:waypoint x=\"590\" y=\"170\" />\n        <di:waypoint x=\"670\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"620\" y=\"152\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q3_Low_di\" bpmnElement=\"Flow_Q3_Low\">\n        <di:waypoint x=\"565\" y=\"145\" />\n        <di:waypoint x=\"565\" y=\"80\" />\n        <di:waypoint x=\"670\" y=\"80\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"575\" y=\"102\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q4_di\" bpmnElement=\"Flow_Q4\">\n        <di:waypoint x=\"770\" y=\"80\" />\n        <di:waypoint x=\"830\" y=\"80\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q5_Conf_di\" bpmnElement=\"Flow_Q5_Conf\">\n        <di:waypoint x=\"880\" y=\"80\" />\n        <di:waypoint x=\"950\" y=\"60\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q5_Rej_di\" bpmnElement=\"Flow_Q5_Rej\">\n        <di:waypoint x=\"880\" y=\"80\" />\n        <di:waypoint x=\"905\" y=\"80\" />\n        <di:waypoint x=\"905\" y=\"160\" />\n        <di:waypoint x=\"950\" y=\"160\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q5_Time_di\" bpmnElement=\"Flow_Q5_Time\">\n        <di:waypoint x=\"880\" y=\"80\" />\n        <di:waypoint x=\"895\" y=\"80\" />\n        <di:waypoint x=\"895\" y=\"230\" />\n        <di:waypoint x=\"950\" y=\"230\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q6_di\" bpmnElement=\"Flow_Q6\">\n        <di:waypoint x=\"986\" y=\"60\" />\n        <di:waypoint x=\"1090\" y=\"60\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q7_di\" bpmnElement=\"Flow_Q7\">\n        <di:waypoint x=\"968\" y=\"178\" />\n        <di:waypoint x=\"968\" y=\"350\" />\n        <di:waypoint x=\"1090\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q8_di\" bpmnElement=\"Flow_Q8\">\n        <di:waypoint x=\"968\" y=\"248\" />\n        <di:waypoint x=\"968\" y=\"350\" />\n        <di:waypoint x=\"1090\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q9_di\" bpmnElement=\"Flow_Q9\">\n        <di:waypoint x=\"1190\" y=\"350\" />\n        <di:waypoint x=\"1250\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q10_di\" bpmnElement=\"Flow_Q10\">\n        <di:waypoint x=\"1350\" y=\"350\" />\n        <di:waypoint x=\"1410\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q11_Yes_di\" bpmnElement=\"Flow_Q11_Yes\">\n        <di:waypoint x=\"1460\" y=\"350\" />\n        <di:waypoint x=\"1475\" y=\"350\" />\n        <di:waypoint x=\"1475\" y=\"300\" />\n        <di:waypoint x=\"1490\" y=\"300\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1468\" y=\"312\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Q11_No_di\" bpmnElement=\"Flow_Q11_No\">\n        <di:waypoint x=\"1460\" y=\"350\" />\n        <di:waypoint x=\"1492\" y=\"380\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1472\" y=\"366\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_Q12_di\" bpmnElement=\"Flow_Q12\">\n        <di:waypoint x=\"1590\" y=\"300\" />\n        <di:waypoint x=\"1620\" y=\"300\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_OrderRequestStandard_di\" bpmnElement=\"MF_OrderRequestStandard\">\n        <di:waypoint x=\"720\" y=\"40\" />\n        <di:waypoint x=\"720\" y=\"520\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_Confirmation_di\" bpmnElement=\"MF_Confirmation\">\n        <di:waypoint x=\"980\" y=\"520\" />\n        <di:waypoint x=\"980\" y=\"490\" />\n        <di:waypoint x=\"968\" y=\"490\" />\n        <di:waypoint x=\"968\" y=\"78\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_Rejection_di\" bpmnElement=\"MF_Rejection\">\n        <di:waypoint x=\"1020\" y=\"520\" />\n        <di:waypoint x=\"1020\" y=\"160\" />\n        <di:waypoint x=\"986\" y=\"160\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_OrderRequestAlternative_di\" bpmnElement=\"MF_OrderRequestAlternative\">\n        <di:waypoint x=\"1540\" y=\"260\" />\n        <di:waypoint x=\"1540\" y=\"630\" />\n      </bpmndi:BPMNEdge>\n\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</bpmn:definitions>\"\n}