<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Return" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Return">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_Retailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" processRef="Process_Customer" />
    <bpmn:messageFlow id="MF_RegisterReturn" name="Return request" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
    <bpmn:messageFlow id="MF_ReturnLabel" name="Return label" sourceRef="TaskSendReturnLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_DamagedNotice" name="No refund" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_CloseNoRefund" name="Closed" sourceRef="EndClosedNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_CreditConfirmation" name="Credit" sourceRef="EndCreditConfirmed" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendReturnLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitArrivalOrTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchPackageArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch14DaysExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCloseNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouseAccounting" name="Warehouse & Accounting">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndNoRefundDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToAccounting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCreditConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartReturnRegistered" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendReturnLabel" name="Send label">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitArrivalOrTimeout">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchPackageArrived" name="Package arrived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchPackageArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch14DaysExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14DaysExceeded" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="TaskCloseNoRefund" name="Close return">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndClosedNoRefund" name="Closed no refund">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndClosedNoRefund" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskInspectGoods" name="Inspect goods">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods ok?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformNoRefund" name="Inform no refund">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndNoRefundDamaged" name="No refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskForwardToAccounting" name="Forward info">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndCreditConfirmed" name="Credit sent">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndCreditConfirmed" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateLabel" targetRef="TaskSendReturnLabel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskSendReturnLabel" targetRef="GwWaitArrivalOrTimeout" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitArrivalOrTimeout" targetRef="CatchPackageArrived" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitArrivalOrTimeout" targetRef="Catch14DaysExceeded" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchPackageArrived" targetRef="TaskInspectGoods" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Catch14DaysExceeded" targetRef="TaskCloseNoRefund" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskCloseNoRefund" targetRef="EndClosedNoRefund" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="TaskInspectGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="Flow_11" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardToAccounting" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskInformNoRefund" targetRef="EndNoRefundDamaged" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskForwardToAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskInitiateRefund" targetRef="EndCreditConfirmed" />
  </bpmn:process>

  <bpmn:process id="Process_Customer" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_Return">
    <bpmndi:BPMNPlane id="BPMNPlane_Return" bpmnElement="Collaboration_Return">
      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouseAccounting_di" bpmnElement="LaneWarehouseAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="195" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskGenerateLabel_di" bpmnElement="TaskGenerateLabel">
        <dc:Bounds x="340" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendReturnLabel_di" bpmnElement="TaskSendReturnLabel">
        <dc:Bounds x="500" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitArrivalOrTimeout_di" bpmnElement="GwWaitArrivalOrTimeout">
        <dc:Bounds x="660" y="145" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch14DaysExceeded_di" bpmnElement="Catch14DaysExceeded">
        <dc:Bounds x="800" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="770" y="76" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCloseNoRefund_di" bpmnElement="TaskCloseNoRefund">
        <dc:Bounds x="900" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndClosedNoRefund_di" bpmnElement="EndClosedNoRefund">
        <dc:Bounds x="1040" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1014" y="155" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchPackageArrived_di" bpmnElement="CatchPackageArrived">
        <dc:Bounds x="800" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="776" y="335" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskInspectGoods_di" bpmnElement="TaskInspectGoods">
        <dc:Bounds x="900" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="1060" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1045" y="342" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskInformNoRefund_di" bpmnElement="TaskInformNoRefund">
        <dc:Bounds x="1200" y="255" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndNoRefundDamaged_di" bpmnElement="EndNoRefundDamaged">
        <dc:Bounds x="1340" y="277" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1325" y="320" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToAccounting_di" bpmnElement="TaskForwardToAccounting">
        <dc:Bounds x="1200" y="345" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="1340" y="345" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCreditConfirmed_di" bpmnElement="EndCreditConfirmed">
        <dc:Bounds x="1490" y="367" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1472" y="410" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="340" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="170" />
        <di:waypoint x="660" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="685" y="195" />
        <di:waypoint x="685" y="310" />
        <di:waypoint x="800" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="685" y="145" />
        <di:waypoint x="685" y="130" />
        <di:waypoint x="800" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="836" y="310" />
        <di:waypoint x="900" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="836" y="130" />
        <di:waypoint x="900" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1000" y="130" />
        <di:waypoint x="1040" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1000" y="310" />
        <di:waypoint x="1060" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1110" y="310" />
        <di:waypoint x="1200" y="295" />
        <bpmndi:BPMNLabel><dc:Bounds x="1148" y="286" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1085" y="335" />
        <di:waypoint x="1085" y="385" />
        <di:waypoint x="1200" y="385" />
        <bpmndi:BPMNLabel><dc:Bounds x="1092" y="345" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1300" y="295" />
        <di:waypoint x="1340" y="295" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1300" y="385" />
        <di:waypoint x="1340" y="385" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1440" y="385" />
        <di:waypoint x="1490" y="385" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RegisterReturn_di" bpmnElement="MF_RegisterReturn">
        <di:waypoint x="860" y="520" />
        <di:waypoint x="860" y="60" />
        <di:waypoint x="238" y="60" />
        <di:waypoint x="238" y="152" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ReturnLabel_di" bpmnElement="MF_ReturnLabel">
        <di:waypoint x="550" y="210" />
        <di:waypoint x="550" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_DamagedNotice_di" bpmnElement="MF_DamagedNotice">
        <di:waypoint x="1250" y="255" />
        <di:waypoint x="1250" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_CloseNoRefund_di" bpmnElement="MF_CloseNoRefund">
        <di:waypoint x="1058" y="112" />
        <di:waypoint x="1058" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_CreditConfirmation_di" bpmnElement="MF_CreditConfirmation">
        <di:waypoint x="1508" y="367" />
        <di:waypoint x="1508" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>