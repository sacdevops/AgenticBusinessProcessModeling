<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolEmployee" name="Employee" />
    <bpmn:participant id="PoolSupervisor" name="Direct Supervisor" />
    <bpmn:participant id="PoolHRManager" name="HR Manager" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="PoolEmployee" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_RequestApproval" name="Approval request" sourceRef="TaskSendToSupervisor" targetRef="PoolSupervisor" />
    <bpmn:messageFlow id="MF_SupervisorFeedback" name="Feedback" sourceRef="PoolSupervisor" targetRef="CatchSupervisorFeedback" />
    <bpmn:messageFlow id="MF_Escalation" name="Escalation" sourceRef="TaskEscalateToHRManager" targetRef="PoolHRManager" />
    <bpmn:messageFlow id="MF_HRManagerDecision" name="Decision" sourceRef="PoolHRManager" targetRef="CatchHRManagerDecision" />

    <bpmn:messageFlow id="MF_NotifyRejectedInsufficient" name="Rejected" sourceRef="TaskNotifyRejectedInsufficient" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyRejectedSupervisor" name="Rejected" sourceRef="TaskNotifyRejectedSupervisor" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyRejectedHRManager" name="Rejected" sourceRef="TaskNotifyRejectedHRManager" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_NotifyApproved" name="Approved" sourceRef="TaskNotifyApproved" targetRef="PoolEmployee" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" name="Vacation Request Process" isExecutable="false">

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_Start_To_Check</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_Start_To_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_To_GwEnough</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_Check_To_GwEnough</bpmn:incoming>
      <bpmn:outgoing>Flow_GwEnough_To_SendSupervisor</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwEnough_To_NotifyInsufficient</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Send request">
      <bpmn:incoming>Flow_GwEnough_To_SendSupervisor</bpmn:incoming>
      <bpmn:outgoing>Flow_SendSupervisor_To_GwWait</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback" name="">
      <bpmn:incoming>Flow_SendSupervisor_To_GwWait</bpmn:incoming>
      <bpmn:outgoing>Flow_GwWait_To_CatchFeedback</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwWait_To_CatchTimer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorFeedback" name="Feedback received">
      <bpmn:incoming>Flow_GwWait_To_CatchFeedback</bpmn:incoming>
      <bpmn:outgoing>Flow_CatchFeedback_To_GwSupervisorApproved</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorFeedback" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_CatchFeedback_To_GwSupervisorApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_GwSupervisorApproved_To_Book</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwSupervisorApproved_To_NotifyRejectedSupervisor</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_GwSupervisorApproved_To_Book</bpmn:incoming>
      <bpmn:incoming>Flow_GwHRApproved_To_Book</bpmn:incoming>
      <bpmn:outgoing>Flow_Book_To_NotifyApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskNotifyApproved" name="Send decision">
      <bpmn:incoming>Flow_Book_To_NotifyApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyApproved_To_EndApproved</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_NotifyApproved_To_EndApproved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskNotifyRejectedSupervisor" name="Send decision">
      <bpmn:incoming>Flow_GwSupervisorApproved_To_NotifyRejectedSupervisor</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyRejectedSupervisor_To_EndRejectedSupervisor</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Rejected">
      <bpmn:incoming>Flow_NotifyRejectedSupervisor_To_EndRejectedSupervisor</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="Catch5Days" name="5 days elapsed">
      <bpmn:incoming>Flow_GwWait_To_CatchTimer</bpmn:incoming>
      <bpmn:outgoing>Flow_Catch5Days_To_Escalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskEscalateToHRManager" name="Escalate case">
      <bpmn:incoming>Flow_Catch5Days_To_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Escalate_To_CatchHRDecision</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="CatchHRManagerDecision" name="Receive decision">
      <bpmn:incoming>Flow_Escalate_To_CatchHRDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_CatchHRDecision_To_GwHRApproved</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="GwHRApproved" name="Approved?">
      <bpmn:incoming>Flow_CatchHRDecision_To_GwHRApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_GwHRApproved_To_Book</bpmn:outgoing>
      <bpmn:outgoing>Flow_GwHRApproved_To_NotifyRejectedHR</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskNotifyRejectedHRManager" name="Send decision">
      <bpmn:incoming>Flow_GwHRApproved_To_NotifyRejectedHR</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyRejectedHR_To_EndRejectedHR</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedHR" name="Rejected">
      <bpmn:incoming>Flow_NotifyRejectedHR_To_EndRejectedHR</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskNotifyRejectedInsufficient" name="Send decision">
      <bpmn:incoming>Flow_GwEnough_To_NotifyInsufficient</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyInsufficient_To_EndRejectedInsufficient</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejectedInsufficient" name="Rejected">
      <bpmn:incoming>Flow_NotifyInsufficient_To_EndRejectedInsufficient</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Check" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_Check_To_GwEnough" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />

    <bpmn:sequenceFlow id="Flow_GwEnough_To_SendSupervisor" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_GwEnough_To_NotifyInsufficient" name="No" sourceRef="GwEnoughDays" targetRef="TaskNotifyRejectedInsufficient" />

    <bpmn:sequenceFlow id="Flow_SendSupervisor_To_GwWait" sourceRef="TaskSendToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_GwWait_To_CatchFeedback" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorFeedback" />
    <bpmn:sequenceFlow id="Flow_GwWait_To_CatchTimer" sourceRef="GwWaitFeedback" targetRef="Catch5Days" />

    <bpmn:sequenceFlow id="Flow_CatchFeedback_To_GwSupervisorApproved" sourceRef="CatchSupervisorFeedback" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_GwSupervisorApproved_To_Book" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_GwSupervisorApproved_To_NotifyRejectedSupervisor" name="No" sourceRef="GwSupervisorApproved" targetRef="TaskNotifyRejectedSupervisor" />

    <bpmn:sequenceFlow id="Flow_Book_To_NotifyApproved" sourceRef="TaskBookVacation" targetRef="TaskNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_NotifyApproved_To_EndApproved" sourceRef="TaskNotifyApproved" targetRef="EndApproved" />

    <bpmn:sequenceFlow id="Flow_NotifyRejectedSupervisor_To_EndRejectedSupervisor" sourceRef="TaskNotifyRejectedSupervisor" targetRef="EndRejectedSupervisor" />

    <bpmn:sequenceFlow id="Flow_Catch5Days_To_Escalate" sourceRef="Catch5Days" targetRef="TaskEscalateToHRManager" />
    <bpmn:sequenceFlow id="Flow_Escalate_To_CatchHRDecision" sourceRef="TaskEscalateToHRManager" targetRef="CatchHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_CatchHRDecision_To_GwHRApproved" sourceRef="CatchHRManagerDecision" targetRef="GwHRApproved" />
    <bpmn:sequenceFlow id="Flow_GwHRApproved_To_Book" name="Yes" sourceRef="GwHRApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_GwHRApproved_To_NotifyRejectedHR" name="No" sourceRef="GwHRApproved" targetRef="TaskNotifyRejectedHRManager" />
    <bpmn:sequenceFlow id="Flow_NotifyRejectedHR_To_EndRejectedHR" sourceRef="TaskNotifyRejectedHRManager" targetRef="EndRejectedHR" />

    <bpmn:sequenceFlow id="Flow_NotifyInsufficient_To_EndRejectedInsufficient" sourceRef="TaskNotifyRejectedInsufficient" targetRef="EndRejectedInsufficient" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="380" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolSupervisor_di" bpmnElement="PoolSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="620" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHRManager_di" bpmnElement="PoolHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="730" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="240" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="214" y="275" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="360" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="520" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="505" y="282" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejectedInsufficient_di" bpmnElement="TaskNotifyRejectedInsufficient">
        <dc:Bounds x="650" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedInsufficient_di" bpmnElement="EndRejectedInsufficient">
        <dc:Bounds x="820" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="806" y="185" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToSupervisor_di" bpmnElement="TaskSendToSupervisor">
        <dc:Bounds x="650" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="820" y="315" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorFeedback_di" bpmnElement="CatchSupervisorFeedback">
        <dc:Bounds x="960" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="930" y="265" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="1060" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1047" y="272" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1180" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyApproved_di" bpmnElement="TaskNotifyApproved">
        <dc:Bounds x="1320" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1460" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1442" y="255" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejectedSupervisor_di" bpmnElement="TaskNotifyRejectedSupervisor">
        <dc:Bounds x="1180" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisor_di" bpmnElement="EndRejectedSupervisor">
        <dc:Bounds x="1320" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1306" y="365" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch5Days_di" bpmnElement="Catch5Days">
        <dc:Bounds x="960" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="928" y="435" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskEscalateToHRManager_di" bpmnElement="TaskEscalateToHRManager">
        <dc:Bounds x="1060" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchHRManagerDecision_di" bpmnElement="CatchHRManagerDecision">
        <dc:Bounds x="1210" y="382" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRApproved_di" bpmnElement="GwHRApproved" isMarkerVisible="true">
        <dc:Bounds x="1340" y="395" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1328" y="452" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskNotifyRejectedHRManager_di" bpmnElement="TaskNotifyRejectedHRManager">
        <dc:Bounds x="1420" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHR_di" bpmnElement="EndRejectedHR">
        <dc:Bounds x="1540" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1526" y="425" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_Check_di" bpmnElement="Flow_Start_To_Check">
        <di:waypoint x="276" y="250" />
        <di:waypoint x="360" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Check_To_GwEnough_di" bpmnElement="Flow_Check_To_GwEnough">
        <di:waypoint x="460" y="250" />
        <di:waypoint x="520" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwEnough_To_NotifyInsufficient_di" bpmnElement="Flow_GwEnough_To_NotifyInsufficient">
        <di:waypoint x="545" y="225" />
        <di:waypoint x="545" y="160" />
        <di:waypoint x="650" y="160" />
        <bpmndi:BPMNLabel><dc:Bounds x="555" y="188" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NotifyInsufficient_To_EndRejectedInsufficient_di" bpmnElement="Flow_NotifyInsufficient_To_EndRejectedInsufficient">
        <di:waypoint x="750" y="160" />
        <di:waypoint x="820" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwEnough_To_SendSupervisor_di" bpmnElement="Flow_GwEnough_To_SendSupervisor">
        <di:waypoint x="570" y="250" />
        <di:waypoint x="610" y="250" />
        <di:waypoint x="610" y="340" />
        <di:waypoint x="650" y="340" />
        <bpmndi:BPMNLabel><dc:Bounds x="590" y="286" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SendSupervisor_To_GwWait_di" bpmnElement="Flow_SendSupervisor_To_GwWait">
        <di:waypoint x="750" y="340" />
        <di:waypoint x="820" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwWait_To_CatchFeedback_di" bpmnElement="Flow_GwWait_To_CatchFeedback">
        <di:waypoint x="845" y="315" />
        <di:waypoint x="845" y="240" />
        <di:waypoint x="960" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwWait_To_CatchTimer_di" bpmnElement="Flow_GwWait_To_CatchTimer">
        <di:waypoint x="845" y="365" />
        <di:waypoint x="845" y="410" />
        <di:waypoint x="960" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CatchFeedback_To_GwSupervisorApproved_di" bpmnElement="Flow_CatchFeedback_To_GwSupervisorApproved">
        <di:waypoint x="996" y="240" />
        <di:waypoint x="1060" y="240" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwSupervisorApproved_To_Book_di" bpmnElement="Flow_GwSupervisorApproved_To_Book">
        <di:waypoint x="1110" y="240" />
        <di:waypoint x="1180" y="230" />
        <bpmndi:BPMNLabel><dc:Bounds x="1138" y="222" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwSupervisorApproved_To_NotifyRejectedSupervisor_di" bpmnElement="Flow_GwSupervisorApproved_To_NotifyRejectedSupervisor">
        <di:waypoint x="1085" y="265" />
        <di:waypoint x="1085" y="340" />
        <di:waypoint x="1180" y="340" />
        <bpmndi:BPMNLabel><dc:Bounds x="1092" y="300" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Book_To_NotifyApproved_di" bpmnElement="Flow_Book_To_NotifyApproved">
        <di:waypoint x="1280" y="230" />
        <di:waypoint x="1320" y="230" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NotifyApproved_To_EndApproved_di" bpmnElement="Flow_NotifyApproved_To_EndApproved">
        <di:waypoint x="1420" y="230" />
        <di:waypoint x="1460" y="230" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NotifyRejectedSupervisor_To_EndRejectedSupervisor_di" bpmnElement="Flow_NotifyRejectedSupervisor_To_EndRejectedSupervisor">
        <di:waypoint x="1280" y="340" />
        <di:waypoint x="1320" y="340" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Catch5Days_To_Escalate_di" bpmnElement="Flow_Catch5Days_To_Escalate">
        <di:waypoint x="996" y="410" />
        <di:waypoint x="1060" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Escalate_To_CatchHRDecision_di" bpmnElement="Flow_Escalate_To_CatchHRDecision">
        <di:waypoint x="1160" y="410" />
        <di:waypoint x="1210" y="422" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_CatchHRDecision_To_GwHRApproved_di" bpmnElement="Flow_CatchHRDecision_To_GwHRApproved">
        <di:waypoint x="1310" y="422" />
        <di:waypoint x="1340" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GwHRApproved_To_Book_di" bpmnElement="Flow_GwHRApproved_To_Book">
        <di:waypoint x="1365" y="395" />
        <di:waypoint x="1365" y="300" />
        <di:waypoint x="1230" y="300" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
        <di:waypoint x="1230" y="270" />
