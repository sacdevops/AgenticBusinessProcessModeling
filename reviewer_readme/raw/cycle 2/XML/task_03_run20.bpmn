      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedNoDays_di" bpmnElement="EndInformRejectedNoDays">
        <dc:Bounds x="620" y="230" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="606" y="273" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedSupervisor_di" bpmnElement="EndInformRejectedSupervisor">
        <dc:Bounds x="1160" y="230" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1146" y="273" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformRejectedHR_di" bpmnElement="EndInformRejectedHR">
        <dc:Bounds x="1330" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1316" y="355" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolSupervisor_di" bpmnElement="PoolSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="240" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApprovalRequested_di" bpmnElement="StartApprovalRequested">
        <dc:Bounds x="240" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="214" y="635" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="330" y="570" width="100" height="80" />
