      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="240" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="220" y="195" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="330" y="130" width="100" height="80" />
