      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_9_di" bpmnElement="Flow_HR_9">
        <di:waypoint x="936" y="320" />
        <di:waypoint x="1020" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_10_di" bpmnElement="Flow_HR_10">
        <di:waypoint x="1070" y="160" />
        <di:waypoint x="1180" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="1116" y="150" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_11_di" bpmnElement="Flow_HR_11">
        <di:waypoint x="1045" y="185" />
        <di:waypoint x="1045" y="248" />
        <di:waypoint x="1160" y="248" />
        <bpmndi:BPMNLabel><dc:Bounds x="1052" y="220" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_12_di" bpmnElement="Flow_HR_12">
        <di:waypoint x="1120" y="320" />
        <di:waypoint x="1160" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_13_di" bpmnElement="Flow_HR_13">
        <di:waypoint x="1210" y="320" />
