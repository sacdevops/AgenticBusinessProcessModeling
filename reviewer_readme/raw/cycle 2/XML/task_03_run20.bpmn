      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalRequest_di" bpmnElement="TaskSendApprovalRequest">
        <dc:Bounds x="620" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="780" y="145" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorDecision_di" bpmnElement="CatchSupervisorDecision">
        <dc:Bounds x="900" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="872" y="185" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchFiveDays_di" bpmnElement="CatchFiveDays">
        <dc:Bounds x="900" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="872" y="345" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="1020" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1012" y="192" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewEscalation_di" bpmnElement="TaskReviewEscalation">
        <dc:Bounds x="1020" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwHRApproved_di" bpmnElement="GwHRApproved" isMarkerVisible="true">
        <dc:Bounds x="1160" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1152" y="352" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1180" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndInformApproved_di" bpmnElement="EndInformApproved">
