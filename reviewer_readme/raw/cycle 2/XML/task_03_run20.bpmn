<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolSupervisor" name="Supervisor" processRef="Process_Supervisor" />
    <bpmn:participant id="PoolEmployee" name="Employee" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="PoolEmployee" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_RequestApproval" name="Approval request" sourceRef="TaskSendApprovalRequest" targetRef="StartApprovalRequested" />
    <bpmn:messageFlow id="MF_SupervisorDecision" name="Decision" sourceRef="EndSupervisorDecision" targetRef="CatchSupervisorDecision" />

    <bpmn:messageFlow id="MF_InformApproval" name="Approved" sourceRef="EndInformApproved" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_InformRejectNoDays" name="Rejected" sourceRef="EndInformRejectedNoDays" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_InformRejectSupervisor" name="Rejected" sourceRef="EndInformRejectedSupervisor" targetRef="PoolEmployee" />
    <bpmn:messageFlow id="MF_InformRejectHR" name="Rejected" sourceRef="EndInformRejectedHR" targetRef="PoolEmployee" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HRPortal">
      <bpmn:lane id="LaneHRSystem" name="HR System">
        <bpmn:flowNodeRef>StartRequestReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchFiveDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedNoDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndInformRejectedHR</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_HR_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_HR_1</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_HR_2</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_HR_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendApprovalRequest" name="Request approval">
      <bpmn:incoming>Flow_HR_3</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback">
      <bpmn:incoming>Flow_HR_5</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_HR_7</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorDecision" name="Decision received">
      <bpmn:incoming>Flow_HR_6</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_SupervisorDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchFiveDays" name="5 days exceeded">
      <bpmn:incoming>Flow_HR_7</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_FiveDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_HR_8</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_HR_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskReviewEscalation" name="Review escalation">
      <bpmn:incoming>Flow_HR_9</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRApproved" name="Approved?">
      <bpmn:incoming>Flow_HR_12</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_HR_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_HR_10</bpmn:incoming>
      <bpmn:incoming>Flow_HR_13</bpmn:incoming>
      <bpmn:outgoing>Flow_HR_15</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndInformApproved" name="Decision sent">
      <bpmn:incoming>Flow_HR_15</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_InformApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejectedNoDays" name="Decision sent">
      <bpmn:incoming>Flow_HR_4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectNoDays" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejectedSupervisor" name="Decision sent">
      <bpmn:incoming>Flow_HR_11</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectSupervisor" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndInformRejectedHR" name="Decision sent">
      <bpmn:incoming>Flow_HR_14</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_RejectHR" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_HR_1" sourceRef="StartRequestReceived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_HR_2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_HR_3" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendApprovalRequest" />
    <bpmn:sequenceFlow id="Flow_HR_4" name="No" sourceRef="GwEnoughDays" targetRef="EndInformRejectedNoDays" />
    <bpmn:sequenceFlow id="Flow_HR_5" sourceRef="TaskSendApprovalRequest" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_HR_6" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_HR_7" sourceRef="GwWaitFeedback" targetRef="CatchFiveDays" />
    <bpmn:sequenceFlow id="Flow_HR_8" sourceRef="CatchSupervisorDecision" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_HR_9" sourceRef="CatchFiveDays" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_HR_10" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_HR_11" name="No" sourceRef="GwSupervisorApproved" targetRef="EndInformRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_HR_12" sourceRef="TaskReviewEscalation" targetRef="GwHRApproved" />
    <bpmn:sequenceFlow id="Flow_HR_13" name="Yes" sourceRef="GwHRApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_HR_14" name="No" sourceRef="GwHRApproved" targetRef="EndInformRejectedHR" />
    <bpmn:sequenceFlow id="Flow_HR_15" sourceRef="TaskBookVacation" targetRef="EndInformApproved" />
  </bpmn:process>

  <bpmn:process id="Process_Supervisor" isExecutable="false">
    <bpmn:startEvent id="StartApprovalRequested" name="Approval requested">
      <bpmn:messageEventDefinition id="MED_StartApprovalRequested" />
      <bpmn:outgoing>Flow_S_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_S_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorDecision" name="Approve?">
      <bpmn:incoming>Flow_S_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendApprove" name="Send approval">
      <bpmn:incoming>Flow_S_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S_5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendReject" name="Send rejection">
      <bpmn:incoming>Flow_S_4</bpmn:incoming>
      <bpmn:outgoing>Flow_S_6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndSupervisorDecision" name="Decision sent">
      <bpmn:incoming>Flow_S_5</bpmn:incoming>
      <bpmn:incoming>Flow_S_6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndSupervisorDecision" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S_1" sourceRef="StartApprovalRequested" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_S_2" sourceRef="TaskReviewRequest" targetRef="GwSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S_3" name="Yes" sourceRef="GwSupervisorDecision" targetRef="TaskSendApprove" />
    <bpmn:sequenceFlow id="Flow_S_4" name="No" sourceRef="GwSupervisorDecision" targetRef="TaskSendReject" />
    <bpmn:sequenceFlow id="Flow_S_5" sourceRef="TaskSendApprove" targetRef="EndSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S_6" sourceRef="TaskSendReject" targetRef="EndSupervisorDecision" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRSystem_di" bpmnElement="LaneHRSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
