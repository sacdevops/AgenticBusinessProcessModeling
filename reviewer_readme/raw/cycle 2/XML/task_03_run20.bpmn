        <bpmndi:BPMNLabel><dc:Bounds x="494" y="642" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprove_di" bpmnElement="TaskSendApprove">
        <dc:Bounds x="620" y="540" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendReject_di" bpmnElement="TaskSendReject">
        <dc:Bounds x="620" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndSupervisorDecision_di" bpmnElement="EndSupervisorDecision">
        <dc:Bounds x="780" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="754" y="635" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="780" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_HR_1_di" bpmnElement="Flow_HR_1">
        <di:waypoint x="276" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_2_di" bpmnElement="Flow_HR_2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_3_di" bpmnElement="Flow_HR_3">
        <di:waypoint x="550" y="170" />
        <di:waypoint x="620" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="580" y="152" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_4_di" bpmnElement="Flow_HR_4">
        <di:waypoint x="525" y="195" />
        <di:waypoint x="525" y="248" />
        <di:waypoint x="620" y="248" />
        <bpmndi:BPMNLabel><dc:Bounds x="532" y="220" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_5_di" bpmnElement="Flow_HR_5">
        <di:waypoint x="720" y="170" />
        <di:waypoint x="780" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_6_di" bpmnElement="Flow_HR_6">
        <di:waypoint x="830" y="170" />
        <di:waypoint x="900" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_7_di" bpmnElement="Flow_HR_7">
        <di:waypoint x="805" y="195" />
        <di:waypoint x="805" y="320" />
        <di:waypoint x="900" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HR_8_di" bpmnElement="Flow_HR_8">
        <di:waypoint x="936" y="160" />
