      <bpmndi:BPMNShape id="GwLowInventory_di" bpmnElement="GwLowInventory" isMarkerVisible="true">
        <dc:Bounds x="490" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="475" y="202" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStockSufficient_di" bpmnElement="EndStockSufficient">
        <dc:Bounds x="650" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="625" y="195" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderRequestStandard_di" bpmnElement="TaskSendOrderRequestStandard">
        <dc:Bounds x="650" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwWaitStandardResponse_di" bpmnElement="GwWaitStandardResponse">
        <dc:Bounds x="810" y="45" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchStandardConfirmation_di" bpmnElement="CatchStandardConfirmation">
        <dc:Bounds x="930" y="32" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="6" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndProcuredStandard_di" bpmnElement="EndProcuredStandard">
        <dc:Bounds x="1040" y="32" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1015" y="75" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchStandardRejection_di" bpmnElement="CatchStandardRejection">
        <dc:Bounds x="930" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="905" y="155" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchStandardTimeout_di" bpmnElement="CatchStandardTimeout">
        <dc:Bounds x="930" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="902" y="235" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAlternative_di" bpmnElement="TaskReviewAlternative">
        <dc:Bounds x="1090" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwUseAlternative_di" bpmnElement="GwUseAlternative" isMarkerVisible="true">
        <dc:Bounds x="1240" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1215" y="382" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1390" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1365" y="305" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskSendOrderRequestAlternative_di" bpmnElement="TaskSendOrderRequestAlternative">
        <dc:Bounds x="1390" y="350" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndOrderedAlternative_di" bpmnElement="EndOrderedAlternative">
        <dc:Bounds x="1520" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1495" y="415" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolStandardSupplier_di" bpmnElement="PoolStandardSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartStandardOrderReceived_di" bpmnElement="StartStandardOrderReceived">
        <dc:Bounds x="230" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="625" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskAssessStandard_di" bpmnElement="TaskAssessStandard">
        <dc:Bounds x="330" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwStandardConfirm_di" bpmnElement="GwStandardConfirm" isMarkerVisible="true">
        <dc:Bounds x="490" y="575" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="475" y="632" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardConfirmed_di" bpmnElement="EndStandardConfirmed">
        <dc:Bounds x="650" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="640" y="585" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndStandardRejected_di" bpmnElement="EndStandardRejected">
        <dc:Bounds x="650" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="642" y="665" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAlternativeSupplier_di" bpmnElement="PoolAlternativeSupplier" isHorizontal="true">
        <dc:Bounds x="160" y="760" width="1400" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartAlternativeOrderReceived_di" bpmnElement="StartAlternativeOrderReceived">
        <dc:Bounds x="230" y="852" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="895" width="85" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskAcceptAlternative_di" bpmnElement="TaskAcceptAlternative">
        <dc:Bounds x="330" y="830" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndAlternativeConfirmed_di" bpmnElement="EndAlternativeConfirmed">
        <dc:Bounds x="490" y="852" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="478" y="895" width="62" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="266" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="490" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C3_di" bpmnElement="Flow_C3">
        <di:waypoint x="515" y="145" />
        <di:waypoint x="515" y="70" />
        <di:waypoint x="650" y="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="522" y="100" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <di:waypoint x="540" y="170" />
        <di:waypoint x="650" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="590" y="152" width="20" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C5_di" bpmnElement="Flow_C5">
        <di:waypoint x="750" y="70" />
        <di:waypoint x="810" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C6_di" bpmnElement="Flow_C6">
        <di:waypoint x="860" y="60" />
        <di:waypoint x="930" y="50" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C7_di" bpmnElement="Flow_C7">
        <di:waypoint x="835" y="95" />
        <di:waypoint x="835" y="130" />
        <di:waypoint x="930" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8_di" bpmnElement="Flow_C8">
        <di:waypoint x="835" y="95" />
        <di:waypoint x="835" y="210" />
        <di:waypoint x="930" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C9_di" bpmnElement="Flow_C9">
        <di:waypoint x="966" y="50" />
        <di:waypoint x="1040" y="50" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C10_di" bpmnElement="Flow_C10">
        <di:waypoint x="948" y="148" />
        <di:waypoint x="948" y="350" />
        <di:waypoint x="1090" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C11_di" bpmnElement="Flow_C11">
        <di:waypoint x="948" y="228" />
        <di:waypoint x="948" y="350" />
        <di:waypoint x="1090" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C12_di" bpmnElement="Flow_C12">
        <di:waypoint x="1190" y="350" />
        <di:waypoint x="1240" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C13_di" bpmnElement="Flow_C13">
        <di:waypoint x="1290" y="350" />
        <di:waypoint x="1390" y="390" />
        <bpmndi:BPMNLabel><dc:Bounds x="1330" y="360" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C14_di" bpmnElement="Flow_C14">
        <di:waypoint x="1265" y="325" />
        <di:waypoint x="1265" y="280" />
        <di:waypoint x="1390" y="280" />
        <bpmndi:BPMNLabel><dc:Bounds x="1272" y="290" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C15_di" bpmnElement="Flow_C15">
        <di:waypoint x="1490" y="390" />
        <di:waypoint x="1520" y="390" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="266" y="600" />
        <di:waypoint x="330" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="430" y="600" />
