<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_OfficeSupplyProcurement" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_OfficeSupplyProcurement">
    <bpmn:participant id="PoolCompany" name="Company" processRef="Process_PoolCompany" />
    <bpmn:participant id="PoolStandardSupplier" name="Standard Supplier" processRef="Process_PoolStandardSupplier" />
    <bpmn:participant id="PoolAlternativeSupplier" name="Alternative Supplier" processRef="Process_PoolAlternativeSupplier" />

    <bpmn:messageFlow id="MF_OrderRequest_Standard" name="Order request" sourceRef="TaskSendOrderRequestStandard" targetRef="StartStandardOrderReceived" />
    <bpmn:messageFlow id="MF_Confirmation_FromStandard" name="Confirmation" sourceRef="EndStandardConfirmed" targetRef="CatchStandardConfirmation" />
    <bpmn:messageFlow id="MF_Rejection_FromStandard" name="Rejection" sourceRef="EndStandardRejected" targetRef="CatchStandardRejection" />

    <bpmn:messageFlow id="MF_OrderRequest_Alternative" name="Order request" sourceRef="TaskSendOrderRequestAlternative" targetRef="StartAlternativeOrderReceived" />
    <bpmn:messageFlow id="MF_Confirmation_FromAlternative" name="Confirmation" sourceRef="EndAlternativeConfirmed" targetRef="PoolCompany" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PoolCompany" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="LaneSystem" name="System">
        <bpmn:flowNodeRef>StartQuarter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwLowInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestStandard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitStandardResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchStandardTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndStockSufficient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndProcuredStandard</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAdministration" name="Administration">
        <bpmn:flowNodeRef>TaskReviewAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwUseAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrderRequestAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndOrderedAlternative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartQuarter" name="Quarter start">
      <bpmn:outgoing>Flow_C1</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_QuarterStart" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckInventory" name="Check inventory">
      <bpmn:incoming>Flow_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwLowInventory" name="Low stock?">
      <bpmn:incoming>Flow_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C3</bpmn:outgoing>
      <bpmn:outgoing>Flow_C4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStockSufficient" name="No order needed">
      <bpmn:incoming>Flow_C4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestStandard" name="Send request">
      <bpmn:incoming>Flow_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitStandardResponse">
      <bpmn:incoming>Flow_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C6</bpmn:outgoing>
      <bpmn:outgoing>Flow_C7</bpmn:outgoing>
      <bpmn:outgoing>Flow_C8</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchStandardConfirmation" name="Confirmation received">
      <bpmn:incoming>Flow_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchStandardConfirmation" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndProcuredStandard" name="Order confirmed">
      <bpmn:incoming>Flow_C9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardRejection" name="Rejection received">
      <bpmn:incoming>Flow_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchStandardRejection" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchStandardTimeout" name="3 days exceeded">
      <bpmn:incoming>Flow_C8</bpmn:incoming>
      <bpmn:outgoing>Flow_C11</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_3BusinessDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskReviewAlternative" name="Review option">
      <bpmn:incoming>Flow_C10</bpmn:incoming>
      <bpmn:incoming>Flow_C11</bpmn:incoming>
      <bpmn:outgoing>Flow_C12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwUseAlternative" name="Use alternative?">
      <bpmn:incoming>Flow_C12</bpmn:incoming>
      <bpmn:outgoing>Flow_C13</bpmn:outgoing>
      <bpmn:outgoing>Flow_C14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndCancelled" name="Order cancelled">
      <bpmn:incoming>Flow_C14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrderRequestAlternative" name="Send request">
      <bpmn:incoming>Flow_C13</bpmn:incoming>
      <bpmn:outgoing>Flow_C15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndOrderedAlternative" name="Order sent">
      <bpmn:incoming>Flow_C15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_C1" sourceRef="StartQuarter" targetRef="TaskCheckInventory" />
    <bpmn:sequenceFlow id="Flow_C2" sourceRef="TaskCheckInventory" targetRef="GwLowInventory" />
    <bpmn:sequenceFlow id="Flow_C3" name="Yes" sourceRef="GwLowInventory" targetRef="TaskSendOrderRequestStandard" />
    <bpmn:sequenceFlow id="Flow_C4" name="No" sourceRef="GwLowInventory" targetRef="EndStockSufficient" />
    <bpmn:sequenceFlow id="Flow_C5" sourceRef="TaskSendOrderRequestStandard" targetRef="GwWaitStandardResponse" />
    <bpmn:sequenceFlow id="Flow_C6" sourceRef="GwWaitStandardResponse" targetRef="CatchStandardConfirmation" />
    <bpmn:sequenceFlow id="Flow_C7" sourceRef="GwWaitStandardResponse" targetRef="CatchStandardRejection" />
    <bpmn:sequenceFlow id="Flow_C8" sourceRef="GwWaitStandardResponse" targetRef="CatchStandardTimeout" />
    <bpmn:sequenceFlow id="Flow_C9" sourceRef="CatchStandardConfirmation" targetRef="EndProcuredStandard" />
    <bpmn:sequenceFlow id="Flow_C10" sourceRef="CatchStandardRejection" targetRef="TaskReviewAlternative" />
    <bpmn:sequenceFlow id="Flow_C11" sourceRef="CatchStandardTimeout" targetRef="TaskReviewAlternative" />
    <bpmn:sequenceFlow id="Flow_C12" sourceRef="TaskReviewAlternative" targetRef="GwUseAlternative" />
    <bpmn:sequenceFlow id="Flow_C13" name="Yes" sourceRef="GwUseAlternative" targetRef="TaskSendOrderRequestAlternative" />
    <bpmn:sequenceFlow id="Flow_C14" name="No" sourceRef="GwUseAlternative" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_C15" sourceRef="TaskSendOrderRequestAlternative" targetRef="EndOrderedAlternative" />
  </bpmn:process>

  <bpmn:process id="Process_PoolStandardSupplier" isExecutable="false">
    <bpmn:startEvent id="StartStandardOrderReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartStandardOrderReceived" />
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:businessRuleTask id="TaskAssessStandard" name="Assess order">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="GwStandardConfirm" name="Deliverable?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndStandardConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStandardConfirmed" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndStandardRejected" name="Rejected">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndStandardRejected" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartStandardOrderReceived" targetRef="TaskAssessStandard" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskAssessStandard" targetRef="GwStandardConfirm" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwStandardConfirm" targetRef="EndStandardConfirmed" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwStandardConfirm" targetRef="EndStandardRejected" />
  </bpmn:process>

  <bpmn:process id="Process_PoolAlternativeSupplier" isExecutable="false">
    <bpmn:startEvent id="StartAlternativeOrderReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartAlternativeOrderReceived" />
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskAcceptAlternative" name="Register order">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndAlternativeConfirmed" name="Confirmed">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndAlternativeConfirmed" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartAlternativeOrderReceived" targetRef="TaskAcceptAlternative" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="TaskAcceptAlternative" targetRef="EndAlternativeConfirmed" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OfficeSupplyProcurement">
    <bpmndi:BPMNPlane id="BPMNPlane_OfficeSupplyProcurement" bpmnElement="Collaboration_OfficeSupplyProcurement">

      <bpmndi:BPMNShape id="PoolCompany_di" bpmnElement="PoolCompany" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSystem_di" bpmnElement="LaneSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAdministration_di" bpmnElement="LaneAdministration" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartQuarter_di" bpmnElement="StartQuarter">
        <dc:Bounds x="230" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="214" y="195" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TaskCheckInventory_di" bpmnElement="TaskCheckInventory">
        <dc:Bounds x="330" y="130" width="100" height="80" />
