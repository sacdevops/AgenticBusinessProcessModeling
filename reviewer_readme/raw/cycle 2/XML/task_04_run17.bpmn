<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_BuildingPermits_1\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n\n  <bpmn:collaboration id=\"Collaboration_BuildingPermits\">\n    <bpmn:participant id=\"PoolBuildingAuthority\" name=\"Building Authority\" processRef=\"Process_BuildingAuthority\" />\n    <bpmn:participant id=\"PoolCitizen\" name=\"Citizen\" />\n    <bpmn:participant id=\"PoolEnvironmentalAgency\" name=\"Environmental Agency\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitApplication\" name=\"Application\" sourceRef=\"PoolCitizen\" targetRef=\"StartApplicationReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestMissingDocs\" name=\"Missing docs\" sourceRef=\"TaskRequestMissingDocs\" targetRef=\"PoolCitizen\" />\n    <bpmn:messageFlow id=\"MF_SubmitMissingDocs\" name=\"Missing docs\" sourceRef=\"PoolCitizen\" targetRef=\"CatchMissingDocs\" />\n\n    <bpmn:messageFlow id=\"MF_RequestEnvironmentalReview\" name=\"Review request\" sourceRef=\"TaskSendToEnvironmentalAgency\" targetRef=\"PoolEnvironmentalAgency\" />\n    <bpmn:messageFlow id=\"MF_EnvironmentalOpinion\" name=\"Opinion\" sourceRef=\"PoolEnvironmentalAgency\" targetRef=\"CatchEnvironmentalOpinion\" />\n\n    <bpmn:messageFlow id=\"MF_InformApproval\" name=\"Approval\" sourceRef=\"TaskInformApproval\" targetRef=\"PoolCitizen\" />\n    <bpmn:messageFlow id=\"MF_InformRejection\" name=\"Rejection\" sourceRef=\"TaskInformRejection\" targetRef=\"PoolCitizen\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_BuildingAuthority\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_BuildingAuthority\">\n      <bpmn:lane id=\"LaneOfficial\" name=\"Official\">\n        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwWaitMissingDocs</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchDeadlineExceeded</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendToEnvironmentalAgency</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>CatchEnvironmentalOpinion</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwOpinionPositive</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformRejection</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskInformApproval</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwTechnicalOk</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneTestEngineer\" name=\"Test Engineer\">\n        <bpmn:flowNodeRef>TaskCheckTechnicalDetails</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartApplicationReceived\" name=\"Application received\">\n      <bpmn:messageEventDefinition id=\"MED_StartApplicationReceived\" />\n      <bpmn:outgoing>Flow_1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskCheckCompleteness\" name=\"Check completeness\">\n      <bpmn:incoming>Flow_1</bpmn:incoming>\n      <bpmn:outgoing>Flow_2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwComplete\" name=\"Complete?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_2</bpmn:incoming>\n      <bpmn:outgoing>Flow_3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskRequestMissingDocs\" name=\"Request documents\">\n      <bpmn:incoming>Flow_4</bpmn:incoming>\n      <bpmn:outgoing>Flow_5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitMissingDocs\">\n      <bpmn:incoming>Flow_5</bpmn:incoming>\n      <bpmn:outgoing>Flow_6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_7</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchMissingDocs\" name=\"Documents received\">\n      <bpmn:messageEventDefinition id=\"MED_CatchMissingDocs\" />\n      <bpmn:incoming>Flow_6</bpmn:incoming>\n      <bpmn:outgoing>Flow_8</bpmn:outgoing>\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchDeadlineExceeded\" name=\"14 days exceeded\">\n      <bpmn:timerEventDefinition id=\"TED_CatchDeadlineExceeded\" />\n      <bpmn:incoming>Flow_7</bpmn:incoming>\n      <bpmn:outgoing>Flow_9</bpmn:outgoing>\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:sendTask id=\"TaskSendToEnvironmentalAgency\" name=\"Send for review\">\n      <bpmn:incoming>Flow_3</bpmn:incoming>\n      <bpmn:incoming>Flow_8</bpmn:incoming>\n      <bpmn:outgoing>Flow_10</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:intermediateCatchEvent id=\"CatchEnvironmentalOpinion\" name=\"Opinion received\">\n      <bpmn:messageEventDefinition id=\"MED_CatchEnvironmentalOpinion\" />\n      <bpmn:incoming>Flow_10</bpmn:incoming>\n      <bpmn:outgoing>Flow_11</bpmn:outgoing>\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwOpinionPositive\" name=\"Positive?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_11</bpmn:incoming>\n      <bpmn:outgoing>Flow_12</bpmn:outgoing>\n      <bpmn:outgoing>Flow_13</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:userTask id=\"TaskCheckTechnicalDetails\" name=\"Check technical\">\n      <bpmn:incoming>Flow_12</bpmn:incoming>\n      <bpmn:outgoing>Flow_14</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwTechnicalOk\" name=\"Technical ok?\" isMarkerVisible=\"true\">\n      <bpmn:incoming>Flow_14</bpmn:incoming>\n      <bpmn:outgoing>Flow_15</bpmn:outgoing>\n      <bpmn:outgoing>Flow_16</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:userTask id=\"TaskIssuePermit\" name=\"Issue permit\">\n      <bpmn:incoming>Flow_15</bpmn:incoming>\n      <bpmn:outgoing>Flow_17</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:sendTask id=\"TaskInformApproval\" name=\"Inform approval\">\n      <bpmn:incoming>Flow_17</bpmn:incoming>\n      <bpmn:outgoing>Flow_18</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:sendTask id=\"TaskInformRejection\" name=\"Inform rejection\">\n      <bpmn:incoming>Flow_9</bpmn:incoming>\n      <bpmn:incoming>Flow_13</bpmn:incoming>\n      <bpmn:incoming>Flow_16</bpmn:incoming>\n      <bpmn:outgoing>Flow_19</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndApproved\" name=\"Permit issued\">\n      <bpmn:incoming>Flow_18</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndRejected\" name=\"Application rejected\">\n      <bpmn:incoming>Flow_19</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_1\" sourceRef=\"StartApplicationReceived\" targetRef=\"TaskCheckCompleteness\" />\n    <bpmn:sequenceFlow id=\"Flow_2\" sourceRef=\"TaskCheckCompleteness\" targetRef=\"GwComplete\" />\n    <bpmn:sequenceFlow id=\"Flow_3\" name=\"Yes\" sourceRef=\"GwComplete\" targetRef=\"TaskSendToEnvironmentalAgency\" />\n    <bpmn:sequenceFlow id=\"Flow_4\" name=\"No\" sourceRef=\"GwComplete\" targetRef=\"TaskRequestMissingDocs\" />\n    <bpmn:sequenceFlow id=\"Flow_5\" sourceRef=\"TaskRequestMissingDocs\" targetRef=\"GwWaitMissingDocs\" />\n    <bpmn:sequenceFlow id=\"Flow_6\" sourceRef=\"GwWaitMissingDocs\" targetRef=\"CatchMissingDocs\" />\n    <bpmn:sequenceFlow id=\"Flow_7\" sourceRef=\"GwWaitMissingDocs\" targetRef=\"CatchDeadlineExceeded\" />\n    <bpmn:sequenceFlow id=\"Flow_8\" sourceRef=\"CatchMissingDocs\" targetRef=\"TaskSendToEnvironmentalAgency\" />\n    <bpmn:sequenceFlow id=\"Flow_9\" sourceRef=\"CatchDeadlineExceeded\" targetRef=\"TaskInformRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_10\" sourceRef=\"TaskSendToEnvironmentalAgency\" targetRef=\"CatchEnvironmentalOpinion\" />\n    <bpmn:sequenceFlow id=\"Flow_11\" sourceRef=\"CatchEnvironmentalOpinion\" targetRef=\"GwOpinionPositive\" />\n    <bpmn:sequenceFlow id=\"Flow_12\" name=\"Yes\" sourceRef=\"GwOpinionPositive\" targetRef=\"TaskCheckTechnicalDetails\" />\n    <bpmn:sequenceFlow id=\"Flow_13\" name=\"No\" sourceRef=\"GwOpinionPositive\" targetRef=\"TaskInformRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_14\" sourceRef=\"TaskCheckTechnicalDetails\" targetRef=\"GwTechnicalOk\" />\n    <bpmn:sequenceFlow id=\"Flow_15\" name=\"Yes\" sourceRef=\"GwTechnicalOk\" targetRef=\"TaskIssuePermit\" />\n    <bpmn:sequenceFlow id=\"Flow_16\" name=\"No\" sourceRef=\"GwTechnicalOk\" targetRef=\"TaskInformRejection\" />\n    <bpmn:sequenceFlow id=\"Flow_17\" sourceRef=\"TaskIssuePermit\" targetRef=\"TaskInformApproval\" />\n    <bpmn:sequenceFlow id=\"Flow_18\" sourceRef=\"TaskInformApproval\" targetRef=\"EndApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_19\" sourceRef=\"TaskInformRejection\" targetRef=\"EndRejected\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_BuildingPermits\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_BuildingPermits\" bpmnElement=\"Collaboration_BuildingPermits\">\n\n      <bpmndi:BPMNShape id=\"PoolBuildingAuthority_di\" bpmnElement=\"PoolBuildingAuthority\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"360\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"LaneOfficial_di\" bpmnElement=\"LaneOfficial\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"LaneTestEngineer_di\" bpmnElement=\"LaneTestEngineer\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"260\" width=\"1400\" height=\"180\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolCitizen_di\" bpmnElement=\"PoolCitizen\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"490\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolEnvironmentalAgency_di\" bpmnElement=\"PoolEnvironmentalAgency\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"600\" width=\"1400\" height=\"60\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartApplicationReceived_di\" bpmnElement=\"StartApplicationReceived\">\n        <dc:Bounds x=\"220\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"195\" y=\"195\" width=\"86\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckCompleteness_di\" bpmnElement=\"TaskCheckCompleteness\">\n        <dc:Bounds x=\"320\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwComplete_di\" bpmnElement=\"GwComplete\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"470\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"462\" y=\"202\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskRequestMissingDocs_di\" bpmnElement=\"TaskRequestMissingDocs\">\n        <dc:Bounds x=\"590\" y=\"220\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwWaitMissingDocs_di\" bpmnElement=\"GwWaitMissingDocs\">\n        <dc:Bounds x=\"750\" y=\"235\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchMissingDocs_di\" bpmnElement=\"CatchMissingDocs\">\n        <dc:Bounds x=\"860\" y=\"232\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"830\" y=\"210\" width=\"96\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchDeadlineExceeded_di\" bpmnElement=\"CatchDeadlineExceeded\">\n        <dc:Bounds x=\"860\" y=\"312\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"828\" y=\"352\" width=\"100\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskSendToEnvironmentalAgency_di\" bpmnElement=\"TaskSendToEnvironmentalAgency\">\n        <dc:Bounds x=\"590\" y=\"130\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchEnvironmentalOpinion_di\" bpmnElement=\"CatchEnvironmentalOpinion\">\n        <dc:Bounds x=\"760\" y=\"152\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"730\" y=\"195\" width=\"96\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwOpinionPositive_di\" bpmnElement=\"GwOpinionPositive\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"870\" y=\"145\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"862\" y=\"202\" width=\"66\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskCheckTechnicalDetails_di\" bpmnElement=\"TaskCheckTechnicalDetails\">\n        <dc:Bounds x=\"1000\" y=\"310\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"GwTechnicalOk_di\" bpmnElement=\"GwTechnicalOk\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1150\" y=\"325\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1130\" y=\"382\" width=\"90\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskIssuePermit_di\" bpmnElement=\"TaskIssuePermit\">\n        <dc:Bounds x=\"1260\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformApproval_di\" bpmnElement=\"TaskInformApproval\">\n        <dc:Bounds x=\"1410\" y=\"290\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndApproved_di\" bpmnElement=\"EndApproved\">\n        <dc:Bounds x=\"1530\" y=\"312\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1507\" y=\"355\" width=\"82\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskInformRejection_di\" bpmnElement=\"TaskInformRejection\">\n        <dc:Bounds x=\"1260\" y=\"110\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"EndRejected_di\" bpmnElement=\"EndRejected\">\n        <dc:Bounds x=\"1530\" y=\"132\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1498\" y=\"175\" width=\"100\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNEdge id=\"Flow_1_di\" bpmnElement=\"Flow_1\">\n        <di:waypoint x=\"256\" y=\"170\" />\n        <di:waypoint x=\"320\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_2_di\" bpmnElement=\"Flow_2\">\n        <di:waypoint x=\"420\" y=\"170\" />\n        <di:waypoint x=\"470\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_3_di\" bpmnElement=\"Flow_3\">\n        <di:waypoint x=\"520\" y=\"170\" />\n        <di:waypoint x=\"590\" y=\"170\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"545\" y=\"152\" width=\"24\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_4_di\" bpmnElement=\"Flow_4\">\n        <di:waypoint x=\"495\" y=\"195\" />\n        <di:waypoint x=\"495\" y=\"260\" />\n        <di:waypoint x=\"590\" y=\"260\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"506\" y=\"229\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_5_di\" bpmnElement=\"Flow_5\">\n        <di:waypoint x=\"690\" y=\"260\" />\n        <di:waypoint x=\"750\" y=\"260\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_6_di\" bpmnElement=\"Flow_6\">\n        <di:waypoint x=\"800\" y=\"260\" />\n        <di:waypoint x=\"860\" y=\"250\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_7_di\" bpmnElement=\"Flow_7\">\n        <di:waypoint x=\"775\" y=\"285\" />\n        <di:waypoint x=\"775\" y=\"330\" />\n        <di:waypoint x=\"860\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_8_di\" bpmnElement=\"Flow_8\">\n        <di:waypoint x=\"896\" y=\"250\" />\n        <di:waypoint x=\"950\" y=\"250\" />\n        <di:waypoint x=\"950\" y=\"170\" />\n        <di:waypoint x=\"690\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_9_di\" bpmnElement=\"Flow_9\">\n        <di:waypoint x=\"896\" y=\"330\" />\n        <di:waypoint x=\"940\" y=\"330\" />\n        <di:waypoint x=\"940\" y=\"150\" />\n        <di:waypoint x=\"1260\" y=\"150\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_10_di\" bpmnElement=\"Flow_10\">\n        <di:waypoint x=\"690\" y=\"170\" />\n        <di:waypoint x=\"760\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_11_di\" bpmnElement=\"Flow_11\">\n        <di:waypoint x=\"796\" y=\"170\" />\n        <di:waypoint x=\"870\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_12_di\" bpmnElement=\"Flow_12\">\n        <di:waypoint x=\"920\" y=\"170\" />\n        <di:waypoint x=\"945\" y=\"170\" />\n        <di:waypoint x=\"945\" y=\"350\" />\n        <di:waypoint x=\"1000\" y=\"350\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"931\" y=\"232\" width=\"24\" height=\"14\" /></bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_13_di\" bpmnElement=\"Flow_13\">\n        <di:waypoint x=\"920\" y=\"170\" />\n        <di:waypoint x=\"1260\" y=\"150\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1080\" y=\"142\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_14_di\" bpmnElement=\"Flow_14\">\n        <di:waypoint x=\"1100\" y=\"350\" />\n        <di:waypoint x=\"1150\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_15_di\" bpmnElement=\"Flow_15\">\n        <di:waypoint x=\"1200\" y=\"350\" />\n        <di:waypoint x=\"1260\" y=\"330\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1215\" y=\"322\" width=\"24\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_16_di\" bpmnElement=\"Flow_16\">\n        <di:waypoint x=\"1175\" y=\"325\" />\n        <di:waypoint x=\"1175\" y=\"150\" />\n        <di:waypoint x=\"1260\" y=\"150\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1183\" y=\"226\" width=\"22\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_17_di\" bpmnElement=\"Flow_17\">\n        <di:waypoint x=\"1360\" y=\"330\" />\n        <di:waypoint x=\"1410\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_18_di\" bpmnElement=\"Flow_18\">\n        <di:waypoint x=\"1510\" y=\"330\" />\n        <di:waypoint x=\"1530\" y=\"330\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"Flow_19_di\" bpmnElement=\"Flow_19\">\n        <di:waypoint x=\"1360\" y=\"150\" />\n        <di:waypoint x=\"1530\" y=\"150\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_SubmitApplication_di\" bpmnElement=\"MF_SubmitApplication\">\n        <di:waypoint x=\"420\" y=\"490\" />\n        <di:waypoint x=\"420\" y=\"70\" />\n        <di:waypoint x=\"238\" y=\"70\" />\n        <di:waypoint x=\"238\" y=\"152\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_RequestMissingDocs_di\" bpmnElement=\"MF_RequestMissingDocs\">\n        <di:waypoint x=\"640\" y=\"300\" />\n        <di:waypoint x=\"640\" y=\"490\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_SubmitMissingDocs_di\" bpmnElement=\"MF_SubmitMissingDocs\">\n        <di:waypoint x=\"980\" y=\"490\" />\n        <di:waypoint x=\"980\" y=\"250\" />\n        <di:waypoint x=\"878\" y=\"250\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_RequestEnvironmentalReview_di\" bpmnElement=\"MF_RequestEnvironmentalReview\">\n        <di:waypoint x=\"640\" y=\"130\" />\n        <di:waypoint x=\"640\" y=\"600\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_EnvironmentalOpinion_di\" bpmnElement=\"MF_EnvironmentalOpinion\">\n        <di:waypoint x=\"820\" y=\"600\" />\n        <di:waypoint x=\"820\" y=\"170\" />\n        <di:waypoint x=\"778\" y=\"170\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_InformApproval_di\" bpmnElement=\"MF_InformApproval\">\n        <di:waypoint x=\"1460\" y=\"370\" />\n        <di:waypoint x=\"1460\" y=\"490\" />\n      </bpmndi:BPMNEdge>\n\n      <bpmndi:BPMNEdge id=\"MF_InformRejection_di\" bpmnElement=\"MF_InformRejection\">\n        <di:waypoint x=\"1310\" y=\"190\" />\n        <di:waypoint x=\"1310\" y=\"490\" />\n      </bpmndi:BPMNEdge>\n\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n\n</bpmn:definitions>\"\n}