<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_InsuranceClaim" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_InsuranceClaim">
    <bpmn:participant id="PoolInsurance" name="Insurance Company" processRef="Process_Insurance" />
    <bpmn:participant id="PoolAssessor" name="Assessor" processRef="Process_Assessor" />
    <bpmn:participant id="PoolCustomer" name="Customer" />

    <bpmn:messageFlow id="MF_ReportToInsurance" name="Damage report" sourceRef="PoolCustomer" targetRef="StartDamageReport" />
    <bpmn:messageFlow id="MF_OrderToAssessor" name="Assessment order" sourceRef="TaskSendOrder" targetRef="StartOrderReceived" />
    <bpmn:messageFlow id="MF_ReportToInsurance2" name="Assessment report" sourceRef="TaskSendReport" targetRef="CatchReport" />

    <bpmn:messageFlow id="MF_NotifyRejectedNotCovered" name="Rejection" sourceRef="TaskSendRejectionNotCovered" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyApprovedLow" name="Approval" sourceRef="TaskSendApprovalLow" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyRejectedDeadline" name="Rejection" sourceRef="TaskSendRejectionDeadline" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyApprovedFinal" name="Approval" sourceRef="TaskSendApprovalFinal" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NotifyRejectedFinal" name="Rejection" sourceRef="TaskSendRejectionFinal" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Insurance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Insurance">
      <bpmn:lane id="LaneClaimsHandler" name="Claims Handler">
        <bpmn:flowNodeRef>StartDamageReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCreateCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNotCovered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckAmount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAmountHigh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedFinalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedFinalRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneClaimsSystem" name="Claims System">
        <bpmn:flowNodeRef>TaskInitiatePaymentLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApprovalLow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedLowApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejectionDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInitiatePaymentFinal</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartDamageReport" name="Damage report received">
      <bpmn:outgoing>Flow_I1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartDamageReport" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCreateCase" name="Create case">
      <bpmn:incoming>Flow_I1</bpmn:incoming>
      <bpmn:outgoing>Flow_I2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="TaskCheckCoverage" name="Check coverage">
      <bpmn:incoming>Flow_I2</bpmn:incoming>
      <bpmn:outgoing>Flow_I3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwCovered" name="Covered?">
      <bpmn:incoming>Flow_I3</bpmn:incoming>
      <bpmn:outgoing>Flow_I4</bpmn:outgoing>
      <bpmn:outgoing>Flow_I5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendRejectionNotCovered" name="Send rejection">
      <bpmn:incoming>Flow_I4</bpmn:incoming>
      <bpmn:outgoing>Flow_I6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedNotCovered" name="Case closed">
      <bpmn:incoming>Flow_I6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskCheckAmount" name="Check amount">
      <bpmn:incoming>Flow_I5</bpmn:incoming>
      <bpmn:outgoing>Flow_I7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwAmountHigh" name="> €1500?">
      <bpmn:incoming>Flow_I7</bpmn:incoming>
      <bpmn:outgoing>Flow_I8</bpmn:outgoing>
      <bpmn:outgoing>Flow_I9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePaymentLow" name="Initiate payment">
      <bpmn:incoming>Flow_I8</bpmn:incoming>
      <bpmn:outgoing>Flow_I10</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalLow" name="Send approval">
      <bpmn:incoming>Flow_I10</bpmn:incoming>
      <bpmn:outgoing>Flow_I11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedLowApproved" name="Case closed">
      <bpmn:incoming>Flow_I11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendOrder" name="Send order">
      <bpmn:incoming>Flow_I9</bpmn:incoming>
      <bpmn:outgoing>Flow_I12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitReport">
      <bpmn:incoming>Flow_I12</bpmn:incoming>
      <bpmn:outgoing>Flow_I13</bpmn:outgoing>
      <bpmn:outgoing>Flow_I14</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReport" name="Report received">
      <bpmn:incoming>Flow_I13</bpmn:incoming>
      <bpmn:outgoing>Flow_I15</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchReport" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDeadline" name="10 days exceeded">
      <bpmn:incoming>Flow_I14</bpmn:incoming>
      <bpmn:outgoing>Flow_I16</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_10Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendRejectionDeadline" name="Send rejection">
      <bpmn:incoming>Flow_I16</bpmn:incoming>
      <bpmn:outgoing>Flow_I17</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedDeadline" name="Case closed">
      <bpmn:incoming>Flow_I17</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewAssessment" name="Review assessment">
      <bpmn:incoming>Flow_I15</bpmn:incoming>
      <bpmn:outgoing>Flow_I18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwFinalApproved" name="Approved?">
      <bpmn:incoming>Flow_I18</bpmn:incoming>
      <bpmn:outgoing>Flow_I19</bpmn:outgoing>
      <bpmn:outgoing>Flow_I20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskInitiatePaymentFinal" name="Initiate payment">
      <bpmn:incoming>Flow_I19</bpmn:incoming>
      <bpmn:outgoing>Flow_I21</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendApprovalFinal" name="Send approval">
      <bpmn:incoming>Flow_I21</bpmn:incoming>
      <bpmn:outgoing>Flow_I22</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedFinalApproved" name="Case closed">
      <bpmn:incoming>Flow_I22</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendRejectionFinal" name="Send rejection">
      <bpmn:incoming>Flow_I20</bpmn:incoming>
      <bpmn:outgoing>Flow_I23</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedFinalRejected" name="Case closed">
      <bpmn:incoming>Flow_I23</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_I1" sourceRef="StartDamageReport" targetRef="TaskCreateCase" />
    <bpmn:sequenceFlow id="Flow_I2" sourceRef="TaskCreateCase" targetRef="TaskCheckCoverage" />
    <bpmn:sequenceFlow id="Flow_I3" sourceRef="TaskCheckCoverage" targetRef="GwCovered" />
    <bpmn:sequenceFlow id="Flow_I4" name="No" sourceRef="GwCovered" targetRef="TaskSendRejectionNotCovered" />
    <bpmn:sequenceFlow id="Flow_I5" name="Yes" sourceRef="GwCovered" targetRef="TaskCheckAmount" />
    <bpmn:sequenceFlow id="Flow_I6" sourceRef="TaskSendRejectionNotCovered" targetRef="EndClosedNotCovered" />
    <bpmn:sequenceFlow id="Flow_I7" sourceRef="TaskCheckAmount" targetRef="GwAmountHigh" />
    <bpmn:sequenceFlow id="Flow_I8" name="No" sourceRef="GwAmountHigh" targetRef="TaskInitiatePaymentLow" />
    <bpmn:sequenceFlow id="Flow_I9" name="Yes" sourceRef="GwAmountHigh" targetRef="TaskSendOrder" />
    <bpmn:sequenceFlow id="Flow_I10" sourceRef="TaskInitiatePaymentLow" targetRef="TaskSendApprovalLow" />
    <bpmn:sequenceFlow id="Flow_I11" sourceRef="TaskSendApprovalLow" targetRef="EndClosedLowApproved" />
    <bpmn:sequenceFlow id="Flow_I12" sourceRef="TaskSendOrder" targetRef="GwWaitReport" />
    <bpmn:sequenceFlow id="Flow_I13" sourceRef="GwWaitReport" targetRef="CatchReport" />
    <bpmn:sequenceFlow id="Flow_I14" sourceRef="GwWaitReport" targetRef="CatchDeadline" />
    <bpmn:sequenceFlow id="Flow_I15" sourceRef="CatchReport" targetRef="TaskReviewAssessment" />
    <bpmn:sequenceFlow id="Flow_I16" sourceRef="CatchDeadline" targetRef="TaskSendRejectionDeadline" />
    <bpmn:sequenceFlow id="Flow_I17" sourceRef="TaskSendRejectionDeadline" targetRef="EndClosedDeadline" />
    <bpmn:sequenceFlow id="Flow_I18" sourceRef="TaskReviewAssessment" targetRef="GwFinalApproved" />
    <bpmn:sequenceFlow id="Flow_I19" name="Yes" sourceRef="GwFinalApproved" targetRef="TaskInitiatePaymentFinal" />
    <bpmn:sequenceFlow id="Flow_I20" name="No" sourceRef="GwFinalApproved" targetRef="TaskSendRejectionFinal" />
    <bpmn:sequenceFlow id="Flow_I21" sourceRef="TaskInitiatePaymentFinal" targetRef="TaskSendApprovalFinal" />
    <bpmn:sequenceFlow id="Flow_I22" sourceRef="TaskSendApprovalFinal" targetRef="EndClosedFinalApproved" />
    <bpmn:sequenceFlow id="Flow_I23" sourceRef="TaskSendRejectionFinal" targetRef="EndClosedFinalRejected" />
  </bpmn:process>

  <bpmn:process id="Process_Assessor" isExecutable="false">
    <bpmn:startEvent id="StartOrderReceived" name="Order received">
      <bpmn:outgoing>Flow_A1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartOrder" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskAssessDamage" name="Assess damage">
      <bpmn:incoming>Flow_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskSendReport" name="Send report">
      <bpmn:incoming>Flow_A2</bpmn:incoming>
      <bpmn:outgoing>Flow_A3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndAssessorDone" name="Done">
      <bpmn:incoming>Flow_A3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_A1" sourceRef="StartOrderReceived" targetRef="TaskAssessDamage" />
    <bpmn:sequenceFlow id="Flow_A2" sourceRef="TaskAssessDamage" targetRef="TaskSendReport" />
    <bpmn:sequenceFlow id="Flow_A3" sourceRef="TaskSendReport" targetRef="EndAssessorDone" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="Collaboration_InsuranceClaim">

      <bpmndi:BPMNShape id="PoolInsurance_di" bpmnElement="PoolInsurance" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneClaimsHandler_di" bpmnElement="LaneClaimsHandler" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneClaimsSystem_di" bpmnElement="LaneClaimsSystem" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1500" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartDamageReport_di" bpmnElement="StartDamageReport">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="185" y="195" width="110" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCreateCase_di" bpmnElement="TaskCreateCase">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCoverage_di" bpmnElement="TaskCheckCoverage">
        <dc:Bounds x="480" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCovered_di" bpmnElement="GwCovered" isMarkerVisible="true">
        <dc:Bounds x="635" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="628" y="202" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionNotCovered_di" bpmnElement="TaskSendRejectionNotCovered">
        <dc:Bounds x="750" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNotCovered_di" bpmnElement="EndClosedNotCovered">
        <dc:Bounds x="920" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="145" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckAmount_di" bpmnElement="TaskCheckAmount">
        <dc:Bounds x="750" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwAmountHigh_di" bpmnElement="GwAmountHigh" isMarkerVisible="true">
        <dc:Bounds x="905" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="890" y="242" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePaymentLow_di" bpmnElement="TaskInitiatePaymentLow">
        <dc:Bounds x="1030" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalLow_di" bpmnElement="TaskSendApprovalLow">
        <dc:Bounds x="1190" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedLowApproved_di" bpmnElement="EndClosedLowApproved">
        <dc:Bounds x="1355" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1335" y="365" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendOrder_di" bpmnElement="TaskSendOrder">
        <dc:Bounds x="1030" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitReport_di" bpmnElement="GwWaitReport">
        <dc:Bounds x="1195" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReport_di" bpmnElement="CatchReport">
        <dc:Bounds x="1310" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1285" y="215" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDeadline_di" bpmnElement="CatchDeadline">
        <dc:Bounds x="1310" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1280" y="345" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionDeadline_di" bpmnElement="TaskSendRejectionDeadline">
        <dc:Bounds x="1430" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedDeadline_di" bpmnElement="EndClosedDeadline">
        <dc:Bounds x="1590" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1570" y="345" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewAssessment_di" bpmnElement="TaskReviewAssessment">
        <dc:Bounds x="1430" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwFinalApproved_di" bpmnElement="GwFinalApproved" isMarkerVisible="true">
        <dc:Bounds x="1585" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1578" y="202" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiatePaymentFinal_di" bpmnElement="TaskInitiatePaymentFinal">
        <dc:Bounds x="1710" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApprovalFinal_di" bpmnElement="TaskSendApprovalFinal">
        <dc:Bounds x="1870" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedFinalApproved_di" bpmnElement="EndClosedFinalApproved">
        <dc:Bounds x="2035" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2015" y="145" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejectionFinal_di" bpmnElement="TaskSendRejectionFinal">
        <dc:Bounds x="1710" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedFinalRejected_di" bpmnElement="EndClosedFinalRejected">
        <dc:Bounds x="1875" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1855" y="245" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolAssessor_di" bpmnElement="PoolAssessor" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1500" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartOrderReceived_di" bpmnElement="StartOrderReceived">
        <dc:Bounds x="220" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="625" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskAssessDamage_di" bpmnElement="TaskAssessDamage">
        <dc:Bounds x="320" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendReport_di" bpmnElement="TaskSendReport">
        <dc:Bounds x="480" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndAssessorDone_di" bpmnElement="EndAssessorDone">
        <dc:Bounds x="640" y="582" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="628" y="625" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="760" width="1500" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_I1_di" bpmnElement="Flow_I1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I2_di" bpmnElement="Flow_I2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="480" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I3_di" bpmnElement="Flow_I3">
        <di:waypoint x="580" y="170" />
        <di:waypoint x="635" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I4_di" bpmnElement="Flow_I4">
        <di:waypoint x="660" y="145" />
        <di:waypoint x="660" y="120" />
        <di:waypoint x="750" y="120" />
        <bpmndi:BPMNLabel><dc:Bounds x="670" y="124" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I6_di" bpmnElement="Flow_I6">
        <di:waypoint x="850" y="120" />
        <di:waypoint x="920" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I5_di" bpmnElement="Flow_I5">
        <di:waypoint x="685" y="170" />
        <di:waypoint x="750" y="210" />
        <bpmndi:BPMNLabel><dc:Bounds x="700" y="188" width="22" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I7_di" bpmnElement="Flow_I7">
        <di:waypoint x="850" y="210" />
        <di:waypoint x="905" y="210" />
      </bpmndi:BPMNEdge>
