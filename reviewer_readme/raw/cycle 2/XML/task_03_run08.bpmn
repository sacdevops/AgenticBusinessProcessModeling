<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Vacation" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Vacation">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHR" name="HR Department" processRef="Process_HR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Request" sourceRef="TaskSubmitRequest" targetRef="StartRequestArrived" />
    <bpmn:messageFlow id="MF_OutcomeApproved" name="Approved" sourceRef="EndApprovedMsg" targetRef="CatchApproved" />
    <bpmn:messageFlow id="MF_OutcomeRejectedDays" name="Rejected" sourceRef="EndRejectedDaysMsg" targetRef="CatchRejected" />
    <bpmn:messageFlow id="MF_OutcomeRejectedSupervisor" name="Rejected" sourceRef="EndRejectedSupervisorMsg" targetRef="CatchRejected" />
    <bpmn:messageFlow id="MF_OutcomeRejectedHR" name="Rejected" sourceRef="EndRejectedHRMsg" targetRef="CatchRejected" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartNeedVacation" name="Vacation needed">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitOutcome" name="">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:outgoing>Flow_E4</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchApproved" name="Approval received">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
      <bpmn:outgoing>Flow_E5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchApproved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchRejected" name="Rejection received">
      <bpmn:incoming>Flow_E4</bpmn:incoming>
      <bpmn:outgoing>Flow_E6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchRejected" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndEmployeeInformedApproved" name="Decision received">
      <bpmn:incoming>Flow_E5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEmployeeInformedRejected" name="Decision received">
      <bpmn:incoming>Flow_E6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartNeedVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="GwWaitOutcome" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="GwWaitOutcome" targetRef="CatchApproved" />
    <bpmn:sequenceFlow id="Flow_E4" sourceRef="GwWaitOutcome" targetRef="CatchRejected" />
    <bpmn:sequenceFlow id="Flow_E5" sourceRef="CatchApproved" targetRef="EndEmployeeInformedApproved" />
    <bpmn:sequenceFlow id="Flow_E6" sourceRef="CatchRejected" targetRef="EndEmployeeInformedRejected" />
  </bpmn:process>

  <bpmn:process id="Process_HR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR">
      <bpmn:lane id="LaneHRPortal" name="HR Portal">
        <bpmn:flowNodeRef>StartRequestArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckBalance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwEnoughDays</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToSupervisor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchSupervisorDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchTimeout5Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskBookVacation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApprovedMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedDaysMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedSupervisorMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejectedHRMsg</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupervisorApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendRejection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwManagerApprove</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartRequestArrived" name="Request received">
      <bpmn:messageEventDefinition id="MED_StartRequest" />
      <bpmn:outgoing>Flow_H1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckBalance" name="Check balance">
      <bpmn:incoming>Flow_H1</bpmn:incoming>
      <bpmn:outgoing>Flow_H2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_H2</bpmn:incoming>
      <bpmn:outgoing>Flow_H3</bpmn:outgoing>
      <bpmn:outgoing>Flow_H4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndRejectedDaysMsg" name="Rejection sent">
      <bpmn:incoming>Flow_H4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedDays" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Send approval">
      <bpmn:incoming>Flow_H3</bpmn:incoming>
      <bpmn:outgoing>Flow_H5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_H5</bpmn:incoming>
      <bpmn:outgoing>Flow_H6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupervisorApprove" name="Approved?">
      <bpmn:incoming>Flow_H6</bpmn:incoming>
      <bpmn:outgoing>Flow_H7</bpmn:outgoing>
      <bpmn:outgoing>Flow_H8</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendApproval" name="Send decision">
      <bpmn:incoming>Flow_H7</bpmn:incoming>
      <bpmn:outgoing>Flow_H9</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="TaskSendRejection" name="Send decision">
      <bpmn:incoming>Flow_H8</bpmn:incoming>
      <bpmn:outgoing>Flow_H10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback" name="">
      <bpmn:incoming>Flow_H9</bpmn:incoming>
      <bpmn:incoming>Flow_H10</bpmn:incoming>
      <bpmn:outgoing>Flow_H11</bpmn:outgoing>
      <bpmn:outgoing>Flow_H12</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorDecision" name="Feedback received">
      <bpmn:incoming>Flow_H11</bpmn:incoming>
      <bpmn:outgoing>Flow_H13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchSupervisorDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout5Days" name="5 days exceeded">
      <bpmn:incoming>Flow_H12</bpmn:incoming>
      <bpmn:outgoing>Flow_H14</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorOutcome" name="Approved?">
      <bpmn:incoming>Flow_H13</bpmn:incoming>
      <bpmn:outgoing>Flow_H15</bpmn:outgoing>
      <bpmn:outgoing>Flow_H16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_H15</bpmn:incoming>
      <bpmn:outgoing>Flow_H17</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndApprovedMsg" name="Approval sent">
      <bpmn:incoming>Flow_H17</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedSupervisorMsg" name="Rejection sent">
      <bpmn:incoming>Flow_H16</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedSupervisor" />
    </bpmn:endEvent>

    <bpmn:userTask id="TaskReviewEscalation" name="Review escalation">
      <bpmn:incoming>Flow_H14</bpmn:incoming>
      <bpmn:outgoing>Flow_H18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwManagerApprove" name="Approved?">
      <bpmn:incoming>Flow_H18</bpmn:incoming>
      <bpmn:outgoing>Flow_H19</bpmn:outgoing>
      <bpmn:outgoing>Flow_H20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_H1" sourceRef="StartRequestArrived" targetRef="TaskCheckBalance" />
    <bpmn:sequenceFlow id="Flow_H2" sourceRef="TaskCheckBalance" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_H3" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_H4" name="No" sourceRef="GwEnoughDays" targetRef="EndRejectedDaysMsg" />

    <bpmn:sequenceFlow id="Flow_H5" sourceRef="TaskSendToSupervisor" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_H6" sourceRef="TaskReviewRequest" targetRef="GwSupervisorApprove" />
    <bpmn:sequenceFlow id="Flow_H7" name="Yes" sourceRef="GwSupervisorApprove" targetRef="TaskSendApproval" />
    <bpmn:sequenceFlow id="Flow_H8" name="No" sourceRef="GwSupervisorApprove" targetRef="TaskSendRejection" />

    <bpmn:sequenceFlow id="Flow_H9" sourceRef="TaskSendApproval" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_H10" sourceRef="TaskSendRejection" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_H11" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_H12" sourceRef="GwWaitFeedback" targetRef="CatchTimeout5Days" />

    <bpmn:sequenceFlow id="Flow_H13" sourceRef="CatchSupervisorDecision" targetRef="GwSupervisorOutcome" />
    <bpmn:sequenceFlow id="Flow_H15" name="Yes" sourceRef="GwSupervisorOutcome" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H16" name="No" sourceRef="GwSupervisorOutcome" targetRef="EndRejectedSupervisorMsg" />
    <bpmn:sequenceFlow id="Flow_H17" sourceRef="TaskBookVacation" targetRef="EndApprovedMsg" />

    <bpmn:sequenceFlow id="Flow_H14" sourceRef="CatchTimeout5Days" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_H18" sourceRef="TaskReviewEscalation" targetRef="GwManagerApprove" />
    <bpmn:sequenceFlow id="Flow_H19" name="Yes" sourceRef="GwManagerApprove" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_H20" name="No" sourceRef="GwManagerApprove" targetRef="EndRejectedHRMsg" />

    <bpmn:endEvent id="EndRejectedHRMsg" name="Rejection sent">
      <bpmn:incoming>Flow_H20</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndRejectedHR" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_H19_toBook" sourceRef="GwManagerApprove" targetRef="TaskBookVacation" name="Yes" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Vacation">
    <bpmndi:BPMNPlane id="BPMNPlane_Vacation" bpmnElement="Collaboration_Vacation">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="260" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartNeedVacation_di" bpmnElement="StartNeedVacation">
        <dc:Bounds x="220" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="199" y="235" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="340" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitOutcome_di" bpmnElement="GwWaitOutcome">
        <dc:Bounds x="520" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchApproved_di" bpmnElement="CatchApproved">
        <dc:Bounds x="650" y="140" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="621" y="105" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchRejected_di" bpmnElement="CatchRejected">
        <dc:Bounds x="650" y="260" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="620" y="303" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeInformedApproved_di" bpmnElement="EndEmployeeInformedApproved">
        <dc:Bounds x="820" y="140" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="796" y="183" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEmployeeInformedRejected_di" bpmnElement="EndEmployeeInformedRejected">
        <dc:Bounds x="820" y="260" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="796" y="303" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_E1_di" bpmnElement="Flow_E1">
        <di:waypoint x="256" y="210" />
        <di:waypoint x="340" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_di" bpmnElement="Flow_E2">
        <di:waypoint x="440" y="210" />
        <di:waypoint x="520" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E3_di" bpmnElement="Flow_E3">
        <di:waypoint x="545" y="185" />
        <di:waypoint x="545" y="158" />
        <di:waypoint x="650" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E4_di" bpmnElement="Flow_E4">
        <di:waypoint x="545" y="235" />
        <di:waypoint x="545" y="278" />
        <di:waypoint x="650" y="278" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E5_di" bpmnElement="Flow_E5">
        <di:waypoint x="686" y="158" />
        <di:waypoint x="820" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E6_di" bpmnElement="Flow_E6">
        <di:waypoint x="686" y="278" />
        <di:waypoint x="820" y="278" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="PoolHR_di" bpmnElement="PoolHR" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="420" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneHRPortal_di" bpmnElement="LaneHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneSupervisor_di" bpmnElement="LaneSupervisor" isHorizontal="true">
        <dc:Bounds x="160" y="530" width="1400" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneHRManager_di" bpmnElement="LaneHRManager" isHorizontal="true">
        <dc:Bounds x="160" y="670" width="1400" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestArrived_di" bpmnElement="StartRequestArrived">
        <dc:Bounds x="220" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="485" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckBalance_di" bpmnElement="TaskCheckBalance">
        <dc:Bounds x="340" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="520" y="435" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="505" y="492" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedDaysMsg_di" bpmnElement="EndRejectedDaysMsg">
        <dc:Bounds x="680" y="420" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="654" y="463" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToSupervisor_di" bpmnElement="TaskSendToSupervisor">
        <dc:Bounds x="650" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewRequest_di" bpmnElement="TaskReviewRequest">
        <dc:Bounds x="820" y="560" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApprove_di" bpmnElement="GwSupervisorApprove" isMarkerVisible="true">
        <dc:Bounds x="980" y="575" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="973" y="632" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendApproval_di" bpmnElement="TaskSendApproval">
        <dc:Bounds x="1120" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendRejection_di" bpmnElement="TaskSendRejection">
        <dc:Bounds x="1120" y="640" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="1280" y="575" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorDecision_di" bpmnElement="CatchSupervisorDecision">
        <dc:Bounds x="1400" y="540" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1368" y="503" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout5Days_di" bpmnElement="CatchTimeout5Days">
        <dc:Bounds x="1400" y="660" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1367" y="703" width="102" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorOutcome_di" bpmnElement="GwSupervisorOutcome" isMarkerVisible="true">
        <dc:Bounds x="1480" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1473" y="592" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1480" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApprovedMsg_di" bpmnElement="EndApprovedMsg">
        <dc:Bounds x="1620" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1594" y="485" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedSupervisorMsg_di" bpmnElement="EndRejectedSupervisorMsg">
        <dc:Bounds x="1620" y="540" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1592" y="583" width="92" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskReviewEscalation_di" bpmnElement="TaskReviewEscalation">
        <dc:Bounds x="820" y="700" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwManagerApprove_di" bpmnElement="GwManagerApprove" isMarkerVisible="true">
        <dc:Bounds x="980" y="715" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="973" y="772" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejectedHRMsg_di" bpmnElement="EndRejectedHRMsg">
        <dc:Bounds x="1120" y="722" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1094" y="765" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_H1_di" bpmnElement="Flow_H1">
        <di:waypoint x="256" y="460" />
        <di:waypoint x="340" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H2_di" bpmnElement="Flow_H2">
        <di:waypoint x="440" y="460" />
        <di:waypoint x="520" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_H3_di" bpmnElement="Flow_H3">
        <di:waypoint x="570" y="460" />
        <di:waypoint x="620" y="520" />
        <di:waypoint x="650" y="520" />
