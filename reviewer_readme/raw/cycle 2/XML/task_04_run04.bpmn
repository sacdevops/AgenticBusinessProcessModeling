<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_BuildingPermits"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_BuildingPermits">
    <bpmn:participant id="PoolBuildingAuthority" name="Building Authority" processRef="Process_BuildingAuthority" />
    <bpmn:participant id="PoolCitizen" name="Citizen" />
    <bpmn:participant id="PoolEnvAgency" name="Environmental Agency" />

    <bpmn:messageFlow id="MF_SubmitApplication" name="Application" sourceRef="PoolCitizen" targetRef="StartApplicationReceived" />
    <bpmn:messageFlow id="MF_RequestMissingDocs" name="Missing docs" sourceRef="TaskRequestMissingDocs" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_SubmitMissingDocs" name="Missing docs" sourceRef="PoolCitizen" targetRef="CatchMissingDocs" />

    <bpmn:messageFlow id="MF_SendToEnvAgency" name="Application" sourceRef="TaskSendToEnvAgency" targetRef="PoolEnvAgency" />
    <bpmn:messageFlow id="MF_EnvOpinion" name="Opinion" sourceRef="PoolEnvAgency" targetRef="CatchEnvOpinion" />

    <bpmn:messageFlow id="MF_InformApproval" name="Permit" sourceRef="TaskInformApproval" targetRef="PoolCitizen" />
    <bpmn:messageFlow id="MF_InformRejection" name="Rejection" sourceRef="TaskInformRejection" targetRef="PoolCitizen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_BuildingAuthority" name="Processing of building permits" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BuildingAuthority">
      <bpmn:lane id="LaneOfficial" name="Official">
        <bpmn:flowNodeRef>StartApplicationReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskCheckCompleteness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskRequestMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchMissingDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchDocsDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendToEnvAgency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEnvOpinion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwOpinionPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskIssuePermit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneTestEngineer" name="Test Engineer">
        <bpmn:flowNodeRef>TaskCheckTechnical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwTechPositive</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApplicationReceived" name="Application received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_StartApplication" />
    </bpmn:startEvent>

    <bpmn:userTask id="TaskCheckCompleteness" name="Check completeness">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwComplete" name="Complete?" isMarkerVisible="true">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskRequestMissingDocs" name="Request documents">
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDocs" isMarkerVisible="true">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5_Msg</bpmn:outgoing>
      <bpmn:outgoing>Flow_5_Timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchMissingDocs" name="Docs received">
      <bpmn:incoming>Flow_5_Msg</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_MissingDocs" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDocsDeadline" name="14 days exceeded">
      <bpmn:incoming>Flow_5_Timer</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="TaskSendToEnvAgency" name="Send to agency">
      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:intermediateCatchEvent id="CatchEnvOpinion" name="Opinion received">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_EnvOpinion" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwOpinionPositive" name="Positive?" isMarkerVisible="true">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_10_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskCheckTechnical" name="Check technical">
      <bpmn:incoming>Flow_10_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwTechPositive" name="OK?" isMarkerVisible="true">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="TaskIssuePermit" name="Issue permit">
      <bpmn:incoming>Flow_12_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="TaskInformApproval" name="Inform citizen">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndApproved" name="Approved">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskInformRejection" name="Inform citizen">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_10_No</bpmn:incoming>
      <bpmn:incoming>Flow_12_No</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRejected" name="Rejected">
      <bpmn:incoming>Flow_15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartApplicationReceived" targetRef="TaskCheckCompleteness" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskCheckCompleteness" targetRef="GwComplete" />
    <bpmn:sequenceFlow id="Flow_3_Yes" name="Yes" sourceRef="GwComplete" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="GwComplete" targetRef="TaskRequestMissingDocs" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="TaskRequestMissingDocs" targetRef="GwWaitDocs" />
    <bpmn:sequenceFlow id="Flow_5_Msg" sourceRef="GwWaitDocs" targetRef="CatchMissingDocs" />
    <bpmn:sequenceFlow id="Flow_5_Timer" sourceRef="GwWaitDocs" targetRef="CatchDocsDeadline" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchMissingDocs" targetRef="TaskSendToEnvAgency" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="CatchDocsDeadline" targetRef="TaskInformRejection" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskSendToEnvAgency" targetRef="CatchEnvOpinion" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="CatchEnvOpinion" targetRef="GwOpinionPositive" />
    <bpmn:sequenceFlow id="Flow_10_Yes" name="Yes" sourceRef="GwOpinionPositive" targetRef="TaskCheckTechnical" />
    <bpmn:sequenceFlow id="Flow_10_No" name="No" sourceRef="GwOpinionPositive" targetRef="TaskInformRejection" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskCheckTechnical" targetRef="GwTechPositive" />
    <bpmn:sequenceFlow id="Flow_12_Yes" name="Yes" sourceRef="GwTechPositive" targetRef="TaskIssuePermit" />
    <bpmn:sequenceFlow id="Flow_12_No" name="No" sourceRef="GwTechPositive" targetRef="TaskInformRejection" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskIssuePermit" targetRef="TaskInformApproval" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskInformApproval" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="TaskInformRejection" targetRef="EndRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BuildingPermits">
    <bpmndi:BPMNPlane id="BPMNPlane_BuildingPermits" bpmnElement="Collaboration_BuildingPermits">

      <bpmndi:BPMNShape id="PoolBuildingAuthority_di" bpmnElement="PoolBuildingAuthority" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneOfficial_di" bpmnElement="LaneOfficial" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneTestEngineer_di" bpmnElement="LaneTestEngineer" isHorizontal="true">
        <dc:Bounds x="160" y="260" width="1400" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCitizen_di" bpmnElement="PoolCitizen" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolEnvAgency_di" bpmnElement="PoolEnvAgency" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartApplicationReceived_di" bpmnElement="StartApplicationReceived">
        <dc:Bounds x="220" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="195" y="195" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckCompleteness_di" bpmnElement="TaskCheckCompleteness">
        <dc:Bounds x="330" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwComplete_di" bpmnElement="GwComplete" isMarkerVisible="true">
        <dc:Bounds x="500" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="488" y="202" width="75" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRequestMissingDocs_di" bpmnElement="TaskRequestMissingDocs">
        <dc:Bounds x="610" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDocs_di" bpmnElement="GwWaitDocs" isMarkerVisible="true">
        <dc:Bounds x="770" y="55" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchMissingDocs_di" bpmnElement="CatchMissingDocs">
        <dc:Bounds x="900" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="876" y="38" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDocsDeadline_di" bpmnElement="CatchDocsDeadline">
        <dc:Bounds x="900" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="862" y="195" width="112" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToEnvAgency_di" bpmnElement="TaskSendToEnvAgency">
        <dc:Bounds x="610" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchEnvOpinion_di" bpmnElement="CatchEnvOpinion">
        <dc:Bounds x="770" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="744" y="195" width="88" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOpinionPositive_di" bpmnElement="GwOpinionPositive" isMarkerVisible="true">
        <dc:Bounds x="860" y="145" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="852" y="202" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="980" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechPositive_di" bpmnElement="GwTechPositive" isMarkerVisible="true">
        <dc:Bounds x="1140" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1153" y="382" width="30" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1250" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformApproval_di" bpmnElement="TaskInformApproval">
        <dc:Bounds x="1410" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1530" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1514" y="375" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformRejection_di" bpmnElement="TaskInformRejection">
        <dc:Bounds x="1030" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="1200" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1186" y="195" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="170" />
        <di:waypoint x="330" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="170" />
        <di:waypoint x="500" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_Yes_di" bpmnElement="Flow_3_Yes">
        <di:waypoint x="550" y="170" />
        <di:waypoint x="610" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="571" y="152" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_No_di" bpmnElement="Flow_3_No">
        <di:waypoint x="525" y="145" />
        <di:waypoint x="525" y="80" />
        <di:waypoint x="610" y="80" />
        <bpmndi:BPMNLabel><dc:Bounds x="533" y="103" width="18" height="14" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="710" y="80" />
        <di:waypoint x="770" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_Msg_di" bpmnElement="Flow_5_Msg">
        <di:waypoint x="820" y="80" />
        <di:waypoint x="900" y="80" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_Timer_di" bpmnElement="Flow_5_Timer">
        <di:waypoint x="795" y="105" />
        <di:waypoint x="795" y="170" />
        <di:waypoint x="900" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="918" y="80" />
        <di:waypoint x="918" y="120" />
        <di:waypoint x="660" y="120" />
        <di:waypoint x="660" y="130" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="936" y="170" />
        <di:waypoint x="1030" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="710" y="170" />
        <di:waypoint x="770" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="806" y="170" />
        <di:waypoint x="860" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_Yes_di" bpmnElement="Flow_10_Yes">
        <di:waypoint x="885" y="195" />
        <di:waypoint x="885" y="350" />
        <di:waypoint x="980" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="893" y="270" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_No_di" bpmnElement="Flow_10_No">
        <di:waypoint x="910" y="170" />
        <di:waypoint x="1030" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="955" y="152" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1080" y="350" />
        <di:waypoint x="1140" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_Yes_di" bpmnElement="Flow_12_Yes">
        <di:waypoint x="1190" y="350" />
        <di:waypoint x="1250" y="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="1210" y="332" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_No_di" bpmnElement="Flow_12_No">
        <di:waypoint x="1165" y="325" />
        <di:waypoint x="1165" y="210" />
        <di:waypoint x="1080" y="210" />
        <di:waypoint x="1080" y="210" />
        <di:waypoint x="1080" y="170" />
        <di:waypoint x="1130" y="170" />
        <bpmndi:BPMNLabel><dc:Bounds x="1174" y="252" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1350" y="350" />
        <di:waypoint x="1410" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1510" y="350" />
        <di:waypoint x="1530" y="350" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1130" y="170" />
        <di:waypoint x="1200" y="170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitApplication_di" bpmnElement="MF_SubmitApplication">
        <di:waypoint x="860" y="490" />
        <di:waypoint x="238" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RequestMissingDocs_di" bpmnElement="MF_RequestMissingDocs">
        <di:waypoint x="660" y="120" />
        <di:waypoint x="660" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SubmitMissingDocs_di" bpmnElement="MF_SubmitMissingDocs">
        <di:waypoint x="520" y="490" />
        <di:waypoint x="520" y="20" />
        <di:waypoint x="918" y="20" />
        <di:waypoint x="918" y="62" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_SendToEnvAgency_di" bpmnElement="MF_SendToEnvAgency">
        <di:waypoint x="660" y="210" />
        <di:waypoint x="660" y="600" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_EnvOpinion_di" bpmnElement="MF_EnvOpinion">
        <di:waypoint x="860" y="600" />
        <di:waypoint x="860" y="520" />
        <di:waypoint x="788" y="520" />
        <di:waypoint x="788" y="188" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_InformApproval_di" bpmnElement="MF_InformApproval">
        <di:waypoint x="1460" y="310" />
        <di:waypoint x="1460" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_InformRejection_di" bpmnElement="MF_InformRejection">
        <di:waypoint x="1080" y="130" />
        <di:waypoint x="1080" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>