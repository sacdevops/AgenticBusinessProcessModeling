<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ReturnProcess" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_ReturnProcessing">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_Retailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" processRef="Process_Customer" />
    <bpmn:messageFlow id="MF_ReturnLabel" name="Return label" sourceRef="TaskSendLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_NoRefundInfo" name="No refund" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_CreditConfirm" name="Credit confirmation" sourceRef="TaskSendCredit" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Retailer" name="Return Processing" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitArrivalOrTimeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchPackageArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch14DaysExceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefundTimeout</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskInspectGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefundDamaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToAccounting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCredit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRefunded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendLabel" name="Send label">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitArrivalOrTimeout">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchPackageArrived" name="Package arrived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_PackageArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch14DaysExceeded" name="14 days exceeded">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndClosedNoRefundTimeout" name="Closed no refund">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskInspectGoods" name="Inspect goods">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods ok?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformNoRefund" name="Inform customer">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndClosedNoRefundDamaged" name="Closed no refund">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="TaskForwardToAccounting" name="Forward info">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendCredit" name="Send credit">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRefunded" name="Refunded">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateLabel" targetRef="TaskSendLabel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskSendLabel" targetRef="GwWaitArrivalOrTimeout" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitArrivalOrTimeout" targetRef="CatchPackageArrived" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitArrivalOrTimeout" targetRef="Catch14DaysExceeded" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchPackageArrived" targetRef="TaskInspectGoods" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Catch14DaysExceeded" targetRef="EndClosedNoRefundTimeout" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskInspectGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_9" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardToAccounting" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskInformNoRefund" targetRef="EndClosedNoRefundDamaged" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskForwardToAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskInitiateRefund" targetRef="TaskSendCredit" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskSendCredit" targetRef="EndRefunded" />
  </bpmn:process>

  <bpmn:process id="Process_Customer" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_ReturnProcessing">
    <bpmndi:BPMNPlane id="BPMNPlane_ReturnProcessing" bpmnElement="Collaboration_ReturnProcessing">
      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouse_di" bpmnElement="LaneWarehouse" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAccounting_di" bpmnElement="LaneAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="220" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="165" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskGenerateLabel_di" bpmnElement="TaskGenerateLabel">
        <dc:Bounds x="340" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendLabel_di" bpmnElement="TaskSendLabel">
        <dc:Bounds x="500" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitArrivalOrTimeout_di" bpmnElement="GwWaitArrivalOrTimeout">
        <dc:Bounds x="660" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchPackageArrived_di" bpmnElement="CatchPackageArrived">
        <dc:Bounds x="800" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="776" y="185" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch14DaysExceeded_di" bpmnElement="Catch14DaysExceeded">
        <dc:Bounds x="800" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="770" y="50" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoRefundTimeout_di" bpmnElement="EndClosedNoRefundTimeout">
        <dc:Bounds x="980" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="950" y="50" width="96" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInspectGoods_di" bpmnElement="TaskInspectGoods">
        <dc:Bounds x="920" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="1080" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1063" y="292" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformNoRefund_di" bpmnElement="TaskInformNoRefund">
        <dc:Bounds x="1220" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoRefundDamaged_di" bpmnElement="EndClosedNoRefundDamaged">
        <dc:Bounds x="1380" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1348" y="285" width="100" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToAccounting_di" bpmnElement="TaskForwardToAccounting">
        <dc:Bounds x="1220" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="920" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendCredit_di" bpmnElement="TaskSendCredit">
        <dc:Bounds x="1060" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRefunded_di" bpmnElement="EndRefunded">
        <dc:Bounds x="1380" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1366" y="405" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="140" />
        <di:waypoint x="340" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="140" />
        <di:waypoint x="500" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="140" />
        <di:waypoint x="660" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="710" y="140" />
        <di:waypoint x="800" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="685" y="115" />
        <di:waypoint x="685" y="100" />
        <di:waypoint x="800" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="836" y="160" />
        <di:waypoint x="870" y="160" />
        <di:waypoint x="870" y="260" />
        <di:waypoint x="920" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="836" y="100" />
        <di:waypoint x="980" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1020" y="260" />
        <di:waypoint x="1080" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1105" y="285" />
        <di:waypoint x="1105" y="380" />
        <di:waypoint x="1220" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="1112" y="304" width="22" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1130" y="260" />
        <di:waypoint x="1220" y="260" />
        <bpmndi:BPMNLabel><dc:Bounds x="1166" y="243" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1320" y="260" />
        <di:waypoint x="1380" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1220" y="380" />
        <di:waypoint x="1120" y="380" />
        <di:waypoint x="1120" y="380" />
        <di:waypoint x="1020" y="380" />
        <di:waypoint x="920" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1020" y="380" />
        <di:waypoint x="1060" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1160" y="380" />
        <di:waypoint x="1380" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_ReturnLabel_di" bpmnElement="MF_ReturnLabel">
        <di:waypoint x="550" y="180" />
        <di:waypoint x="550" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_NoRefundInfo_di" bpmnElement="MF_NoRefundInfo">
        <di:waypoint x="1270" y="300" />
        <di:waypoint x="1270" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_CreditConfirm_di" bpmnElement="MF_CreditConfirm">
        <di:waypoint x="1110" y="420" />
        <di:waypoint x="1110" y="490" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>