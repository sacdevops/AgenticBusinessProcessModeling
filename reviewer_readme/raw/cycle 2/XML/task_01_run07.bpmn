<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_ReturnProcessing"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_ReturnProcessing">
    <bpmn:participant id="PoolRetailer" name="Online Retailer" processRef="Process_Retailer" />
    <bpmn:participant id="PoolCustomer" name="Customer" />

    <bpmn:messageFlow id="MF_RegisterReturn" name="Return registration" sourceRef="PoolCustomer" targetRef="StartReturnRegistered" />
    <bpmn:messageFlow id="MF_ReturnLabel" name="Return label" sourceRef="TaskSendReturnLabel" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_DamageInfo" name="No refund" sourceRef="TaskInformNoRefund" targetRef="PoolCustomer" />
    <bpmn:messageFlow id="MF_CreditConfirmation" name="Credit confirmation" sourceRef="TaskSendCreditConfirmation" targetRef="PoolCustomer" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Retailer" name="Return Processing" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="LaneCustomerPortal" name="Customer Portal">
        <bpmn:flowNodeRef>StartReturnRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskGenerateReturnLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendReturnLabel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwWaitReturn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchReturnArrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch14Days</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndClosedNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndTimeoutNoRefund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneWarehouse" name="Warehouse">
        <bpmn:flowNodeRef>TaskCheckGoods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwGoodsOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskInformNoRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskForwardToAccounting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneAccounting" name="Accounting">
        <bpmn:flowNodeRef>TaskInitiateRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskSendCreditConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRefunded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartReturnRegistered" name="Return registered">
      <bpmn:messageEventDefinition id="MED_StartReturnRegistered" />
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskGenerateReturnLabel" name="Generate label">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendReturnLabel" name="Send label">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitReturn">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchReturnArrived" name="Return arrived">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_CatchReturnArrived" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Catch14Days" name="14 days exceeded">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Catch14Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="TaskCheckGoods" name="Check goods">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwGoodsOk" name="Goods ok?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskInformNoRefund" name="Inform customer">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:serviceTask id="TaskForwardToAccounting" name="Forward info">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="TaskInitiateRefund" name="Initiate refund">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="TaskSendCreditConfirmation" name="Send confirmation">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndRefunded" name="Refunded">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndClosedNoRefund" name="Closed">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndTimeoutNoRefund" name="Closed">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartReturnRegistered" targetRef="TaskGenerateReturnLabel" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="TaskGenerateReturnLabel" targetRef="TaskSendReturnLabel" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="TaskSendReturnLabel" targetRef="GwWaitReturn" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="GwWaitReturn" targetRef="CatchReturnArrived" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="GwWaitReturn" targetRef="Catch14Days" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="CatchReturnArrived" targetRef="TaskCheckGoods" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Catch14Days" targetRef="EndTimeoutNoRefund" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="TaskCheckGoods" targetRef="GwGoodsOk" />
    <bpmn:sequenceFlow id="Flow_9" name="Yes" sourceRef="GwGoodsOk" targetRef="TaskForwardToAccounting" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="GwGoodsOk" targetRef="TaskInformNoRefund" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="TaskInformNoRefund" targetRef="EndClosedNoRefund" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="TaskForwardToAccounting" targetRef="TaskInitiateRefund" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="TaskInitiateRefund" targetRef="TaskSendCreditConfirmation" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="TaskSendCreditConfirmation" targetRef="EndRefunded" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ReturnProcessing">
    <bpmndi:BPMNPlane id="BPMNPlane_ReturnProcessing" bpmnElement="Collaboration_ReturnProcessing">

      <bpmndi:BPMNShape id="PoolRetailer_di" bpmnElement="PoolRetailer" isHorizontal="true" isExpanded="true">
        <dc:Bounds x="160" y="80" width="1400" height="360" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="LaneCustomerPortal_di" bpmnElement="LaneCustomerPortal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneWarehouse_di" bpmnElement="LaneWarehouse" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="1400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LaneAccounting_di" bpmnElement="LaneAccounting" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="1400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolCustomer_di" bpmnElement="PoolCustomer" isHorizontal="true">
        <dc:Bounds x="160" y="490" width="1400" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartReturnRegistered_di" bpmnElement="StartReturnRegistered">
        <dc:Bounds x="220" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="203" y="165" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskGenerateReturnLabel_di" bpmnElement="TaskGenerateReturnLabel">
        <dc:Bounds x="330" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendReturnLabel_di" bpmnElement="TaskSendReturnLabel">
        <dc:Bounds x="500" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitReturn_di" bpmnElement="GwWaitReturn">
        <dc:Bounds x="660" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch14Days_di" bpmnElement="Catch14Days">
        <dc:Bounds x="810" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="792" y="72" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndTimeoutNoRefund_di" bpmnElement="EndTimeoutNoRefund">
        <dc:Bounds x="930" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="922" y="145" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchReturnArrived_di" bpmnElement="CatchReturnArrived">
        <dc:Bounds x="810" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="792" y="265" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckGoods_di" bpmnElement="TaskCheckGoods">
        <dc:Bounds x="930" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwGoodsOk_di" bpmnElement="GwGoodsOk" isMarkerVisible="true">
        <dc:Bounds x="1100" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1092" y="292" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInformNoRefund_di" bpmnElement="TaskInformNoRefund">
        <dc:Bounds x="1230" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndClosedNoRefund_di" bpmnElement="EndClosedNoRefund">
        <dc:Bounds x="1370" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1362" y="275" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToAccounting_di" bpmnElement="TaskForwardToAccounting">
        <dc:Bounds x="1230" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskInitiateRefund_di" bpmnElement="TaskInitiateRefund">
        <dc:Bounds x="1370" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendCreditConfirmation_di" bpmnElement="TaskSendCreditConfirmation">
        <dc:Bounds x="1530" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndRefunded_di" bpmnElement="EndRefunded">
        <dc:Bounds x="1660" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1650" y="405" width="56" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="256" y="140" />
        <di:waypoint x="330" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="140" />
        <di:waypoint x="500" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="140" />
        <di:waypoint x="660" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="685" y="165" />
        <di:waypoint x="685" y="240" />
        <di:waypoint x="810" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="710" y="140" />
        <di:waypoint x="810" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="846" y="120" />
        <di:waypoint x="930" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="828" y="258" />
        <di:waypoint x="828" y="260" />
        <di:waypoint x="930" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1030" y="260" />
        <di:waypoint x="1100" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1150" y="260" />
        <di:waypoint x="1230" y="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1176" y="240" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1330" y="250" />
        <di:waypoint x="1370" y="250" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1125" y="285" />
        <di:waypoint x="1125" y="380" />
        <di:waypoint x="1230" y="380" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1132" y="320" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1330" y="380" />
        <di:waypoint x="1370" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1470" y="380" />
        <di:waypoint x="1530" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1630" y="380" />
        <di:waypoint x="1660" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_RegisterReturn_di" bpmnElement="MF_RegisterReturn">
        <di:waypoint x="520" y="490" />
        <di:waypoint x="520" y="60" />
        <di:waypoint x="238" y="60" />
        <di:waypoint x="238" y="122" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_ReturnLabel_di" bpmnElement="MF_ReturnLabel">
        <di:waypoint x="550" y="180" />
        <di:waypoint x="550" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_DamageInfo_di" bpmnElement="MF_DamageInfo">
        <di:waypoint x="1280" y="210" />
        <di:waypoint x="1280" y="490" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_CreditConfirmation_di" bpmnElement="MF_CreditConfirmation">
        <di:waypoint x="1580" y="340" />
        <di:waypoint x="1580" y="490" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>