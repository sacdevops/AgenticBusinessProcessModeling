<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\"\n  xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\"\n  xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\"\n  xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\"\n  id=\"Definitions_VacationRequest\" targetNamespace=\"http://bpmn.io/schema/bpmn\">\n\n  <bpmn:collaboration id=\"Collaboration_VacationRequest\">\n    <bpmn:participant id=\"PoolEmployee\" name=\"Employee\" processRef=\"Process_Employee\" />\n    <bpmn:participant id=\"PoolHRPortal\" name=\"HR Portal\" processRef=\"Process_HRPortal\" />\n    <bpmn:participant id=\"PoolSupervisorHR\" name=\"Supervisor &amp; HR\" processRef=\"Process_SupervisorHR\" />\n\n    <bpmn:messageFlow id=\"MF_SubmitRequest\" name=\"Request\" sourceRef=\"TaskSubmitRequest\" targetRef=\"StartRequestReceived\" />\n    <bpmn:messageFlow id=\"MF_RequestApproval\" name=\"Approval request\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"StartApprovalRequested\" />\n    <bpmn:messageFlow id=\"MF_SupervisorDecision\" name=\"Decision\" sourceRef=\"TaskSendSupervisorDecision\" targetRef=\"CatchSupervisorDecision\" />\n    <bpmn:messageFlow id=\"MF_Escalation\" name=\"Escalation\" sourceRef=\"TaskSendEscalation\" targetRef=\"StartEscalationReceived\" />\n    <bpmn:messageFlow id=\"MF_HRManagerDecision\" name=\"Final decision\" sourceRef=\"TaskSendHRManagerDecision\" targetRef=\"CatchHRManagerDecision\" />\n\n    <bpmn:messageFlow id=\"MF_NotifyApproved\" name=\"Approved\" sourceRef=\"EndNotifyApproved\" targetRef=\"CatchApproved\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedDays\" name=\"Rejected\" sourceRef=\"EndNotifyRejectedDays\" targetRef=\"CatchRejected\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedSupervisor\" name=\"Rejected\" sourceRef=\"EndNotifyRejectedSupervisor\" targetRef=\"CatchRejected\" />\n    <bpmn:messageFlow id=\"MF_NotifyRejectedHR\" name=\"Rejected\" sourceRef=\"EndNotifyRejectedHR\" targetRef=\"CatchRejected\" />\n  </bpmn:collaboration>\n\n  <bpmn:process id=\"Process_Employee\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartNeedVacation\" name=\"Request needed\">\n      <bpmn:outgoing>Flow_E1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:sendTask id=\"TaskSubmitRequest\" name=\"Submit request\">\n      <bpmn:incoming>Flow_E1</bpmn:incoming>\n      <bpmn:outgoing>Flow_E2</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitOutcome\" name=\"\">\n      <bpmn:incoming>Flow_E2</bpmn:incoming>\n      <bpmn:outgoing>Flow_E3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_E4</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchApproved\" name=\"Approved received\">\n      <bpmn:incoming>Flow_E3</bpmn:incoming>\n      <bpmn:outgoing>Flow_E5</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_E_Approved\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndApproved\" name=\"Request approved\">\n      <bpmn:incoming>Flow_E5</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:intermediateCatchEvent id=\"CatchRejected\" name=\"Rejected received\">\n      <bpmn:incoming>Flow_E4</bpmn:incoming>\n      <bpmn:outgoing>Flow_E6</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_E_Rejected\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:endEvent id=\"EndRejected\" name=\"Request rejected\">\n      <bpmn:incoming>Flow_E6</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_E1\" sourceRef=\"StartNeedVacation\" targetRef=\"TaskSubmitRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_E2\" sourceRef=\"TaskSubmitRequest\" targetRef=\"GwWaitOutcome\" />\n    <bpmn:sequenceFlow id=\"Flow_E3\" sourceRef=\"GwWaitOutcome\" targetRef=\"CatchApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_E4\" sourceRef=\"GwWaitOutcome\" targetRef=\"CatchRejected\" />\n    <bpmn:sequenceFlow id=\"Flow_E5\" sourceRef=\"CatchApproved\" targetRef=\"EndApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_E6\" sourceRef=\"CatchRejected\" targetRef=\"EndRejected\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_HRPortal\" isExecutable=\"false\">\n    <bpmn:startEvent id=\"StartRequestReceived\" name=\"Request received\">\n      <bpmn:messageEventDefinition id=\"MED_HR_StartRequest\" />\n      <bpmn:outgoing>Flow_H1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:serviceTask id=\"TaskCheckBalance\" name=\"Check balance\">\n      <bpmn:incoming>Flow_H1</bpmn:incoming>\n      <bpmn:outgoing>Flow_H2</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:exclusiveGateway id=\"GwEnoughDays\" name=\"Enough days?\">\n      <bpmn:incoming>Flow_H2</bpmn:incoming>\n      <bpmn:outgoing>Flow_H3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendApprovalRequest\" name=\"Send approval\">\n      <bpmn:incoming>Flow_H3</bpmn:incoming>\n      <bpmn:outgoing>Flow_H5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:eventBasedGateway id=\"GwWaitFeedback\" name=\"\">\n      <bpmn:incoming>Flow_H5</bpmn:incoming>\n      <bpmn:outgoing>Flow_H6</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H7</bpmn:outgoing>\n    </bpmn:eventBasedGateway>\n\n    <bpmn:intermediateCatchEvent id=\"CatchSupervisorDecision\" name=\"Feedback received\">\n      <bpmn:incoming>Flow_H6</bpmn:incoming>\n      <bpmn:outgoing>Flow_H8</bpmn:outgoing>\n      <bpmn:messageEventDefinition id=\"MED_HR_SupDecision\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:intermediateCatchEvent id=\"Catch5Days\" name=\"5 days exceeded\">\n      <bpmn:incoming>Flow_H7</bpmn:incoming>\n      <bpmn:outgoing>Flow_H9</bpmn:outgoing>\n      <bpmn:timerEventDefinition id=\"TED_HR_5Days\" />\n    </bpmn:intermediateCatchEvent>\n\n    <bpmn:exclusiveGateway id=\"GwSupervisorApproved\" name=\"Approved?\">\n      <bpmn:incoming>Flow_H8</bpmn:incoming>\n      <bpmn:outgoing>Flow_H10</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H11</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendEscalation\" name=\"Send escalation\">\n      <bpmn:incoming>Flow_H9</bpmn:incoming>\n      <bpmn:outgoing>Flow_H12</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:receiveTask id=\"TaskReceiveFinalDecision\" name=\"Receive decision\">\n      <bpmn:incoming>Flow_H12</bpmn:incoming>\n      <bpmn:outgoing>Flow_H13</bpmn:outgoing>\n    </bpmn:receiveTask>\n\n    <bpmn:exclusiveGateway id=\"GwHRManagerApproved\" name=\"Approved?\">\n      <bpmn:incoming>Flow_H13</bpmn:incoming>\n      <bpmn:outgoing>Flow_H14</bpmn:outgoing>\n      <bpmn:outgoing>Flow_H15</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:serviceTask id=\"TaskBookVacation\" name=\"Book vacation\">\n      <bpmn:incoming>Flow_H10</bpmn:incoming>\n      <bpmn:incoming>Flow_H14</bpmn:incoming>\n      <bpmn:outgoing>Flow_H16</bpmn:outgoing>\n    </bpmn:serviceTask>\n\n    <bpmn:endEvent id=\"EndNotifyApproved\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_H16</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_HR_NotifyApproved\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndNotifyRejectedDays\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_H4</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_HR_NotifyRejectedDays\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndNotifyRejectedSupervisor\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_H11</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_HR_NotifyRejectedSupervisor\" />\n    </bpmn:endEvent>\n\n    <bpmn:endEvent id=\"EndNotifyRejectedHR\" name=\"Decision sent\">\n      <bpmn:incoming>Flow_H15</bpmn:incoming>\n      <bpmn:messageEventDefinition id=\"MED_HR_NotifyRejectedHR\" />\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_H1\" sourceRef=\"StartRequestReceived\" targetRef=\"TaskCheckBalance\" />\n    <bpmn:sequenceFlow id=\"Flow_H2\" sourceRef=\"TaskCheckBalance\" targetRef=\"GwEnoughDays\" />\n    <bpmn:sequenceFlow id=\"Flow_H3\" name=\"Yes\" sourceRef=\"GwEnoughDays\" targetRef=\"TaskSendApprovalRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_H4\" name=\"No\" sourceRef=\"GwEnoughDays\" targetRef=\"EndNotifyRejectedDays\" />\n    <bpmn:sequenceFlow id=\"Flow_H5\" sourceRef=\"TaskSendApprovalRequest\" targetRef=\"GwWaitFeedback\" />\n    <bpmn:sequenceFlow id=\"Flow_H6\" sourceRef=\"GwWaitFeedback\" targetRef=\"CatchSupervisorDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_H7\" sourceRef=\"GwWaitFeedback\" targetRef=\"Catch5Days\" />\n    <bpmn:sequenceFlow id=\"Flow_H8\" sourceRef=\"CatchSupervisorDecision\" targetRef=\"GwSupervisorApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_H9\" sourceRef=\"Catch5Days\" targetRef=\"TaskSendEscalation\" />\n    <bpmn:sequenceFlow id=\"Flow_H10\" name=\"Yes\" sourceRef=\"GwSupervisorApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_H11\" name=\"No\" sourceRef=\"GwSupervisorApproved\" targetRef=\"EndNotifyRejectedSupervisor\" />\n    <bpmn:sequenceFlow id=\"Flow_H12\" sourceRef=\"TaskSendEscalation\" targetRef=\"TaskReceiveFinalDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_H13\" sourceRef=\"TaskReceiveFinalDecision\" targetRef=\"GwHRManagerApproved\" />\n    <bpmn:sequenceFlow id=\"Flow_H14\" name=\"Yes\" sourceRef=\"GwHRManagerApproved\" targetRef=\"TaskBookVacation\" />\n    <bpmn:sequenceFlow id=\"Flow_H15\" name=\"No\" sourceRef=\"GwHRManagerApproved\" targetRef=\"EndNotifyRejectedHR\" />\n    <bpmn:sequenceFlow id=\"Flow_H16\" sourceRef=\"TaskBookVacation\" targetRef=\"EndNotifyApproved\" />\n  </bpmn:process>\n\n  <bpmn:process id=\"Process_SupervisorHR\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"LaneSet_SupervisorHR\">\n      <bpmn:lane id=\"LaneSupervisor\" name=\"Supervisor\">\n        <bpmn:flowNodeRef>StartApprovalRequested</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwSupervisorDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendSupervisorDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndSupervisorDone</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"LaneHRManager\" name=\"HR Manager\">\n        <bpmn:flowNodeRef>StartEscalationReceived</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>GwHRManagerDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>TaskSendHRManagerDecision</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>EndHRManagerDone</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n\n    <bpmn:startEvent id=\"StartApprovalRequested\" name=\"Approval requested\">\n      <bpmn:messageEventDefinition id=\"MED_SH_StartApproval\" />\n      <bpmn:outgoing>Flow_S1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskReviewRequest\" name=\"Review request\">\n      <bpmn:incoming>Flow_S1</bpmn:incoming>\n      <bpmn:outgoing>Flow_S2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwSupervisorDecision\" name=\"Approve?\">\n      <bpmn:incoming>Flow_S2</bpmn:incoming>\n      <bpmn:outgoing>Flow_S3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_S4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendSupervisorDecision\" name=\"Send decision\">\n      <bpmn:incoming>Flow_S3</bpmn:incoming>\n      <bpmn:incoming>Flow_S4</bpmn:incoming>\n      <bpmn:outgoing>Flow_S5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndSupervisorDone\" name=\"Supervisor done\">\n      <bpmn:incoming>Flow_S5</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:startEvent id=\"StartEscalationReceived\" name=\"Escalation received\">\n      <bpmn:messageEventDefinition id=\"MED_SH_StartEscalation\" />\n      <bpmn:outgoing>Flow_M1</bpmn:outgoing>\n    </bpmn:startEvent>\n\n    <bpmn:userTask id=\"TaskReviewEscalation\" name=\"Review case\">\n      <bpmn:incoming>Flow_M1</bpmn:incoming>\n      <bpmn:outgoing>Flow_M2</bpmn:outgoing>\n    </bpmn:userTask>\n\n    <bpmn:exclusiveGateway id=\"GwHRManagerDecision\" name=\"Approve?\">\n      <bpmn:incoming>Flow_M2</bpmn:incoming>\n      <bpmn:outgoing>Flow_M3</bpmn:outgoing>\n      <bpmn:outgoing>Flow_M4</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n\n    <bpmn:sendTask id=\"TaskSendHRManagerDecision\" name=\"Send decision\">\n      <bpmn:incoming>Flow_M3</bpmn:incoming>\n      <bpmn:incoming>Flow_M4</bpmn:incoming>\n      <bpmn:outgoing>Flow_M5</bpmn:outgoing>\n    </bpmn:sendTask>\n\n    <bpmn:endEvent id=\"EndHRManagerDone\" name=\"Manager done\">\n      <bpmn:incoming>Flow_M5</bpmn:incoming>\n    </bpmn:endEvent>\n\n    <bpmn:sequenceFlow id=\"Flow_S1\" sourceRef=\"StartApprovalRequested\" targetRef=\"TaskReviewRequest\" />\n    <bpmn:sequenceFlow id=\"Flow_S2\" sourceRef=\"TaskReviewRequest\" targetRef=\"GwSupervisorDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_S3\" name=\"Yes\" sourceRef=\"GwSupervisorDecision\" targetRef=\"TaskSendSupervisorDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_S4\" name=\"No\" sourceRef=\"GwSupervisorDecision\" targetRef=\"TaskSendSupervisorDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_S5\" sourceRef=\"TaskSendSupervisorDecision\" targetRef=\"EndSupervisorDone\" />\n\n    <bpmn:sequenceFlow id=\"Flow_M1\" sourceRef=\"StartEscalationReceived\" targetRef=\"TaskReviewEscalation\" />\n    <bpmn:sequenceFlow id=\"Flow_M2\" sourceRef=\"TaskReviewEscalation\" targetRef=\"GwHRManagerDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_M3\" name=\"Yes\" sourceRef=\"GwHRManagerDecision\" targetRef=\"TaskSendHRManagerDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_M4\" name=\"No\" sourceRef=\"GwHRManagerDecision\" targetRef=\"TaskSendHRManagerDecision\" />\n    <bpmn:sequenceFlow id=\"Flow_M5\" sourceRef=\"TaskSendHRManagerDecision\" targetRef=\"EndHRManagerDone\" />\n  </bpmn:process>\n\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_VacationRequest\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_VacationRequest\" bpmnElement=\"Collaboration_VacationRequest\">\n\n      <bpmndi:BPMNShape id=\"PoolEmployee_di\" bpmnElement=\"PoolEmployee\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"80\" width=\"1400\" height=\"260\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartNeedVacation_di\" bpmnElement=\"StartNeedVacation\">\n        <dc:Bounds x=\"220\" y=\"192\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskSubmitRequest_di\" bpmnElement=\"TaskSubmitRequest\">\n        <dc:Bounds x=\"320\" y=\"170\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitOutcome_di\" bpmnElement=\"GwWaitOutcome\">\n        <dc:Bounds x=\"470\" y=\"185\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchApproved_di\" bpmnElement=\"CatchApproved\">\n        <dc:Bounds x=\"600\" y=\"130\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndApproved_di\" bpmnElement=\"EndApproved\">\n        <dc:Bounds x=\"720\" y=\"130\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"CatchRejected_di\" bpmnElement=\"CatchRejected\">\n        <dc:Bounds x=\"600\" y=\"250\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndRejected_di\" bpmnElement=\"EndRejected\">\n        <dc:Bounds x=\"720\" y=\"250\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"PoolHRPortal_di\" bpmnElement=\"PoolHRPortal\" isHorizontal=\"true\">\n        <dc:Bounds x=\"160\" y=\"390\" width=\"1400\" height=\"330\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"StartRequestReceived_di\" bpmnElement=\"StartRequestReceived\">\n        <dc:Bounds x=\"220\" y=\"532\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskCheckBalance_di\" bpmnElement=\"TaskCheckBalance\">\n        <dc:Bounds x=\"320\" y=\"510\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwEnoughDays_di\" bpmnElement=\"GwEnoughDays\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"470\" y=\"525\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskSendApprovalRequest_di\" bpmnElement=\"TaskSendApprovalRequest\">\n        <dc:Bounds x=\"600\" y=\"510\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwWaitFeedback_di\" bpmnElement=\"GwWaitFeedback\">\n        <dc:Bounds x=\"750\" y=\"525\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"CatchSupervisorDecision_di\" bpmnElement=\"CatchSupervisorDecision\">\n        <dc:Bounds x=\"880\" y=\"450\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwSupervisorApproved_di\" bpmnElement=\"GwSupervisorApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1000\" y=\"443\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Catch5Days_di\" bpmnElement=\"Catch5Days\">\n        <dc:Bounds x=\"880\" y=\"630\" width=\"36\" height=\"36\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskSendEscalation_di\" bpmnElement=\"TaskSendEscalation\">\n        <dc:Bounds x=\"1000\" y=\"608\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"TaskReceiveFinalDecision_di\" bpmnElement=\"TaskReceiveFinalDecision\">\n        <dc:Bounds x=\"1150\" y=\"608\" width=\"100\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"GwHRManagerApproved_di\" bpmnElement=\"GwHRManagerApproved\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1290\" y=\"623\" width=\"50\" height=\"50\" />\n      </bpmndi:BPMNShape>\n\n      <bpmndi:BPMNShape id=\"TaskBookVacation_di\" bpmnElement=\"TaskBookVacation\">\n        <dc:Bounds x=\"1150\" y=\"450\" width=\"100\" height=\"80