      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskRecheckCompleteness_di" bpmnElement="TaskRecheckCompleteness">
        <dc:Bounds x="960" y="70" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwCompleteAfter_di" bpmnElement="GwCompleteAfter" isMarkerVisible="true">
        <dc:Bounds x="1120" y="85" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1108" y="142" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskForwardToAgency_di" bpmnElement="TaskForwardToAgency">
        <dc:Bounds x="590" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchAgencyOpinion_di" bpmnElement="CatchAgencyOpinion">
        <dc:Bounds x="740" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="711" y="255" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwOpinionPositive_di" bpmnElement="GwOpinionPositive" isMarkerVisible="true">
        <dc:Bounds x="860" y="205" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="850" y="262" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckTechnical_di" bpmnElement="TaskCheckTechnical">
        <dc:Bounds x="980" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwTechOk_di" bpmnElement="GwTechOk" isMarkerVisible="true">
        <dc:Bounds x="1140" y="325" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1152" y="382" width="26" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskIssuePermit_di" bpmnElement="TaskIssuePermit">
        <dc:Bounds x="1260" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndPermitIssued_di" bpmnElement="EndPermitIssued">
        <dc:Bounds x="1410" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1392" y="345" width="72" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndApplicationRejected_di" bpmnElement="EndApplicationRejected">
        <dc:Bounds x="1410" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1380" y="245" width="96" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="246" y="170" />
        <di:waypoint x="310" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="410" y="170" />
        <di:waypoint x="470" y="170" />
      </bpmndi:BPMNEdge>
