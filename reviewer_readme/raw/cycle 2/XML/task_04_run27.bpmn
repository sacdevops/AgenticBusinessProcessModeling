        <di:waypoint x="1225" y="320" />
        <di:waypoint x="1260" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="1200" y="332" width="18" height="14" /></bpmndi:BPMNEdge>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_19_di" bpmnElement="Flow_19">
        <di:waypoint x="1165" y="325" />
