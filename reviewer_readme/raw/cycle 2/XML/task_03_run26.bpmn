<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_VacationRequest" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_VacationRequest">
    <bpmn:participant id="PoolEmployee" name="Employee" processRef="Process_Employee" />
    <bpmn:participant id="PoolHRPortal" name="HR Portal" processRef="Process_HRPortal" />
    <bpmn:participant id="PoolSupervisorHR" name="Supervisor & HR" processRef="Process_SupervisorHR" />

    <bpmn:messageFlow id="MF_SubmitRequest" name="Vacation request" sourceRef="TaskSubmitRequest" targetRef="StartRequestReceived" />
    <bpmn:messageFlow id="MF_ApprovalRequest" name="Approval request" sourceRef="TaskSendToSupervisor" targetRef="StartApprovalRequest" />

    <bpmn:messageFlow id="MF_SupervisorDecision" name="Supervisor decision" sourceRef="EndSupervisorDecision" targetRef="CatchSupervisorDecision" />
    <bpmn:messageFlow id="MF_HRManagerDecision" name="HR manager decision" sourceRef="EndHRManagerDecision" targetRef="CatchHRManagerDecision" />

    <bpmn:messageFlow id="MF_NotifyApproved" name="Approved" sourceRef="EndNotifyApproved" targetRef="CatchDecisionApproved" />
    <bpmn:messageFlow id="MF_NotifyRejectedDays" name="Rejected (days)" sourceRef="EndNotifyRejectedDays" targetRef="CatchDecisionRejectedDays" />
    <bpmn:messageFlow id="MF_NotifyRejectedSupervisor" name="Rejected (supervisor)" sourceRef="EndNotifyRejectedSupervisor" targetRef="CatchDecisionRejectedSupervisor" />
    <bpmn:messageFlow id="MF_NotifyRejectedHR" name="Rejected (HR)" sourceRef="EndNotifyRejectedHR" targetRef="CatchDecisionRejectedHR" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Employee" isExecutable="false">
    <bpmn:startEvent id="StartNeedVacation" name="Vacation needed">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="TaskSubmitRequest" name="Submit request">
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitDecision" name="">
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
      <bpmn:outgoing>Flow_E4</bpmn:outgoing>
      <bpmn:outgoing>Flow_E5</bpmn:outgoing>
      <bpmn:outgoing>Flow_E6</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchDecisionApproved" name="Approved received">
      <bpmn:incoming>Flow_E3</bpmn:incoming>
      <bpmn:outgoing>Flow_E7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_Approved" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejectedDays" name="Rejected days received">
      <bpmn:incoming>Flow_E4</bpmn:incoming>
      <bpmn:outgoing>Flow_E8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_RejectedDays" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejectedSupervisor" name="Rejected supervisor received">
      <bpmn:incoming>Flow_E5</bpmn:incoming>
      <bpmn:outgoing>Flow_E9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_RejectedSupervisor" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchDecisionRejectedHR" name="Rejected HR received">
      <bpmn:incoming>Flow_E6</bpmn:incoming>
      <bpmn:outgoing>Flow_E10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_E_RejectedHR" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="EndApproved" name="Vacation approved">
      <bpmn:incoming>Flow_E7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedDays" name="Request rejected">
      <bpmn:incoming>Flow_E8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedSupervisor" name="Request rejected">
      <bpmn:incoming>Flow_E9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndRejectedHR" name="Request rejected">
      <bpmn:incoming>Flow_E10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_E1" sourceRef="StartNeedVacation" targetRef="TaskSubmitRequest" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="TaskSubmitRequest" targetRef="GwWaitDecision" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="GwWaitDecision" targetRef="CatchDecisionApproved" />
    <bpmn:sequenceFlow id="Flow_E4" sourceRef="GwWaitDecision" targetRef="CatchDecisionRejectedDays" />
    <bpmn:sequenceFlow id="Flow_E5" sourceRef="GwWaitDecision" targetRef="CatchDecisionRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_E6" sourceRef="GwWaitDecision" targetRef="CatchDecisionRejectedHR" />
    <bpmn:sequenceFlow id="Flow_E7" sourceRef="CatchDecisionApproved" targetRef="EndApproved" />
    <bpmn:sequenceFlow id="Flow_E8" sourceRef="CatchDecisionRejectedDays" targetRef="EndRejectedDays" />
    <bpmn:sequenceFlow id="Flow_E9" sourceRef="CatchDecisionRejectedSupervisor" targetRef="EndRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_E10" sourceRef="CatchDecisionRejectedHR" targetRef="EndRejectedHR" />
  </bpmn:process>

  <bpmn:process id="Process_HRPortal" isExecutable="false">
    <bpmn:startEvent id="StartRequestReceived" name="Request received">
      <bpmn:messageEventDefinition id="MED_P_RequestReceived" />
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="TaskCheckDays" name="Check days">
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GwEnoughDays" name="Enough days?">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:outgoing>Flow_P3</bpmn:outgoing>
      <bpmn:outgoing>Flow_P4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="TaskSendToSupervisor" name="Send approval">
      <bpmn:incoming>Flow_P3</bpmn:incoming>
      <bpmn:outgoing>Flow_P5</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="GwWaitFeedback" name="">
      <bpmn:incoming>Flow_P5</bpmn:incoming>
      <bpmn:outgoing>Flow_P6</bpmn:outgoing>
      <bpmn:outgoing>Flow_P7</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="CatchSupervisorDecision" name="Supervisor feedback">
      <bpmn:incoming>Flow_P6</bpmn:incoming>
      <bpmn:outgoing>Flow_P8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_P_SupervisorDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="CatchTimeout5Days" name="5 days exceeded">
      <bpmn:incoming>Flow_P7</bpmn:incoming>
      <bpmn:outgoing>Flow_P9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_P_5Days" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwSupervisorApproved" name="Approved?">
      <bpmn:incoming>Flow_P8</bpmn:incoming>
      <bpmn:outgoing>Flow_P10</bpmn:outgoing>
      <bpmn:outgoing>Flow_P11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="TaskBookVacation" name="Book vacation">
      <bpmn:incoming>Flow_P10</bpmn:incoming>
      <bpmn:incoming>Flow_P12</bpmn:incoming>
      <bpmn:outgoing>Flow_P13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndNotifyApproved" name="Notify approved">
      <bpmn:incoming>Flow_P13</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_P_NotifyApproved" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndNotifyRejectedSupervisor" name="Notify rejected">
      <bpmn:incoming>Flow_P11</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_P_NotifyRejectedSupervisor" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndNotifyRejectedDays" name="Notify rejected">
      <bpmn:incoming>Flow_P4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_P_NotifyRejectedDays" />
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchHRManagerDecision" name="HR decision">
      <bpmn:incoming>Flow_P14</bpmn:incoming>
      <bpmn:outgoing>Flow_P15</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_P_HRManagerDecision" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="GwHRApproved" name="Approved?">
      <bpmn:incoming>Flow_P15</bpmn:incoming>
      <bpmn:outgoing>Flow_P12</bpmn:outgoing>
      <bpmn:outgoing>Flow_P16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndNotifyRejectedHR" name="Notify rejected">
      <bpmn:incoming>Flow_P16</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_P_NotifyRejectedHR" />
    </bpmn:endEvent>

    <bpmn:sendTask id="TaskEscalateToHR" name="Escalate case">
      <bpmn:incoming>Flow_P9</bpmn:incoming>
      <bpmn:outgoing>Flow_P14</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sequenceFlow id="Flow_P1" sourceRef="StartRequestReceived" targetRef="TaskCheckDays" />
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="TaskCheckDays" targetRef="GwEnoughDays" />
    <bpmn:sequenceFlow id="Flow_P3" name="Yes" sourceRef="GwEnoughDays" targetRef="TaskSendToSupervisor" />
    <bpmn:sequenceFlow id="Flow_P4" name="No" sourceRef="GwEnoughDays" targetRef="EndNotifyRejectedDays" />
    <bpmn:sequenceFlow id="Flow_P5" sourceRef="TaskSendToSupervisor" targetRef="GwWaitFeedback" />
    <bpmn:sequenceFlow id="Flow_P6" sourceRef="GwWaitFeedback" targetRef="CatchSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_P7" sourceRef="GwWaitFeedback" targetRef="CatchTimeout5Days" />
    <bpmn:sequenceFlow id="Flow_P8" sourceRef="CatchSupervisorDecision" targetRef="GwSupervisorApproved" />
    <bpmn:sequenceFlow id="Flow_P9" sourceRef="CatchTimeout5Days" targetRef="TaskEscalateToHR" />
    <bpmn:sequenceFlow id="Flow_P10" name="Yes" sourceRef="GwSupervisorApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P11" name="No" sourceRef="GwSupervisorApproved" targetRef="EndNotifyRejectedSupervisor" />
    <bpmn:sequenceFlow id="Flow_P12" name="Yes" sourceRef="GwHRApproved" targetRef="TaskBookVacation" />
    <bpmn:sequenceFlow id="Flow_P13" sourceRef="TaskBookVacation" targetRef="EndNotifyApproved" />
    <bpmn:sequenceFlow id="Flow_P14" sourceRef="TaskEscalateToHR" targetRef="CatchHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_P15" sourceRef="CatchHRManagerDecision" targetRef="GwHRApproved" />
    <bpmn:sequenceFlow id="Flow_P16" name="No" sourceRef="GwHRApproved" targetRef="EndNotifyRejectedHR" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisorHR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_SupervisorHR">
      <bpmn:lane id="LaneSupervisor" name="Supervisor">
        <bpmn:flowNodeRef>StartApprovalRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSupDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndSupervisorDecision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LaneHRManager" name="HR Manager">
        <bpmn:flowNodeRef>StartEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TaskReviewEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwHRDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndHRManagerDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartApprovalRequest" name="Approval needed">
      <bpmn:messageEventDefinition id="MED_S_ApprovalRequest" />
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewRequest" name="Review request">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwSupDecision" name="Approve?">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndSupervisorDecision" name="Decision sent">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_S_SupervisorDecision" />
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEscalation" name="Escalation received">
      <bpmn:messageEventDefinition id="MED_S_Escalation" />
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="TaskReviewEscalation" name="Review escalation">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GwHRDecision" name="Approve?">
      <bpmn:incoming>Flow_S6</bpmn:incoming>
      <bpmn:outgoing>Flow_S7</bpmn:outgoing>
      <bpmn:outgoing>Flow_S8</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndHRManagerDecision" name="Decision sent">
      <bpmn:incoming>Flow_S7</bpmn:incoming>
      <bpmn:incoming>Flow_S8</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_S_HRManagerDecision" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_S1" sourceRef="StartApprovalRequest" targetRef="TaskReviewRequest" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="TaskReviewRequest" targetRef="GwSupDecision" />
    <bpmn:sequenceFlow id="Flow_S3" name="Yes" sourceRef="GwSupDecision" targetRef="EndSupervisorDecision" />
    <bpmn:sequenceFlow id="Flow_S4" name="No" sourceRef="GwSupDecision" targetRef="EndSupervisorDecision" />

    <bpmn:sequenceFlow id="Flow_S5" sourceRef="StartEscalation" targetRef="TaskReviewEscalation" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="TaskReviewEscalation" targetRef="GwHRDecision" />
    <bpmn:sequenceFlow id="Flow_S7" name="Yes" sourceRef="GwHRDecision" targetRef="EndHRManagerDecision" />
    <bpmn:sequenceFlow id="Flow_S8" name="No" sourceRef="GwHRDecision" targetRef="EndHRManagerDecision" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_VacationRequest">
    <bpmndi:BPMNPlane id="BPMNPlane_VacationRequest" bpmnElement="Collaboration_VacationRequest">

      <bpmndi:BPMNShape id="PoolEmployee_di" bpmnElement="PoolEmployee" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1400" height="260" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartNeedVacation_di" bpmnElement="StartNeedVacation">
        <dc:Bounds x="220" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="195" y="235" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSubmitRequest_di" bpmnElement="TaskSubmitRequest">
        <dc:Bounds x="320" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitDecision_di" bpmnElement="GwWaitDecision">
        <dc:Bounds x="500" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionApproved_di" bpmnElement="CatchDecisionApproved">
        <dc:Bounds x="620" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="588" y="76" width="101" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="740" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="715" y="155" width="86" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejectedDays_di" bpmnElement="CatchDecisionRejectedDays">
        <dc:Bounds x="620" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="572" y="215" width="132" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejectedDays_di" bpmnElement="EndRejectedDays">
        <dc:Bounds x="740" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="720" y="215" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejectedSupervisor_di" bpmnElement="CatchDecisionRejectedSupervisor">
        <dc:Bounds x="620" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="557" y="275" width="162" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejectedSupervisor_di" bpmnElement="EndRejectedSupervisor">
        <dc:Bounds x="740" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="720" y="275" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchDecisionRejectedHR_di" bpmnElement="CatchDecisionRejectedHR">
        <dc:Bounds x="620" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="571" y="335" width="134" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejectedHR_di" bpmnElement="EndRejectedHR">
        <dc:Bounds x="740" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="720" y="335" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="PoolHRPortal_di" bpmnElement="PoolHRPortal" isHorizontal="true">
        <dc:Bounds x="160" y="390" width="1400" height="340" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartRequestReceived_di" bpmnElement="StartRequestReceived">
        <dc:Bounds x="220" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="201" y="585" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskCheckDays_di" bpmnElement="TaskCheckDays">
        <dc:Bounds x="320" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwEnoughDays_di" bpmnElement="GwEnoughDays" isMarkerVisible="true">
        <dc:Bounds x="480" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="463" y="592" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNotifyRejectedDays_di" bpmnElement="EndNotifyRejectedDays">
        <dc:Bounds x="620" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="597" y="475" width="82" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskSendToSupervisor_di" bpmnElement="TaskSendToSupervisor">
        <dc:Bounds x="620" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwWaitFeedback_di" bpmnElement="GwWaitFeedback">
        <dc:Bounds x="780" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchSupervisorDecision_di" bpmnElement="CatchSupervisorDecision">
        <dc:Bounds x="900" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="865" y="425" width="106" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="CatchTimeout5Days_di" bpmnElement="CatchTimeout5Days">
        <dc:Bounds x="900" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="871" y="665" width="94" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GwSupervisorApproved_di" bpmnElement="GwSupervisorApproved" isMarkerVisible="true">
        <dc:Bounds x="1020" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1017" y="512" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskBookVacation_di" bpmnElement="TaskBookVacation">
        <dc:Bounds x="1140" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNotifyApproved_di" bpmnElement="EndNotifyApproved">
        <dc:Bounds x="1280" y="422" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1256" y="465" width="84" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndNotifyRejectedSupervisor_di" bpmnElement="EndNotifyRejectedSupervisor">
        <dc:Bounds x="1140" y="520" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1118" y="563" width="81" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TaskEscalateToHR_di" bpmnElement="TaskEscalateToHR">
        <dc:Bounds x="1020" y="610" width="100" height="80" />
